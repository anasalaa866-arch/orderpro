  *{overflow:visible!important}
}
.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(80px);background:#1e293b;color:#fff;padding:11px 20px;border-radius:10px;font-size:13px;font-weight:500;z-index:9999;transition:transform .3s;box-shadow:0 8px 30px rgba(0,0,0,.25);max-width:400px}
.toast.show{transform:translateX(-50%) translateY(0)}

/* ===== 📱 MOBILE OVERHAUL (v202) ===== */
/* Hamburger button (hidden by default, shown on mobile) */
.mobile-menu-btn{display:none;background:none;border:none;cursor:pointer;font-size:22px;padding:6px 10px;color:var(--text)}
.sidebar-backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:998;opacity:0;transition:opacity .25s}
.sidebar-backdrop.show{display:block;opacity:1}

/* Tablet (≤1024px) — الـ sidebar تبقى drawer */
@media(max-width:1024px){
  .stats-row{grid-template-columns:repeat(2,1fr)}
  .cgrid{grid-template-columns:repeat(2,1fr)}
  .content{padding:14px}
  .search-wrap input{width:140px;font-size:12px}
  /* 🔧 v210: على الـ tablet/laptop العادي، السايدبار تفضل ظاهرة بس أصغر */
  :root{--sidebar-w:200px}
}

/* Mobile (≤768px) - drawer mode + تعديلات إضافية */
@media(max-width:768px){
  :root{--sidebar-w:280px;--topbar-h:54px}
  body{font-size:13px}

  /* Sidebar — drawer mode فقط على الموبايل */
  .app{position:relative}
  .sidebar{
    position:fixed;top:0;right:0;bottom:0;
    width:var(--sidebar-w);max-width:80vw;
    transform:translateX(100%);transition:transform .25s;
    z-index:999;box-shadow:-10px 0 30px rgba(0,0,0,.3);
  }
  .sidebar.open{transform:translateX(0)}
  .mobile-menu-btn{display:block}
  .main-area{width:100%}

  /* 🔧 v210: على الموبايل، الـ sidebar drawer كاملة — كل العناصر ظاهرة */
  .sidebar .sb-logo h2,
  .sidebar .sb-logo p,
  .sidebar .ni-label,
  .sidebar .nbadge,
  .sidebar .nav-label,
  .sidebar .sb-status-text{display:revert !important}
  .sb-logo-inner{justify-content:flex-start}
  .ni{justify-content:flex-start;padding:12px 16px;font-size:14px}
  .ni-icon{font-size:18px}
  .sb-status{justify-content:flex-start}

  /* Topbar */
  .topbar{padding:0 10px;gap:6px}
  .topbar-title{font-size:14px}
  .search-wrap{display:none} /* search في كل صفحة جواها */
  .search-wrap input{width:130px}

  /* Hide non-essential desktop buttons in topbar */
  .topbar .desktop-only{display:none}

  /* Content */
  .content{padding:10px;padding-bottom:80px} /* مساحة لـ FAB */

  /* Cards */
  .card-hd{padding:12px;flex-wrap:wrap}
  .card-hd h3{font-size:15px}
  .card-body{padding:12px}

  /* Stats grids - smaller on mobile */
  .stats-row{grid-template-columns:repeat(2,1fr);gap:8px}
  .cgrid{grid-template-columns:1fr;gap:10px}
  .sc{padding:10px}
  .sc-val{font-size:18px}
  .sc-label{font-size:11px}

  /* Tables - convert to cards on mobile */
  .tbl-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
  table{font-size:12px;min-width:auto}
  thead th{padding:6px 4px;font-size:11px}
  td{padding:6px 4px}

  /* MOBILE TABLE → CARDS pattern */
  .mobile-cards table,
  .mobile-cards thead{display:none}
  .mobile-cards tbody,
  .mobile-cards tr,
  .mobile-cards td{display:block;width:100%}
  .mobile-cards tr{
    background:var(--card);border:1px solid var(--border);
    border-radius:10px;padding:10px;margin-bottom:8px;
    box-shadow:0 1px 3px rgba(0,0,0,.04);
  }
  .mobile-cards td{
    border:none;padding:4px 0;
    display:flex;justify-content:space-between;align-items:center;gap:8px;
  }
  .mobile-cards td::before{
    content:attr(data-label);
    font-weight:600;color:var(--muted);font-size:11px;flex-shrink:0;
  }
  .mobile-cards td:first-child::before{content:none}
  .mobile-cards td:first-child{font-weight:700;font-size:14px;border-bottom:1px solid var(--border);padding-bottom:8px;margin-bottom:6px}

  /* Buttons - bigger touch targets */
  .btn{padding:8px 12px;font-size:13px;min-height:36px}
  .btn-sm{padding:6px 10px;font-size:12px;min-height:32px}
  .btn-xs{padding:5px 8px;font-size:11px;min-height:28px}

  /* Chips/tabs */
  .chip{padding:8px 12px;font-size:12px}

  /* Modals - full screen on mobile */
  .modal{
    width:100%;max-width:100%;height:100vh;max-height:100vh;
    border-radius:0;margin:0;padding:0;
  }
  .mhd{padding:14px 16px;border-bottom:1px solid var(--border);position:sticky;top:0;background:var(--card);z-index:5}
  .mbody{padding:14px 16px;flex:1;overflow-y:auto}
  .mft{padding:12px 16px;border-top:1px solid var(--border);position:sticky;bottom:0;background:var(--card);display:flex;gap:8px}
  .mft .btn{flex:1;justify-content:center}

  /* Inputs - bigger on mobile */
  input[type=text],input[type=number],input[type=tel],input[type=email],input[type=password],input[type=date],select,textarea{
    font-size:16px !important; /* prevents iOS zoom */
    padding:10px 12px;
  }

  /* Specific page tweaks */
  .courier-card{padding:12px}
  .courier-card-name{font-size:15px}

  /* Filter rows scroll horizontally */
  .filter-row,.tabs-row,.chip-row,#courier-tabs,#cdash-tabs{
    overflow-x:auto;flex-wrap:nowrap;-webkit-overflow-scrolling:touch;
    scrollbar-width:none;
  }
  .filter-row::-webkit-scrollbar,
  .tabs-row::-webkit-scrollbar,
  .chip-row::-webkit-scrollbar,
  #courier-tabs::-webkit-scrollbar,
  #cdash-tabs::-webkit-scrollbar{display:none}

  /* Dashboard cards - 2 cols instead of 4 */
  #cdash-content .stats-grid-4{grid-template-columns:repeat(2,1fr) !important}

  /* Toast */
  .toast{bottom:14px;font-size:12px;padding:10px 14px}
}

/* Small mobile (≤480px) */
@media(max-width:480px){
  .content{padding:8px;padding-bottom:80px}
  .card-hd{padding:10px}
  .card-body{padding:10px}
  .topbar-title{font-size:13px}
  .stats-row{grid-template-columns:1fr 1fr;gap:6px}
  .sc{padding:8px}
  .sc-val{font-size:16px}
  .btn{padding:7px 10px;font-size:12px}
  .chip{padding:6px 10px;font-size:11px}
}

