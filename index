function _timeAgo(ts){
  if(!ts) return '—';
  const age = Math.round((Date.now() - new Date(ts).getTime()) / (1000*60));
  if(age < 1) return 'الآن';
  if(age < 60) return 'من ' + age + ' دقيقة';
  if(age < 1440) return 'من ' + Math.round(age/60) + ' ساعة';
  return 'من ' + Math.round(age/1440) + ' يوم';
}

function _escapeHtml(s){
  if(s == null) return '';
  return String(s).replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
}

// 🔧 v218 FIX: viewStarsProof - بنستخدم fetch مع token بدل window.open المباشر
// المشكلة كانت: window.open بيفتح URL في tab جديد بدون authorization header
// النتيجة: السيرفر بيرفض ويرجع "No admin token"
// الحل: نـ fetch الصورة مع Bearer token، نحوّلها blob، ونعرضها في modal
async function viewStarsProof(kind, id){
  const url = API_URL.replace(/\/$/,'') +
    (kind === 'payment' ? '/api/pending-reviews/'+id+'/proof' : '/api/courier-adjustments/'+id+'/proof');
  
  // اعرض loading toast
  toast('⏳ جاري تحميل الصورة...');
  
  try{
    const token = localStorage.getItem('admin_token');
    if(!token){
      toast('❌ لازم تسجل دخول من جديد');
      return;
    }
    
    const response = await fetch(url, {
      headers: { 'Authorization': 'Bearer ' + token }
    });
    
    if(!response.ok){
      if(response.status === 401){
        toast('❌ session منتهية - سجل دخول من جديد');
      } else if(response.status === 404){
        toast('❌ الصورة غير موجودة');
      } else {
        toast(`❌ خطأ: ${response.status}`);
      }
      return;
    }
    
    // هل الـ response صورة فعلاً؟
    const contentType = response.headers.get('content-type') || '';
    if(!contentType.startsWith('image/')){
      // ممكن يكون JSON error
      try{
        const text = await response.text();
        const json = JSON.parse(text);
        toast('❌ ' + (json.error || 'حدث خطأ'));
      }catch(e){
        toast('❌ الـ response مش صورة');
      }
      return;
    }
    
    // حول لـ blob ثم URL
    const blob = await response.blob();
    const blobUrl = URL.createObjectURL(blob);
    
    // اعرض في modal بدل tab جديد - أحسن user experience
    showProofImageModal(blobUrl, kind, id);
  }catch(e){
    toast('❌ فشل تحميل الصورة: ' + (e.message || ''));
  }
}

