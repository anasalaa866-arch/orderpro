function addToOfflineQueue(path, method, body){
  // ما تحفظش GET requests
  if(method==='GET') return;
  _offlineQueue.push({
    id: Date.now()+'_'+Math.random().toString(36).slice(2,7),
    path, method, body,
    ts: new Date().toISOString(),
    retries: 0
  });
  saveOfflineQueue();
}

async function processOfflineQueue(){
  if(_syncInProgress || !_offlineQueue.length || !API_URL) return;
  _syncInProgress = true;
  const baseUrl = API_URL.replace(/\/$/,'');
  const remaining = [];
  let synced = 0, failed = 0;

  for(const item of _offlineQueue){
    try{
      const opts = { method:item.method, headers:{'Content-Type':'application/json'}, mode:'cors' };
      if(item.body) opts.body = JSON.stringify(item.body);
      const r = await fetch(baseUrl+item.path, opts);
      if(r.ok){
        synced++;
        continue; // نجحت → ما نضيفهاش للـ remaining
      }
      // خطأ 4xx يعني بيانات غلط — نحذفها
      if(r.status >= 400 && r.status < 500){
        console.warn('Dropping bad request:', item.path, r.status);
        failed++;
        continue;
      }
      // خطأ 5xx أو شبكة → نحاول تاني
      item.retries = (item.retries||0) + 1;
      if(item.retries < 20) remaining.push(item);
      else failed++;
    }catch(e){
      // الشبكة مش شغالة — خلاص نوقف
      item.retries = (item.retries||0) + 1;
      if(item.retries < 20) remaining.push(item);
      else failed++;
      // ما نكملش باقي العمليات لو مفيش نت
      const idx = _offlineQueue.indexOf(item);
      for(let j=idx+1; j<_offlineQueue.length; j++) remaining.push(_offlineQueue[j]);
      break;
    }
  }

  _offlineQueue = remaining;
  saveOfflineQueue();
  _syncInProgress = false;

  if(synced > 0){
    toast('✅ تم رفع '+synced+' عملية للسيرفر');
  }
  return { synced, failed, remaining: remaining.length };
}

// 🆕 v203: cache للـ Last-Modified بالـ path
const _apiLastModified = {};
const _apiCachedData = {};

async function apiFetch(path, method='GET', body=null){
  const baseUrl = API_URL || BACKEND_URL;
  if(!baseUrl) return null;

  // أضف اسم المستخدم تلقائياً في PATCH للطلبات
  if(body && method==='PATCH' && path.match(/\/api\/orders\/[^/]+$/) && currentUser){
    body = {...body, _user: currentUser.name};
  }

  try{
    const opts = { method, headers:{'Content-Type':'application/json'}, mode:'cors' };
    if(body) opts.body = JSON.stringify(body);

    // 🆕 v206: ابعت admin token (إذا كان متاح) — مطلوب لكل /api/* عدا /api/login
    if(window._adminToken && path !== '/api/login'){
      opts.headers['Authorization'] = 'Bearer ' + window._adminToken;
    }

    // 🆕 v203: لو GET وعندنا Last-Modified للـ path، ابعتها
    if(method === 'GET' && _apiLastModified[path]){
      opts.headers['If-Modified-Since'] = _apiLastModified[path];
    }

    const r = await fetch(baseUrl.replace(/\/$/,'')+path, opts);

    // 🆕 v203: 304 Not Modified — استخدم الـ cache
    if(r.status === 304 && _apiCachedData[path]){
      return _apiCachedData[path];
    }

    // 🆕 v206: 401 = الـ token منتهي → logout
    if(r.status === 401 && path !== '/api/login'){
      console.warn('🔒 401 Unauthorized — session expired');
      // امسح الـ session واطلب login تاني
      window._adminToken = null;
      localStorage.removeItem('admin_token');
      localStorage.removeItem('current_user_session');
      // لو على main app، رجع لـ login
      const loginScreen = document.getElementById('login-screen');
      const mainApp = document.getElementById('main-app');
      if(loginScreen && mainApp){
        loginScreen.classList.remove('hidden');
        mainApp.style.display = 'none';
        const errEl = document.getElementById('login-err');
        if(errEl) errEl.textContent = '⏰ انتهت الجلسة — سجّل دخول من جديد';
      }
      throw new Error('401');
    }

    if(!r.ok){
      // للعمليات الكتابية: لو 5xx → حفظ في الـ queue
      if(method !== 'GET' && r.status >= 500){
        addToOfflineQueue(path, method, body);
      }
      // 🔧 v366: حاول تقرأ الـ error message من الـ response body
      // عشان الـ user يشوف الرسالة العربية من الـ backend بدل "❌ 400"
      let errMsg = String(r.status);
      try {
        const errData = await r.json();
        if(errData?.error){
          errMsg = errData.error;
          console.warn(`[apiFetch] ${method} ${path} → ${r.status}: ${errMsg}`);
        }
      } catch(parseErr){
        // الـ response مش JSON - استخدم الـ status code
      }
      throw new Error(errMsg);
    }
    const data = await r.json();

    // 🆕 v203: cache الـ Last-Modified للـ GET requests
    if(method === 'GET'){
      const lm = r.headers.get('Last-Modified');
      if(lm){
        _apiLastModified[path] = lm;
        _apiCachedData[path] = data;
      }
    }

    return data;
  }catch(e){
    // الشبكة فشلت — العمليات الكتابية تتحفظ في الـ queue
    if(method !== 'GET' && !e.message.match(/^\d+$/)){
      addToOfflineQueue(path, method, body);
    }
    console.warn('API:', path, e.message);
    return null;
  }
}

