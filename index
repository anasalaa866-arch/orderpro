// helper: تحويل الرقم لكلام عربي (مبسّط)
function numToArabicWords(num){
  if(!num) return 'صفر جنيه';
  const n = Math.round(parseFloat(num));
  const ones = ['','واحد','اثنان','ثلاثة','أربعة','خمسة','ستة','سبعة','ثمانية','تسعة','عشرة','أحد عشر','اثنا عشر','ثلاثة عشر','أربعة عشر','خمسة عشر','ستة عشر','سبعة عشر','ثمانية عشر','تسعة عشر'];
  const tens = ['','','عشرون','ثلاثون','أربعون','خمسون','ستون','سبعون','ثمانون','تسعون'];
  
  function sub(n){
    if(n < 20) return ones[n];
    if(n < 100){
      const t = Math.floor(n/10), o = n%10;
      return o ? ones[o] + ' و' + tens[t] : tens[t];
    }
    if(n < 1000){
      const h = Math.floor(n/100), r = n%100;
      const hStr = h===1 ? 'مائة' : h===2 ? 'مائتان' : ones[h] + 'مائة';
      return r ? hStr + ' و' + sub(r) : hStr;
    }
    return n.toString();
  }
  
  if(n < 1000) return sub(n) + ' جنيه';
  if(n < 1000000){
    const k = Math.floor(n/1000), r = n%1000;
    const kStr = k===1 ? 'ألف' : k===2 ? 'ألفان' : k<11 ? sub(k) + ' آلاف' : sub(k) + ' ألف';
    return r ? kStr + ' و' + sub(r) + ' جنيه' : kStr + ' جنيه';
  }
  return n.toLocaleString('ar-EG') + ' جنيه';
}

