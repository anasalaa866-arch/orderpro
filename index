      : (dryRun 
        ? `${mismatched.length} طلب فيهم فرق (معاينة فقط — اضغط "تنفيذ المزامنة" للتحديث)`
        : `تم تحديث ${r.updated} طلب من Shopify (${r.tookSec}s)`);
    
