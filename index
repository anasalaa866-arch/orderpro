        ${p.payee ? `<div style="font-size:11px;color:var(--muted);margin-top:2px">${escapeHtml(p.payee)}</div>` : ''}
      </div>
      <div style="font-size:22px;font-weight:900;color:#16a34a">${parseFloat(p.amount).toFixed(0)} ج</div>
