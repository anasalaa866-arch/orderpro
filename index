        ? `<span style="display:inline-flex;align-items:center;gap:3px;background:${newType.color}22;color:${newType.color};padding:3px 9px;border-radius:6px;font-weight:700;font-size:11px">${newType.emoji||'📦'} ${escapeHtml(newType.label_ar)}</span>`
