// 🆕 v390: MANUAL ORDER RETURN — مرتجع للطلبات اليدوية
// ───────────────────────────────────────────────────────────
// تختار منتج + الكمية الجديدة → الكمية تتغيّر في Shopify + الفرق
// يرجع المخزن (restock) + من غير أي refund مالي.
let _moReturnState = null; // { shopifyId, orderName, items[] }

async function moOpenReturn(shopifyId, orderName){
  if(!API_URL){ toast('❌ API غير متاح'); return; }
  _moReturnState = { shopifyId, orderName, items: [] };

  // افتح الـ modal بحالة تحميل
  let modal = document.getElementById('mo-return-modal');
  if(!modal){
    modal = document.createElement('div');
    modal.id = 'mo-return-modal';
    modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;display:flex;align-items:center;justify-content:center;padding:16px';
    document.body.appendChild(modal);
  }
  modal.innerHTML = `
    <div style="background:#fff;border-radius:16px;max-width:560px;width:100%;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.3)">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid var(--border)">
        <div style="font-weight:800;font-size:15px">↩️ مرتجع — ${escapeHtml(orderName)}</div>
        <button class="btn btn-ghost btn-sm" onclick="moCloseReturn()" style="font-size:18px;padding:2px 10px">✕</button>
      </div>
      <div id="mo-return-body" style="padding:18px">
        <div style="text-align:center;padding:30px;color:var(--muted)">⏳ جاري جلب منتجات الطلب...</div>
      </div>
    </div>
  `;
  modal.style.display = 'flex';

  // جيب الـ line items
  try {
    const r = await apiFetch('/api/manual-orders/' + encodeURIComponent(shopifyId) + '/line-items');
    if(!r || !r.items){ throw new Error(r?.error || 'فشل جلب المنتجات'); }
    _moReturnState.items = r.items.map(it => ({ ...it, newQuantity: it.currentQuantity }));
    moRenderReturnBody();
  } catch(e){
    document.getElementById('mo-return-body').innerHTML =
      `<div style="color:var(--danger);text-align:center;padding:20px">❌ ${escapeHtml(e.message)}</div>`;
  }
}

function moCloseReturn(){
  const m = document.getElementById('mo-return-modal');
  if(m) m.style.display = 'none';
  _moReturnState = null;
}

function moRenderReturnBody(){
  const body = document.getElementById('mo-return-body');
  if(!body || !_moReturnState) return;
  const its = _moReturnState.items;
  if(!its.length){
    body.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">مفيش منتجات في الطلب</div>';
    return;
  }

  const rows = its.map((it, idx) => {
    const willReturn = it.currentQuantity - it.newQuantity;
    return `
      <div style="display:grid;grid-template-columns:1fr auto;gap:10px;align-items:center;padding:12px;border:1px solid var(--border);border-radius:10px;margin-bottom:10px">
        <div style="min-width:0">
          <div style="font-weight:700;font-size:13px">${escapeHtml(it.title)}</div>
          <div style="font-size:10px;color:var(--muted);font-family:monospace">${it.sku ? escapeHtml(it.sku) : ''}</div>
          <div style="font-size:11px;color:var(--muted);margin-top:3px">الكمية الحالية: <strong>${it.currentQuantity}</strong>${willReturn > 0 ? ` · <span style="color:#dc2626">هيرجع المخزن: ${willReturn}</span>` : ''}</div>
        </div>
        <div style="display:flex;gap:4px;align-items:center">
          <span style="font-size:10px;color:var(--muted)">الكمية الجديدة</span>
          <button class="btn btn-ghost btn-sm" onclick="moReturnQtyStep(${idx},-1)" style="padding:2px 9px;font-size:15px">−</button>
          <input type="number" min="0" max="${it.currentQuantity}" value="${it.newQuantity}"
                 onchange="moReturnSetQty(${idx}, this.value)"
                 style="width:50px;text-align:center;font-weight:800;padding:5px;border:1px solid var(--border);border-radius:7px;font-family:Cairo,sans-serif">
        </div>
      </div>
    `;
  }).join('');

  const totalReturn = its.reduce((s,it) => s + (it.currentQuantity - it.newQuantity), 0);
  const anyChange = totalReturn > 0;

  body.innerHTML = `
    <div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;padding:10px;margin-bottom:14px;font-size:12px;color:#1e40af;line-height:1.6">
      💡 غيّر الكمية للقيمة <strong>الجديدة</strong> (بعد المرتجع). الفرق هيرجع المخزن تلقائياً. <strong>مفيش أي رد فلوس</strong> — التعديل على المخزون والطلب بس.
    </div>
    ${rows}
    <div style="margin-top:8px">
      <label style="font-size:11px;color:var(--muted);font-weight:700;display:block;margin-bottom:4px">ملاحظة (اختياري)</label>
      <input id="mo-return-note" placeholder="سبب المرتجع..." style="width:100%;padding:7px 10px;border:1px solid var(--border);border-radius:8px;font-family:Cairo,sans-serif;font-size:12px">
    </div>
    <div style="display:flex;gap:8px;margin-top:16px">
      <button class="btn btn-primary" id="mo-return-confirm" onclick="moConfirmReturn()" ${anyChange?'':'disabled style="opacity:.5;cursor:not-allowed"'}>
        ↩️ نفّذ المرتجع ${anyChange ? `(${totalReturn} قطعة)` : ''}
      </button>
      <button class="btn btn-ghost" onclick="moCloseReturn()">إلغاء</button>
    </div>
  `;
}

function moReturnSetQty(idx, val){
  if(!_moReturnState) return;
  const it = _moReturnState.items[idx];
  let q = parseInt(val);
  if(isNaN(q) || q < 0) q = 0;
  if(q > it.currentQuantity) q = it.currentQuantity;
  it.newQuantity = q;
  moRenderReturnBody();
}

function moReturnQtyStep(idx, delta){
  if(!_moReturnState) return;
  const it = _moReturnState.items[idx];
  moReturnSetQty(idx, it.newQuantity + delta);
}

async function moConfirmReturn(){
  if(!_moReturnState) return;
  // بس المنتجات اللي كميتها اتغيّرت
  const changed = _moReturnState.items
    .filter(it => it.newQuantity < it.currentQuantity)
    .map(it => ({ lineItemId: it.lineItemId, sku: it.sku || '', title: it.title || '', newQuantity: it.newQuantity }));

  if(!changed.length){ toast('⚠️ مفيش أي كمية اتغيّرت'); return; }

  const totalReturn = _moReturnState.items.reduce((s,it) => s + (it.currentQuantity - it.newQuantity), 0);
  if(!confirm(`تأكيد المرتجع؟\n\n${changed.length} منتج هيتعدّل\n${totalReturn} قطعة هترجع المخزن\n\nمفيش أي رد فلوس — تعديل مخزون وطلب بس.`)) return;

  const note = document.getElementById('mo-return-note')?.value?.trim() || '';
  const btn = document.getElementById('mo-return-confirm');
  if(btn){ btn.disabled = true; btn.textContent = '⏳ جاري التنفيذ...'; }

  try {
    const r = await apiFetch('/api/manual-orders/' + encodeURIComponent(_moReturnState.shopifyId) + '/return', 'POST', {
      items: changed,
      note,
    });
    if(r && r.success){
      toast('✅ ' + (r.message || 'تم المرتجع'));
      if(r.failed && r.failed.length){
        toast('⚠️ ' + r.failed.length + ' منتج فشل');
      }
      moCloseReturn();
      loadManualOrders(); // حدّث الجدول
    } else {
      toast('❌ ' + (r?.error || 'فشل المرتجع'));
      if(btn){ btn.disabled = false; btn.textContent = '↩️ نفّذ المرتجع'; }
    }
  } catch(e){
    toast('❌ ' + e.message);
    if(btn){ btn.disabled = false; btn.textContent = '↩️ نفّذ المرتجع'; }
  }
}

// ═══════════════════════════════════════════════════════════
// 🆕 v392: BULK IMAGE FIX
// ═══════════════════════════════════════════════════════════
let _imgfixItems = [];        // كل المنتجات اللي اتفحصت
let _imgfixScanning = false;
let _imgfixJobPoll = null;    // interval للـ progress

function imgfixOnOpen(){
  // لو فيه job شغّال، استأنف المتابعة
  imgfixCheckActiveJob();
  // 🆕 v399: حمّل المنتجات الجديدة (review queue) تلقائياً
  imgfixLoadReviewQueue();
}

// 🆕 v399: حمّل المنتجات الجديدة المعلّمة (من products/create webhook)
async function imgfixLoadReviewQueue(){
  if(!API_URL) return;
  try {
    const r = await apiFetch('/api/image-fix/review-queue');
    const items = (r && r.items) ? r.items : [];
    if(items.length){
      // احقن المنتجات الجديدة في القايمة (من غير ما نمسح نتيجة فحص كامل لو موجودة)
      const existing = new Set(_imgfixItems.map(i => i.mediaGid));
      const fresh = items.filter(i => !existing.has(i.mediaGid)).map(i => ({...i, hasImage: true, _isNew: true}));
      _imgfixItems = [...fresh, ..._imgfixItems];
      imgfixRender();
      const prog = document.getElementById('imgfix-scan-progress');
      if(prog && !_imgfixScanning){
        prog.textContent = `🆕 ${items.length} منتج جديد محتاج مراجعة صورة` + (_imgfixItems.length > items.length ? ` · ${_imgfixItems.length} إجمالي` : '');
      }
      // فعّل زرار "ظبّط الكل" لو فيه محتاج
      const fixAll = document.getElementById('imgfix-fixall-btn');
      if(fixAll && _imgfixItems.some(i => i.needsFix)) fixAll.style.display = 'inline-flex';
    }
  } catch(e){}
}

async function imgfixScan(){
  if(!API_URL){ toast('❌ الـ backend غير متصل'); return; }
  if(_imgfixScanning) return;
  _imgfixScanning = true;
  _imgfixItems = [];
  const btn = document.getElementById('imgfix-scan-btn');
  if(btn){ btn.disabled = true; btn.textContent = '⏳ جاري الفحص...'; }
  const prog = document.getElementById('imgfix-scan-progress');

  try {
    let cursor = null, pages = 0;
    do {
      const params = new URLSearchParams({ limit: '50' });
      if(cursor) params.set('cursor', cursor);
      const r = await apiFetch('/api/image-fix/scan?' + params.toString());
      if(!r || !r.items) throw new Error(r?.error || 'فشل الفحص');
      _imgfixItems.push(...r.items.filter(it => it.hasImage));
      cursor = r.hasNextPage ? r.endCursor : null;
      pages++;
      const needed = _imgfixItems.filter(i => i.needsFix).length;
      if(prog) prog.textContent = `تم فحص ${_imgfixItems.length} منتج... (${needed} محتاج تظبيط)`;
      imgfixRender();
      // safety: حد أقصى ~160 صفحة (8000 منتج)
      if(pages > 165) break;
    } while(cursor);

    const needed = _imgfixItems.filter(i => i.needsFix).length;
    if(prog) prog.textContent = `✅ خلص الفحص: ${_imgfixItems.length} منتج · ${needed} محتاج تظبيط`;
    const fixAll = document.getElementById('imgfix-fixall-btn');
    if(fixAll) fixAll.style.display = needed > 0 ? 'inline-flex' : 'none';
  } catch(e){
    if(prog) prog.textContent = '❌ ' + e.message;
    toast('❌ ' + e.message);
  } finally {
    _imgfixScanning = false;
    if(btn){ btn.disabled = false; btn.textContent = '🔍 افحص الكتالوج'; }
  }
}

function imgfixRender(){
  const cont = document.getElementById('imgfix-results');
  if(!cont) return;
  const onlyNeeded = document.getElementById('imgfix-only-needed')?.checked;
  const search = (document.getElementById('imgfix-search')?.value || '').trim().toLowerCase();
  let list = _imgfixItems.slice();
  if(onlyNeeded) list = list.filter(i => i.needsFix);
  if(search) list = list.filter(i => (i.title || '').toLowerCase().includes(search));

  // 🆕 v396: فلتر بالحجم (KB)
  const sizeFilter = document.getElementById('imgfix-size-filter')?.value || 'all';
  if(sizeFilter !== 'all'){
    list = list.filter(i => {
      const kb = (i.fileSize || 0) / 1024;
      if(!i.fileSize) return false; // الصور بدون حجم تُستثنى من الفلترة بالحجم
      switch(sizeFilter){
        case 'lt100': return kb < 100;
        case '100-300': return kb >= 100 && kb < 300;
        case '300-500': return kb >= 300 && kb < 500;
        case 'gt500': return kb >= 500;
        case 'gt1mb': return kb >= 1024;
        default: return true;
      }
    });
  }

  // 🆕 v396: ترتيب
  const sortBy = document.getElementById('imgfix-sort')?.value || 'none';
  if(sortBy === 'size-desc') list.sort((a,b) => (b.fileSize||0) - (a.fileSize||0));
  else if(sortBy === 'size-asc') list.sort((a,b) => (a.fileSize||0) - (b.fileSize||0));
  else if(sortBy === 'title') list.sort((a,b) => (a.title||'').localeCompare(b.title||'', 'ar'));

  if(!list.length){
    let msg, sub;
    if(search){ msg = '🔎 مفيش نتائج للبحث'; sub = 'جرّب كلمة تانية'; }
    else if(sizeFilter !== 'all'){ msg = '📏 مفيش صور في نطاق الحجم ده'; sub = 'جرّب نطاق تاني'; }
    else if(_imgfixItems.length){ msg = '✅ كل الصور المعروضة متظبطة'; sub = ''; }
    else { msg = 'اضغط "افحص الكتالوج"'; sub = ''; }
    cont.innerHTML = `<div style="text-align:center;padding:40px;color:var(--muted)"><div style="font-size:42px;opacity:.3">${search?'🔎':sizeFilter!=='all'?'📏':'🖼️'}</div><div style="margin-top:10px;font-weight:700">${msg}</div>${sub?`<div style="font-size:12px;margin-top:4px">${sub}</div>`:''}</div>`;
    return;
  }

  const rows = list.map(it => {
    const dim = (it.width && it.height) ? `${it.width}×${it.height}` : '؟';
    const sizeStr = imgfixFmtSize(it.fileSize);
    const badge = it.needsFix
      ? `<span style="background:#fef3c7;color:#92400e;padding:2px 8px;border-radius:6px;font-size:10px;font-weight:700">⚠️ محتاج تظبيط</span>`
      : `<span style="background:#dcfce7;color:#166534;padding:2px 8px;border-radius:6px;font-size:10px;font-weight:700">✅ متظبط</span>`;
    const newBadge = it._isNew
      ? `<span style="background:#ede9fe;color:#6d28d9;padding:2px 6px;border-radius:6px;font-size:9px;font-weight:700;margin-right:4px">🆕 جديد</span>`
      : '';
    return `
      <tr data-media="${it.mediaGid}">
        <td style="width:48px"><img src="${it.imageUrl}" style="width:42px;height:42px;object-fit:contain;background:#f3f4f6;border-radius:6px;border:1px solid var(--border)"></td>
        <td style="font-size:12px;font-weight:600">${newBadge}${escapeHtml(it.title)}</td>
        <td style="text-align:center;font-size:11px;font-family:monospace">${dim}</td>
        <td style="text-align:center;font-size:11px;font-family:monospace;color:var(--muted)">${sizeStr}</td>
        <td style="text-align:center">${badge}</td>
        <td style="text-align:center">
          ${it.needsFix ? `<button class="btn btn-ghost btn-xs" onclick='imgfixOne(this, ${JSON.stringify(it).replace(/'/g,"&#39;")})' style="color:#16a34a">🖼️ ظبّط</button>` : '—'}
        </td>
      </tr>`;
  }).join('');

  // إجمالي حجم الصور المعروضة (لو فيها أحجام)
  const totalBytes = list.reduce((s,i) => s + (i.fileSize||0), 0);
  const totalStr = totalBytes > 0 ? ` · إجمالي ${imgfixFmtSize(totalBytes)}` : '';

  cont.innerHTML = `
    <div class="card">
      <div class="card-hd"><h3 style="margin:0">${list.length} منتج${search?` (بحث: "${escapeHtml(search)}")`:''}${totalStr}</h3></div>
      <div class="tw" style="overflow-x:auto">
        <table style="width:100%;font-size:12px">
          <thead><tr>
            <th></th><th>المنتج</th>
            <th style="text-align:center">الأبعاد</th>
            <th style="text-align:center">الحجم</th>
            <th style="text-align:center">الحالة</th>
            <th style="text-align:center"></th>
          </tr></thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    </div>`;
}

// تنسيق حجم الملف (bytes → KB/MB)
function imgfixFmtSize(bytes){
  if(!bytes || bytes <= 0) return '—';
  if(bytes < 1024) return bytes + ' B';
  if(bytes < 1024*1024) return Math.round(bytes/1024) + ' KB';
  return (bytes/(1024*1024)).toFixed(1) + ' MB';
}

async function imgfixOne(btn, item){
  if(!confirm(`ظبّط صورة "${item.title}"؟`)) return;
  btn.disabled = true; btn.textContent = '⏳';
  try {
    const r = await apiFetch('/api/image-fix/single', 'POST', {
      mediaGid: item.mediaGid, imageUrl: item.imageUrl, title: item.title,
      productId: item.productId || item.productGid,  // 🆕 v399: عشان العلم يتشال
    });
    if(r && r.success){
      toast('✅ اتظبطت: ' + (r.filename || ''));
      // 🆕 v399: شيل الصف من القايمة (اتظبط خلاص)، والباقي يفضل
      _imgfixItems = _imgfixItems.filter(x => x.mediaGid !== item.mediaGid);
      imgfixRender();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
      btn.disabled = false; btn.textContent = '🖼️ ظبّط';
    }
  } catch(e){
    toast('❌ ' + e.message);
    btn.disabled = false; btn.textContent = '🖼️ ظبّط';
  }
}

async function imgfixStartAll(){
  const needed = _imgfixItems.filter(i => i.needsFix);
  if(!needed.length){ toast('مفيش صور محتاجة تظبيط'); return; }
  if(!confirm(`هتظبّط ${needed.length} صورة. العملية بتشتغل في الخلفية وممكن تاخد وقت. نبدأ؟`)) return;

  try {
    const items = needed.map(i => ({
      productGid: i.productGid, mediaGid: i.mediaGid, title: i.title, imageUrl: i.imageUrl,
    }));
    const r = await apiFetch('/api/image-fix/jobs', 'POST', { items });
    if(r && r.success){
      toast(`✅ بدأ تظبيط ${r.total} صورة`);
      imgfixTrackJob(r.jobId);
    } else {
      toast('❌ ' + (r?.error || 'فشل بدء العملية'));
    }
  } catch(e){
    toast('❌ ' + e.message);
  }
}

async function imgfixCheckActiveJob(){
  if(!API_URL) return;
  try {
    const r = await apiFetch('/api/image-fix/jobs');
    const running = (r?.jobs || []).find(j => j.status === 'running');
    if(running) imgfixTrackJob(running.id);
  } catch(e){}
}

function imgfixTrackJob(jobId){
  const card = document.getElementById('imgfix-job-card');
  if(card) card.style.display = 'block';
  if(_imgfixJobPoll) clearInterval(_imgfixJobPoll);

  const poll = async () => {
    try {
      const r = await apiFetch('/api/image-fix/jobs/' + jobId);
      if(!r || !r.job) return;
      const j = r.job;
      const pct = j.total > 0 ? Math.round(((j.done + j.failed) / j.total) * 100) : 0;
      const bar = document.getElementById('imgfix-job-bar');
      const stats = document.getElementById('imgfix-job-stats');
      const title = document.getElementById('imgfix-job-title');
      if(bar) bar.style.width = pct + '%';
      if(stats) stats.textContent = `${j.done + j.failed} / ${j.total} (✅ ${j.done} · ❌ ${j.failed})`;
      if(title) title.textContent = j.status === 'done' ? '✅ خلصت المعالجة' : '⏳ جاري المعالجة...';

      const failBox = document.getElementById('imgfix-job-failed');
      if(failBox && r.recentFailed && r.recentFailed.length){
        failBox.innerHTML = '<div style="color:#991b1b;font-weight:700;margin-bottom:4px">آخر اللي فشلوا:</div>' +
          r.recentFailed.slice(0,5).map(f => `<div style="color:var(--muted)">• ${escapeHtml(f.product_title||'')}: ${escapeHtml((f.error||'').slice(0,60))}</div>`).join('');
      }

      if(j.status === 'done'){
        clearInterval(_imgfixJobPoll);
        _imgfixJobPoll = null;
        toast(`✅ خلصت: ${j.done} نجحت · ${j.failed} فشلت`);
        // أعد الفحص عشان نحدّث الحالات
        setTimeout(() => imgfixScan(), 1500);
      }
    } catch(e){}
  };
  poll();
  _imgfixJobPoll = setInterval(poll, 3000);
}

// 🆕 v371: طباعة الفاتورة مباشرة من الـ backend (بدون الحاجة لـ orders cache)
// بـ يفتح الـ /api/orders/:id/invoice في نافذة جديدة + auto-print
async function printManualOrderInvoiceDirect(orderId){
  if(!API_URL){ toast('❌ API غير متاح'); return; }
  if(!window._adminToken){ toast('❌ لازم تسجل دخول أولاً'); return; }
  
  // 🆕 v283: بـ نبعت الـ token كـ query string عشان الـ adminAuth يقبله
  // (window.open ما بـ يقدر يبعت Authorization header)
  const invoiceUrl = API_URL.replace(/\/$/,'') 
    + '/api/orders/' + encodeURIComponent(orderId) + '/invoice'
    + '?token=' + encodeURIComponent(window._adminToken);
  
  // افتح الـ invoice في نافذة جديدة
  const w = window.open(invoiceUrl, '_blank', 'width=900,height=1000');
  if(!w){
    toast('❌ المتصفح منع فتح النافذة - فعّل popups');
    return;
  }
  
  // انتظر تحميل الـ HTML ثم اطبع
  let printed = false;
  const tryPrint = () => {
    if(printed) return;
    printed = true;
    try { w.focus(); w.print(); } catch(e){}
  };
  
  // listener للـ signal من النافذة (لو الـ invoice page بـ يبعت "invoice-ready")
  const onMsg = (ev) => {
    if(ev.source !== w) return;
    if(ev.data && ev.data.type === 'invoice-ready'){
      window.removeEventListener('message', onMsg);
      tryPrint();
    }
  };
  window.addEventListener('message', onMsg);
  
  // safety timeout - 3 ثوان
  setTimeout(() => {
    window.removeEventListener('message', onMsg);
    tryPrint();
  }, 3000);
}

