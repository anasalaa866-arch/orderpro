  } else {
    const strategy = document.querySelector('input[name="stk-rnd-strategy"]:checked')?.value || 'smart';
    payload.templateType = strategy === 'smart' ? 'random_smart' : 'random_simple';
    payload.randomCount = parseInt(document.getElementById('stk-random-count')?.value) || 50;
  }
  
  try {
    const r = await apiFetch('/api/stocktake/templates', 'POST', payload);
    if(r?.success){
      toast('✅ تم حفظ الـ template');
      closeM('m-save-stk-template');
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  } catch(e) {
    toast('❌ ' + e.message);
  }
}

