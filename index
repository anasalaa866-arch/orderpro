// 🆕 v300: حفظ الـ batch المرتبط بـ PO
async function _saveBatchFromPO(poId, itemId){
  const exp_date = document.getElementById('batch-exp-date')?.value;
  const quantity = parseInt(document.getElementById('batch-qty')?.value);
  const notes = document.getElementById('batch-notes')?.value?.trim() || '';
  
  if(!exp_date){
    toast('❌ التاريخ مطلوب');
    return;
  }
  if(!quantity || quantity < 1){
    toast('❌ كمية غير صالحة');
    return;
  }
  
  // validate date not in past
  const today = new Date().toISOString().slice(0, 10);
  if(exp_date < today){
    if(!confirm('⚠️ التاريخ ده فات بالفعل - متأكد؟')) return;
  }
  
  try {
    const r = await apiFetch(
      `/api/purchase-orders/${poId}/items/${itemId}/batch`,
      'POST',
      { exp_date, quantity, notes }
    );
    
    document.getElementById('batch-date-modal')?.remove();
    toast('✅ تم حفظ الصلاحية + ربطها بصفحة تواريخ الصلاحية');
    
    // refresh الـ pricing section عشان نشوف الـ active_batches count يحدث
    _loadPOPricingSection(poId);
  } catch(e){
    toast('❌ ' + e.message);
  }
}

