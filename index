function confirmAccBatchSelection(){
  const ctx = window._accBatchCtx;
  if(!ctx) return;
  const checked = [...document.querySelectorAll('.acc-batch-chk:checked')].map(c=>c.value);
  if(!checked.length){ toast('❗ اختر دفعة واحدة على الأقل'); return; }

  let selectedOrders = [];
  checked.forEach(code => {
    if(code === '__nobatch__') selectedOrders.push(...ctx.noBatchOrders);
    else if(ctx.batchMap[code]) selectedOrders.push(...ctx.batchMap[code]);
  });

  if(!selectedOrders.length){ toast('❗ لا توجد طلبات'); return; }

  closeM('m-acc-batch');
  _startCourierAccSession(ctx.cId, ctx.courier, selectedOrders);
}

function _startCourierAccSession(cId, c, sessionOrders){
  // ترتيب زي ورقة التوصيل: Express أولاً، بعدين Normal مرتبة بالمنطقة
  const express = sessionOrders.filter(o=>isSameDay(o));
  const normal = sessionOrders.filter(o=>!isSameDay(o));

  // ترتيب Normal: zones الخاصة بالمندوب أولاً (بنفس ترتيبها)، بعدين الباقي، "أخري" في الآخر
  const courierZones = (c.zone||'').split(/[،,\/\-–\n]+/).map(z=>z.trim()).filter(z=>z.length>1);
  const zonesMap = {};
  normal.forEach(o=>{
    const z = o.assignedZone || getOrderZoneForCourier(o,c) || 'أخري';
    if(!zonesMap[z]) zonesMap[z] = [];
    zonesMap[z].push(o);
  });
  const zoneKeys = Object.keys(zonesMap);
  const sortedZones = [
    ...courierZones.filter(z=>zoneKeys.includes(z)),
    ...zoneKeys.filter(z=>!courierZones.includes(z)&&z!=='أخري').sort((a,b)=>a.localeCompare(b,'ar')),
    ...zoneKeys.filter(z=>z==='أخري'),
  ];
  const normalSorted = sortedZones.flatMap(z=>zonesMap[z]||[]);

  sessionOrders = [...express, ...normalSorted];

  _courierAccSession = {
    courierId: cId,
    courierName: c.name,
    orders: sessionOrders,
    index: 0,
    updates: {} // { orderId: {status, paid} }
  };

  renderCourierAccSession();
}

