async function printPackingSlip(orderId){
  const o = orders.find(x=>x.id===orderId);
  if(!o){ toast('❗ الطلب غير موجود'); return; }

  // 🆕 v154: تحذير لو اتطبع قبل كده
  const ok = await _checkAndWarnIfPrintedBefore(orderId, 'invoice');
  if(!ok){ toast('تم إلغاء الطباعة'); return; }

  // جرّب الفاتورة المخزنة من الـ backend أولاً (أسرع + صور مضمونة)
  if(API_URL){
    try{
      const invoiceUrl = API_URL.replace(/\/$/,'')+'/api/orders/'+encodeURIComponent(orderId)+'/invoice';
      // تحقق أن الـ endpoint شغال قبل ما نفتح نافذة
      const testResp = await fetch(invoiceUrl, { method: 'HEAD' }).catch(()=>null);
      if(testResp && testResp.ok){
        const w = window.open(invoiceUrl, '_blank', 'width=900,height=1000');
        if(w){
          // 🆕 v259: انتظر signal "invoice-ready" من النافذة (الصور جاهزة فعلاً)
          // بدل setTimeout(1500) اللي كان guess
          let printed = false;
          const tryPrint = () => {
            if(printed) return;
            printed = true;
            try{ w.focus(); w.print(); }catch(e){}
          };
          
          // listener للـ event
          const onMsg = (ev) => {
            if(ev.source !== w) return;
            if(ev.data && ev.data.type === 'invoice-ready'){
              window.removeEventListener('message', onMsg);
              tryPrint();
            }
          };
          window.addEventListener('message', onMsg);
          
          // safety timeout - 5 ثوان كحد أقصى (لو الـ signal فشل، نطبع برضو)
          setTimeout(() => {
            window.removeEventListener('message', onMsg);
            tryPrint();
          }, 5000);
          
          // 🆕 v154: سجّل الطباعة
          _logPrintAction(orderId, 'invoice');
          return;
        }
      } else {
        console.log('Invoice endpoint not ready, using legacy print');
      }
    }catch(e){ console.warn('cached invoice failed, falling back:', e); }
  }

  // Fallback — الطريقة القديمة لو الـ backend مش شغال أو الـ endpoint مش موجود
  await printPackingSlipLegacy(orderId);
  // 🆕 v154: سجّل الطباعة بعد ما الـ legacy تخلص
  _logPrintAction(orderId, 'invoice');
}

