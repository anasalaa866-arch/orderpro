async function spBulkSearchNow(){
  const q = document.getElementById('sp-bulk-search').value.trim();
  const status = document.getElementById('sp-bulk-status');
  const wrap = document.getElementById('sp-bulk-results-wrap');
  const empty = document.getElementById('sp-bulk-empty');
  const addBtn = document.getElementById('sp-bulk-add-btn');

  if(q.length < 2){
    status.style.display = 'block';
    status.innerHTML = '⚠️ اكتب على الأقل حرفين';
    status.style.background = '#fef3c7';
    status.style.color = '#92400e';
    wrap.style.display = 'none';
    empty.style.display = 'none';
    addBtn.disabled = true;
    return;
  }

  // Loading state
  status.style.display = 'block';
  status.style.background = 'var(--bg)';
  status.style.color = 'var(--muted)';
  status.innerHTML = '⏳ جاري البحث...';
  empty.style.display = 'none';
  addBtn.disabled = true;

  try {
    const r = await apiFetch('/api/suppliers/' + _spCurrentSupplierId + '/bulk-search?q=' + encodeURIComponent(q));
    _spBulkResults = r?.results || [];
    const newOnly = _spBulkResults.filter(v => !v.already_added);

    if(!_spBulkResults.length){
      status.innerHTML = '❌ مفيش منتجات تطابق "' + escapeHtml(q) + '"';
      status.style.background = '#fee2e2';
      status.style.color = '#991b1b';
      wrap.style.display = 'none';
      return;
    }

    // Status
    status.style.background = '#dcfce7';
    status.style.color = '#166534';
    status.innerHTML = `✅ <strong>${_spBulkResults.length}</strong> منتج تطابق "${escapeHtml(q)}" — `
      + `<strong>${newOnly.length}</strong> جديد قابل للإضافة`
      + (r.alreadyAddedCount ? `، ${r.alreadyAddedCount} موجود سابقاً` : '');

    // Render list - select all new by default
    _spBulkSelected = new Set(newOnly.map(v => v.variant_id));
    spBulkRenderResults();
    wrap.style.display = '';
    document.getElementById('sp-bulk-select-all').checked = newOnly.length > 0;
    spBulkUpdateAddBtn();
  } catch(e) {
    status.innerHTML = '❌ خطأ: ' + escapeHtml(e.message || '');
    status.style.background = '#fee2e2';
    status.style.color = '#991b1b';
    wrap.style.display = 'none';
  }
}

function spBulkRenderResults(){
  const html = _spBulkResults.map((v, i) => {
    const isAlready = !!v.already_added;
    const isChecked = !isAlready && _spBulkSelected.has(v.variant_id);
    const title = (v.product_title || '') + (v.variant_title ? ' - ' + v.variant_title : '');
    const price = parseFloat(v.price) || 0;
    const imgUrl = v.image_url || '';
    return `
    <div style="padding:8px 12px;border-bottom:1px solid var(--border);display:flex;gap:10px;align-items:center;${isAlready?'opacity:.5;background:var(--bg)':''}">
      <input type="checkbox" ${isAlready?'disabled':''} ${isChecked?'checked':''} onchange="spBulkToggleItem('${escapeAttr(v.variant_id)}', this.checked)" style="cursor:${isAlready?'not-allowed':'pointer'};margin:0;flex-shrink:0">
      <div style="width:42px;height:42px;background:var(--bg);border-radius:6px;overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center">
        ${imgUrl
          ? `<img src="${escapeAttr(imgUrl)}" style="width:100%;height:100%;object-fit:cover" loading="lazy" onerror="this.style.display='none'">`
          : '<span style="font-size:18px;opacity:.4">📦</span>'}
      </div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:700;font-size:12px;line-height:1.4">${escapeHtml(title)} ${isAlready?'<span style="color:#16a34a;font-size:10px;margin-right:4px">✓ موجود</span>':''}</div>
        <div style="color:var(--muted);font-size:10px;margin-top:2px">
          ${v.sku ? 'SKU: '+escapeHtml(v.sku)+' · ' : ''}${price ? price.toFixed(0)+' ج · ' : ''}مخزون: ${v.total_stock || 0}
