async function loadTreasury(){
  if(!API_URL){ return; }
  try{
    const [r1, r2] = await Promise.all([
      apiFetch('/api/treasuries'),
      apiFetch('/api/treasury-tx')
    ]);
    if(r1?.treasuries) _treasuries = r1.treasuries;
    if(r2?.transactions) _treasuryTx = r2.transactions;
  }catch(e){ console.error('loadTreasury:', e); }
}

