async function resyncOrderPrice(orderId, newTotal){
  if(!confirm('هيتم تحديث المنتجات والإجمالي من Shopify (بيشيل المنتجات المحذوفة بعد تعديل الطلب). نكمل؟'))return;
  const o = orders.find(x=>x.id===orderId);
  if(!o)return;
  if(!API_URL){ toast('❗ الـ backend غير متصل'); return; }
  const oldTotal = o.total;

  // 🆕 v389: نعمل full re-fetch (منتجات + سعر) بدل تحديث السعر بس.
  // ده بيصلّح الطلبات المعدّلة على Shopify (المنتجات المحذوفة current_quantity=0)
  if(o.shopifyId){
    toast('⏳ جاري التحديث من Shopify...');
    try{
      const r = await apiFetch('/api/shopify/fetch-line-items','POST',{
        shopifyOrderId: String(o.shopifyId),
        orderId: o.id,
      });
      if(r && r.success){
        if(r.lineItemsJson) o.lineItemsJson = r.lineItemsJson;
        if(r.totalPrice != null) o.total = r.totalPrice;
        else o.total = newTotal;
        if(r.subtotalPrice != null) o.subtotalPrice = r.subtotalPrice;
        if(r.shippingPrice != null) o.shippingPrice = r.shippingPrice;
        debouncedSaveOrders();
        document.getElementById('price-check-popup')?.remove();
        const totInput = document.getElementById('eo-total');
        if(totInput) totInput.value = o.total;
        refreshAll();
        toast('✅ تم تحديث المنتجات والإجمالي إلى '+(o.total||0).toLocaleString()+' ج');
        return;
      }
    }catch(e){ console.warn('resync full:', e.message); }
  }

  // fallback: لو مفيش shopifyId أو فشل، حدّث السعر بس (السلوك القديم)
  o.total = newTotal;
  debouncedSaveOrders();
  apiFetch('/api/orders/'+orderId,'PATCH',{total:newTotal}).catch(()=>{});
  document.getElementById('price-check-popup')?.remove();
  const totInput = document.getElementById('eo-total');
  if(totInput) totInput.value = newTotal;
  refreshAll();
  toast('✅ تم التحديث من '+oldTotal.toLocaleString()+' إلى '+newTotal.toLocaleString()+' ج');
}

