  const get = id => document.getElementById(id)?.value?.trim()||'';
  const name = get('eo-name');
  const area = get('eo-area');
  if(!name||!area){ toast('❗ اسم العميل والمنطقة مطلوبان'); return; }
  const total = parseFloat(get('eo-total'))||0;
  const ship  = parseFloat(get('eo-ship'))||50;
  const paid  = document.getElementById('eo-paid')?.checked||false;
  const phone = get('eo-phone')||'—';
  const addr  = get('eo-addr');
  const orderNote = get('eo-order-note');
  const details = get('eo-details');
  const deliveryType = get('eo-delivery-type')||'normal';
  const status = get('eo-status');
  const courierRaw = document.getElementById('eo-courier')?.value;
  const courierId = courierRaw ? (isNaN(+courierRaw)?courierRaw:+courierRaw) : null;
  // orderNote بدل note — نحفظها في الحقلين للتوافق
  const upd = { name, phone, area, addr, total, ship, paid, note: orderNote, orderNote, details, deliveryType, status, courierId };
