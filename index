      <!-- Product info -->
      <div style="min-width:0">
        <div style="font-weight:600;color:#1a1c1d;font-size:13px;line-height:1.4;word-break:break-word">${escapeHtml(it.productTitle)}${it.variantTitle ? ' - '+escapeHtml(it.variantTitle) : ''}</div>
        ${it.sku || it.barcode ? `
          <div style="font-size:11px;color:#6d7175;margin-top:3px;font-family:monospace">
            ${it.sku ? 'SKU: ' + escapeHtml(it.sku) : ''}${it.sku && it.barcode ? ' · ' : ''}${it.barcode ? escapeHtml(it.barcode) : ''}
          </div>
        ` : ''}
      </div>
      
      <!-- Quantity (editable inline) -->
      <div>
        <input type="number" min="1" value="${it.orderedQty}" 
          data-poitem-qty="${i}"
          onchange="updatePOItemField(${i}, 'orderedQty', parseInt(this.value)||1)" 
          class="form-input" 
          style="width:100%;text-align:center;padding:6px 4px;font-size:13px;font-family:monospace">
      </div>
      
      <!-- Unit cost (editable inline) -->
      <div>
        <input type="number" min="0" step="0.01" value="${parseFloat(it.unitCost).toFixed(2)}" 
          data-poitem-cost="${i}"
          onchange="updatePOItemField(${i}, 'unitCost', parseFloat(this.value)||0)" 
          class="form-input" 
          style="width:100%;text-align:left;padding:6px 4px;font-size:13px;font-family:monospace${isJustAdded ? ';border-color:#f59e0b;border-width:2px' : ''}">
      </div>
      
      <!-- Line total -->
      <div style="text-align:left;font-weight:700;font-family:monospace;color:#1a1c1d">
        ${(it.orderedQty * it.unitCost).toFixed(2)} ج
      </div>
      
      <!-- Reserved column (for tax/extras future) -->
      <div></div>
      
      <!-- Remove -->
      <div>
        <button onclick="removePOItem(${i})" style="background:transparent;border:none;cursor:pointer;color:#d72c0d;font-size:18px;padding:4px 6px;border-radius:4px" onmouseover="this.style.background='#fef2f2'" onmouseout="this.style.background='transparent'" title="حذف">✕</button>
      </div>
    </div>`;
  }).join('');
  
  // 🆕 v337: لو فيه سطر اتضاف، شيل الـ highlight بعد ثانية
  if(_poJustAddedIdx >= 0){
    const addedIdx = _poJustAddedIdx;
    setTimeout(() => {
      if(_poJustAddedIdx === addedIdx){
        _poJustAddedIdx = -1;
        // re-render بدون highlight (لكن مش render كامل عشان مايلخبطش الـ focus)
        const row = list.querySelector(`[data-poitem-row="${addedIdx}"]`);
        if(row){
          row.style.background = 'transparent';
          const costInp = row.querySelector(`[data-poitem-cost="${addedIdx}"]`);
          if(costInp){
            costInp.style.borderColor = '#c9cccf';
            costInp.style.borderWidth = '1px';
          }
        }
      }
    }, 1500);
  }
}

// 🆕 v337: تعديل قيمة من inside الـ table مباشرة
function updatePOItemField(idx, field, value){
  if(!_poItems[idx]) return;
