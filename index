      // 🆕 v332: لو الأسبوع فيه شيكات، خليه قابل للضغط
      const hasChecks = w.checks.length > 0;
      const clickHandler = hasChecks ? `onclick="openWeekChecksModal(${w.w})" onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='${bg}'"` : '';
