      '<table class="ds-table">'+DS_HEADERS+'<tbody>'+rows+'</tbody></table>';
  }

  sheetEl.innerHTML='<div class="ds-hd"><div><div class="ds-title">'+c.name+'</div><div class="ds-sub">OrderPro · '+today+'</div></div>'+
    '<div style="text-align:left"><div style="font-size:11px;color:var(--muted)">📦 '+all.length+' طلب</div>'+
    '<div style="font-size:13px;font-weight:700;color:var(--danger)">💰 '+totalCod.toLocaleString()+' ج</div>'+
    '<div style="font-size:11px;color:var(--muted)">🚚 شحن: '+shipFee.toLocaleString()+' ج</div></div></div>'+
    expHtml+normHtml+
    '<div class="ds-foot" style="font-size:10px;color:var(--muted);margin-top:8px">'+
