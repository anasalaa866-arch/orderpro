async function confirmBatchDepleted(batchId){
  if(!confirm('متأكد إن الـ batch ده فعلاً خلص؟ هيتشال من القائمة.')) return;
  try {
    const r = await apiFetch(`/api/product-batches/${batchId}/confirm-depleted`, 'POST', {});
    if(r?.success){
      toast('✅ تم التأكيد');
      loadBatchesPage();
    }
  } catch(e){ toast('❌ ' + e.message); }
}

async function restoreBatch(batchId){
  const qty = prompt('فيه كام قطعة موجودة فعلاً؟');
  if(!qty) return;
  const q = parseInt(qty);
  if(!q || q < 1){ toast('❌ كمية غلط'); return; }
  
  try {
    const r = await apiFetch(`/api/product-batches/${batchId}/restore`, 'POST', { quantity: q });
    if(r?.success){
      toast('✅ تم الاسترجاع');
      loadBatchesPage();
    }
  } catch(e){ toast('❌ ' + e.message); }
}

async function deleteBatch(batchId){
  if(!confirm('هتمسح الـ batch ده. متأكد؟')) return;
  try {
    const r = await apiFetch(`/api/product-batches/${batchId}`, 'DELETE');
    if(r?.success){
      toast('🗑️ تم الحذف');
      loadBatchesPage();
    }
  } catch(e){ toast('❌ ' + e.message); }
}

async function editBatch(batchId){
  // جيب الـ batch من _batchesData
  let batch = null;
  for(const p of (_batchesData.products || [])){
    if(Array.isArray(p.batches)){
      batch = p.batches.find(b => b.id === batchId);
      if(batch){ batch._product = p; break; }
    }
  }
  if(!batch){ toast('❌ batch مش موجود'); return; }
  
  const newDate = prompt('تاريخ الانتهاء الجديد (YYYY-MM-DD):', batch.expDate ? batch.expDate.split('T')[0] : '');
  if(!newDate) return;
  
  const newQty = prompt('الكمية:', batch.currentQuantity);
  if(newQty === null) return;
  const q = parseInt(newQty);
  if(isNaN(q) || q < 0){ toast('❌ كمية غلط'); return; }
  
  try {
    const r = await apiFetch(`/api/product-batches/${batchId}`, 'PATCH', {
      expDate: newDate,
      quantity: q
    });
    if(r?.success){
      toast('✅ تم التعديل');
      loadBatchesPage();
    }
  } catch(e){ toast('❌ ' + e.message); }
}

