function renderPurchaseSuggestions(){
  const results = document.getElementById('ps-results');
  if(!results) return;
  
  let suggestions = _psData.suggestions || [];
  
  // filter by search
  const search = (document.getElementById('ps-search')?.value || '').trim().toLowerCase();
  if(search){
    suggestions = suggestions.filter(s => 
      (s.product_title || '').toLowerCase().includes(search) ||
      (s.sku || '').toLowerCase().includes(search) ||
      (s.barcode || '').toLowerCase().includes(search)
    );
  }
  
  // filter by formula
  if(_psFormulaFilter !== 'all'){
    suggestions = suggestions.filter(s => s.formula.chosen === _psFormulaFilter);
  }
  
  if(!suggestions.length){
    results.innerHTML = `
      <div style="text-align:center;padding:50px;color:var(--muted)">
        <div style="font-size:48px;opacity:.4">✅</div>
        <div style="font-weight:700;margin-top:10px">مفيش توصيات شراء حالياً</div>
        <div style="font-size:12px;margin-top:4px">المخزون كافي لكل المنتجات</div>
      </div>
    `;
    return;
  }
  
  results.innerHTML = suggestions.map(s => renderPSCard(s)).join('');
}

function renderPSCard(s){
  const dl = s.priority_days_left;
  const isCritical = dl !== null && dl <= 7;
  const isLow = dl !== null && dl > 7 && dl <= 14;
  const borderColor = isCritical ? '#ef4444' : (isLow ? '#f59e0b' : '#3b82f6');
  const isSelected = _psSelected.has(s.variant_id);
  
  // warehouse breakdown
  const whHtml = (s.warehouses || []).map(w => {
    const days = w.velocity > 0 ? (w.stock / w.velocity).toFixed(1) : (w.stock > 0 ? '∞' : '0');
    const color = w.velocity > 0 && w.stock / w.velocity <= 7 ? '#ef4444' :
                  w.velocity > 0 && w.stock / w.velocity <= 14 ? '#f59e0b' : '#10b981';
    const icon = w.is_master ? '🏠' : (w.is_pos ? '🏪' : '📦');
    
    return `
      <div style="display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr 1fr;gap:8px;padding:8px 10px;background:${w.is_master ? '#f0fdf4' : 'var(--bg)'};border-radius:6px;font-size:12px;align-items:center;border-right:3px solid ${color}">
        <div>
          <div style="font-weight:700">${icon} ${escapeHtml(w.warehouse_name)}${w.is_master ? ' <span style=\"font-size:9px;background:#10b981;color:#fff;padding:1px 5px;border-radius:99px\">رئيسي</span>' : ''}</div>
        </div>
        <div style="text-align:center">
          <div style="color:var(--muted);font-size:10px">المخزون</div>
          <div style="font-weight:800;font-size:14px">${w.stock}</div>
        </div>
        <div style="text-align:center">
          <div style="color:var(--muted);font-size:10px">بيع/يوم</div>
          <div style="font-weight:700">${w.velocity.toFixed(2)}</div>
          <div style="font-size:9px;color:var(--muted)">7d:${w.velocity_7d.toFixed(1)} · 14d:${w.velocity_14d.toFixed(1)}</div>
        </div>
        <div style="text-align:center">
          <div style="color:var(--muted);font-size:10px">يكفي لـ</div>
          <div style="font-weight:800;color:${color}">${days} يوم</div>
        </div>
        <div style="text-align:center">
          <div style="color:var(--muted);font-size:10px">حاجة المخزن</div>
          <div style="font-weight:700;color:${w.contribution_A > 0 ? '#ef4444' : '#10b981'}">${w.contribution_A > 0 ? '+' : ''}${w.contribution_A.toFixed(0)}</div>
        </div>
      </div>
    `;
  }).join('');
  
  // formula box
  const f = s.formula;
  const aHighlight = f.chosen === 'A' ? 'background:#dcfce7;border:2px solid #10b981' : 'background:var(--bg);border:1px solid var(--border)';
  const bHighlight = f.chosen === 'B' ? 'background:#dcfce7;border:2px solid #10b981' : 'background:var(--bg);border:1px solid var(--border)';
  
  return `
    <div class="card" style="margin-bottom:14px;border-right:4px solid ${borderColor};${isSelected ? 'box-shadow:0 0 0 2px #3b82f6' : ''}">
      <div style="padding:14px">
        <!-- Header -->
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px;margin-bottom:10px">
          <div style="flex:1;min-width:200px;display:flex;gap:10px;align-items:flex-start">
            <input type="checkbox" 
                   ${isSelected ? 'checked' : ''}
                   onchange="psToggleSelect('${escapeAttr(s.variant_id)}')"
                   style="margin-top:4px;width:18px;height:18px;cursor:pointer">
            <div style="flex:1">
              <div style="font-weight:800;font-size:14px">${escapeHtml(s.product_title || '')}${s.variant_title ? ' - ' + escapeHtml(s.variant_title) : ''}</div>
              <div style="font-size:11px;color:var(--muted);font-family:monospace;margin-top:3px">
                ${s.sku ? 'SKU: ' + escapeHtml(s.sku) : ''}${s.barcode ? ' · ' + escapeHtml(s.barcode) : ''}
              </div>
            </div>
          </div>
          <div style="text-align:left">
            <div style="font-size:11px;color:var(--muted)">Obour متبقي</div>
            <div style="font-weight:800;font-size:18px;color:${s.master_days_left !== null && s.master_days_left <= 7 ? '#ef4444' : '#1e293b'}">
              ${s.master_days_left === null ? '∞' : s.master_days_left + ' يوم'}
            </div>
          </div>
        </div>
        
        <!-- Warehouses breakdown -->
        <div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px">
          ${whHtml}
        </div>
        
        <!-- Formula calculation -->
        <div style="background:#fafafa;border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:10px">
          <div style="font-size:11px;color:var(--muted);margin-bottom:6px;font-weight:700">📐 حساب الكمية المقترحة (لـ ${f.period_days} يوم):</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
            <div style="${aHighlight};border-radius:6px;padding:8px;font-size:12px">
              <div style="font-weight:700;margin-bottom:3px">A · إجمالي المخازن</div>
              <div style="font-size:10px;color:var(--muted)">Σ(velocity × period) − Σ(stock)</div>
              <div style="font-weight:800;font-size:16px;margin-top:4px;color:${f.chosen === 'A' ? '#15803d' : 'inherit'}">${f.A}</div>
            </div>
            <div style="${bHighlight};border-radius:6px;padding:8px;font-size:12px">
              <div style="font-weight:700;margin-bottom:3px">B · Obour وحده 🏠</div>
              <div style="font-size:10px;color:var(--muted)">(velocity_obour × period) − stock_obour</div>
              <div style="font-weight:800;font-size:16px;margin-top:4px;color:${f.chosen === 'B' ? '#15803d' : 'inherit'}">${f.B}</div>
            </div>
          </div>
          <div style="margin-top:8px;text-align:center;font-size:13px;font-weight:800;color:#10b981">
            ✅ المختار: ${f.chosen} · كمية الشراء = MAX(A, B) = <span style="font-size:18px">${s.purchase_qty}</span> قطعة
          </div>
        </div>
      </div>
    </div>
  `;
}

function psToggleSelect(vid){
  if(_psSelected.has(vid)) _psSelected.delete(vid);
  else _psSelected.add(vid);
  psUpdateBulkBar();
}

function psUpdateBulkBar(){
  const bar = document.getElementById('ps-bulk-bar');
  if(!bar) return;
  const count = _psSelected.size;
  if(count === 0){
    bar.style.display = 'none';
    return;
  }
  bar.style.display = 'flex';
  
  // calculate total qty
  let totalQty = 0;
  for(const vid of _psSelected){
    const s = _psData.suggestions.find(x => x.variant_id === vid);
    if(s) totalQty += s.purchase_qty;
  }
  
  document.getElementById('ps-bulk-count').textContent = count;
  document.getElementById('ps-bulk-qty').textContent = totalQty.toLocaleString('ar-EG');
}

function psClearSelection(){
  _psSelected.clear();
  psUpdateBulkBar();
  renderPurchaseSuggestions();
}

async function psCreatePO(){
  if(_psSelected.size === 0){ toast('❌ اختار منتج واحد على الأقل'); return; }
  
  // collect items
  const items = [];
  for(const vid of _psSelected){
    const s = _psData.suggestions.find(x => x.variant_id === vid);
    if(s){
      items.push({
        variantId: s.variant_id,
        productTitle: s.product_title,
        variantTitle: s.variant_title,
        sku: s.sku,
        barcode: s.barcode,
        qty: s.purchase_qty,
        // ما عندناش supplier price دلوقتي — سيبه فاضي للمستخدم يكمل
        unitCost: 0,
      });
    }
  }
  
  if(!items.length) return;
  
  // open PO modal with pre-filled items (لو الـ function موجودة)
  if(typeof openCreatePOFromSuggestions === 'function'){
    openCreatePOFromSuggestions(items);
    return;
  }
  
  // fallback: نـ redirect لصفحة الـ POs
  // مع حفظ الـ items في sessionStorage بحيث الصفحة تـ pick them up
  try {
    // 🆕 v253: لو في supplier محدد من الـ filter، حفظه
    const supplierId = document.getElementById('ps-supplier')?.value || null;
    sessionStorage.setItem('po_suggestions_draft', JSON.stringify({
      items,
      supplierId, // 🆕 v253
      createdAt: new Date().toISOString(),
      source: 'purchase-suggestions'
    }));
  } catch(e){}
  
  toast('✅ تم تجهيز ' + items.length + ' منتج — انتقل لصفحة "أوامر الشراء" واضغط "+ أمر شراء جديد"');
  
  if(confirm('روح لصفحة "أوامر الشراء" دلوقتي؟')){
    const navEl = document.querySelector('[data-p="purchase-orders"]');
    if(navEl) goPage(navEl, 'purchase-orders');
  }
}

