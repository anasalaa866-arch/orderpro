async function restoreCheckBook(bookId, idx){
  const name = document.getElementById('rec-name-'+idx)?.value?.trim();
  if(!name){ toast('❗ أدخل اسم الدفتر'); return; }
  const bank = document.getElementById('rec-bank-'+idx)?.value?.trim() || '';
  const account = document.getElementById('rec-account-'+idx)?.value?.trim() || '';
  const firstNum = parseInt(document.getElementById('rec-first-'+idx)?.value) || 1;
  const pages = parseInt(document.getElementById('rec-pages-'+idx)?.value) || 48;
  const note = document.getElementById('rec-note-'+idx)?.value?.trim() || '';
  const lastNum = firstNum + pages - 1;

  try{
    const r = await apiFetch('/api/check-books/restore','POST',{
      id: bookId,
      name, bank, account, pages, note,
      firstNum, lastNum
    });
    if(r && r.ok){
      toast(`✅ تم استعادة الدفتر — اتربط بـ ${r.linkedChecks} شيك`, 'success');
      // أعد التحميل
      await loadChks();
      await loadCheckBookOrphans();
      // برضه نـ render عشان الواجهة تتحدث (مع احترام الفلتر النشط)
      if(typeof chkRenderActive === 'function') chkRenderActive();
      else if(typeof renderChecksPage === 'function') renderChecksPage();
    } else {
      toast('❌ ' + (r?.error || 'فشل الاستعادة'), 'error');
    }
  }catch(e){
    toast('❌ ' + e.message, 'error');
  }
}

