function _parseStatementCSV(){
  const csv = document.getElementById('stmt-csv').value.trim();
  if(!csv){ return null; }
  
  const lines = csv.split(/\n/).filter(l => l.trim());
  const transactions = [];
  
  // Skip header لو موجود
  const startIdx = (lines[0] && /^[a-zA-Z]/.test(lines[0])) ? 1 : 0;
  
  for(let i = startIdx; i < lines.length; i++){
    // يدعم comma أو tab (paste from Excel)
    const parts = lines[i].split(/[,\t]/).map(p => p.trim().replace(/^["']|["']$/g, ''));
    
    if(parts.length < 1) continue;
    
    const amount = parseFloat(parts[0]);
    if(isNaN(amount) || amount <= 0) continue;
    
    transactions.push({
      amount,
      ref_number: parts[1] || '',
      date: parts[2] || '',
      time: parts[3] || ''
    });
  }
  
  return transactions;
}

function previewStatement(){
  const txns = _parseStatementCSV();
  if(!txns || !txns.length){
