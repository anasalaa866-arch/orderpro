async function handleStkScan(){
  const inp = document.getElementById('stk-scan-input');
  const qtyInp = document.getElementById('stk-scan-qty');
  if(!inp) return;
  
  const barcode = inp.value.trim();
  const qty = parseInt(qtyInp?.value) || 1;
  
  if(!barcode) return;
  
  try{
    const r = await apiFetch('/api/stocktake/sessions/' + _stkCurrentSession.id + '/scan', 'POST', {barcode, qty});
    if(r && r.success){
      // Beep + flash effect
      try {
        const audio = new Audio('data:audio/wav;base64,UklGRl9vT19XQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YU' + 'A'.repeat(100));
        audio.play().catch(()=>{});
      } catch(e){}
      
      inp.style.background = '#d1fae5';
      setTimeout(() => { inp.style.background = ''; }, 300);
      
      toast(`✅ ${r.product.title} (×${r.newCountedQty})`);
      
      // أعد تحميل الجلسة
      await reloadStkSession();
    } else {
      inp.style.background = '#fee2e2';
      setTimeout(() => { inp.style.background = ''; }, 500);
      toast('❌ ' + (r?.error || 'فشل'));
    }
  }catch(e){
    toast('❌ ' + e.message);
  }
  
  inp.value = '';
  inp.focus();
}

async function reloadStkSession(){
  if(!_stkCurrentSession) return;
  const r = await apiFetch('/api/stocktake/sessions/' + _stkCurrentSession.id);
  if(r){
    _stkCurrentSession = r.session;
    _stkCurrentItems = r.items || [];
    renderStocktakeDetail();
  }
}

async function updateStkReason(itemId, reason){
  try{
    const item = _stkCurrentItems.find(i => i.id === itemId);
    if(!item) return;
    await apiFetch('/api/stocktake/items/' + itemId, 'PUT', {
      countedQty: item.counted_qty, reason
    });
    item.reason = reason;
  }catch(e){
    toast('❌ ' + e.message);
  }
}

async function deleteStkItem(itemId){
  if(!confirm('حذف هذا المنتج من الجلسة؟')) return;
  try{
    const r = await apiFetch('/api/stocktake/items/' + itemId, 'DELETE');
    if(r && r.success){
      toast('✅ تم الحذف');
      await reloadStkSession();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  }catch(e){
    toast('❌ ' + e.message);
  }
}

