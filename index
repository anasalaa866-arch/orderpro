    return: 'رقم إذن المرتجع (اختياري)',
    adjustment: 'مرجع التسوية (اختياري)'
  };
  
  $('vtx-title').textContent = titles[type] || 'حركة';
  $('vtx-ref-label').textContent = refLabels[type] || 'المرجع';
