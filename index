        <td style="color:var(--success)">${doneAmt>0?doneAmt.toLocaleString()+' ج':'—'}</td>
        <td style="color:${pendingAmt>0?'var(--warn)':'var(--muted)'}">${pendingAmt>0?pendingAmt.toLocaleString()+' ج':'—'}</td>
      </tr>`;
    }).join('');
}

// 🆕 v332: فتح modal بتفاصيل شيكات أسبوع معين
function openWeekChecksModal(weekNum){
  const year = new Date().getFullYear();
  
  // اعد حساب نطاق الأسبوع (نفس الـ logic بتاع renderWeeklyReport)
  const yearStart = new Date(year, 0, 1);
  const yearStartDay = yearStart.getDay();
  const daysToFirstFriday = (5 - yearStartDay + 7) % 7;
  const firstFriday = new Date(year, 0, 1 + daysToFirstFriday - 7);
  
  const start = new Date(firstFriday);
  start.setDate(firstFriday.getDate() + (weekNum - 1) * 7);
  start.setHours(0, 0, 0, 0);
  const end = new Date(start);
  end.setDate(start.getDate() + 6);
  end.setHours(23, 59, 59, 999);
  
  // فلتر الشيكات
  const weekChecks = chkList.filter(c => {
    const d = new Date(c.date);
    return d >= start && d <= end;
  });
  
  // إحصائيات
  const total = weekChecks.reduce((s, c) => s + Number(c.amount), 0);
  const pendingChks = weekChecks.filter(c => c.status === 'pending');
  const doneChks = weekChecks.filter(c => c.status === 'done');
  const voidChks = weekChecks.filter(c => c.status === 'void' || c.status === 'void_requested');
  const pendingAmt = pendingChks.reduce((s, c) => s + Number(c.amount), 0);
  const doneAmt = doneChks.reduce((s, c) => s + Number(c.amount), 0);
  
  // امسح modal قديم
  const existing = document.getElementById('week-checks-modal');
  if(existing) existing.remove();
  
  const modal = document.createElement('div');
  modal.id = 'week-checks-modal';
  modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:9999;display:flex;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(4px)';
  
  // رتب الشيكات بـ status (pending أولاً، done أخيراً) ثم تاريخ
  const sorted = weekChecks.slice().sort((a, b) => {
    const order = { pending: 0, void_requested: 1, void: 2, done: 3 };
    const oa = order[a.status] ?? 9;
    const ob = order[b.status] ?? 9;
    if(oa !== ob) return oa - ob;
    return new Date(a.date) - new Date(b.date);
  });
  
  const checksRows = sorted.map(c => {
    const book = chkBooks.find(b => b.id === c.bookId);
    const days = chkDaysUntil(c.date);
    const isOverdue = c.status === 'pending' && days < 0;
    const bg = c.status === 'done' ? '#f0fdf4' : c.status === 'void' || c.status === 'void_requested' ? '#f3f4f6' : isOverdue ? '#fef2f2' : '#fff';
    const dayLbl = c.status === 'pending' 
      ? (days < 0 ? `<span style="color:var(--danger);font-size:10px;font-weight:700">⚠️ ${Math.abs(days)} يوم تأخير</span>` 
        : days <= 7 ? `<span style="color:var(--warn);font-size:10px">بعد ${days} أيام</span>` : '')
      : '';
    return `
      <tr style="background:${bg};border-bottom:1px solid var(--border)">
        <td style="padding:8px;font-weight:700">${c.num || '—'}</td>
        <td style="padding:8px">
          <strong>${escapeHtml(c.payee || '—')}</strong>
          ${c.note ? `<div style="font-size:10px;color:var(--muted);margin-top:2px">${escapeHtml(c.note)}</div>` : ''}
        </td>
        <td style="padding:8px;font-weight:700;font-size:13px">${chkFmtAmount(c.amount)} ج</td>
        <td style="padding:8px;font-size:11px">${chkFmtDate(c.date)}<br>${dayLbl}</td>
        <td style="padding:8px;font-size:11px;color:var(--muted)">${book ? escapeHtml(book.name) : '—'}</td>
        <td style="padding:8px;font-size:11px;color:var(--muted)">${c.invoice ? escapeHtml(c.invoice) : '—'}</td>
        <td style="padding:8px;text-align:center">${chkGetBadge(c)}</td>
        <td style="padding:8px;text-align:center">
          ${c.img ? `<button class="btn btn-ghost btn-xs" onclick="viewChkImg('${c.id}')" title="عرض الصورة">🖼️</button>` : '—'}
        </td>
        <td style="padding:8px">
          <div style="display:flex;gap:3px;flex-wrap:wrap">
            ${c.status === 'pending' ? `<button class="btn btn-xs" style="background:var(--success);color:#fff;border:none" onclick="chkMarkDone('${c.id}');closeWeekChecksModal();" title="ضع كمصروف">✅</button>` : ''}
