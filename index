// ===== INTERNAL ASSIGNMENT TRACKING =====
// بنتتبع الـ API calls بتاعة التوزيع عشان نتأكد إن كل طلب وصل DB
const _assignmentQueue = [];
let _assignmentFailed = []; // الطلبات اللي PATCH بتاعها فشل

async function _savePatchWithRetry(orderId, upd, maxAttempts = 3){
  for(let attempt = 1; attempt <= maxAttempts; attempt++){
    try{
      const r = await apiFetch('/api/orders/'+orderId, 'PATCH', upd);
      if(r) return { success: true, result: r };
    }catch(e){
      console.warn(`PATCH attempt ${attempt}/${maxAttempts} failed for ${orderId}:`, e.message);
    }
    if(attempt < maxAttempts){
      await new Promise(r => setTimeout(r, 500 * attempt)); // backoff
    }
  }
  return { success: false };
}

function _trackAssignmentFailure(orderId, orderName, courierName){
  _assignmentFailed.push({ orderId, orderName, courierName, ts: Date.now() });
  _updateAssignmentFailuresBadge();
}

function _updateAssignmentFailuresBadge(){
  let el = document.getElementById('assign-failures-badge');
  if(!_assignmentFailed.length){
    if(el) el.remove();
    return;
  }
  if(!el){
    el = document.createElement('div');
    el.id = 'assign-failures-badge';
    el.style.cssText = 'position:fixed;bottom:90px;left:20px;background:#fff;border:2px solid var(--danger);border-radius:12px;padding:12px 16px;box-shadow:0 4px 12px rgba(0,0,0,.15);z-index:9999;font-family:Cairo,sans-serif;font-size:12px;min-width:220px;max-width:320px';
    document.body.appendChild(el);
  }
  el.innerHTML = `<div style="font-weight:700;color:var(--danger);margin-bottom:4px;display:flex;justify-content:space-between;align-items:center">
    <span>⚠️ طلبات لم تحفظ</span>
    <span onclick="this.parentElement.parentElement.remove()" style="cursor:pointer;color:var(--muted);font-size:14px;padding:0 4px">✕</span>
  </div>
  <div style="font-size:11px;color:var(--muted);margin-bottom:6px">${_assignmentFailed.length} طلب مش متأكدين إنه وصل السيرفر</div>
  <button onclick="showAssignmentFailures()" style="font-size:11px;padding:4px 10px;background:var(--danger);color:#fff;border:none;border-radius:4px;cursor:pointer;margin-left:4px">عرض القائمة</button>
  <button onclick="retryAssignmentFailures()" style="font-size:11px;padding:4px 10px;background:var(--warn);color:#fff;border:none;border-radius:4px;cursor:pointer">إعادة محاولة</button>`;
}

function showAssignmentFailures(){
  if(!_assignmentFailed.length){ toast('✅ لا توجد فشل'); return; }
  const list = _assignmentFailed.map(t =>
    `• ${t.orderId} — ${t.orderName} → ${t.courierName}`
  ).join('\n');
  infoModal('⚠️ طلبات لم نتأكد إنها اتحفظت', list + '\n\nيُفضّل إعادة المحاولة أو إعادة التوزيع يدوياً.', { pre: true });
}

async function retryAssignmentFailures(){
  if(!_assignmentFailed.length) return;
  const failures = [..._assignmentFailed];
  _assignmentFailed = [];
  _updateAssignmentFailuresBadge();
  let recovered = 0;
  for(const f of failures){
    const o = orders.find(x => x.id === f.orderId);
    if(!o) continue;
    const upd = {
      courierId: o.courierId,
      isBosta: o.isBosta || false,
      ship: o.ship,
      status: o.status,
      assignedZone: o.assignedZone,
      batchCode: o.batchCode,
    };
    const r = await _savePatchWithRetry(f.orderId, upd, 3);
    if(r.success) recovered++;
    else _trackAssignmentFailure(f.orderId, f.orderName, f.courierName);
  }
  toast(`🔄 تم حفظ ${recovered} من ${failures.length}`);
}

async function batchAssign(courierId){
  const o=batchOrders[batchIndex];
  if(!o){ console.warn('batchAssign: no order at index', batchIndex); return; }

  // خد snapshot من الطلب كامل (قبل أي تعديل)
  const orderSnapshot = JSON.parse(JSON.stringify(o));
  const orderId = o.id;
  const orderName = o.name;

  if(courierId===0)courierId='bosta';
  const c=courierId!=='bosta'?couriers.find(x=>x.id==courierId):null;
  // 🔧 v238: استخدم getShipCost
  const ship=c?getShipCost(o,c):50;
  const assignedZone=getOrderZoneForCourier(o,c||{zone:''});
  const isBosta=courierId==='bosta';
  const isShop = !isBosta && SHOP_COURIER_ID && Number(courierId) === Number(SHOP_COURIER_ID);
  const courierName = c ? c.name : 'بوسطة';

  // 🆕 v192: لو التوزيع للمحل، حوّل delivery_type لـ 'pickup' عشان Stars يشوف الطلب
  // وإذا مش للمحل (مندوب أو بوسطة) ولسه pickup، رجّعه لـ normal/express
  let upd;
  if(isBosta){
    upd = {courierId:null,isBosta:true,ship,status:'جاري التوصيل',assignedZone,batchCode:_currentBatchCode};
    // لو كان pickup قبل كده، رجّعه لـ normal
    if(o.deliveryType==='pickup') upd.deliveryType = isSameDay(o)?'express':'normal';
  } else if(isShop){
    upd = {courierId,isBosta:false,ship,status:'جاري التوصيل',assignedZone,batchCode:_currentBatchCode,deliveryType:'pickup'};
  } else {
    upd = {courierId,isBosta:false,ship,status:'جاري التوصيل',assignedZone,batchCode:_currentBatchCode};
    // لو كان pickup ودلوقتي مندوب عادي، رجّعه لـ normal/express
    if(o.deliveryType==='pickup') upd.deliveryType = isSameDay(o)?'express':'normal';
  }

  // طبّق محلياً فوراً (optimistic) — عشان الـ wizard يتحرك
  Object.assign(o,upd);
  // لو الطلب اتعاد توزيعه لمندوب/محل، شيله من bosta_ids المحلية
  if(!isBosta){
    try{
      const bIds = JSON.parse(localStorage.getItem('bosta_ids')||'{}');
      if(bIds[orderId]){
        delete bIds[orderId];
        localStorage.setItem('bosta_ids', JSON.stringify(bIds));
      }
    }catch(e){}
  } else {
    // لو اتعمل assign لـ bosta، احفظه في bosta_ids
    try{
      const bIds = JSON.parse(localStorage.getItem('bosta_ids')||'{}');
      bIds[orderId] = true;
      localStorage.setItem('bosta_ids', JSON.stringify(bIds));
    }catch(e){}
  }
  if(c)c.status='نشط';
  debouncedSaveOrders();
  batchResults.push({orderId,name:orderName,courierId,courierName,action:'assigned'});
  batchIndex++;
  renderBatchOrder();

  // احفظ على السيرفر مع توست حقيقي (بيتحول من pending لنجاح أو فشل)
  if(!API_URL){
    // لا يوجد backend — بنحفظ محلياً بس، ونعرض توست نجاح عادي
    toastSuccess(`✅ ${orderName} → ${courierName} (محلياً فقط)`);
    // Shopify fulfill مش منطقي لو مفيش backend
    return;
  }

  doAction(
    `${orderId} → ${courierName}`,
    async () => {
      // الخطوة الأولى: حفظ الـ PATCH على السيرفر
      const r = await _savePatchWithRetry(orderId, upd, 3);
      if(!r.success) return { success: false, error: 'تعذر حفظ التعيين على السيرفر بعد 3 محاولات' };
      return { success: true, patched: true };
    },
    {
      onSuccess: () => {
        // بعد ما نتأكد إن السيرفر حفظ، ابدأ الـ Shopify fulfill
        if(isBosta) shopifyFulfill({ ...orderSnapshot, ...upd }, 'Bosta');
        else if(c) shopifyFulfill({ ...orderSnapshot, ...upd }, c.name);
      },
      rollback: () => {
        // فشل السيرفر → ارجع الطلب لحالته الأصلية
        const orderRef = orders.find(x => x.id === orderId);
        if(orderRef){
          Object.assign(orderRef, orderSnapshot);
          debouncedSaveOrders();
        }
        // كمان شيله من batchResults
        const idx = batchResults.findIndex(br => br.orderId === orderId && br.action === 'assigned');
        if(idx >= 0) batchResults.splice(idx, 1);
        // نعرض تحذير واضح
        _trackAssignmentFailure(orderId, orderName, courierName);
      },
      retry: true, // السماح بإعادة المحاولة من الـ toast
    }
  );
}

