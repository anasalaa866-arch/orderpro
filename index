      ? '<span class="badge" style="background:#fef3c7;color:#92400e">⚠️ منخفض</span>'
      : '<span class="badge" style="background:#d1fae5;color:#065f46">✅ متوفّر</span>';
    
    const whCells = _invWarehouses.map(w => {
      const lvl = item.levels[w.id];
