function updateAISourceHint(){
  const hint = document.getElementById('ai-source-hint');
  if(!hint) return;
  const sel = document.querySelector('input[name="ai_source"]:checked')?.value;
  if (sel === 'auto') {
    const auto = _autoSelectAISource();
    if (auto && auto !== 'all') {
      const store = _aiPosStores.find(s => String(s.id) === String(auto));
      hint.textContent = '💡 هيتم استخدام: ' + (store ? store.name : (auto === 'online' ? 'Online' : auto));
    } else {
      hint.textContent = '💡 اختار مخزن من فوق عشان نستخدم مبيعاته';
    }
  } else if (sel === 'all') {
    hint.textContent = '💡 هيتم جمع مبيعات Online + كل المحلات';
  } else if (sel === 'online') {
    hint.textContent = '💡 هيتم استخدام مبيعات Shopify Online فقط';
  } else {
    const store = _aiPosStores.find(s => String(s.id) === String(sel));
    hint.textContent = '💡 هيتم استخدام مبيعات ' + (store ? store.name : 'المحل المختار') + ' فقط';
  }
}

// (B) Auto-select based on selected warehouse
function _autoSelectAISource(){
  // 🆕 v253: Master Warehouse mode هو الـ default
  // لو الـ user اختار warehouse في الـ reorder modal:
  //   - لو الـ warehouse هو POS store → استخدم الـ store
  //   - لو هو غير POS (مثل Obour) → استخدم master mode
  // لو ما اختارش حاجة → master (الـ default)
  const whSelect = document.getElementById('reorder-warehouse');
  const whId = whSelect?.value;
  if (!whId) return 'master';
  
  // ابحث عن المحل (POS store) اللي مرتبط بالمخزن ده
  const store = _aiPosStores.find(s => String(s.warehouse_id) === String(whId));
  if (store) return String(store.id);
  
  // المخزن ده مش مرتبط بـ POS store → غالباً master warehouse
  return 'master';
}

// 🆕 v285: build tooltip text showing breakdown per source
function _buildBreakdownTooltip(p, field){
  // p might have ai_breakdown (from AI assistant) or naive_avg_30d (smart metadata)
  const lines = [];
  const breakdown = p.ai_sources_breakdown;
  if (breakdown && Object.keys(breakdown).length) {
    Object.values(breakdown).forEach(src => {
      const val = src[field] != null ? src[field] : 0;
      const soldField = field.replace('avg_', 'sold_');
      const sold = src[soldField] != null ? src[soldField] : 0;
      lines.push(`${src.display_name}: ${val.toFixed(2)}/يوم (${sold} مبيع)`);
    });
  } else {
    // Fallback: show smart metadata comparison
    if (p.smart_metadata && p.smart_metadata.improvement_pct) {
      lines.push('الذكي: ' + p[field].toFixed(2));
      const naiveField = 'naive_' + field;
      if (p[naiveField] != null) lines.push('الساذج: ' + p[naiveField].toFixed(2));
      lines.push('تحسين: ' + p.smart_metadata.improvement_pct + '%');
    }
  }
  return lines.join(' | ').replace(/"/g, '&quot;');
}

