// 1. courier_ship_rates table بـ order_type_id (✅ مصدر الحقيقة الجديد)
// 2. order.ship لو الـ Backend حدد سعر تلقائي (للطلبات اللي مفيهاش orderTypeId)
// 3. fallback القديم: courier.shipExpress/courier.ship حسب delivery_type
const getShipCost=(order,courier)=>{
  if(!courier)return order.ship||50;
  
  // Priority 0: لو المندوب هو المحل، السعر دايماً 0
  if(SHOP_COURIER_ID && Number(courier.id) === Number(SHOP_COURIER_ID)){
    if(window._debugShipCost) console.log(`🚚 [P0-SHOP] returning 0 for ${order.id} (المحل)`);
    return 0;
  }
  
  // 🔧 v239 Priority 1: courier_ship_rates (الأولوية الأعلى - يعدل أي قيمة قديمة في o.ship)
  // مهم: 0 قيمة صحيحة - متخلطش بين 0 و null
  if(order.orderTypeId && _courierRatesMap[courier.id]){
    const rate = _courierRatesMap[courier.id][order.orderTypeId];
    if(rate != null && !isNaN(rate)){
      if(window._debugShipCost) console.log(`🚚 [P1-RATE] rates[${courier.id}][${order.orderTypeId}]=${rate} for ${order.id} (${courier.name})`);
      return parseFloat(rate);
    } else {
      if(window._debugShipCost) console.log(`🚚 [P1-MISS] no rate for courier=${courier.id}, type=${order.orderTypeId}`);
    }
  } else {
    if(window._debugShipCost) {
      const reason = !order.orderTypeId ? 'order.orderTypeId is null' : `_courierRatesMap[${courier.id}] not found`;
      console.log(`🚚 [P1-SKIP] ${reason} for ${order.id}`);
    }
  }
  
  // Priority 2: لو الـ ship موجود من Backend (للطلبات بدون orderTypeId)
  if(order.ship != null && order.ship !== '' && !isNaN(order.ship)){
    const v = parseFloat(order.ship);
    if(window._debugShipCost) console.log(`🚚 [P2-OSHIP] order.ship=${v} for ${order.id}`);
    return v;
  }
  
  // Priority 3 (fallback للنظام القديم - مفيش o.ship + مفيش rate)
  if(isPickup(order)||isTransit(order)) {
    if(window._debugShipCost) console.log(`🚚 [P3-PICKUP] returning 0 for ${order.id}`);
    return 0;
  }
  if(isSameDay(order)) {
    const v = +(courier.shipExpress||courier.ship||80);
    if(window._debugShipCost) console.log(`🚚 [P3-EXPRESS] using courier.shipExpress=${v} for ${order.id}`);
    return v;
  }
  const v = +(courier.ship||50);
  if(window._debugShipCost) console.log(`🚚 [P3-NORMAL] using courier.ship=${v} for ${order.id}`);
  return v;
};
