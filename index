          <button onclick="courierAccMark('جاري التوصيل')" style="padding:14px 8px;border-radius:12px;border:2px solid ${currentStatus==='جاري التوصيل'?'#d97706':'var(--border)'};background:${currentStatus==='جاري التوصيل'?'#fef3c7':'var(--card)'};color:${currentStatus==='جاري التوصيل'?'#d97706':'var(--text)'};font-family:Cairo,sans-serif;font-weight:700;font-size:14px;cursor:pointer">⏳ لسا</button>
          <button onclick="courierAccMark('ملغي')" style="padding:14px 8px;border-radius:12px;border:2px solid ${currentStatus==='ملغي'?'#dc2626':'var(--border)'};background:${currentStatus==='ملغي'?'#fee2e2':'var(--card)'};color:${currentStatus==='ملغي'?'#dc2626':'var(--text)'};font-family:Cairo,sans-serif;font-weight:700;font-size:14px;cursor:pointer">❌ ملغي</button>
