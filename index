// لما يضغط Enter:
// - لو في نتيجة exact match (barcode/sku) → اختاره فوراً
// - لو في نتيجة واحدة بس → اختارها
// - لو متعدد → سيب الـ user يختار
async function handleExpirySearchEnter(){
  const input = document.getElementById('exp-modal-search');
  const q = (input.value || '').trim();
  if(!q) return;
  
  if(_expSearchTimer){
    clearTimeout(_expSearchTimer);
    _expSearchTimer = null;
  }
  
  await searchExpiryProducts(q, true); // tryExact = true
}

async function searchExpiryProducts(q, tryExact = false){
  const resEl = document.getElementById('exp-search-results');
  const statusEl = document.getElementById('exp-search-status');
  
  try {
    const r = await apiFetch('/api/inventory/search?q=' + encodeURIComponent(q) + '&limit=20');
    const results = r?.results || [];
    
    if(!results.length){
      resEl.innerHTML = '<div style="padding:14px;text-align:center;color:#6d7175;font-size:12px">مفيش نتائج لـ "' + escapeHtml(q) + '"</div>';
      resEl.style.display = 'block';
      
      // beep خطأ لو tryExact (يعني الـ user ضغط Enter أو scanner)
      if(tryExact){
        try {
          const ctx = new (window.AudioContext || window.webkitAudioContext)();
          const osc = ctx.createOscillator();
          const gain = ctx.createGain();
          osc.connect(gain); gain.connect(ctx.destination);
          osc.frequency.value = 200; gain.gain.value = 0.15;
          osc.start();
          setTimeout(() => { osc.stop(); ctx.close(); }, 200);
        } catch(e){}
      }
      return;
    }
    
    // لو tryExact: شوف لو في exact match
    if(tryExact){
      const exact = results.find(p => 
        (p.barcode || '').trim() === q || 
        (p.sku || '').trim() === q
      );
      if(exact){
        selectExpiryProduct(exact);
        return;
      }
      // لو واحدة بس
      if(results.length === 1){
        selectExpiryProduct(results[0]);
        return;
      }
    }
    
    // اعرض القائمة
    resEl.innerHTML = results.map((v, i) => `
      <div onclick='selectExpiryProductByIndex(${i})' 
        data-exp-idx='${i}'
        style="padding:10px 12px;border-bottom:1px solid var(--border);cursor:pointer;font-size:12px"
        onmouseover="this.style.background='#fafbfb'" 
        onmouseout="this.style.background='transparent'">
        <div style="font-weight:700;color:#1a1c1d">${escapeHtml(v.product_title || '')}${v.variant_title ? ' - '+escapeHtml(v.variant_title) : ''}</div>
