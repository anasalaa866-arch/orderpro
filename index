  boxes.forEach(b => { b.checked = !allChecked; });
  const sel = document.querySelectorAll('#stk-failed-uploads-modal .failed-item-chk:checked').length;
  const cnt = document.getElementById('failed-selected-count');
  if(cnt) cnt.textContent = sel + ' مختار';
