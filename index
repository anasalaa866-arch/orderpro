let _shopifyReportsState = {
  period: '-30d',
  currentReport: 'sales'
};

function initShopifyReports(){
  // ابدأ بـ Sales report
  switchShopifyReport('sales', document.querySelector('#sr-tabs .chip.on'));
}

function setReportPeriod(period, btn){
  _shopifyReportsState.period = period;
  document.querySelectorAll('#page-shopify-reports .chip').forEach(b => {
    if(b.id && b.id.startsWith('sr-period-')) b.classList.remove('on');
  });
  if(btn) btn.classList.add('on');
  // أعد تحميل التقرير الحالي
  switchShopifyReport(_shopifyReportsState.currentReport, null);
}

function switchShopifyReport(report, btn){
  _shopifyReportsState.currentReport = report;
  document.querySelectorAll('#sr-tabs .chip').forEach(b => b.classList.remove('on'));
  if(btn) btn.classList.add('on');
  else {
    // ابحث عن الزرار اللي بيمثل الـ report ده
    const buttons = document.querySelectorAll('#sr-tabs .chip');
    buttons.forEach(b => {
      if(b.getAttribute('onclick') && b.getAttribute('onclick').includes(`'${report}'`)){
        b.classList.add('on');
      }
    });
  }
  
  loadShopifyReport(report);
}

async function loadShopifyReport(report){
  const content = document.getElementById('sr-content');
  if(!content) return;
  
  content.innerHTML = `
    <div style="text-align:center;padding:40px">
      <div style="font-size:32px;margin-bottom:10px">⏳</div>
      <div style="color:var(--muted)">جاري تحميل التقرير من Shopify...</div>
    </div>
  `;
  
  try{
    const period = _shopifyReportsState.period;
    let endpoint = '';
    let renderFn = null;
    
    switch(report){
      case 'sales':
        endpoint = `/api/shopify-reports/sales?since=${period}&groupBy=day`;
        renderFn = renderSalesReport;
        break;
      case 'products':
        endpoint = `/api/shopify-reports/products-sold?since=${period}&limit=50`;
        renderFn = renderProductsReport;
        break;
      case 'customers':
        endpoint = `/api/shopify-reports/customers?since=${period}`;
        renderFn = renderCustomersReport;
        break;
      case 'inventory':
        endpoint = `/api/shopify-reports/inventory?limit=250`;
        renderFn = renderInventoryReport;
        break;
      case 'acquisition':
        endpoint = `/api/shopify-reports/acquisition?since=${period}`;
        renderFn = renderAcquisitionReport;
        break;
      case 'behavior':
        endpoint = `/api/shopify-reports/behavior?since=${period}`;
        renderFn = renderBehaviorReport;
        break;
      case 'marketing':
        endpoint = `/api/shopify-reports/marketing?since=${period}`;
        renderFn = renderMarketingReport;
        break;
      default:
        content.innerHTML = '<div style="text-align:center;padding:40px;color:var(--muted)">تقرير غير معروف</div>';
        return;
    }
    
    // 🔧 v234: استخدم raw fetch عشان نقدر نقرأ الـ error response details حتى لو 500
    const baseUrl = API_URL || BACKEND_URL;
    const response = await fetch(baseUrl.replace(/\/$/,'') + endpoint, {
      method: 'GET',
      headers: {
        'Authorization': 'Bearer ' + window._adminToken,
        'Content-Type': 'application/json'
      }
    });
    const data = await response.json();
    
    if(!response.ok || !data || !data.success){
      // اعرض details من الـ response
      const err = new Error(data?.error || `HTTP ${response.status}`);
      err.attemptedQuery = data?.attemptedQuery || data?.query || '';
      err.parseErrors = data?.parseErrors || [];
      throw err;
    }
    
    if(renderFn) renderFn(data, content);
    
  }catch(e){
    const queryDisplay = e.attemptedQuery ? `
      <div style="background:#1e293b;color:#e2e8f0;padding:12px;border-radius:8px;margin:14px auto;max-width:600px;font-family:monospace;font-size:11px;direction:ltr;text-align:left;white-space:pre-wrap">
        <div style="color:#94a3b8;margin-bottom:6px;font-weight:700">📝 Query:</div>
        ${escapeHtml(e.attemptedQuery)}
      </div>` : '';
    
    const parseErrorsDisplay = (e.parseErrors && e.parseErrors.length) ? `
      <div style="background:#fef2f2;padding:10px 12px;border-radius:6px;margin:14px auto;max-width:600px;font-size:11px;text-align:right">
        <strong>Parse Errors:</strong>
        ${e.parseErrors.map(err => '<div>• ' + escapeHtml(typeof err === 'string' ? err : JSON.stringify(err)) + '</div>').join('')}
      </div>` : '';
    
    content.innerHTML = `
      <div style="text-align:center;padding:40px">
        <div style="font-size:32px;margin-bottom:10px">❌</div>
        <div style="color:var(--danger);margin-bottom:8px;font-weight:700">فشل تحميل التقرير</div>
        <div style="font-size:12px;color:var(--muted);margin-bottom:14px;max-width:600px;margin-left:auto;margin-right:auto;direction:ltr">${escapeHtml(e.message)}</div>
        ${parseErrorsDisplay}
        ${queryDisplay}
        <div style="background:#fef3c7;border-radius:8px;padding:12px 14px;font-size:11px;color:#78350f;max-width:600px;margin:14px auto 0;text-align:right">
          <strong>💡 معلومات:</strong>
          <ul style="margin:6px 0 0;padding-right:20px">
            <li>المشكلة في الـ ShopifyQL syntax الخاص بالتقرير ده</li>
            <li>التقارير الأخرى ممكن تكون شغالة</li>
            <li>راجع الـ query في الـ console للـ debugging</li>
          </ul>
        </div>
        <button class="btn btn-primary btn-sm" onclick="loadShopifyReport('${report}')" style="margin-top:14px">🔄 إعادة المحاولة</button>
      </div>
    `;
  }
}

