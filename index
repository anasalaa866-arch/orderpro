function sha256(str){
  let hash = 0;
  for(let i=0;i<str.length;i++){hash=((hash<<5)-hash)+str.charCodeAt(i);hash|=0;}
  return Math.abs(hash).toString(16).padStart(8,'0');
}

async function hashPass(pass){
  const msgBuffer = new TextEncoder().encode(pass);
  const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
  const hashArray = Array.from(new Uint8Array(hashBuffer));
  return hashArray.map(b=>b.toString(16).padStart(2,'0')).join('');
}

async function doLogin(){
  const username = document.getElementById('login-username')?.value.trim();
  const password = document.getElementById('login-password')?.value;
  const err = document.getElementById('login-err');

  if(!username||!password){ err.textContent='أدخل اسم المستخدم وكلمة المرور'; return; }

  const passHash = await hashPass(password);

  let user = null;
  let serverToken = null;

  // 🆕 v206: جرّب السيرفر الأول دائماً (admin أو عادي)
  if(API_URL){
    try{
      const r = await apiFetch('/api/login','POST',{username, passHash});
      if(r && r.found){
        user = r.user;
        serverToken = r.token; // 🆕 v206: token من السيرفر
      }
    }catch(e){}
  }

  // Fallback: admin محلي لو السيرفر مش متصل
  if(!user && username === ADMIN_USER.username && passHash === ADMIN_USER.passHash){
    user = {...ADMIN_USER};
    // ⚠️ بدون السيرفر، الـ admin هيقدر يدخل بس مش هيقدر يعمل API calls
  }

  // Fallback: localStorage users (للـ offline mode)
  if(!user){
    const found = sysUsers.find(u=>u.username===username && u.passHash===passHash && u.active!==false);
    if(found) user = found;
  }

  if(!user){
    err.textContent = '❌ اسم المستخدم أو كلمة المرور غير صحيحة';
    document.getElementById('login-password').value = '';
    return;
  }

  // 🆕 v208: لو السيرفر متاح بس مفيش token، يبقى فيه مشكلة — متخش
  // (قبل كده كان admin محلي يدخل بدون token ويعمل 401 loop)
  if(API_URL && !serverToken){
    err.textContent = '⚠️ السيرفر مش رد بـ token. تأكد إنه شغال وحاول تاني.';
    document.getElementById('login-password').value = '';
    return;
  }

  currentUser = user;
  // 🆕 v206: احفظ الـ token مع الـ session
  const sessionData = {...user, _token: serverToken, _expires: Date.now() + 30*24*60*60*1000};
  localStorage.setItem('current_user_session', JSON.stringify(sessionData));
  if(serverToken){
    localStorage.setItem('admin_token', serverToken);
    window._adminToken = serverToken;
  }

  document.getElementById('login-screen').classList.add('hidden');
  document.getElementById('main-app').style.display = '';

  applyPermissions(user.role, user.pages||null);

  const userBadge = document.getElementById('user-badge');
