async function loadUnmappedShippingMethods(){
  if(!API_URL) return;
  try{
    _unmappedShippingMethods = await apiFetch('/api/shipping-mappings/unmapped');
    renderUnmappedWarning();
  }catch(e){ /* silent */ }
}

function renderUnmappedWarning(){
  const warning = document.getElementById('unmapped-warning');
  const list = document.getElementById('unmapped-list');
  const cnt = document.getElementById('unmapped-count');
  const sidebarBadge = document.getElementById('nb-shipping-unmapped');
  
  if(!_unmappedShippingMethods.length){
    if(warning) warning.style.display = 'none';
    if(sidebarBadge){ sidebarBadge.textContent = '0'; sidebarBadge.style.display = 'none'; }
    return;
  }
  
  if(warning) warning.style.display = '';
  if(cnt) cnt.textContent = _unmappedShippingMethods.length;
  if(sidebarBadge){ 
    sidebarBadge.textContent = _unmappedShippingMethods.length; 
    sidebarBadge.style.display = ''; 
  }
  
  if(list){
    list.innerHTML = _unmappedShippingMethods.map(u => `
      <button class="btn btn-warn btn-sm" onclick="quickMapShippingMethod('${escapeAttr(u.shipping_method)}')">
        ${escapeHtml(u.shipping_method)} <span style="opacity:.7">(${u.count})</span>
      </button>
    `).join('');
  }
}

function quickMapShippingMethod(method){
  document.getElementById('sm-modal-title').textContent = '🔗 ربط Shipping Method';
  document.getElementById('sm-id').value = '';
  document.getElementById('sm-method').value = method;
  document.getElementById('sm-method').readOnly = true;
  document.getElementById('sm-notes').value = '';
  populateShippingMappingTypeSelect();
  openM('m-shipping-mapping');
}

async function bulkMapToDefault(){
  if(!_unmappedShippingMethods.length) return;
  const def = _orderTypes.find(t => t.is_default);
  if(!def){ toast('⚠️ لازم تحدد نوع Default الأول'); return; }
  if(!confirm(`هتربط ${_unmappedShippingMethods.length} shipping method بالنوع الـ Default (${def.label_ar})؟`)) return;
  
  try{
    let success = 0;
    for(const u of _unmappedShippingMethods){
      try{
        await apiFetch('/api/shipping-mappings', 'POST', {
          shipping_method: u.shipping_method,
          order_type_id: def.id,
          notes: 'ربط تلقائي بالـ Default'
        });
        success++;
      }catch(e){ /* skip duplicates */ }
    }
    toast(`✅ تم ربط ${success} shipping method`);
    loadShippingMappings();
    loadUnmappedShippingMethods();
  }catch(e){
    toast('❌ ' + e.message);
  }
}

