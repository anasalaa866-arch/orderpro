// ─── New Transfer Modal ───
async function openNewTransfer(){
  // املأ المخازن
  if(!_invWarehouses.length){
    try{ _invWarehouses = await apiFetch('/api/inventory/warehouses') || []; }catch(e){}
  }
  if(!_invItems.length){
    try { 
      toast('⏳ تحميل المنتجات...');
      _invItems = await apiFetch('/api/inventory/items') || []; 
    } catch(e){}
  }
  
  // ابني الـ dropdowns
  const fromSel = document.getElementById('trf-from-wh');
  const toSel = document.getElementById('trf-to-wh');
  const opts = '<option value="">-- اختار --</option>' + _invWarehouses.map(w => `<option value="${w.id}">${escapeHtml(w.name)}</option>`).join('');
  if(fromSel) fromSel.innerHTML = opts;
  if(toSel) toSel.innerHTML = opts;
  
  document.getElementById('trf-search').value = '';
  document.getElementById('trf-notes').value = '';
  document.getElementById('trf-sync-shopify').checked = true;
  _trfSelectedItems = {};
  
  renderTransferProductPicker();
  renderTransferSelectedList();
  
  openM('m-new-transfer');
}

function renderTransferProductPicker(){
  const container = document.getElementById('trf-product-picker');
  if(!container) return;
  
  const search = (document.getElementById('trf-search')?.value || '').trim().toLowerCase();
  const fromWhId = document.getElementById('trf-from-wh')?.value;
  
  if(!fromWhId){
    container.innerHTML = '<div style="padding:30px;text-align:center;color:var(--muted);font-size:12px">اختار "من مخزن" أولاً</div>';
    return;
  }
  
  let items = _invItems.filter(i => {
    const lvl = i.levels?.[fromWhId];
    return lvl && lvl.qty > 0;
  });
  
  if(search){
    items = items.filter(i => 
      (i.productTitle||'').toLowerCase().includes(search) ||
      (i.sku||'').toLowerCase().includes(search) ||
      (i.barcode||'').toLowerCase().includes(search)
    );
  }
  
  // أول 50 للأداء
  const showItems = items.slice(0, 50);
  
  if(!showItems.length){
    container.innerHTML = '<div style="padding:20px;text-align:center;color:var(--muted);font-size:12px">مفيش منتجات في المخزن ده</div>';
    return;
  }
  
  container.innerHTML = showItems.map(item => {
    const lvl = item.levels[fromWhId];
    const qty = lvl?.qty || 0;
    const selected = _trfSelectedItems[item.variantId];
    const inputVal = selected?.qty || '';
    
    return `<div style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-bottom:1px solid var(--border);${selected?'background:#f0fdf4':''}">
      <div style="flex:1;min-width:0">
        <div style="font-weight:700;font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escapeHtml(item.productTitle)}${item.variantTitle ? ' - '+escapeHtml(item.variantTitle) : ''}</div>
        <div style="font-size:10px;color:var(--muted)">${escapeHtml(item.sku || '—')} · متوفر: <strong style="color:#16a34a">${qty}</strong></div>
      </div>
      <input type="number" min="0" max="${qty}" value="${inputVal}" placeholder="0" 
             style="width:70px;text-align:center;font-weight:700;border:1px solid var(--border);border-radius:6px;padding:6px;font-family:Cairo,sans-serif"
             onchange="setTransferQty('${item.variantId}', this.value, ${qty}, '${escapeHtml(item.productTitle).replace(/'/g,"\\'")}')">
    </div>`;
  }).join('');
  
  if(items.length > 50){
    container.innerHTML += `<div style="padding:10px;text-align:center;color:var(--muted);font-size:11px;background:#f9fafb">عرض أول 50 من ${items.length} - استخدم البحث للفلترة</div>`;
  }
}

function setTransferQty(variantId, qty, maxQty, productTitle){
  const q = parseInt(qty);
  if(!q || q <= 0){
    delete _trfSelectedItems[variantId];
  } else if(q > maxQty){
    toast(`❌ الكمية المتوفرة ${maxQty} فقط`);
    return;
  } else {
    _trfSelectedItems[variantId] = { qty: q, productTitle };
  }
  
  document.getElementById('trf-selected-count').textContent = `${Object.keys(_trfSelectedItems).length} منتج`;
  renderTransferSelectedList();
}

function renderTransferSelectedList(){
  const container = document.getElementById('trf-selected-items');
  const wrapper = document.getElementById('trf-selected-list');
  if(!container || !wrapper) return;
  
  const items = Object.entries(_trfSelectedItems);
  
  if(!items.length){
    wrapper.style.display = 'none';
    return;
  }
  
  wrapper.style.display = 'block';
  container.innerHTML = items.map(([variantId, data]) => `
    <div style="display:flex;justify-content:space-between;align-items:center;padding:6px;font-size:12px;border-bottom:1px dashed #16a34a40">
      <span style="flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escapeHtml(data.productTitle)}</span>
      <strong style="color:#15803d;margin:0 12px">${data.qty}</strong>
      <button class="btn btn-ghost btn-xs" onclick="setTransferQty('${variantId}', 0, 0); renderTransferProductPicker()" style="color:var(--danger)">✕</button>
    </div>
  `).join('');
}

function clearTransferProducts(){
  if(!confirm('مسح كل المنتجات المحددة؟')) return;
  _trfSelectedItems = {};
  document.getElementById('trf-selected-count').textContent = '0 منتج';
  renderTransferSelectedList();
  renderTransferProductPicker();
}

async function createTransfer(){
  const fromId = document.getElementById('trf-from-wh').value;
  const toId = document.getElementById('trf-to-wh').value;
  const notes = document.getElementById('trf-notes').value.trim();
  const syncShopify = document.getElementById('trf-sync-shopify').checked;
  
  if(!fromId || !toId){ toast('❌ اختار المخزنين'); return; }
  if(fromId === toId){ toast('❌ المخزنين لازم يكونوا مختلفين'); return; }
  
  const items = Object.entries(_trfSelectedItems).map(([variantId, data]) => ({
    variantId, qty: data.qty
  }));
  
  if(!items.length){ toast('❌ اختار منتج واحد على الأقل'); return; }
  
  if(!confirm(`إنشاء تحويل بـ ${items.length} منتج؟\n\nملاحظة: التحويل هيكون في حالة "معلّق" - لازم تضغط "📤 إرسال" بعد كده عشان يتخصم من المخزن.`)) return;
  
  try {
    const r = await apiFetch('/api/transfers', 'POST', {
      fromWarehouseId: fromId,
      toWarehouseId: toId,
      items, notes,
      syncToShopify: syncShopify
    });
    
    if(r && r.success){
      toast(`✅ تم إنشاء التحويل: ${r.transferNumber}`);
      closeM('m-new-transfer');
      await loadTransfersPage();
      // افتح التفاصيل مباشرة
      setTimeout(() => openTransferDetail(r.transferId), 300);
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  } catch(e) {
    toast('❌ ' + e.message);
  }
}

// ─── Transfer Detail ───
let _trfCurrentTransfer = null;

async function openTransferDetail(transferId){
  try {
    const r = await apiFetch('/api/transfers/' + transferId);
    if(!r || !r.transfer){ toast('❌ مفيش بيانات'); return; }
    
    _trfCurrentTransfer = r;
    document.getElementById('trf-detail-title').textContent = `📋 ${r.transfer.transfer_number || '#'+r.transfer.id}`;
    renderTransferDetail();
    openM('m-transfer-detail');
  } catch(e) {
    toast('❌ ' + e.message);
  }
}

function renderTransferDetail(){
  const t = _trfCurrentTransfer.transfer;
  const items = _trfCurrentTransfer.items || [];
  const isPending = t.status === 'pending';
  const isInTransit = t.status === 'in_transit';
  
  const statusLabel = {
    pending: '⏳ معلّق - لم يُرسل بعد',
    in_transit: '🚚 في الطريق',
    completed: '✅ مكتمل',
    cancelled: '❌ ملغي'
  }[t.status] || t.status;
  
  const statusColor = {
    pending: '#f59e0b',
    in_transit: '#3b82f6',
    completed: '#16a34a',
    cancelled: '#ef4444'
  }[t.status] || '#64748b';
  
  // header
  let html = `
    <div style="background:var(--bg);padding:14px;border-radius:10px;margin-bottom:14px;border-right:4px solid ${statusColor}">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px;margin-bottom:8px">
        <div>
          <div style="font-size:18px;font-weight:800;margin-bottom:4px">${escapeHtml(t.from_name || '')} → ${escapeHtml(t.to_name || '')}</div>
          <div style="color:${statusColor};font-weight:700">${statusLabel}</div>
        </div>
        <div style="font-size:12px;color:var(--muted)">
          📅 ${new Date(t.created_at).toLocaleString('ar-EG')}<br>
          👤 ${escapeHtml(t.created_by || '')}
        </div>
      </div>
      ${t.notes ? `<div style="font-size:12px;color:var(--muted);margin-top:6px;padding:6px;background:#fff;border-radius:6px">📝 ${escapeHtml(t.notes)}</div>` : ''}
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:8px;margin-top:10px;font-size:11px">
        <div>📦 منتجات: <strong>${items.length}</strong></div>
        <div>🔢 إجمالي: <strong>${t.total_qty || 0}</strong></div>
        ${t.sent_at ? `<div>📤 أُرسل: <strong>${new Date(t.sent_at).toLocaleString('ar-EG')}</strong> ${t.sent_by ? '<br>👤 '+escapeHtml(t.sent_by) : ''}</div>` : ''}
        ${t.received_at ? `<div>📥 استُلم: <strong>${new Date(t.received_at).toLocaleString('ar-EG')}</strong> ${t.received_by ? '<br>👤 '+escapeHtml(t.received_by) : ''}</div>` : ''}
        <div>🔁 sync: <strong>${t.sync_to_shopify ? '✅ مفعّل' : '❌ معطّل'}</strong></div>
      </div>
    </div>
  `;
  
  // Action buttons
  html += '<div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap">';
  if(isPending){
    html += `<button class="btn btn-success" onclick="sendTransfer()">📤 إرسال (خصم من المخزن المرسل)</button>`;
    html += `<button class="btn btn-ghost" onclick="cancelTransfer()" style="color:var(--danger)">🗑️ حذف</button>`;
  } else if(isInTransit){
    html += `<button class="btn btn-success" onclick="receiveTransfer()">📥 استلام (إضافة للمخزن المستقبل)</button>`;
    html += `<button class="btn btn-ghost" onclick="cancelTransfer()" style="color:var(--warn)">↩️ إلغاء (إرجاع للمرسل)</button>`;
  }
  html += '</div>';
  
  // Items table
  html += `
    <table style="width:100%;border-collapse:collapse;font-size:12px">
      <thead style="background:var(--bg)">
        <tr>
          <th style="text-align:right;padding:10px">المنتج</th>
          <th style="text-align:center;padding:10px;width:90px">المرسل</th>
          <th style="text-align:center;padding:10px;width:90px">المستقبل</th>
          <th style="text-align:center;padding:10px;width:90px">الكمية</th>
          ${isInTransit || t.status === 'completed' ? '<th style="text-align:center;padding:10px;width:90px">المستلمة</th>' : ''}
        </tr>
      </thead>
      <tbody>
  `;
  
  items.forEach(item => {
    const qtyReceivedDisplay = item.qty_received != null ? item.qty_received : (isInTransit ? `<input type="number" id="rcv-${item.id}" value="${item.qty_planned}" min="0" max="${item.qty_planned}" style="width:60px;text-align:center;border:1px solid var(--border);border-radius:4px;padding:4px;font-family:Cairo,sans-serif">` : '—');
    
    html += `<tr style="border-bottom:1px solid var(--border)">
      <td style="padding:8px 10px">
        <div style="font-weight:700;font-size:12px">${escapeHtml(item.product_title || '')}${item.variant_title ? ' - '+escapeHtml(item.variant_title) : ''}</div>
        <div style="font-size:10px;color:var(--muted)">${escapeHtml(item.sku || '—')}</div>
      </td>
      <td style="text-align:center;font-weight:700">${item.from_current_qty || 0}</td>
      <td style="text-align:center;font-weight:700">${item.to_current_qty || 0}</td>
      <td style="text-align:center;font-weight:800;color:var(--accent);font-size:14px">${item.qty_planned}</td>
      ${isInTransit || t.status === 'completed' ? `<td style="text-align:center">${qtyReceivedDisplay}</td>` : ''}
    </tr>`;
  });
  
  html += '</tbody></table>';
  
  document.getElementById('trf-detail-content').innerHTML = html;
}

async function sendTransfer(){
  if(!_trfCurrentTransfer) return;
  if(!confirm(`📤 إرسال التحويل؟\n\nده هيخصم ${_trfCurrentTransfer.transfer.total_qty} منتج من ${_trfCurrentTransfer.transfer.from_name}\n${_trfCurrentTransfer.transfer.sync_to_shopify ? 'وهيتم تحديث Shopify' : '(بدون تحديث Shopify)'}`)) return;
  
  toast('🔄 جاري الإرسال...');
  try {
    const r = await apiFetch('/api/transfers/' + _trfCurrentTransfer.transfer.id + '/send', 'POST', {});
    if(r && r.success){
      toast(r.message || '✅ تم الإرسال');
      if(r.errors && r.errors.length) infoModal('⚠️ بعض الأخطاء', r.errors.join('\n'), {pre: true});
      closeM('m-transfer-detail');
      await loadTransfersPage();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  } catch(e) {
    toast('❌ ' + e.message);
  }
}

async function receiveTransfer(){
  if(!_trfCurrentTransfer) return;
  
  // اجمع الكميات المستلمة
  const receivedItems = _trfCurrentTransfer.items.map(item => {
    const inp = document.getElementById('rcv-' + item.id);
    const qty = inp ? parseInt(inp.value) : item.qty_planned;
    return { itemId: item.id, qtyReceived: qty };
  });
  
  if(!confirm(`📥 تأكيد الاستلام؟\n\nده هيضيف المنتجات لـ ${_trfCurrentTransfer.transfer.to_name}`)) return;
  
  toast('🔄 جاري الاستلام...');
  try {
    const r = await apiFetch('/api/transfers/' + _trfCurrentTransfer.transfer.id + '/receive', 'POST', {receivedItems});
    if(r && r.success){
      toast(r.message || '✅ تم الاستلام');
      if(r.errors && r.errors.length) infoModal('⚠️ بعض الأخطاء', r.errors.join('\n'), {pre: true});
      closeM('m-transfer-detail');
      await loadTransfersPage();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  } catch(e) {
    toast('❌ ' + e.message);
  }
}

async function cancelTransfer(){
  if(!_trfCurrentTransfer) return;
  const isInTransit = _trfCurrentTransfer.transfer.status === 'in_transit';
  
  const msg = isInTransit 
    ? '↩️ إلغاء التحويل؟\n\nالكميات هترجع للمخزن المرسل.'
    : '🗑️ حذف التحويل؟';
  
  if(!confirm(msg)) return;
  
  try {
    const url = isInTransit 
      ? '/api/transfers/' + _trfCurrentTransfer.transfer.id + '/cancel'
      : '/api/transfers/' + _trfCurrentTransfer.transfer.id;
    const method = isInTransit ? 'POST' : 'DELETE';
    
    const r = await apiFetch(url, method, isInTransit ? {} : null);
    if(r && r.success){
      toast(r.message || '✅ تم');
      closeM('m-transfer-detail');
      await loadTransfersPage();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  } catch(e) {
    toast('❌ ' + e.message);
  }
}

