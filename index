function toggleNavGroup(groupEl){
  if(!groupEl) return;
  groupEl.classList.toggle('open');
  // احفظ الحالة في localStorage
  try {
    const states = JSON.parse(localStorage.getItem('sb_groups') || '{}');
    const key = groupEl.dataset.group;
    if(key) {
      states[key] = groupEl.classList.contains('open');
      localStorage.setItem('sb_groups', JSON.stringify(states));
    }
  } catch(e) {}
}

function restoreNavGroups(){
  // استعادة حالة الـ groups من localStorage
  try {
    const states = JSON.parse(localStorage.getItem('sb_groups') || '{}');
    document.querySelectorAll('.nav-group').forEach(g => {
      const key = g.dataset.group;
      if (key && states[key] === true) g.classList.add('open');
      else if (key && states[key] === false) g.classList.remove('open');
    });
  } catch(e) {}
}

// 🆕 v290: Sidebar search filter
function sidebarFilter(query){
  const q = (query || '').trim().toLowerCase();
  const items = document.querySelectorAll('.sb-nav .ni');
  const groups = document.querySelectorAll('.sb-nav .nav-group');

  if (!q) {
    // امسح الفلتر
    items.forEach(i => i.classList.remove('sb-hidden'));
    groups.forEach(g => { g.classList.remove('sb-hidden'); g.classList.remove('sb-search-open'); });
    return;
  }

  // فلتر items
  groups.forEach(g => {
    let visibleCount = 0;
    g.querySelectorAll('.ni').forEach(i => {
      const label = (i.querySelector('.ni-label')?.textContent || '').toLowerCase();
      const matches = label.includes(q);
      i.classList.toggle('sb-hidden', !matches);
      if (matches) visibleCount++;
    });
    // اخفي الـ group لو مفيش items ظاهرة
    g.classList.toggle('sb-hidden', visibleCount === 0);
    // افتح الـ group لو فيه نتائج (مؤقتاً)
    g.classList.toggle('sb-search-open', visibleCount > 0);
  });
}

// 🆕 v290: Aggregate badges for groups (مجموع الـ badges داخل كل group)
function updateGroupBadges(){
  document.querySelectorAll('.nav-group').forEach(g => {
    const badge = g.querySelector('[data-group-badge]');
    if(!badge) return;
    let total = 0;
    g.querySelectorAll('.nbadge').forEach(b => {
      const v = parseInt(b.textContent) || 0;
      total += v;
    });
    if (total > 0) {
      badge.textContent = total > 99 ? '99+' : total;
      badge.classList.add('show');
    } else {
      badge.classList.remove('show');
    }
  });
}

