function exportChecksExcel(){
  if(typeof XLSX==='undefined'){toast('❗ مكتبة Excel غير محملة');return;}
  const list=getFilteredChkList();
  if(!list.length){toast('❗ لا توجد شيكات للتصدير');return;}

  const headers=['#','رقم الشيك','المورد','القيمة','تاريخ الاستحقاق','الدفتر','رقم الفاتورة','الحالة','ملاحظات'];
  const rows=list.map((c,i)=>{
    const book=chkBooks.find(b=>b.id===c.bookId);
    const status=c.status==='done'?'مصروف':chkIsOverdue(c)?'متأخر':'لم يُصرف';
    return [i+1, c.num, c.payee||'', Number(c.amount)||0,
      c.date||'', book?book.name:'', c.invoice||'', status, c.note||''];
  });

  const ws=XLSX.utils.aoa_to_sheet([headers,...rows]);
  ws['!cols']=[{wch:4},{wch:12},{wch:20},{wch:12},{wch:16},{wch:16},{wch:14},{wch:12},{wch:20}];
  const wb=XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb,ws,'الشيكات');

  // شيت ثاني — ملخص بالموردين
  const byPayee={};
  list.forEach(c=>{
    if(!byPayee[c.payee])byPayee[c.payee]={total:0,pending:0,done:0,count:0};
    byPayee[c.payee].total+=Number(c.amount);
    byPayee[c.payee].count++;
    if(c.status==='done')byPayee[c.payee].done+=Number(c.amount);
    else byPayee[c.payee].pending+=Number(c.amount);
  });
  const sumHeaders=['المورد','عدد الشيكات','الإجمالي','مصروف','غير مصروف'];
  const sumRows=Object.entries(byPayee)
    .sort((a,b)=>b[1].total-a[1].total)
    .map(([name,d])=>[name,d.count,d.total,d.done,d.pending]);
  const ws2=XLSX.utils.aoa_to_sheet([sumHeaders,...sumRows]);
  ws2['!cols']=[{wch:22},{wch:12},{wch:14},{wch:14},{wch:14}];
  XLSX.utils.book_append_sheet(wb,ws2,'ملخص الموردين');

  const now=new Date();
  const fname='Checks_'+now.toLocaleDateString('en-GB').replace(/\//g,'-')+'.xlsx';
  XLSX.writeFile(wb,fname);
  toast('✅ تم تصدير '+list.length+' شيك');
}

function calcChkUntil(){
  const d=$('chk-until').value;if(!d)return;
  const until=new Date(d);
  const list=chkList.filter(c=>c.status==='pending'&&new Date(c.date)<=until);
  const total=list.reduce((s,c)=>s+Number(c.amount),0);
  $('chk-until-result').textContent=chkFmtAmount(total)+' ج';
  $('chk-until-count').textContent=list.length+' شيك غير مصروف حتى '+chkFmtDate(d);
}
