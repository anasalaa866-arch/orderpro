let _currentPartialRepayAdv = null;
async function openPartialRepay(id){
  try{
    const adv = await apiFetch('/api/hr/advances/' + id + '/details');
    if(!adv) return;
    
    _currentPartialRepayAdv = adv;
    document.getElementById('pr-adv-id').value = id;
    document.getElementById('pr-amount').value = '';
    document.getElementById('pr-note').value = '';
    document.getElementById('pr-deposit').checked = true;
    
    document.getElementById('pr-info').innerHTML = `
      <div><strong>الموظف:</strong> ${escapeHtml(adv.name_ar)} ${adv.code ? `<span style="color:var(--muted)">(${escapeHtml(adv.code)})</span>` : ''}</div>
      <div style="margin-top:6px"><strong>السلفة:</strong> ${fmtMoney(adv.amount)} على ${adv.installments_count} أقساط</div>
      <div style="margin-top:6px;color:var(--accent)"><strong>المتبقي:</strong> ${fmtMoney(adv.remaining_balance)}</div>
      <div style="margin-top:6px;color:var(--muted);font-size:11px">المخصوم حتى الآن: ${fmtMoney(adv.deducted_so_far || 0)}</div>
    `;
    
    document.getElementById('m-hr-partial-repay').style.display = 'flex';
  }catch(e){
    toast('❌ ' + e.message);
  }
}

async function confirmPartialRepay(){
  const id = document.getElementById('pr-adv-id').value;
  const amount = parseFloat(document.getElementById('pr-amount').value);
  const note = document.getElementById('pr-note').value.trim();
  const depositToTreasury = document.getElementById('pr-deposit').checked;
  
  if(!amount || amount <= 0){ toast('❌ المبلغ مطلوب'); return; }
  
  if(_currentPartialRepayAdv && amount > parseFloat(_currentPartialRepayAdv.remaining_balance) + 0.01){
    toast(`❌ المبلغ أكبر من المتبقي (${fmtMoney(_currentPartialRepayAdv.remaining_balance)})`);
    return;
  }
  
  // اختار الخزنة لو deposit
  let treasuryId = null;
  if(depositToTreasury && _treasuries && _treasuries.length > 0){
    if(_treasuries.length === 1){
      treasuryId = _treasuries[0].id;
    } else {
      const opts = _treasuries.map((t,i) => `${i+1}. ${t.name}`).join('\n');
      const choice = prompt(`في أي خزنة تودع المبلغ؟\n\n${opts}\n\nاكتب رقم الخزنة:`);
      if(choice === null) return;
      const idx = parseInt(choice) - 1;
      if(isNaN(idx) || idx < 0 || idx >= _treasuries.length){ toast('❌ اختيار غير صحيح'); return; }
      treasuryId = _treasuries[idx].id;
    }
  }
  
  try{
    const r = await apiFetch('/api/hr/advances/' + id + '/partial-repay', 'POST', {
      amount, note,
      treasury_id: treasuryId,
      deposit_to_treasury: depositToTreasury
    });
    
    if(r && r.success){
      toast(r.isComplete ? '✅ السلفة اكتملت!' : `✅ تم السداد - متبقي: ${fmtMoney(r.newRemaining)}`);
      closeM('m-hr-partial-repay');
      loadHrAdvances();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  }catch(e){
    toast('❌ ' + e.message);
  }
}

// 🆕 v249: إلغاء سلفة نشطة (مع option لإرجاع المتبقي)
async function forceCancelAdvance(id){
  try{
    const adv = await apiFetch('/api/hr/advances/' + id + '/details');
    if(!adv) return;
    
    const remaining = parseFloat(adv.remaining_balance);
    const reason = prompt(`إلغاء السلفة النشطة لـ ${adv.name_ar}؟\nالمتبقي: ${fmtMoney(remaining)}\n\nاكتب السبب:`);
    if(reason === null) return;
    
    let refundRemaining = false;
    let treasuryId = null;
    
    if(remaining > 0){
      refundRemaining = confirm(`المتبقي ${fmtMoney(remaining)}\n\nهل الموظف رجّع المبلغ كاش؟\n\nنعم = إيداع في الخزنة\nلا = إلغاء بدون إيداع (شطب)`);
      
      if(refundRemaining && _treasuries && _treasuries.length > 0){
        if(_treasuries.length === 1){
          treasuryId = _treasuries[0].id;
        } else {
          const opts = _treasuries.map((t,i) => `${i+1}. ${t.name}`).join('\n');
          const choice = prompt(`في أي خزنة تودع المبلغ؟\n\n${opts}`);
          if(choice === null) return;
          const idx = parseInt(choice) - 1;
          if(isNaN(idx) || idx < 0 || idx >= _treasuries.length){ toast('❌ اختيار غير صحيح'); return; }
          treasuryId = _treasuries[idx].id;
        }
      }
    }
    
    const r = await apiFetch('/api/hr/advances/' + id + '/force-cancel', 'POST', {
      reason, refund_remaining: refundRemaining, treasury_id: treasuryId
    });
    
    if(r && r.success){
      toast(refundRemaining ? '✅ تم الإلغاء وإيداع المتبقي' : '✅ تم الإلغاء');
      loadHrAdvances();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  }catch(e){
    toast('❌ ' + e.message);
  }
}

