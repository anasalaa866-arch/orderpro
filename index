async function approveShippingTransfer(id){
  if(!confirm('تأكيد تحويل الشحن؟ الطلب هينقل للوجهة المطلوبة.')) return;
  try{
    const r = await apiFetch(`/api/shipping-transfers/${id}/approve`, 'POST', {
      reviewedBy: currentUser?.name || 'admin'
    });
    if(r && r.success){
      toast('✅ تم تأكيد التحويل');
      // أعد تحميل الـ orders والـ transfers
      await Promise.all([loadOrders(), loadShippingTransfers()]);
      refreshAll();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  }catch(e){
    toast('❌ ' + e.message);
  }
}

async function rejectShippingTransfer(id){
  const reason = prompt('سبب الرفض (اختياري):');
  if(reason === null) return; // user cancelled
  try{
    const r = await apiFetch(`/api/shipping-transfers/${id}/reject`, 'POST', {
      reviewedBy: currentUser?.name || 'admin',
      reason: reason || ''
    });
    if(r && r.success){
      toast('✅ تم الرفض');
      loadShippingTransfers();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  }catch(e){
    toast('❌ ' + e.message);
  }
}

