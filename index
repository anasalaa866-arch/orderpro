        <div>
          <div><strong>${escapeHtml(t.warehouse_name||'')}</strong> · ${escapeHtml(t.type)}</div>
          <div style="font-size:10px;color:var(--muted)">${new Date(t.ts).toLocaleString('ar-EG')} ${t.user_id ? '· '+escapeHtml(t.user_id) : ''}</div>
          ${t.reason ? '<div style="font-size:10px;color:var(--muted)">'+escapeHtml(t.reason)+'</div>' : ''}
        </div>
        <div style="text-align:left">
