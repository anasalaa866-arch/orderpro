let bostaExpPage = 1;
const BOSTA_EXP_PAGE_SIZE = 100;

function renderBostaExportedPage(){
  // الطلبات: مصدّرة + مش مرفوعة + مش ملغية
  const searchQ = ($('bosta-exp-search')||{}).value||'';
  let list = orders.filter(o => o && (o.isBosta || String(o.courierId)==='bosta') && !o.bostaId && o.bostaExported && o.status!=='ملغي');
  if(searchQ) list = list.filter(o => (o.id+o.name+o.phone+(o.area||'')).includes(searchQ));

  // Stats
  const total = list.length;
  const cod = list.filter(o=>!o.paid).reduce((s,o)=>s+(o.total||0),0);
  const govs = [...new Set(list.map(o=>o.area))].filter(Boolean).length;

  // أقدم تصدير
  const exportDates = list.map(o=>o.bostaExportedAt).filter(Boolean);
  const oldest = exportDates.length ? new Date(Math.min(...exportDates.map(d=>new Date(d)))) : null;
  const oldestStr = oldest ? formatRelativeTime(oldest) : '—';

  $('bosta-exp-total').textContent = total;
  $('bosta-exp-cod').textContent = cod.toLocaleString() + ' ج';
  $('bosta-exp-govs').textContent = govs;
  $('bosta-exp-oldest').textContent = oldestStr;
  $('bosta-exp-badge').textContent = total || '';

  // badge عداد في sidebar
  if($('nb-bosta-exp')) $('nb-bosta-exp').textContent = total || '';

  // Pagination
  const totalPages = Math.max(1, Math.ceil(total / BOSTA_EXP_PAGE_SIZE));
  if(bostaExpPage > totalPages) bostaExpPage = totalPages;
  if(bostaExpPage < 1) bostaExpPage = 1;
  const startIdx = (bostaExpPage - 1) * BOSTA_EXP_PAGE_SIZE;
  const endIdx = startIdx + BOSTA_EXP_PAGE_SIZE;
  const pageList = list.slice(startIdx, endIdx);

  // Table
  $('bosta-exp-tbody').innerHTML = pageList.length ? pageList.map(o => {
    const exportDate = o.bostaExportedAt ? formatRelativeTime(new Date(o.bostaExportedAt)) : 'منذ فترة';
    return `<tr>
      <td style="text-align:center"><input type="checkbox" class="bosta-exp-chk" value="${o.id}" onchange="updateBostaExpBtns()"/></td>
