  } catch(e){ toast('❌ ' + e.message, 'error'); }
}

async function openOfferEditor(offerId){
  _offerEditingId = offerId || null;
  _offerEditingProducts = [];
  
  // populate stores
  const storeSelect = $('offer-store');
  try {
    const sR = await apiFetch('/api/pos/stores');
    const stores = sR?.stores || [];
    storeSelect.innerHTML = '<option value="">— اختر —</option>' +
      stores.map(s => `<option value="${s.id}">${escapeHtml(s.name)}</option>`).join('');
  } catch(e){}
  
  // reset form
  $('offer-name').value = '';
  $('offer-store').value = '';
  $('offer-active').value = 'true';
  $('offer-start').value = '';
  $('offer-end').value = '';
  $('offer-notes').value = '';
  $('offer-product-search').value = '';
  $('offer-product-search-results').innerHTML = '';
  
  if(offerId){
    // load existing
    $('offer-editor-title').textContent = '✏️ تعديل العرض';
    try {
      const r = await apiFetch(`/api/pos/offers/${offerId}`);
