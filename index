function getTreasuryPrintTxs(){
  const fromVal=document.getElementById('tprint-from')?.value;
  const toVal=document.getElementById('tprint-to')?.value;
  const typeVal=document.getElementById('tprint-type')?.value||'all';
  if(!fromVal||!toVal){toast('❗ حدد الفترة الزمنية');return null;}
  const from=new Date(fromVal+'T00:00:00');
  const to=new Date(toVal+'T23:59:59');
  let txs=_treasuryTx.filter(x=>x.treasuryId===_activeTreasuryId);
  txs=txs.filter(x=>{const d=new Date(x.date);return d>=from&&d<=to;});
  if(typeVal!=='all') txs=txs.filter(x=>x.type===typeVal);
  txs.sort((a,b)=>new Date(a.date)-new Date(b.date));
  return txs;
}

