  renderChkBooks();
  ['bk-name','bk-bank','bk-account','bk-first-num','bk-last-num'].forEach(id=>$(id)&&($(id).value=''));
  $('bk-pages').value=48;
  openM('m-chk-books');
}
function saveChkBook(){
  const name=$('bk-name').value.trim();
  if(!name){toast('❗ أدخل اسم الدفتر');return;}
  const firstNumRaw = $('bk-first-num')?.value?.trim();
  if(!firstNumRaw){ toast('❗ أدخل رقم أول شيك في الدفتر'); $('bk-first-num')?.focus(); return; }
  const firstNum = parseInt(firstNumRaw);
  if(!firstNum || firstNum < 1){ toast('❗ رقم أول شيك غير صحيح'); return; }
  const pages = parseInt($('bk-pages').value)||48;
  const lastNum = firstNum + pages - 1;
  const b = {id:Date.now()+'_bk', name, bank:$('bk-bank').value.trim(), account:$('bk-account').value.trim(), pages, firstNum, lastNum};
  
  console.log('📘 Creating new book:', b);
  
  chkBooks.push(b);
  saveChks(true);
  
  // 🛡️ بنعمل POST مباشر للدفتر الجديد
  if(API_URL){
    (async () => {
      console.log('📤 Sending book to server:', b.id);
      for(let attempt = 1; attempt <= 3; attempt++){
        try{
          console.log(`Attempt ${attempt}/3 for book ${b.id}`);
          const r = await apiFetch('/api/check-books','POST',b);
          if(r){ 
            console.log('✅ Book saved to DB:', b.id, r);
            toast('✅ تم حفظ الدفتر في السيرفر', 'success');
            return; 
          }
        }catch(e){ 
          console.error(`❌ Attempt ${attempt} failed:`, e.message);
          if(attempt === 3){
            toast('⚠️ تحذير: الدفتر محفوظ محلياً لكن فشل حفظه في السيرفر', 'error');
          }
        }
        if(attempt < 3) await new Promise(r => setTimeout(r, 500 * attempt));
      }
    })();
  }
  
  renderChkBooks();
  toast('✅ تم إضافة الدفتر — الأرقام من '+firstNum+' إلى '+lastNum);
  ['bk-name','bk-bank','bk-account','bk-first-num','bk-last-num'].forEach(id=>$(id)&&($(id).value=''));
  $('bk-pages').value = 48;
}

// 🔍 تشخيص حالة الدفاتر في السيرفر
async function diagnoseCheckBooks(){
  if(!API_URL){
    toast('❌ لا يوجد اتصال بالسيرفر');
    return;
  }

  toast('⏳ جاري الفحص...');

  try{
    const [r1, r2] = await Promise.all([
      apiFetch('/api/check-books').catch(e => ({_error: e.message})),
      apiFetch('/api/checks').catch(e => ({_error: e.message}))
    ]);

    const serverBooks = (r1 && r1.books) ? r1.books : [];
    const serverChecks = (r2 && r2.checks) ? r2.checks : [];
    const localBooks = chkBooks.length;
    const localChecks = chkList.length;

    // تحليل
    const missingInServer = chkBooks.filter(lb => !serverBooks.find(sb => sb.id === lb.id));
    const missingLocally = serverBooks.filter(sb => !chkBooks.find(lb => lb.id === sb.id));

    let report = `📊 تقرير حالة الدفاتر والشيكات\n\n`;
    report += `المحلي (localStorage):\n`;
    report += `  • ${localBooks} دفتر\n`;
    report += `  • ${localChecks} شيك\n\n`;
    report += `السيرفر (DB):\n`;
    report += `  • ${serverBooks.length} دفتر\n`;
    report += `  • ${serverChecks.length} شيك\n\n`;

    if(r1 && r1._error) report += `⚠️ خطأ في تحميل الدفاتر من السيرفر: ${r1._error}\n\n`;
    if(r2 && r2._error) report += `⚠️ خطأ في تحميل الشيكات من السيرفر: ${r2._error}\n\n`;

    if(missingInServer.length){
      report += `❌ ${missingInServer.length} دفتر في الجهاز ده مش موجود في السيرفر:\n`;
      missingInServer.slice(0, 5).forEach(b => report += `  • ${b.name}\n`);
      if(missingInServer.length > 5) report += `  • ... و ${missingInServer.length - 5} دفتر آخر\n`;
      report += `\n`;
    }

    if(missingLocally.length){
      report += `⚠️ ${missingLocally.length} دفتر في السيرفر مش محفوظ محلياً:\n`;
      missingLocally.slice(0, 5).forEach(b => report += `  • ${b.name}\n`);
      report += `\n`;
    }

    if(!missingInServer.length && !missingLocally.length){
      report += `✅ كل حاجة متطابقة!`;
      infoModal('📋 تقرير الفحص', report, { pre: true });
      return;
    }

    if(missingInServer.length){
      report += `\n❓ هل تريد رفع الدفاتر المفقودة للسيرفر؟`;
      if(confirm(report)){
        let success = 0, failed = 0;
        for(const b of missingInServer){
          try{
            // 3 retries
            let ok = false;
            for(let attempt = 1; attempt <= 3 && !ok; attempt++){
              const r = await apiFetch('/api/check-books', 'POST', b);
              if(r){ ok = true; success++; break; }
              if(attempt < 3) await new Promise(r => setTimeout(r, 500));
            }
            if(!ok) failed++;
          }catch(e){ failed++; }
        }
        infoModal('📤 نتيجة الرفع', `✅ تم رفع ${success} دفتر${failed ? `\n❌ فشل ${failed}` : ''}\n\nأعد تحميل الصفحة للتحقق.`);
        // إعادة تحميل
        loadChks();
      }
    } else {
      infoModal('📋 تقرير الفحص', report, { pre: true });
    }

  }catch(e){
    toast('❌ فشل الفحص: ' + e.message);
  }
}

function renderChkBooks(){
  const el=$('chk-books-list');if(!el)return;
  if(!chkBooks.length){el.innerHTML='<div style="text-align:center;color:var(--muted);padding:12px;font-size:13px">لا توجد دفاتر</div>';return;}
  el.innerHTML=chkBooks.map(b=>{
    const used=chkList.filter(c=>c.bookId===b.id).length,rem=Math.max(0,b.pages-used);
    const first=b.firstNum||1, last=b.lastNum||(first+b.pages-1);
    return`<div style="display:flex;align-items:center;padding:8px 10px;border:1px solid var(--border);border-radius:8px;margin-bottom:6px;font-size:13px">
      <div style="flex:1">
        <strong>${b.name}</strong>${b.bank?' — '+b.bank:''}
        <div style="font-size:10px;color:var(--muted);margin-top:2px">أرقام: ${first} إلى ${last}</div>
      </div>
      <div style="text-align:center;min-width:60px"><div style="font-weight:700;color:${rem<5?'var(--danger)':rem<10?'var(--warn)':'var(--success)'}">${rem}</div><div style="font-size:10px;color:var(--muted)">من ${b.pages}</div></div>
      <button class="btn btn-ghost btn-xs" style="color:var(--success);margin-right:8px;border-color:var(--success)" onclick="openBookDetails('${b.id}')" title="فتح وعرض الشيكات">📋 فتح</button>
      <button class="btn btn-ghost btn-xs" style="color:var(--accent);margin-right:4px" onclick="openEditChkBook('${b.id}')" title="تعديل">✏️</button>
      <button class="btn btn-ghost btn-xs" style="color:var(--danger);margin-right:4px" onclick="deleteChkBook('${b.id}')" title="حذف">🗑️</button>
    </div>`;
  }).join('');
}

