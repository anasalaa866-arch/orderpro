    if (!confirm(`هل أنت متأكد من تنفيذ المزامنة لآخر ${days} يوم؟\n\nالطلبات اللي مبالغها مختلفة عن Shopify هتتحدث في النظام.`)) {
      return;
    }
  }
  
  resultEl.innerHTML = `
    <div style="display:flex;align-items:center;gap:10px;padding:12px;background:var(--bg);border-radius:8px;color:var(--muted)">
