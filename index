async function saveOrderType(){
  const id = document.getElementById('ot-id').value;
  const code = document.getElementById('ot-code').value.trim().toLowerCase().replace(/\s+/g, '_');
  const label_ar = document.getElementById('ot-label').value.trim();
  const emoji = document.getElementById('ot-emoji').value.trim() || '📦';
  const color = document.getElementById('ot-color').value;
  const sort_order = parseInt(document.getElementById('ot-sort').value) || 0;
  const is_default = document.getElementById('ot-default').checked;
  
  if(!code || !label_ar){ toast('⚠️ الكود والاسم مطلوبين'); return; }
  if(!/^[a-z_]+$/.test(code)){ toast('⚠️ الكود حروف صغيرة فقط بدون مسافات'); return; }
  
  try{
    if(id){
      await apiFetch('/api/order-types/'+id, 'PATCH', { label_ar, emoji, color, sort_order, is_default });
      toast('✅ تم التعديل');
    } else {
      await apiFetch('/api/order-types', 'POST', { code, label_ar, emoji, color, sort_order, is_default });
      toast('✅ تم الإضافة');
    }
    closeM('m-order-type');
    loadOrderTypes();
  }catch(e){
    toast('❌ ' + e.message);
  }
}

async function deleteOrderType(id){
  const t = _orderTypes.find(x => x.id === id);
  if(!t) return;
  if(!confirm(`متأكد من حذف نوع "${t.label_ar}"؟\n\nملاحظة: الطلبات اللي عليه نوعه هتفضل، بس هيبقى order_type_id = null.`)) return;
  try{
    await apiFetch('/api/order-types/'+id, 'DELETE');
    toast('✅ تم الحذف');
    loadOrderTypes();
  }catch(e){
    toast('❌ ' + e.message);
  }
}

