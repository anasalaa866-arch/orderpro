let _payables = [];
let _editingPayableId = null;
let _payingPayable = null;

const PAYABLE_CATEGORIES = {
  rent: { icon: '🏠', label: 'إيجار', color: '#7c3aed' },
  utilities: { icon: '⚡', label: 'مرافق', color: '#0891b2' },
  supplier: { icon: '🏭', label: 'مورد', color: '#ea580c' },
  salary: { icon: '💰', label: 'راتب', color: '#16a34a' },
  tax: { icon: '📋', label: 'ضرائب', color: '#dc2626' },
  other: { icon: '📌', label: 'أخرى', color: '#6b7280' }
};

async function loadPayables(){
  if(!API_URL) return;
  try {
    // ملخص
    const summary = await apiFetch('/api/payables/summary');
    if(summary){
      $('payable-sum-overdue').textContent = parseFloat(summary.overdue_total || 0).toFixed(0) + ' ج';
      $('payable-sum-overdue-cnt').textContent = (summary.overdue_count || 0) + ' دفعة';
      $('payable-sum-week').textContent = parseFloat(summary.week_total || 0).toFixed(0) + ' ج';
      $('payable-sum-week-cnt').textContent = (summary.week_count || 0) + ' دفعة';
      $('payable-sum-month').textContent = parseFloat(summary.month_total || 0).toFixed(0) + ' ج';
      $('payable-sum-month-cnt').textContent = (summary.month_count || 0) + ' دفعة';
      $('payable-sum-paid').textContent = parseFloat(summary.paid_this_month_amount || 0).toFixed(0) + ' ج';
      $('payable-sum-paid-cnt').textContent = (summary.paid_this_month || 0) + ' دفعة';
      if($('nb-payables')) $('nb-payables').textContent = (summary.overdue_count || 0) || '';
    }

    // قائمة بحسب الفلتر
    const period = $('payable-filter-period').value;
    const category = $('payable-filter-category').value;
    let url = '/api/payables?';
    if(period === 'overdue') url += 'period=overdue&';
    else if(period === 'this_week') url += 'period=this_week&';
    else if(period === 'this_month') url += 'period=this_month&';
    else if(period === 'pending') url += 'status=pending&';
    else if(period === 'paid') url += 'status=paid&';
    if(category) url += 'category=' + category;

    const r = await apiFetch(url);
    _payables = r?.payables || [];
    renderPayables();
  } catch(e){
    document.getElementById('payables-content').innerHTML = `<div class="card"><div class="card-body" style="color:var(--danger)">❌ ${escapeHtml(e.message)}</div></div>`;
  }
}

function renderPayables(){
  const cont = document.getElementById('payables-content');
  if(!cont) return;
  if(!_payables.length){
    cont.innerHTML = '<div class="card"><div class="card-body" style="text-align:center;padding:30px"><div style="font-size:42px;opacity:.3">💸</div><div style="font-size:14px;font-weight:700;margin-top:8px">مفيش دفعات</div><div style="font-size:11px;color:var(--muted);margin-top:4px">اضغط "+ دفعة جديدة" عشان تضيف</div></div></div>';
    return;
  }

  const today = new Date().toISOString().slice(0,10);
  cont.innerHTML = _payables.map(p => {
    const cat = PAYABLE_CATEGORIES[p.category] || PAYABLE_CATEGORIES.other;
    const isPaid = p.status === 'paid';
    const isOverdue = !isPaid && p.due_date < today;
    const dueDate = new Date(p.due_date);
    const dueStr = dueDate.toLocaleDateString('ar-EG', { year: 'numeric', month: 'short', day: 'numeric' });
    const daysDiff = Math.floor((dueDate - new Date(today)) / (1000*60*60*24));
    let dueLabel = '';
    if(isPaid) dueLabel = `✅ اتدفعت ${new Date(p.paid_at).toLocaleDateString('ar-EG')}`;
    else if(daysDiff < 0) dueLabel = `⚠️ متأخرة ${Math.abs(daysDiff)} يوم`;
    else if(daysDiff === 0) dueLabel = '⏰ اليوم';
    else if(daysDiff <= 3) dueLabel = `🟠 خلال ${daysDiff} يوم`;
    else dueLabel = `⏳ بعد ${daysDiff} يوم`;

    return `
      <div class="card" style="margin-bottom:8px;${isOverdue ? 'border-color:#fca5a5;background:#fef2f2' : ''}${isPaid ? 'opacity:.7' : ''}">
        <div class="card-body" style="padding:12px">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px">
            <div style="flex:1;min-width:0">
              <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
                <span style="background:${cat.color};color:#fff;padding:2px 7px;border-radius:8px;font-size:10px;font-weight:700">${cat.icon} ${cat.label}</span>
                ${p.is_recurring ? '<span style="background:#3b82f6;color:#fff;padding:2px 7px;border-radius:8px;font-size:10px;font-weight:700">🔁 متكررة</span>' : ''}
                ${p.parent_id ? '<span style="background:#6b7280;color:#fff;padding:2px 7px;border-radius:8px;font-size:10px;font-weight:700">📎 instance</span>' : ''}
              </div>
              <div style="font-weight:800;font-size:14px;margin-top:4px">${escapeHtml(p.title)}</div>
              ${p.payee ? `<div style="font-size:11px;color:var(--muted);margin-top:2px">إلى: ${escapeHtml(p.payee)}</div>` : ''}
              <div style="font-size:11px;margin-top:4px;color:${isOverdue ? '#dc2626' : (isPaid ? '#16a34a' : 'var(--muted)')}">📅 ${dueStr} · ${dueLabel}</div>
              ${p.notes ? `<div style="font-size:10px;color:var(--muted);margin-top:4px">${escapeHtml(p.notes)}</div>` : ''}
              ${isPaid && p.paid_method ? `<div style="font-size:10px;color:#16a34a;margin-top:3px">دفع: ${p.paid_method}${p.paid_reference ? ' · ' + escapeHtml(p.paid_reference) : ''}</div>` : ''}
            </div>
            <div style="text-align:left">
              <div style="font-size:18px;font-weight:900;color:${isOverdue ? '#dc2626' : (isPaid ? '#16a34a' : 'var(--text)')}">${parseFloat(p.amount).toFixed(0)} ج</div>
            </div>
          </div>
          <div style="display:flex;gap:5px;margin-top:10px">
            ${!isPaid ? `<button class="btn btn-sm" onclick="openPayPayable('${p.id}')" style="background:#16a34a;color:#fff;border-color:#16a34a;flex:1">✅ تسجيل دفع</button>` : `<button class="btn btn-sm" onclick="unpayPayable('${p.id}')" style="background:#fbbf24;color:#000;flex:1">↩️ إلغاء الدفع</button>`}
            <button class="btn btn-ghost btn-sm" onclick="editPayable('${p.id}')">✏️</button>
            <button class="btn btn-ghost btn-sm" onclick="deletePayable('${p.id}', ${p.is_recurring})" style="color:var(--danger)">🗑️</button>
          </div>
        </div>
      </div>
    `;
  }).join('');
}

