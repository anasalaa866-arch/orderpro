async function loadVendorStatement(vendorId){
  if(!vendorId || !API_URL) return;
  
  const fromV = $('vstmt-from')?.value;
  const toV = $('vstmt-to')?.value;
  let url = '/api/vendors/' + encodeURIComponent(vendorId) + '/statement';
  const params = [];
  if(fromV) params.push('from=' + fromV);
  if(toV) params.push('to=' + toV);
  if(params.length) url += '?' + params.join('&');
  
  try{
    const r = await apiFetch(url);
    if(!r) return;
    _currentVendorStatement = r;
    renderVendorStatement(r);
  }catch(e){
    toast('❌ ' + e.message);
  }
}

function renderVendorStatement(data){
  const v = data.vendor;
  const txs = data.transactions || [];
  const opening = parseFloat(data.period_opening_balance) || 0;
  
  $('vstmt-title').textContent = '📜 كشف حساب: ' + v.name;
  
  // احسب الـ totals
  let totalPurchases = 0, totalPayments = 0, totalReturns = 0;
  txs.forEach(t => {
    const amt = parseFloat(t.amount) || 0;
    if(t.type === 'purchase') totalPurchases += amt;
    else if(t.type === 'payment') totalPayments += amt;
    else if(t.type === 'return') totalReturns += amt;
  });
  
  const currentBalance = parseFloat(v.current_balance) || 0;
  
  $('vstmt-opening').textContent = chkFmtAmount(opening) + ' ج';
  $('vstmt-purchases').textContent = chkFmtAmount(totalPurchases) + ' ج';
  $('vstmt-payments').textContent = chkFmtAmount(totalPayments) + ' ج';
  $('vstmt-returns').textContent = chkFmtAmount(totalReturns) + ' ج';
  
  const balDisplay = currentBalance === 0 ? '0 ج'
    : currentBalance > 0 ? chkFmtAmount(currentBalance) + ' ج (عليّ)'
    : chkFmtAmount(Math.abs(currentBalance)) + ' ج (ليّ)';
  $('vstmt-current').textContent = balDisplay;
  $('vstmt-current').style.color = currentBalance > 0 ? 'var(--danger)' : currentBalance < 0 ? 'var(--success)' : 'var(--text)';
  
  // الـ table
  const tbody = $('vstmt-tbody');
  const empty = $('vstmt-empty');
  
  if(!txs.length){
    tbody.innerHTML = '';
    if(empty) empty.style.display = 'block';
    return;
  }
  if(empty) empty.style.display = 'none';
  
  // ضيف الـ opening row في الأعلى لو في فترة
  let runningBalance = opening;
  let rows = '';
  
  if(opening !== 0 && ($('vstmt-from')?.value)){
    rows += `<tr style="background:#f9fafb;font-weight:700">
      <td style="padding:8px">${$('vstmt-from')?.value || '—'}</td>
      <td style="padding:8px">📌 رصيد أول الفترة</td>
      <td style="padding:8px">—</td>
      <td style="padding:8px">رصيد افتتاحي للفترة</td>
      <td style="padding:8px;text-align:left">${opening > 0 ? chkFmtAmount(opening) + ' ج' : '—'}</td>
      <td style="padding:8px;text-align:left">${opening < 0 ? chkFmtAmount(Math.abs(opening)) + ' ج' : '—'}</td>
      <td style="padding:8px;text-align:left;font-weight:700">${chkFmtAmount(opening)} ج</td>
      <td></td>
    </tr>`;
  }
  
  txs.forEach(t => {
    const amt = parseFloat(t.amount) || 0;
    let debit = '', credit = '';
    let typeLabel = '', typeColor = '';
    
    if(t.type === 'opening'){
      typeLabel = '📌 افتتاحي'; typeColor = '#6b7280';
      runningBalance = amt;
      if(amt > 0) debit = chkFmtAmount(amt) + ' ج';
      else credit = chkFmtAmount(Math.abs(amt)) + ' ج';
    } else if(t.type === 'purchase'){
      typeLabel = '🛒 مشتريات'; typeColor = 'var(--danger)';
      runningBalance += amt;
      debit = chkFmtAmount(amt) + ' ج';
    } else if(t.type === 'payment'){
      typeLabel = '💵 دفعة'; typeColor = 'var(--success)';
      runningBalance -= amt;
      credit = chkFmtAmount(amt) + ' ج';
    } else if(t.type === 'return'){
      typeLabel = '↩️ مرتجع'; typeColor = 'var(--warn)';
      runningBalance -= amt;
      credit = chkFmtAmount(amt) + ' ج';
    } else if(t.type === 'adjustment'){
      typeLabel = '⚙️ تسوية'; typeColor = 'var(--accent)';
      runningBalance += amt;
      if(amt > 0) debit = chkFmtAmount(amt) + ' ج';
      else credit = chkFmtAmount(Math.abs(amt)) + ' ج';
    }
    
    const isLinked = t.related_check_id || t.related_treasury_tx_id;
    
    rows += `<tr style="border-bottom:1px solid var(--border)${isLinked?';background:#f0f9ff':''}">
      <td style="padding:8px">${chkFmtDate(t.date)}</td>
      <td style="padding:8px;color:${typeColor};font-weight:700">${typeLabel}</td>
      <td style="padding:8px;font-size:11px">${escapeHtml(t.reference||'—')}${isLinked?' <span style="font-size:9px;background:#dbeafe;color:#1e40af;padding:1px 4px;border-radius:4px">🔗 شيك</span>':''}</td>
      <td style="padding:8px;font-size:11px;color:var(--muted)">${escapeHtml(t.description||'—')}</td>
      <td style="padding:8px;text-align:left;color:var(--danger)">${debit}</td>
      <td style="padding:8px;text-align:left;color:var(--success)">${credit}</td>
      <td style="padding:8px;text-align:left;font-weight:700">${chkFmtAmount(runningBalance)} ج</td>
      <td style="padding:8px;text-align:center">
        ${isLinked ? '' : `<button class="btn btn-ghost btn-xs" onclick="deleteVendorTx('${t.id}')" style="color:var(--danger)" title="حذف">🗑️</button>`}
      </td>
    </tr>`;
  });
  
  tbody.innerHTML = rows;
}

