        <div style="font-size:22px;font-weight:900;color:#16a34a">${cashAmt.toLocaleString()} ج</div>
      </div>
    </div>
  `;

  // dropdown للخزن
  const treasurySelect = $('receive-cash-treasury');
  if(treasurySelect){
    if(!treasuries.length){
      treasurySelect.innerHTML = '<option value="">⚠️ مفيش خزن - لازم تضيف خزنة من صفحة الخزنة الأول</option>';
    } else {
      treasurySelect.innerHTML = '<option value="">— اختار الخزنة —</option>' +
        treasuries.map(t => `<option value="${escapeHtml(t.id)}">${escapeHtml(t.name)}</option>`).join('');
      // لو فيه واحدة بس، اختارها تلقائياً
      if(treasuries.length === 1) treasurySelect.value = treasuries[0].id;
    }
  }

  $('receive-cash-amount').value = cashAmt;
  $('receive-cash-notes').value = '';
  openM('m-receive-cash');
}

async function confirmReceiveCash(){
  if(!_receivingCashFor) return;
  const amount = parseFloat($('receive-cash-amount').value);
  const notes = $('receive-cash-notes').value.trim();
  const treasuryId = $('receive-cash-treasury')?.value || '';

  if(isNaN(amount) || amount < 0){ toast('❗ المبلغ غير صحيح'); return; }
  if(!treasuryId){ toast('❗ لازم تختار الخزنة'); return; }

  try {
    const r = await apiFetch(`/api/accountant/settlements/${_receivingCashFor.id}/receive-cash`, 'POST', {
      amount_received: amount,
      notes,
      treasuryId
    });
    if(r?.success){
      const diff = amount - r.expected;
      let msg = `✅ تم استلام ${amount.toLocaleString()} ج`;
      if(Math.abs(diff) > 0.5){
        msg += diff > 0 ? ` (زيادة ${diff.toLocaleString()})` : ` (نقص ${Math.abs(diff).toLocaleString()})`;
      }
      msg += ` - دخل خزنة ${r.treasuryName}`;
      toast(msg);
      closeM('m-receive-cash');
      _receivingCashFor = null;
      loadSettlementsReceipts();
    } else toast('❌ ' + (r?.error || 'فشل'));
  } catch(e){ toast('❌ ' + e.message); }
}

