const OFFLINE_QUEUE_KEY = 'orderpro_offline_queue';
let _offlineQueue = [];
let _isOnline = navigator.onLine;
let _syncInProgress = false;

try{
  _offlineQueue = JSON.parse(localStorage.getItem(OFFLINE_QUEUE_KEY)||'[]');
