// Daily chart - SVG bars
function wlRenderDailyChart(daily){
  if(!daily.length) return '<div style="text-align:center;padding:20px;color:var(--muted);font-size:12px">⚠️ مفيش بيانات</div>';
  
  const values = daily.map(d => parseInt(d.qty) || 0);
  const max = Math.max(...values, 1);
  const w = 680;
  const h = 120;
  const barW = (w - 20) / daily.length;
  
  const bars = daily.map((d, i) => {
    const v = parseInt(d.qty) || 0;
    const barH = (v / max) * (h - 30);
    const x = 10 + i * barW;
    const y = h - 20 - barH;
    const color = v === 0 ? '#e5e7eb' : v >= max * 0.7 ? '#ef4444' : v >= max * 0.4 ? '#f59e0b' : '#22c55e';
    const date = new Date(d.date).toLocaleDateString('ar-EG', { day: 'numeric', month: 'short' });
    return `<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${(barW * 0.8).toFixed(1)}" height="${barH.toFixed(1)}" fill="${color}" rx="1.5"><title>${date}: ${v} قطعة</title></rect>`;
  }).join('');
  
  // Y-axis label (max value)
  const yLabel = `<text x="2" y="10" font-size="9" fill="#94a3b8">${max}</text>`;
  
  // X-axis labels (every ~15 days)
  const xLabels = daily.filter((_, i) => i % 15 === 0).map((d, idx) => {
    const i = idx * 15;
    const x = 10 + i * barW + (barW * 0.4);
    const date = new Date(d.date).toLocaleDateString('ar-EG', { day: 'numeric', month: 'short' });
    return `<text x="${x.toFixed(1)}" y="${h - 4}" font-size="8" fill="#94a3b8" text-anchor="middle">${date}</text>`;
  }).join('');
  
  return `
    <svg viewBox="0 0 ${w} ${h}" style="width:100%;height:auto;max-height:${h}px">
      ${yLabel}
      ${bars}
      ${xLabels}
    </svg>
  `;
}

