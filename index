  // الـ user اللي بـ يطبع
  const printedBy = (typeof currentUser !== 'undefined' && currentUser) 
    ? (currentUser.name || currentUser.username || 'مستخدم')
    : (localStorage.getItem('op_user_name') || 'مستخدم');
  const printedAt = new Date().toLocaleString('ar-EG', { dateStyle: 'short', timeStyle: 'short' });
  
  const isPending = kind === 'pending';
  const statusBadge = isPending 
    ? '<span style="background:#fbbf24;color:#78350f;padding:3px 10px;border-radius:4px;font-weight:800">🟡 مستني المدير</span>'
    : '<span style="background:#16a34a;color:#fff;padding:3px 10px;border-radius:4px;font-weight:800">🟢 شغّال (Live)</span>';
  
  const methodLabels = {
    cash:     { icon: '💵', label: 'كاش',     color: '#d97706' },
    visa:     { icon: '💳', label: 'فيزا',    color: '#6366f1' },
    instapay: { icon: '📱', label: 'انستاباي', color: '#4f46e5' },
