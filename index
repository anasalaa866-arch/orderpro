async function resyncSale(saleId, btn){
  if(!confirm('إعادة محاولة sync لـ Shopify؟')) return;
  const origText = btn.textContent;
  btn.disabled = true;
  btn.textContent = '⏳ جاري...';
  try {
    // 🔧 v318: استخدم raw fetch عشان نشوف الـ error details
    const baseUrl = (API_URL || BACKEND_URL || '').replace(/\/$/, '');
    if(!baseUrl) throw new Error('مفيش API URL');
    const headers = { 'Content-Type': 'application/json' };
    if(window._adminToken) headers['Authorization'] = 'Bearer ' + window._adminToken;

    const httpResp = await fetch(baseUrl + '/api/pos/sales/' + saleId + '/resync', {
      method: 'POST', headers, mode: 'cors', body: '{}'
    });
    let r;
    try { r = await httpResp.json(); } catch(e) { r = null; }

    if(httpResp.ok && r?.success){
      toast(`✅ تم - رقم Shopify: ${r.shopifyOrderName}`, 'success');
      loadSyncFailures();
    } else if (httpResp.status === 401) {
      toast('❌ مش مسجل دخول - اعمل logout/login', 'error');
      btn.disabled = false;
      btn.textContent = origText;
    } else {
      const errMsg = r?.error || `HTTP ${httpResp.status}`;
      // popup كبير يعرض الـ error
      const errOv = document.createElement('div');
      errOv.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:99999;display:flex;align-items:center;justify-content:center;padding:20px';
      errOv.innerHTML = `
        <div style="background:#fff;border-radius:12px;width:min(560px,95vw);max-height:90vh;overflow-y:auto;padding:20px;font-family:Cairo,sans-serif">
          <div style="font-weight:800;color:#dc2626;font-size:16px;margin-bottom:10px">❌ resync فشل (HTTP ${httpResp.status})</div>
          <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:10px;margin-bottom:10px;font-size:12px;direction:ltr;text-align:left;font-family:monospace;word-break:break-word;max-height:300px;overflow-y:auto">${escapeHtml(errMsg)}</div>
          <div style="font-size:11px;color:#666;margin-bottom:10px">💡 لو الـ error بـ يقول "phone already taken" → ده يعني server لسه على نسخة قديمة (محتاج deploy لـ v205 على Railway).</div>
          <div style="text-align:left">
            <button onclick="this.closest('div[style*=fixed]').remove()" style="padding:8px 16px;border-radius:7px;border:none;background:#3b82f6;color:#fff;font-family:Cairo,sans-serif;font-weight:700;cursor:pointer">حسناً</button>
          </div>
        </div>`;
      document.body.appendChild(errOv);
      btn.disabled = false;
      btn.textContent = origText;
    }
  } catch(e){
    toast('❌ ' + e.message);
    btn.disabled = false;
    btn.textContent = origText;
  }
}

