// 🆕 v300: حفظ تعديل سعر (purchase أو sale)
async function _savePOItemPrice(poId, itemId, type, inputEl){
  const newVal = parseFloat(inputEl.value);
  const original = parseFloat(inputEl.dataset.original);
  
  if(isNaN(newVal) || newVal < 0){
    toast('❌ قيمة غير صالحة');
    inputEl.value = original.toFixed(2);
    return;
  }
  
  // لو ما تغيرش، skip
  if(Math.abs(newVal - original) < 0.001){
    return;
  }
  
  const body = {};
  if(type === 'purchase'){
    body.purchase_price = newVal;
  } else {
    body.sale_price = newVal;
  }
  
  // visual loading
  const origBg = inputEl.style.background;
  inputEl.style.background = '#fbbf2422';
  inputEl.disabled = true;
  
  try {
    const r = await apiFetch(
      `/api/purchase-orders/${poId}/items/${itemId}/prices`,
      'PUT',
      body
    );
    
    inputEl.dataset.original = newVal;
    inputEl.style.background = '#16a34a22';
    setTimeout(() => { inputEl.style.background = origBg; }, 1000);
    
    if(type === 'sale'){
      toast('✅ تم تحديث Shopify');
    } else {
      toast('✅ تم تحديث سعر الشراء');
    }
    
    // re-fetch عشان تحدّث الـ profit margin
    setTimeout(() => _loadPOPricingSection(poId), 500);
  } catch(e){
    inputEl.style.background = '#dc262622';
    inputEl.value = original.toFixed(2);
    toast('❌ ' + e.message);
    setTimeout(() => { inputEl.style.background = origBg; }, 2000);
  } finally {
    inputEl.disabled = false;
  }
}

