// 🆕 v255: Smart pagination (مع ... لو الصفحات كتيرة)
function renderInvPagination(totalItems, totalPages){
  if(totalPages <= 1) return '';
  
  const cur = _invCurrentPage;
  const pages = [];
  
  // Logic: عرض أول صفحة، آخر صفحة، الحالية و2 جنبها
  // مثلاً: 1 ... 5 6 [7] 8 9 ... 30
  
  pages.push(1);
  if(cur - 2 > 2) pages.push('...');
  for(let i = Math.max(2, cur - 2); i <= Math.min(totalPages - 1, cur + 2); i++){
    pages.push(i);
  }
  if(cur + 2 < totalPages - 1) pages.push('...');
  if(totalPages > 1) pages.push(totalPages);
  
  // أزل المتكرر
  const uniquePages = [...new Set(pages)];
  
  const btnStyle = 'min-width:36px;padding:6px 10px;border:1px solid var(--border);background:#fff;cursor:pointer;font-family:Cairo,sans-serif;font-size:12px;border-radius:6px';
  const activeBtnStyle = 'min-width:36px;padding:6px 10px;border:1px solid var(--accent);background:var(--accent);color:#fff;cursor:default;font-family:Cairo,sans-serif;font-size:12px;font-weight:700;border-radius:6px';
  const disabledStyle = 'min-width:36px;padding:6px 10px;border:1px solid var(--border);background:#f9fafb;color:#cbd5e1;cursor:not-allowed;font-family:Cairo,sans-serif;font-size:12px;border-radius:6px';
  
  const buttons = uniquePages.map(p => {
    if(p === '...'){
      return `<span style="padding:6px 4px;color:var(--muted)">...</span>`;
    }
    if(p === cur){
      return `<button style="${activeBtnStyle}">${p}</button>`;
    }
    return `<button style="${btnStyle}" onclick="invGoToPage(${p})">${p}</button>`;
  }).join('');
  
  return `
    <div style="display:flex;justify-content:center;align-items:center;gap:6px;padding:14px;border-top:1px solid var(--border);flex-wrap:wrap;background:#fafbfc">
      <button style="${cur === 1 ? disabledStyle : btnStyle}" ${cur === 1 ? 'disabled' : `onclick="invGoToPage(${cur - 1})"`}>← السابق</button>
      ${buttons}
      <button style="${cur === totalPages ? disabledStyle : btnStyle}" ${cur === totalPages ? 'disabled' : `onclick="invGoToPage(${cur + 1})"`}>التالي →</button>
    </div>
  `;
}

function invGoToPage(page){
  _invCurrentPage = page;
  renderInventoryTable();
  // Scroll to top of table
  document.getElementById('inv-table-container')?.scrollIntoView({behavior: 'smooth', block: 'start'});
}

