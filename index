let _whatsappTpls = [];

async function loadWhatsappPage(){
  const list = document.getElementById('whatsapp-tpl-list');
  if(!list) return;
  
  list.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">⏳ جاري التحميل...</div>';
  
  try {
    const r = await apiFetch('/api/whatsapp/templates');
