    // 🔧 v294: تعديل user موجود بدون تغيير كلمة المرور
    // نسيب passHash undefined → الـ backend هيستخدم القديم من DB
    passHash = undefined;
  } else {
    // user جديد - لازم كلمة مرور
    toast('❗ أدخل كلمة المرور للمستخدم الجديد');return;
  }

  const userData = {username, name, role:'custom', pages, active:true};
  if(passHash) userData.passHash = passHash;

  // 🆕 v237: استنى الـ Backend response قبل ما تحفظ في localStorage
  if(API_URL){
    try{
      // 🔧 v294: ابعت passHash بس لو موجود (تغيير كلمة مرور)
      const payload = {username, name, pages, active:true};
      if(passHash) payload.passHash = passHash;

      const r = await apiFetch('/api/users','POST', payload);
      if(!r){
        toast('❌ فشل الحفظ - شيك على الإنترنت');
        return;
      }
      if(r.error){
        toast('❌ ' + r.error);
        return;
      }

      // النجاح - حدّث الـ Frontend
      if(editingUsername){
        const idx = sysUsers.findIndex(u=>u.username===editingUsername);
