          </div>
        `).join('');
      }
      resultsEl.style.display = 'block';
    } catch(e) {
      resultsEl.innerHTML = '<div style="padding:10px;color:var(--danger);font-size:12px">❌ ' + escapeHtml(e.message) + '</div>';
      resultsEl.style.display = 'block';
