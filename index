// تعديل saveSupplier ليدعم edit
async function saveSupplierActual(){
  const name=$('supplier-name-input')?.value.trim();
  if(!name){toast('❗ أدخل اسم المورد');return;}

  // لو في تعديل، نسمح بالاسم الموجود (لأنه نفس المورد)
  if(!editingVendorId && chkSuppliers.find(s=>s.name===name)){
    toast('⚠️ المورد موجود مسبقاً');return;
  }

  const phone=$('supplier-phone-input')?.value.trim()||'';
  const note=$('supplier-note-input')?.value.trim()||'';

  if(editingVendorId){
    // تعديل
    const oldVendor=chkSuppliers.find(s=>s.id===editingVendorId);
    const oldName=oldVendor?.name;
    if(API_URL){
      try{
        const r=await apiFetch('/api/vendors/'+encodeURIComponent(editingVendorId),'PATCH',{name,phone,note});
        if(r&&r.vendor){
          const idx=chkSuppliers.findIndex(s=>s.id===editingVendorId);
          if(idx>=0)chkSuppliers[idx]={id:r.vendor.id,name:r.vendor.name,phone:r.vendor.phone,note:r.vendor.note};
        }
      }catch(e){
        console.warn('Edit vendor failed:',e);
        toast('⚠️ مشكلة في الحفظ على السيرفر');
        return;
      }
    } else {
      const idx=chkSuppliers.findIndex(s=>s.id===editingVendorId);
      if(idx>=0){chkSuppliers[idx].name=name;chkSuppliers[idx].phone=phone;chkSuppliers[idx].note=note;}
    }

    // لو الاسم اتغير، حدّث كل الشيكات
    if(oldName && oldName!==name){
      let updated=0;
      chkList.forEach(c=>{ if(c.payee===oldName){c.payee=name;updated++;} });
      if(updated>0){
        try{ localStorage.setItem('chk_list',JSON.stringify(chkList)); }catch(e){}
        // synced via PATCH already at server level... but we need to update each check
        // ملاحظة: السيرفر لازم يعدل الشيكات كمان (سنضيف ده لو محتاج)
      }
    }

    toast('✅ تم تحديث المورد');
  } else {
    // إضافة
    const sup={
      id:'v_'+Date.now()+'_'+Math.random().toString(36).slice(2,7),
      name,phone,note
    };
    if(API_URL){
      try{
        const r=await apiFetch('/api/vendors','POST',sup);
        if(r&&r.vendor)sup.id=r.vendor.id;
      }catch(e){
        console.warn('Save vendor failed:',e);
        toast('⚠️ مشكلة في الحفظ، تم الإضافة محلياً');
      }
    }
    chkSuppliers.push(sup);
    toast('✅ تم إضافة المورد: '+name);
  }

  try{ localStorage.setItem('chk_suppliers',JSON.stringify(chkSuppliers)); }catch(e){}
  closeM('m-add-supplier');
  fillSupplierSel();
  // 🔧 v297: re-load ledger من السيرفر عشان المورد الجديد يظهر في الجدول
  if(typeof loadVendorsLedger==='function'){
    loadVendorsLedger().then(()=>{
      if(typeof _renderVendorsList==='function') _renderVendorsList();
      else if(typeof renderVendorsPage==='function') renderVendorsPage();
    });
  } else if(typeof renderVendorsPage==='function') renderVendorsPage();
  editingVendorId=null;
}

function renderWeeklyReport(){
  const container=$('chk-tbody');
  if(!container)return;

  const now=new Date();
  const year=now.getFullYear();

  // 🔧 v227: حساب أسابيع الجمعة → الخميس
  // JS getDay(): Sunday=0, Monday=1, ..., Friday=5, Saturday=6
  // المعادلة: (today + 2) % 7 = كم يوم فات من الجمعة الأخيرة
  // مثال: لو النهارده الأحد (0) → (0+2)%7 = 2 → الجمعة من 2 يوم
  
  // ابدأ من أول جمعة في السنة (أو قبلها لو 1 يناير مش جمعة)
  // وامشي بـ 7 أيام لكل أسبوع
  
  // جيب أول جمعة في السنة
  const yearStart = new Date(year, 0, 1);
  const yearStartDay = yearStart.getDay();
  // كم يوم لازم نمشي عشان نوصل لأول جمعة
  // الجمعة = 5، فلو النهارده Sunday (0) لازم +5 أيام
  // لو Monday (1) → +4 أيام، Saturday (6) → -1 (الجمعة الفايتة)
  let daysToFirstFriday = (5 - yearStartDay + 7) % 7;
  // لو 1 يناير نفسه جمعة (daysToFirstFriday=0)، يبدأ منه
  // لو لأ، نبدأ من الجمعة الفايتة عشان نشمل الأيام اللي قبل أول جمعة كاملة
  let firstFriday = new Date(year, 0, 1 + daysToFirstFriday - 7); // الجمعة قبل أول يوم في السنة
  
  const weeks=[];
  // 53 أسبوع لتغطية كل السنة
  for(let w=1;w<=53;w++){
    const start = new Date(firstFriday);
    start.setDate(firstFriday.getDate() + (w-1)*7);
    start.setHours(0,0,0,0);
    const end = new Date(start);
    end.setDate(start.getDate()+6); // الخميس بعدها
    end.setHours(23,59,59,999);
    
    // وقف لو خرجنا من السنة
    if(start.getFullYear() > year) break;
    
    const weekChecks=chkList.filter(c=>{
      const d=new Date(c.date);
      return d>=start&&d<=end;
    });
    const total=weekChecks.reduce((s,c)=>s+Number(c.amount),0);
    const pending=weekChecks.filter(c=>c.status==='pending');
    const done=weekChecks.filter(c=>c.status==='done');
    weeks.push({w,start,end,checks:weekChecks,total,pending,done});
  }

  const sumRow=$('chk-sum-row');
  if(sumRow)sumRow.style.display='none';

  const thead=container.closest('table')?.querySelector('thead tr');
  if(thead){
    thead.innerHTML=`
      <th>الأسبوع</th>
      <th>من</th>
      <th>إلى</th>
      <th>عدد الشيكات</th>
      <th>إجمالي المستحق</th>
      <th>مصروف</th>
      <th>لم يُصرف</th>`;
  }

  const activeWeeks=weeks.filter(w=>w.checks.length>0);
  if(!activeWeeks.length){
    container.innerHTML=`<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--muted)">لا توجد شيكات مسجلة لهذا العام</td></tr>`;
    return;
  }

  // 🆕 v360: ملخص شهري - كل شهر مع سنته (يناير 2025 + يناير 2026 = صفّين)
  // الـ key = "YYYY-MM" - بـ يفصل السنين
  const months={};
  chkList.forEach(c=>{
    const d=new Date(c.date);
    const key = d.getFullYear() + '-' + String(d.getMonth()+1).padStart(2,'0');
    if(!months[key]) months[key] = {checks:[], total:0, year:d.getFullYear(), month:d.getMonth()+1};
    months[key].checks.push(c);
    months[key].total += Number(c.amount);
  });

  const monthNames=['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];

  container.innerHTML=
    `<tr><td colspan="7" style="padding:10px;background:var(--accent-light);font-weight:700;color:var(--accent);font-size:13px">📆 ملخص شهري — كل الشهور</td></tr>`+
    Object.entries(months)
      .sort((a,b) => b[0].localeCompare(a[0])) // ترتيب من الأحدث للأقدم
      .map(([key, d])=>{
        const pending=d.checks.filter(c=>c.status==='pending').reduce((s,c)=>s+Number(c.amount),0);
        const done=d.checks.filter(c=>c.status==='done').reduce((s,c)=>s+Number(c.amount),0);
        // 🆕 v360: زر 👁️ + clickable (الـ key = "YYYY-MM")
        const hasChecks = d.checks.length > 0;
        const clickHandler = hasChecks ? `onclick="openMonthChecksModal(${d.month}, ${d.year})" onmouseover="this.style.background='#eff6ff'" onmouseout="this.style.background='#f8faff'"` : '';
        const cursor = hasChecks ? 'cursor:pointer' : '';
        return`<tr style="background:#f8faff;${cursor}" ${clickHandler} ${hasChecks ? 'title="اضغط لعرض شيكات الشهر"' : ''}>
          <td colspan="3" style="font-weight:700;color:var(--accent)">${monthNames[d.month-1]} ${d.year}${hasChecks ? ' <span style="font-size:10px;color:var(--accent);font-weight:400">👁️</span>' : ''}</td>
          <td>${d.checks.length} شيك</td>
          <td style="font-weight:700">${d.total.toLocaleString()} ج</td>
          <td style="color:var(--success)">${done.toLocaleString()} ج</td>
          <td style="color:var(--warn)">${pending.toLocaleString()} ج</td>
        </tr>`;
      }).join('')+
    `<tr><td colspan="7" style="padding:10px;background:var(--accent-light);font-weight:700;color:var(--accent);font-size:13px">📅 تفاصيل أسبوعية — ${year}</td></tr>`+
