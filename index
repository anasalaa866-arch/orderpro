    const zK=Object.keys(zones);
    const sZ=[...cZ.filter(z=>zK.includes(z)),...zK.filter(z=>z==='أخري'),...zK.filter(z=>!cZ.includes(z)&&z!=='أخري')];
    let rows='',rc=showExp.length;
    sZ.forEach(function(z){
      const zo=zones[z];if(!zo)return;
      const iO=z==='أخري';
