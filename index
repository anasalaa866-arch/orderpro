async function loadBatchesPage(){
  // حمل الـ stats
  try {
    const stats = await apiFetch('/api/product-batches/stats');
    if(stats){
      if($('exp-stat-soon')) $('exp-stat-soon').textContent = stats.soon_count || 0;
      if($('exp-stat-expired')) $('exp-stat-expired').textContent = stats.expired_count || 0;
      if($('exp-stat-ok')) $('exp-stat-ok').textContent = stats.active_count || 0;
      
      // update pending tab badge
      const badge = document.getElementById('exp-pending-badge');
      if(badge){
        if(stats.pending_count > 0){
          badge.style.display = 'inline-block';
