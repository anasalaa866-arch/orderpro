// 🆕 v203: POLLING MANAGER موحّد
// بدل 8 setInterval متفرقين بيشغّلوا API calls حتى لما الـ tab مش ظاهر
const _pollingTasks = []; // [{name, fn, intervalMs, lastRun}]
let _pollingMaster = null;
let _pageVisible = !document.hidden;

function _registerPolling(name, fn, intervalMs){
  _pollingTasks.push({ name, fn, intervalMs, lastRun: 0 });
}

function _runDuePollingTasks(){
  if(!_pageVisible) return; // ما تشغلش حاجة لو الـ tab مخفي
  const now = Date.now();
  for(const task of _pollingTasks){
    if(now - task.lastRun >= task.intervalMs){
      task.lastRun = now;
      try { task.fn(); } catch(e){ console.warn('Polling task',task.name,'failed:',e); }
    }
  }
}

function _startPollingMaster(){
  if(_pollingMaster) return;
  // واحد setInterval بس بيـ check كل 5 ثواني، ويشغّل الـ tasks اللي due
  _pollingMaster = setInterval(_runDuePollingTasks, 5000);
}

// لو الـ tab اختفى، ما نشغلش polling. لما يرجع، نعيد كل الـ tasks اللي فاتت
document.addEventListener('visibilitychange', () => {
  _pageVisible = !document.hidden;
  if(_pageVisible){
    // الـ tasks اللي فاتتها لما الـ tab كان مخفي — شغّلها فوراً مرة واحدة
    _runDuePollingTasks();
  }
});

