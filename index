    const list = await apiFetch('/api/hr/advances' + status) || [];
    
    const container = document.getElementById('hr-adv-table');
    if(!list.length){
      container.innerHTML = '<div style="text-align:center;padding:40px;color:var(--muted)">مفيش سلف</div>';
      return;
    }
    
    const rows = list.map(a => `
      <tr style="border-bottom:1px solid var(--border)">
        <td style="padding:8px 10px"><strong>${escapeHtml(a.employee_name||'—')}</strong><div style="font-size:10px;color:var(--muted)">${escapeHtml(a.employee_code||'')}</div></td>
        <td style="font-weight:700">${fmtMoney(a.amount)}</td>
        <td style="font-size:12px">${escapeHtml(a.reason||'—')}</td>
        <td style="font-size:12px">${a.installments_count} × ${fmtMoney(a.monthly_deduction)}</td>
        <td style="font-weight:700;color:${a.remaining_balance>0?'var(--warn)':'var(--success)'}">${fmtMoney(a.remaining_balance)}</td>
        <td>${advanceStatusLabel(a.status)}</td>
        <td style="font-size:11px;color:var(--muted)">${fmtDate(a.requested_at)}</td>
        <td style="white-space:nowrap">
          <button class="btn btn-ghost btn-xs" onclick="printAdvance(${a.id})" title="طباعة سند">🖨️</button>
          ${a.status === 'pending' ? `<button class="btn btn-success btn-xs" onclick="approveAdvance(${a.id})">✅ اعتماد</button> <button class="btn btn-ghost btn-xs" onclick="cancelAdvance(${a.id})" style="color:var(--danger)" title="حذف">🗑️</button>` : ''}
          ${a.status === 'active' ? `<button class="btn btn-ghost btn-xs" onclick="openPartialRepay(${a.id})" style="color:var(--accent);font-weight:700" title="سداد جزئي">💵 سداد</button> <button class="btn btn-ghost btn-xs" onclick="forceCancelAdvance(${a.id})" style="color:var(--danger)" title="إلغاء نشط">❌</button>` : ''}
