async function _retrySelectedFailedItems(){
  const checked = [...document.querySelectorAll('#stk-failed-uploads-modal .failed-item-chk:checked')];
  if(!checked.length){ toast('❗ اختار منتجات الأول'); return; }
  
  const ids = checked.map(c => parseInt(c.value));
  if(!confirm(`هتحاول ترفع ${ids.length} منتج تاني لـ Shopify؟`)) return;
  
  toast('🔄 جاري إعادة المحاولة...');
  try {
    const r = await apiFetch('/api/stocktake/retry-failed', 'POST', { item_ids: ids });
    if(r?.success){
      const msg = `${r.success_count} نجح / ${r.failed_count} لسه فاشل`;
      toast((r.failed_count === 0 ? '✅ ' : '⚠️ ') + msg);
      // refresh
      setTimeout(() => openFailedUploadsReport(), 600);
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  } catch(e){
    toast('❌ ' + e.message);
  }
}

