function _renderVendorsList(){
  const tbody=$('vendors-tbody');
  const empty=$('vendors-empty');
  if(!tbody)return;

  const search=($('vendor-search')?.value||'').trim().toLowerCase();
  let list=[..._vendorsLedger.length ? _vendorsLedger : chkSuppliers].sort((a,b)=>(a.name||'').localeCompare(b.name||'','ar'));
  // 🆕 v297: لو الـ ledger بيرجع قديم، اعرض من chkSuppliers اللي مش موجودين فيه
  if(_vendorsLedger.length){
    const ledgerIds = new Set(_vendorsLedger.map(v => v.id));
    const ledgerNames = new Set(_vendorsLedger.map(v => (v.name || '').toLowerCase()));
    chkSuppliers.forEach(s => {
      if (!ledgerIds.has(s.id) && !ledgerNames.has((s.name || '').toLowerCase())) {
        list.push({...s, current_balance: 0, tx_count: 0});
      }
    });
    list.sort((a,b)=>(a.name||'').localeCompare(b.name||'','ar'));
  }
  if(search){
    list=list.filter(v=>
      (v.name||'').toLowerCase().includes(search) ||
      (v.phone||'').includes(search) ||
      (v.note||'').toLowerCase().includes(search)
    );
  }

  if(!list.length){
    tbody.innerHTML='';
    if(empty){
      empty.style.display='block';
      empty.textContent=search?'مفيش نتائج للبحث':'مفيش موردين. اضغط "+ إضافة مورد" للبدء.';
    }
    return;
  }
  if(empty)empty.style.display='none';

  tbody.innerHTML=list.map(v=>{
    const balance = parseFloat(v.current_balance) || 0;
    const balanceDisplay = balance === 0 
      ? '<span style="color:var(--muted)">0 ج</span>'
      : balance > 0 
        ? `<span style="color:var(--danger);font-weight:700">${chkFmtAmount(balance)} ج <span style="font-size:10px">(عليّ)</span></span>`
        : `<span style="color:var(--success);font-weight:700">${chkFmtAmount(Math.abs(balance))} ج <span style="font-size:10px">(ليّ)</span></span>`;
    
    const lastTxStr = v.last_tx_date ? new Date(v.last_tx_date).toLocaleDateString('ar-EG') : '—';
    const txCount = v.tx_count || 0;
    
    return `
      <tr style="border-bottom:1px solid var(--border);cursor:pointer" onclick="openVendorStatement('${v.id}')">
        <td style="padding:10px"><b>${escapeHtml(v.name)}</b>${v.note?`<div style="font-size:10px;color:var(--muted)">${escapeHtml(v.note.substring(0,50))}</div>`:''}</td>
        <td style="padding:10px;direction:ltr;text-align:right">${escapeHtml(v.phone||'—')}</td>
        <td style="padding:10px;font-size:12px;color:var(--muted)">${lastTxStr}</td>
        <td style="padding:10px;text-align:center"><span style="background:var(--bg2);padding:2px 8px;border-radius:10px;font-size:12px">${txCount}</span></td>
        <td style="padding:10px;text-align:left">${balanceDisplay}</td>
        <td style="padding:10px;text-align:center" onclick="event.stopPropagation()">
          <button class="btn btn-ghost btn-xs" onclick="openVendorStatement('${v.id}')" title="كشف حساب" style="color:var(--accent)">📜</button>
          <button class="btn btn-ghost btn-xs" onclick="openEditVendor('${v.id}')" title="تعديل">✏️</button>
          <button class="btn btn-ghost btn-xs" onclick="deleteVendor('${v.id}')" title="حذف" style="color:#dc2626">🗑️</button>
        </td>
      </tr>
    `;
  }).join('');
}

