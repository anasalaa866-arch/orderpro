async function deleteChk(id){
  if(!confirm('هتحذف الشيك ده؟'))return;
  chkList=chkList.filter(x=>x.id!==id);
  // 🆕 v302: track deleted IDs عشان sync-checks يحذفها من السيرفر برضه
  try {
    const deletedIds = JSON.parse(localStorage.getItem('chk_deleted_ids') || '[]');
    if(!deletedIds.includes(id)) deletedIds.push(id);
    localStorage.setItem('chk_deleted_ids', JSON.stringify(deletedIds));
  } catch(e){}
  saveChks(true);
  chkRenderActive();
  if(API_URL){
    try {
      const r = await apiFetch('/api/checks/'+id,'DELETE');
      if(r){
        toast('🗑️ تم حذف الشيك');
        // الـ DELETE نجح، نشيله من قائمة deleted_ids
        try {
          const deletedIds = JSON.parse(localStorage.getItem('chk_deleted_ids') || '[]');
          const newList = deletedIds.filter(x => x !== id);
          localStorage.setItem('chk_deleted_ids', JSON.stringify(newList));
        } catch(e){}
      } else {
        toast('⏳ تم محلياً - هيتسجل لما النت يرجع');
        if(typeof addToOfflineQueue==='function'){
          addToOfflineQueue('/api/checks/'+id,'DELETE',null);
        }
      }
    } catch(e) {
      toast('⚠️ ' + (e.message || 'فشل الحذف'));
      if(typeof addToOfflineQueue==='function'){
        addToOfflineQueue('/api/checks/'+id,'DELETE',null);
      }
    }
  } else {
    toast('🗑️ تم الحذف محلياً (مفيش سيرفر)');
  }
}

