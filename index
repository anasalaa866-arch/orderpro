// ===== BATCH INVOICE PRINTING =====
// ═══════════════════════════════════════════════════════════════════
// 🆕 v261: Batch Print Safety - Layer 1 (Pre-Print) + Layer 3 (Post-Print)
// ═══════════════════════════════════════════════════════════════════
// 
// المشكلة: الـ orders array محلي. لو فيه طلب اتسند من بعد ما الـ user
// فتح الصفحة، الطلب ده مش هيكون في الـ array، فلو طبع batch هيتعمل
// طباعة ناقصة.
//
// الحل: قبل/بعد الطباعة، نسأل الـ backend عن الـ truth من الـ DB.
// ═══════════════════════════════════════════════════════════════════

// Layer 1: Pre-Print Verification
// Compares the local orders array with the DB for selected batches
// Returns: 'cancel' | 'refresh' | { dbOrderIds: [...] }
async function _verifyBatchesBeforePrint(selectedBatchCodes, currentOrderIds, optSkipUnassigned){
  if(!API_URL) return 'continue';  // لو مفيش backend، اتجاهل
  
  toast('🔍 جاري التحقق من البيانات...');
  
  try {
    // اجمع البيانات من الـ DB لكل batch مختار
    const allDbResults = [];
    for(const code of selectedBatchCodes){
      try {
        const r = await apiFetch('/api/batches/' + encodeURIComponent(code) + '/verify');
        if(r) allDbResults.push({ code, ...r });
      } catch(e) {
        console.warn('verify failed for batch', code, e);
      }
    }
    
    if(!allDbResults.length){
      // الـ verification فشل - كمل بدون verification
      console.warn('[v261] all verify calls failed, continuing without check');
      return 'continue';
    }
    
    // قارن الـ local vs الـ DB
    const dbAssignedIds = new Set();
    const dbAllIds = new Set();
    allDbResults.forEach(r => {
      (r.assigned_order_ids || []).forEach(id => dbAssignedIds.add(id));
      (r.all_order_ids || []).forEach(id => dbAllIds.add(id));
    });
    
    // فعّل الـ IDs اللي عندنا محلياً
    const localIds = new Set(currentOrderIds);
    
    // الـ IDs في الـ DB لكن مش في الذاكرة
    const missingFromMemory = [...dbAssignedIds].filter(id => !localIds.has(id));
    // الـ IDs في الذاكرة لكن مش في الـ DB (rare - ممكن اتلغوا)
    const extraInMemory = [...localIds].filter(id => !dbAllIds.has(id));
    
    // إجمالي إحصائيات
    const stats = {
      memoryCount: localIds.size,
      dbAssignedCount: dbAssignedIds.size,
      dbTotalCount: dbAllIds.size,
      missingCount: missingFromMemory.length,
      extraCount: extraInMemory.length,
    };
    
    console.log('[v261] verification stats:', stats);
    
    // لو كله متطابق، كمل عادي
    if(missingFromMemory.length === 0 && extraInMemory.length === 0){
      toast(`✅ تم التحقق - ${stats.memoryCount} طلب جاهز للطباعة`);
      return 'continue';
    }
    
    // فيه فروق! اعرض dialog
    return await new Promise((resolve) => {
      const ov = document.createElement('div');
      ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:100000;display:flex;align-items:center;justify-content:center;padding:20px';
      
      // breakdown للـ couriers اللي فيهم طلبات missing
      const missingByCourier = {};
      allDbResults.forEach(r => {
        (r.couriers || []).forEach(c => {
          const ms = c.order_ids.filter(id => missingFromMemory.includes(id));
          if(ms.length){
            const key = c.name;
            missingByCourier[key] = (missingByCourier[key] || 0) + ms.length;
          }
        });
      });
      
      const missingHtml = Object.entries(missingByCourier)
        .sort((a,b)=>b[1]-a[1])
        .slice(0, 10)
        .map(([name, count]) => `
          <div style="display:flex;justify-content:space-between;padding:6px 10px;background:#fef2f2;border-radius:6px;margin-bottom:4px;font-size:12px">
            <span style="font-weight:700;color:#991b1b">${escapeHtml(name)}</span>
            <span style="color:#dc2626;font-weight:800">+${count} طلب</span>
          </div>
        `).join('');
      
      ov.innerHTML = `
        <div style="background:#fff;border-radius:14px;width:min(560px,95vw);max-height:85vh;overflow-y:auto;font-family:Cairo,sans-serif;box-shadow:0 20px 60px rgba(0,0,0,.4)">
          <div style="background:linear-gradient(135deg,#dc2626,#ea580c);color:#fff;padding:14px 18px;border-radius:14px 14px 0 0">
            <div style="font-weight:800;font-size:16px">⚠️ توقف! في فرق بين الذاكرة والـ DB</div>
            <div style="font-size:12px;opacity:.9;margin-top:3px">حماية: قبل ما نطبع، خلينا نتأكد</div>
          </div>
          
          <div style="padding:18px">
            <div style="background:#fef3c7;border:1px solid #fbbf24;border-radius:8px;padding:10px;margin-bottom:14px;font-size:12px;line-height:1.7;color:#78350f">
              <strong>📦 في الذاكرة:</strong> ${stats.memoryCount} طلب<br>
              <strong>🗄️ في الـ DB:</strong> ${stats.dbAssignedCount} طلب مسند
              ${missingFromMemory.length > 0 ? `<br><strong style="color:#dc2626">⚠️ ${missingFromMemory.length} طلب جديد اتسند من بعد ما فتحت الصفحة!</strong>` : ''}
              ${extraInMemory.length > 0 ? `<br><strong style="color:#9333ea">📋 ${extraInMemory.length} طلب في الذاكرة لكن مش في الـ DB (قد يكون اتلغى)</strong>` : ''}
            </div>
            
            ${missingFromMemory.length > 0 ? `
              <div style="margin-bottom:14px">
                <div style="font-weight:700;font-size:13px;margin-bottom:8px;color:#991b1b">📋 الطلبات الناقصة (هتفوت لو طبعت دلوقتي):</div>
                ${missingHtml}
                ${Object.keys(missingByCourier).length > 10 ? `<div style="text-align:center;color:#666;font-size:11px;margin-top:6px">... و ${Object.keys(missingByCourier).length - 10} مندوب آخر</div>` : ''}
              </div>
            ` : ''}
            
            <div style="background:#f1f5f9;border-radius:8px;padding:12px;font-size:12px;color:#475569;margin-bottom:14px">
              <strong>💡 إيه التصرف الصح؟</strong><br>
              <strong>🔄 جدد البيانات:</strong> النظام هيـ reload الطلبات من الـ DB، ثم تضغط طباعة تاني (الأنسب)<br>
              <strong>🖨️ اطبع كله من الـ DB:</strong> النظام هيستخدم الـ IDs من الـ DB مباشرة (الـ ${stats.dbAssignedCount} طلب)<br>
              <strong>⚠️ اطبع الذاكرة فقط:</strong> هيطبع ${stats.memoryCount} طلب اللي في الذاكرة (الـ ${stats.missingCount} طلب الناقصين هيفوتوا)
            </div>
            
            <div style="display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap">
              <button id="vbb-cancel" style="padding:9px 14px;border-radius:7px;border:1px solid #e5e5e5;background:#fff;font-family:Cairo,sans-serif;font-weight:700;cursor:pointer;font-size:13px">إلغاء</button>
              <button id="vbb-print-mem" style="padding:9px 14px;border-radius:7px;border:1px solid #fbbf24;background:#fef3c7;color:#92400e;font-family:Cairo,sans-serif;font-weight:700;cursor:pointer;font-size:13px">⚠️ اطبع الذاكرة فقط (${stats.memoryCount})</button>
              <button id="vbb-use-db" style="padding:9px 14px;border-radius:7px;border:none;background:#16a34a;color:#fff;font-family:Cairo,sans-serif;font-weight:700;cursor:pointer;font-size:13px">🖨️ اطبع من الـ DB (${stats.dbAssignedCount})</button>
              <button id="vbb-refresh" style="padding:9px 14px;border-radius:7px;border:none;background:#6366f1;color:#fff;font-family:Cairo,sans-serif;font-weight:700;cursor:pointer;font-size:13px">🔄 جدد البيانات</button>
            </div>
          </div>
        </div>
      `;
      document.body.appendChild(ov);
      
      document.getElementById('vbb-cancel').onclick = () => { ov.remove(); resolve('cancel'); };
      document.getElementById('vbb-refresh').onclick = () => { ov.remove(); resolve('refresh'); };
      document.getElementById('vbb-print-mem').onclick = () => { ov.remove(); resolve('continue'); };
      document.getElementById('vbb-use-db').onclick = () => { 
        ov.remove(); 
        // فلتر الـ DB IDs بناءً على optSkipUnassigned
        const dbIds = optSkipUnassigned 
          ? [...dbAssignedIds]   // الـ assigned فقط
          : [...dbAllIds];        // كله بما فيه الـ unassigned
        resolve({ dbOrderIds: dbIds }); 
      };
    });
  } catch(e) {
    console.warn('[v261] verification failed:', e);
    toast('⚠️ تعذر التحقق - الطباعة هتكمل بدون verification');
    return 'continue';
  }
}

// Layer 3: Post-Print Audit
// بعد ما الطباعة تخلص، نتحقق إن كل اللي في الـ DB اتطبع فعلاً
async function _auditBatchPrintResults(selectedBatchCodes, printedOrderIds){
  if(!API_URL) return;
  
  try {
    // جيب الـ verification من الـ DB
    const allDbResults = [];
    for(const code of selectedBatchCodes){
      try {
        const r = await apiFetch('/api/batches/' + encodeURIComponent(code) + '/verify');
        if(r) allDbResults.push({ code, ...r });
      } catch(e){}
    }
    
    if(!allDbResults.length) return;
    
    // الـ IDs اللي المفروض اتطبعوا (من الـ DB)
    const expectedAssignedIds = new Set();
    allDbResults.forEach(r => {
      (r.assigned_order_ids || []).forEach(id => expectedAssignedIds.add(id));
    });
    
    // الـ IDs اللي فعلاً اتطبعوا (من الـ frontend)
    const actualPrinted = new Set(printedOrderIds);
    
    // اللي اتعمله print وعنده courier
    const missedIds = [...expectedAssignedIds].filter(id => !actualPrinted.has(id));
    
    // breakdown بـ مندوب
    const missedByCourier = {};
    allDbResults.forEach(r => {
      (r.couriers || []).forEach(c => {
        const missed = c.order_ids.filter(id => missedIds.includes(id));
        if(missed.length){
          missedByCourier[c.name] = { count: missed.length, ids: missed };
        }
      });
    });
    
    // print stats من الـ DB
    let totalNeverPrinted = 0;
    let totalDoublePrinted = 0;
    allDbResults.forEach(r => {
      totalNeverPrinted += (r.print_status?.never_printed || []).length;
      totalDoublePrinted += (r.print_status?.double_printed || []).length;
    });
    
    // اعرض الـ audit dialog
    const ov = document.createElement('div');
    ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.65);z-index:100000;display:flex;align-items:center;justify-content:center;padding:20px';
    
    const allGood = missedIds.length === 0;
    const headerColor = allGood ? '#16a34a' : '#dc2626';
    const headerIcon = allGood ? '✅' : '⚠️';
    const headerText = allGood 
      ? 'تمت الطباعة بنجاح!' 
      : `${missedIds.length} طلب مش اتطبعوا!`;
    
    const missedHtml = Object.entries(missedByCourier)
      .sort((a,b)=>b[1].count - a[1].count)
      .slice(0, 15)
      .map(([name, data]) => `
        <div style="padding:8px 10px;background:#fef2f2;border-radius:6px;margin-bottom:4px;font-size:12px;display:flex;justify-content:space-between;align-items:center">
          <div>
            <div style="font-weight:700;color:#991b1b">${escapeHtml(name)}</div>
