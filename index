  const date = $('exp-date')?.value;
  if(!date) { toast('❗ أدخل تاريخ الانتهاء'); return; }
  
  const qty = parseInt($('exp-qty')?.value) || 1;
  if(qty < 1){ toast('❗ الكمية لازم > 0'); return; }

  const p = _expSelectedProduct;
  
  // 🆕 v249: استخدم الـ batches API
  try {
    const r = await apiFetch('/api/product-batches', 'POST', {
      variantId: p.variant_id,
      productTitle: p.product_title,
      variantTitle: p.variant_title || '',
      sku: p.sku || '',
      barcode: p.barcode || '',
      expDate: date,
      quantity: qty,
      notes: $('exp-note')?.value.trim() || ''
    });
    
    if(r?.success){
      toast('✅ Batch جديد اتضاف');
      closeM('m-expiry');
