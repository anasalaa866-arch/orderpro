function updateReorderQty(idx, val){
  const qty = parseInt(val) || 0;
  _reorderProducts[idx].requested_qty = qty;
  updateReorderTotals();
}

function updateReorderCost(idx, val){
  const cost = parseFloat(val) || 0;
  _reorderProducts[idx].unit_cost = cost;
  updateReorderTotals();
}

function removeReorderProduct(idx){
  _reorderProducts.splice(idx, 1);
  renderReorderTable();
  updateReorderTotals();
}

function updateReorderTotals(){
  const requested = _reorderProducts.filter(p => p.requested_qty > 0);
  const totalQty = requested.reduce((s, p) => s + p.requested_qty, 0);
  const totalCost = requested.reduce((s, p) => s + (p.requested_qty * p.unit_cost), 0);
  
  document.getElementById('reorder-items-count').textContent = requested.length;
  document.getElementById('reorder-total-qty').textContent = totalQty;
  document.getElementById('reorder-total-cost').textContent = totalCost.toFixed(0) + ' ج';
}

function toggleReorderAddPanel(){
  const panel = document.getElementById('reorder-add-panel');
  panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
  if(panel.style.display === 'block'){
    setTimeout(() => document.getElementById('reorder-search-new').focus(), 100);
  }
}

let _reorderSearchTimer = null;
async function searchReorderNewProduct(){
  const q = document.getElementById('reorder-search-new').value.trim();
  const resultsEl = document.getElementById('reorder-search-results');
  
  if(q.length < 2){ resultsEl.style.display = 'none'; return; }
  
  if(_reorderSearchTimer) clearTimeout(_reorderSearchTimer);
  _reorderSearchTimer = setTimeout(async () => {
    try {
      const r = await apiFetch('/api/suppliers/' + _reorderSupplierId + '/search-products?q=' + encodeURIComponent(q));
      const results = r?.results || [];
      
      // فلتر المنتجات الموجودة بالفعل في القائمة
      const existingIds = new Set(_reorderProducts.map(p => p.variant_id));
      const filtered = results.filter(r => !existingIds.has(r.variant_id));
      
      if(!filtered.length){
        resultsEl.innerHTML = '<div style="padding:10px;text-align:center;color:var(--muted);font-size:12px">مفيش نتائج (أو كلها موجودة)</div>';
      } else {
        resultsEl.innerHTML = filtered.map((v, i) => `
          <div onclick="addReorderNewProduct(${i})" data-idx="${i}" style="padding:8px;border-bottom:1px solid #fde68a;cursor:pointer;font-size:12px" onmouseover="this.style.background='#fef3c7'" onmouseout="this.style.background='transparent'">
            <div style="font-weight:700">${escapeHtml(v.product_title)}${v.variant_title ? ' - '+escapeHtml(v.variant_title) : ''}</div>
            <div style="color:#78350f;font-size:10px">${v.sku ? 'SKU: '+escapeHtml(v.sku) : ''} ${v.barcode ? '· '+escapeHtml(v.barcode) : ''} · مخزون: ${v.total_stock}</div>
          </div>
        `).join('');
        // store filtered for clicking
        window._reorderFilteredResults = filtered;
      }
      resultsEl.style.display = 'block';
    } catch(e){}
  }, 300);
}

async function addReorderNewProduct(idx){
  const v = (window._reorderFilteredResults || [])[idx];
  if(!v) return;
  
  // ضيف للقائمة
  // اعمل API call للـ inventory + stats للمنتج ده
  try {
    // ضيف المنتج للمورد + جيب الـ stats من جديد
    await apiFetch('/api/suppliers/' + _reorderSupplierId + '/products', 'POST', {
      variantId: v.variant_id,
      productTitle: v.product_title,
      variantTitle: v.variant_title,
      sku: v.sku,
      barcode: v.barcode
    });
    
    // حدّث القائمة بـ reorder-data جديدة
    const r = await apiFetch('/api/suppliers/' + _reorderSupplierId + '/reorder-data-smart');
    const newProducts = r?.products || [];
    
    // اعمل merge مع _reorderProducts عشان نحافظ على الكميات اللي اتدخلت
    const existingMap = {};
    _reorderProducts.forEach(p => { existingMap[p.variant_id] = p; });
    
    _reorderProducts = newProducts.map(p => {
      const existing = existingMap[p.variant_id];
      if(existing){
        return { ...p, requested_qty: existing.requested_qty, unit_cost: existing.unit_cost };
      }
      return {
        ...p,
        requested_qty: 0,
        unit_cost: parseFloat(p.last_unit_cost) || 0
      };
    });
    
    _reorderWarehouses = r?.warehouses || _reorderWarehouses;
    
    document.getElementById('reorder-search-new').value = '';
    document.getElementById('reorder-search-results').style.display = 'none';
    
    recalcSuggested();
    renderReorderTable();
    updateReorderTotals();
    
    toast('✅ تم الإضافة');
  } catch(e) { toast('❌ ' + e.message); }
}

async function saveReorderAsPO(status){
  const warehouseId = document.getElementById('reorder-warehouse').value;
  if(!warehouseId){ toast('❌ اختار المخزن المستلم'); return; }
  
  const requested = _reorderProducts.filter(p => p.requested_qty > 0);
  if(!requested.length){ toast('❌ مفيش كميات مطلوبة'); return; }
  
  const data = {
    warehouseId: parseInt(warehouseId),
    supplierId: _reorderSupplierId,
    items: requested.map(p => ({
      variantId: p.variant_id,
      productTitle: p.product_title,
      variantTitle: p.variant_title,
      sku: p.sku,
      barcode: p.barcode,
      orderedQty: p.requested_qty,
      unitCost: p.unit_cost
    })),
    expectedDate: document.getElementById('reorder-expected').value || null,
    notes: document.getElementById('reorder-notes').value.trim(),
    status
  };
  
  try {
    const r = await apiFetch('/api/purchase-orders', 'POST', data);
    if(r?.success){
      toast(status === 'sent' ? '✅ تم الإنشاء والإرسال' : '✅ تم الحفظ كمسودة', 'success');
      closeM('m-reorder');
      loadSuppliersPage();
    }
  } catch(e) { toast('❌ ' + e.message); }
}

