      let status, statusBg, statusColor;
      if(t.is_default){
        status = '⭐ افتراضي';
        statusBg = '#fef3c7'; statusColor = '#92400e';
      } else if(!t.is_active){
        status = '⏸️ موقوف';
        statusBg = '#fee2e2'; statusColor = '#991b1b';
      } else if(expired){
        status = '⏰ منتهي';
        statusBg = '#fee2e2'; statusColor = '#991b1b';
      } else if(upcoming){
        status = '⏳ مجدول';
        statusBg = '#dbeafe'; statusColor = '#1e40af';
