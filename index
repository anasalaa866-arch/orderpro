async function bulkRefreshRisk(){
  // 🔧 v226: workflow محسّن - يمسح الـ cache القديم الأول
  const ordersWithCustomerId = orders.filter(o => o.shopifyCustomerId);
  const ordersWithoutCustomerId = orders.filter(o => !o.shopifyCustomerId);
  const uniqueCustomerIds = new Set(ordersWithCustomerId.map(o => o.shopifyCustomerId)).size;
  
  // الخطوة 1: امسح الـ cache القديم (silent - background)
  try{
    await apiFetch('/api/customers-risk-list/clear-old-cache', 'DELETE');
  }catch(e){ /* silent */ }
  
  // لو الأغلب من الطلبات مفيش customer_id → اعرض workflow الـ backfill الأول
  if(uniqueCustomerIds < 10 && ordersWithoutCustomerId.length > 50){
    const proceedBackfill = confirm(
      `⚠️ في ${ordersWithoutCustomerId.length} طلب مفيهم Customer ID (طلبات قديمة).\n\n` +
      `محتاج نعمل "backfill" أول الأول عشان نحدّث الطلبات دي بالـ Customer ID من Shopify.\n\n` +
      `هل تريد أن نبدأ الآن؟ (هياخد دقيقة-اتنين)`
    );
    if(!proceedBackfill) return;
    
    toast('🔄 جاري تحديث الطلبات القديمة بالـ Customer ID...');
    try{
      const r = await apiFetch('/api/orders/backfill-customer-ids', 'POST', { limit: 200, onlyRecent: true });
      if(r && r.success){
        toast(`✅ تم تحديث ${r.updated} طلب بـ Customer ID`);
        // ريفريش الطلبات
        await loadOrders();
        toast('🔄 جاري الآن جلب بيانات العملاء من Shopify...');
        // كمل بالـ build
        const buildR = await apiFetch('/api/customers-risk-list/build', 'POST', { limit: 200 });
        if(buildR && buildR.success){
          toast(`✅ تم جلب ${buildR.fetched} عميل من Shopify`);
          loadRiskList();
        }
      } else {
        toast('❌ فشل التحديث');
      }
    }catch(e){ toast('❌ ' + e.message); }
    return;
  }
  
  if(!uniqueCustomerIds){ 
    toast('⚠️ مفيش طلبات بـ Customer ID. اعمل استيراد من Shopify الأول.'); 
    return; 
  }
  
  if(!confirm(`هيتم جلب بيانات ${uniqueCustomerIds} عميل من Shopify بـ Customer ID مباشرة. متأكد؟`)) return;

  toast(`🔄 جاري بناء القائمة من ${uniqueCustomerIds} عميل...`);
  
  try{
    const r = await apiFetch('/api/customers-risk-list/build', 'POST', { limit: 200 });
    
    if(r && r.success){
      if(r.errors > 0 && r.errorSamples && r.errorSamples.length){
        const sampleMsg = r.errorSamples.slice(0,3).map(e => 
          `• Customer ${e.customerId}: ${e.reason}`
        ).join('\n');
        infoModal('نتيجة الجلب', 
          `تم جلب ${r.fetched} عميل من Shopify\n\n` +
          `❌ ${r.errors} فشلوا\n\n` +
          `أمثلة على الأخطاء:\n${sampleMsg}\n\n` +
          `📊 الإحصائيات:\n` +
          `• إجمالي الطلبات: ${r.stats?.totalOrders || 0}\n` +
          `• طلبات بـ Customer ID: ${r.stats?.ordersWithCustomerId || 0}\n` +
          `• طلبات بدون Customer ID: ${r.stats?.ordersWithoutCustomerId || 0}`
        );
      } else {
        toast(`✅ تم جلب ${r.fetched} عميل من Shopify`);
      }
      loadRiskList();
    } else {
      toast('⚠️ فشل التحديث');
    }
  }catch(e){ toast('❌ ' + e.message); }
}

