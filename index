          <button class="btn btn-ghost btn-xs" onclick="moOpenReturn('${escapeHtml(o.shopify_order_id)}','${escapeHtml(o.shopify_order_name || '#'+o.shopify_order_number)}')" title="مرتجع — رجّع منتج للمخزن" style="color:#dc2626">↩️</button>
          <button class="btn btn-ghost btn-xs" onclick="window.open('https://cafelax.myshopify.com/admin/orders/${escapeHtml(o.shopify_order_id)}','_blank')" title="افتح في Shopify">🛍️</button>
