}

function courierAccMark(status){
  const s = _courierAccSession;
  if(!s) return;
  const o = s.orders[s.index];
  s.updates[o.id] = {...(s.updates[o.id]||{}), status};
  renderCourierAccSession();
}

function courierAccTogglePaid(){
  const s = _courierAccSession;
  if(!s) return;
  const o = s.orders[s.index];
  const cur = s.updates[o.id] || {};
  const currentPaid = cur.paid !== undefined ? cur.paid : o.paid;
  s.updates[o.id] = {...cur, paid: !currentPaid};
  renderCourierAccSession();
}

function courierAccNext(){
  const s = _courierAccSession; if(!s) return;
  if(s.index < s.orders.length) s.index++;
  renderCourierAccSession();
}

function courierAccPrev(){
  const s = _courierAccSession; if(!s) return;
  if(s.index > 0) s.index--;
  renderCourierAccSession();
}

function closeCourierAccSession(){
  const ov = document.getElementById('courier-acc-overlay');
  if(ov) ov.remove();
  _courierAccSession = null;
}

async function commitCourierAccSession(){
  const s = _courierAccSession; if(!s) return;
  let applied = 0;
  for(const ord of s.orders){
    const u = s.updates[ord.id];
    if(!u) continue;
    const patch = {};
    if(u.status && u.status !== ord.status){ ord.status = u.status; patch.status = u.status; }
    if(u.paid !== undefined && u.paid !== ord.paid){ ord.paid = u.paid; patch.paid = u.paid; }
    if(Object.keys(patch).length){
      applied++;
      if(API_URL) apiFetch('/api/orders/'+ord.id,'PATCH',patch).catch(()=>{});
    }
    // حول الطلبات المكتملة لـ "تحت التسوية" عشان تدخل جلسة التسوية
    if(ord.status === 'مكتمل'){
      ord.status = 'تحت التسوية';
      if(API_URL) apiFetch('/api/orders/'+ord.id,'PATCH',{status:'تحت التسوية'}).catch(()=>{});
    }
  }
  debouncedSaveOrders();
  const cId = s.courierId;
  closeCourierAccSession();
  toast('✅ تم حفظ '+applied+' تغيير — افتح شاشة التسوية');
  renderAcc();
  setTimeout(()=>openSettle(cId), 400);
}

async function startSettleSession(cId){
  const c = couriers.find(x=>x.id==cId);
  if(!c) return;
  const active = oByC(cId,'جاري التوصيل');
  if(!active.length){ toast('لا توجد طلبات شغالة'); return; }
  if(!confirm('بدء جلسة تسوية لـ '+c.name+'؟\n\nهذا سيحول '+active.length+' طلب نشط إلى "تحت التسوية" ويفتح شاشة التسوية.')) return;
  for(const o of active){
    o.status = 'تحت التسوية';
    if(API_URL) apiFetch('/api/orders/'+o.id,'PATCH',{status:'تحت التسوية'}).catch(()=>{});
  }
  debouncedSaveOrders();
  toast('✅ تم بدء جلسة تسوية — '+active.length+' طلب');
  renderAcc();
  setTimeout(()=>openSettle(cId), 300);
}

function openSettle(cId){
  settlingCourierId = cId;
  const c = couriers.find(x=>x.id==cId);
  if(!c) return;
  const pending = getPendingSettleOrders(cId);
  _currentSettleOrders = [...pending];
  if(!pending.length){ toast('✅ لا توجد طلبات جديدة'); return; }
  const cod  = pending.filter(o=>!o.paid).reduce((s,o)=>s+o.total,0);
  const paid = pending.filter(o=>o.paid).reduce((s,o)=>s+o.total,0);
  // 🔧 v238: استخدم getShipCost (يستخدم courier_ship_rates)
  const ship = pending.reduce((s,o)=>s+getShipCost(o,c),0);
  const sessNum = _allSettlements.filter(s=>String(s.courierId)===String(cId)).length+1;
  $('settle-title').textContent = 'تسوية حساب — '+c.name;
  $('settle-body').innerHTML = '<div style="background:var(--accent-light);border-radius:8px;padding:8px 14px;margin-bottom:12px;font-size:12px;color:var(--accent);font-weight:700">تسوية رقم '+sessNum+'</div>'
    +'<div style="background:var(--bg);border-radius:9px;padding:14px;margin-bottom:12px">'
    +'<div style="display:flex;justify-content:space-between;margin-bottom:8px"><span>📦 عدد الطلبات</span><strong>'+pending.length+' طلب</strong></div>'
    +'<div style="display:flex;justify-content:space-between;margin-bottom:8px"><span>💰 COD</span><strong style="color:var(--success)">'+cod.toLocaleString()+' ج</strong></div>'
    +(paid?'<div style="display:flex;justify-content:space-between;margin-bottom:8px"><span>💳 مدفوع أونلاين</span><strong style="color:var(--info)">'+paid.toLocaleString()+' ج</strong></div>':'')
    +'<div style="display:flex;justify-content:space-between;border-top:1px solid var(--border);padding-top:8px;margin-top:4px"><span>🚴 يستلم المندوب</span><strong style="color:var(--purple)">'+ship.toLocaleString()+' ج</strong></div>'
    +'<div id="settle-net-display" style="display:flex;justify-content:space-between;margin-top:8px;font-size:15px;font-weight:700;border-top:2px solid var(--accent);padding-top:8px"><span>💵 صافي المحل</span><strong style="color:var(--accent)">'+(cod-ship).toLocaleString()+' ج</strong></div>'
    +'</div>'
    +'<div style="border:1px solid var(--border);border-radius:9px;padding:12px;margin-bottom:8px">'
    +'<div style="font-size:12px;font-weight:700;margin-bottom:8px;color:var(--muted)">➕ تسويات إضافية (اختياري)</div>'
    +'<div id="settle-adjustments"></div>'
    +'<div style="display:flex;gap:8px;margin-top:8px">'
    +'<input type="number" id="settle-adj-amount" placeholder="المبلغ (+ أو -)" style="flex:1;padding:7px 10px;border:1px solid var(--border);border-radius:8px;font-family:Cairo,sans-serif;font-size:13px">'
    +'<input type="text" id="settle-adj-reason" placeholder="السبب (مثال: فرق انستا)" style="flex:2;padding:7px 10px;border:1px solid var(--border);border-radius:8px;font-family:Cairo,sans-serif;font-size:13px">'
    +'<button class="btn btn-ghost btn-sm" onclick="addSettleAdj()">+ إضافة</button>'
    +'</div>'
    +'</div>';
  window._settleAdj = []; // reset adjustments
  window._settleAdjFromStars = []; // 🆕 v199: تعديلات Stars اللي اتوافق عليها
  openM('m-settle');

  // 🆕 v199: جيب الـ approved adjustments من Stars وحطها أوتوماتيك في التسوية
  // عشان مايتنسوش زي اللي حصل قبل كده
  if(API_URL){
    apiFetch('/api/courier-adjustments/approved-unsettled/'+cId, 'GET')
      .then(adjs => {
        if(!Array.isArray(adjs) || !adjs.length) return;
        // ضيفهم في الـ _settleAdj مع علامة _fromStars
        adjs.forEach(a => {
          window._settleAdj.push({
            amount: parseFloat(a.amount) || 0,
            reason: '🌟 ' + (a.reason || 'تعديل من Stars'),
            _fromStars: true,
            _adjustmentId: a.id,
          });
          window._settleAdjFromStars.push(a.id);
        });
        // re-render
        const el = document.getElementById('settle-adjustments');
        if(el) el.innerHTML = window._settleAdj.map((a,i)=>
          '<div style="display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid var(--border)' + (a._fromStars ? ';background:#f0f9ff;padding:6px 8px;border-radius:6px' : '') + '">'
          +'<span style="font-size:12px">'+a.reason+(a._fromStars?' <span style="font-size:10px;color:var(--muted)">(من Stars - معتمد)</span>':'')+'</span>'
          +'<div style="display:flex;gap:8px;align-items:center">'
          +'<strong style="color:'+(a.amount>=0?'var(--success)':'var(--danger)')+';">'+(a.amount>=0?'+':'')+a.amount.toLocaleString()+' ج</strong>'
          + (a._fromStars ? '<span style="color:var(--muted);font-size:11px;cursor:help" title="تعديل من Stars - مش هيتشال">🔒</span>' : '<button onclick="removeSettleAdj('+i+')" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:12px">✕</button>')
          +'</div></div>'
        ).join('');
        _updateSettleNet();
        // عرض رسالة للمحاسب
        toast('✅ تم تحميل '+adjs.length+' تعديل معتمد من Stars');
      })
      .catch(e => console.warn('Failed to load approved adjustments:', e));
  }
}

function addSettleAdj(){
  const amt = parseFloat(document.getElementById('settle-adj-amount')?.value||0);
  const reason = document.getElementById('settle-adj-reason')?.value.trim();
  if(!amt){ toast('أدخل المبلغ'); return; }
  if(!reason){ toast('أدخل السبب'); return; }
  if(!window._settleAdj) window._settleAdj = [];
  window._settleAdj.push({amount:amt, reason});
  const el = document.getElementById('settle-adjustments');
  if(el){
    el.innerHTML = window._settleAdj.map((a,i)=>
      '<div style="display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid var(--border)">'
      +'<span style="font-size:12px">'+a.reason+'</span>'
      +'<div style="display:flex;gap:8px;align-items:center">'
      +'<strong style="color:'+(a.amount>=0?'var(--success)':'var(--danger)')+';">'+(a.amount>=0?'+':'')+a.amount.toLocaleString()+' ج</strong>'
      +'<button onclick="removeSettleAdj('+i+')" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:12px">✕</button>'
      +'</div></div>'
    ).join('');
  }
  _updateSettleNet();
  document.getElementById('settle-adj-amount').value = '';
  document.getElementById('settle-adj-reason').value = '';
}

function removeSettleAdj(i){
  if(window._settleAdj) window._settleAdj.splice(i,1);
  addSettleAdj.call({_skip:true}); // re-render
  const el = document.getElementById('settle-adjustments');
  if(el) el.innerHTML = (window._settleAdj||[]).map((a,i)=>
    '<div style="display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid var(--border)">'
    +'<span style="font-size:12px">'+a.reason+'</span>'
    +'<div style="display:flex;gap:8px;align-items:center">'
    +'<strong style="color:'+(a.amount>=0?'var(--success)':'var(--danger)')+';">'+(a.amount>=0?'+':'')+a.amount.toLocaleString()+' ج</strong>'
    +'<button onclick="removeSettleAdj('+i+')" style="background:none;border:none;color:var(--muted);cursor:pointer;font-size:12px">✕</button>'
    +'</div></div>'
  ).join('');
  _updateSettleNet();
}

function _updateSettleNet(){
  const adj = (window._settleAdj||[]).reduce((s,a)=>s+a.amount,0);
  const el = document.getElementById('settle-net-display');
  if(!el) return;
  const pending = getPendingSettleOrders(settlingCourierId);
  const cour = couriers.find(x=>x.id==settlingCourierId);
  const cod = pending.filter(o=>!o.paid).reduce((s,o)=>s+o.total,0);
  // 🔧 v238: استخدم getShipCost
  const ship = pending.reduce((s,o)=>s+(cour?getShipCost(o,cour):(o.ship||50)),0);
  const net = cod - ship + adj;
  el.innerHTML = '<span>💵 صافي المحل</span><strong style="color:var(--accent)">'+net.toLocaleString()+' ج</strong>'
    +(adj!==0?'<span style="font-size:11px;color:var(--muted);margin-right:8px">(تعديل: '+(adj>=0?'+':'')+adj.toLocaleString()+' ج)</span>':'');
}

async function doSettle(){
  const c = couriers.find(x=>x.id==settlingCourierId);
  if(!c) return;
  const pending = getPendingSettleOrders(c.id);
  if(!pending.length){ toast('لا توجد طلبات'); return; }
  const now = new Date().toISOString();
  const orderIds = pending.map(o=>o.id);
  const cod  = pending.filter(o=>!o.paid).reduce((s,o)=>s+o.total,0);
  // 🔧 v238: استخدم getShipCost
  const ship = pending.reduce((s,o)=>s+getShipCost(o,c),0);
  const adj = window._settleAdj || [];
  const adjTotal = adj.reduce((s,a)=>s+a.amount,0);
  const newS = {id:Date.now(), courierId:c.id, ts:new Date(now), orderIds, cod, ship, adj, adjTotal};
  _allSettlements.push(newS);
  pending.forEach(o=>{
    if(o.status==='تحت التسوية'){
      o.status='مكتمل';
      if(API_URL) apiFetch('/api/orders/'+o.id,'PATCH',{status:'مكتمل'}).catch(()=>{});
    }
  });
  if(API_URL){
    // 🆕 v199: ابعت adjustmentIds عشان السيرفر يربطهم بالتسوية
    const adjustmentIds = window._settleAdjFromStars || [];
    apiFetch('/api/settlements','POST',{courierId:c.id,ts:now,orderIds,cod,ship,adj,adjTotal,adjustmentIds})
      .then(r=>{ if(r&&r.id) newS.id=r.id; }).catch(e=>console.error('settle error:',e));
    apiFetch('/api/couriers/'+c.id,'PATCH',{settled:true}).catch(()=>{});
  }
  closeM('m-settle');
  pushNotif('💰','تمت تسوية حساب '+c.name,'');
  renderAcc();
  toast('✅ تمت تسوية '+c.name+' — '+pending.length+' طلب');
  const _net = cod - ship + adjTotal;
  // طباعة
  setTimeout(()=>{
    if(confirm('هل تريد طباعة ورقة تسوية '+c.name+'؟')) printCurrentSettle();
  },300);
  // ربط الخزنة
  if(_treasuries.length && _net > 0){
    setTimeout(()=>openSettleToTreasury(c.name, _net, now), 800);
  }
}

