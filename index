}

function selectPOItem(idx){
  const v = _poVariantSearchResults[idx];
  if(!v) return;
  
  _poSelectedItem = {
    variantId: v.variant_id || v.id,
    productTitle: v.product_title || v.title,
    variantTitle: v.variant_title || '',
    sku: v.sku || '',
    barcode: v.barcode || ''
  };
  
  document.getElementById('po-selected-name').textContent = _poSelectedItem.productTitle + (_poSelectedItem.variantTitle ? ' - ' + _poSelectedItem.variantTitle : '');
  document.getElementById('po-selected-info').textContent = (_poSelectedItem.sku ? 'SKU: '+_poSelectedItem.sku : '') + (_poSelectedItem.barcode ? ' · '+_poSelectedItem.barcode : '');
  document.getElementById('po-selected-item').style.display = 'block';
  
  document.getElementById('po-item-results').style.display = 'none';
  document.getElementById('po-item-search').value = '';
  
  // اقترح السعر من cost لو موجود
  if(v.cost){
    document.getElementById('po-item-cost').value = parseFloat(v.cost).toFixed(2);
  }
}

function addPOItem(){
  if(!_poSelectedItem){ toast('❌ اختار منتج أولاً'); return; }
  
  const qty = parseInt(document.getElementById('po-item-qty').value);
  const cost = parseFloat(document.getElementById('po-item-cost').value);
  const notes = document.getElementById('po-item-notes').value.trim();
  
  if(!qty || qty < 1){ toast('❌ الكمية لازم > 0'); return; }
  if(isNaN(cost) || cost < 0){ toast('❌ السعر لازم >= 0'); return; }
  
  _poItems.push({
    ..._poSelectedItem,
    orderedQty: qty,
    unitCost: cost,
    notes
  });
  
  renderPOItems();
  updatePOTotals();
  closeM('m-po-add-item');
}

async function savePO(status){
  const supSel = document.getElementById('po-supplier').value;
  const whId = document.getElementById('po-warehouse').value;
  
  if(!whId){ toast('❌ اختار المخزن'); return; }
  if(!supSel){ toast('❌ اختار المورد'); return; }
  if(!_poItems.length){ toast('❌ ضيف منتجات'); return; }
  
  let supplierId = null, supplierName = null, supplierPhone = null;
  
  if(supSel === 'custom'){
    supplierName = document.getElementById('po-supplier-name').value.trim();
    supplierPhone = document.getElementById('po-supplier-phone').value.trim();
    if(!supplierName){ toast('❌ اسم المورد مطلوب'); return; }
    
    // لو محدّد إنه يحفظه
    if(document.getElementById('po-save-supplier').checked){
      try {
        const r = await apiFetch('/api/suppliers', 'POST', {
          name: supplierName,
          phone: supplierPhone
        });
        if(r?.supplier?.id){
          supplierId = r.supplier.id;
          supplierName = null; // مش محتاج نخليهم اتنين
          supplierPhone = null;
        }
      } catch(e){}
    }
  } else {
    supplierId = parseInt(supSel);
  }
  
  const data = {
    warehouseId: parseInt(whId),
    supplierId,
    supplierName,
    supplierPhone,
    items: _poItems,
    expectedDate: document.getElementById('po-expected-date').value || null,
    taxAmount: parseFloat(document.getElementById('po-tax').value) || 0,
    shippingCost: parseFloat(document.getElementById('po-shipping').value) || 0,
    paymentMethod: document.getElementById('po-payment-method').value,
    notes: document.getElementById('po-notes').value.trim(),
    status
  };
  
  try {
    const id = document.getElementById('po-id').value;
    if(id){
      await apiFetch('/api/purchase-orders/' + id, 'PUT', data);
    } else {
      await apiFetch('/api/purchase-orders', 'POST', data);
    }
    toast(status === 'sent' ? '✅ تم الإنشاء والإرسال' : '✅ تم الحفظ كمسودة');
    closeM('m-po');
    loadPurchaseOrdersPage();
  } catch(e) { toast('❌ ' + e.message); }
}

