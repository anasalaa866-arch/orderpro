    status: o.status,
    src: o.src
  })));
  
  toast(`⚠️ ${orphans.length} طلب orphan - شوف console`);
  return orphans;
};

// 🩺 v241: Diagnostic - أصلح الطلبات الـ orphan بإضافة الـ batchCode الحالي
window.fixOrphanOrders = async function(){
  const orphans = window.checkOrphanOrders();
  if(!orphans.length) return;
  
  if(!confirm(`هتضيف batchCode للـ ${orphans.length} طلب orphan؟`)) return;
  
  const batch = await ensureCurrentBatchAsync();
  if(!batch || !batch.code){
    toast('❌ مفيش دفعة مفتوحة');
    return;
  }
  
  let fixed = 0;
  for(const o of orphans){
    try{
      const r = await apiFetch('/api/orders/' + o.id, 'PATCH', { batchCode: batch.code });
      if(r){
        o.batchCode = batch.code;
        fixed++;
      }
    }catch(e){
      console.error('fix failed for', o.id, e.message);
    }
  }
  
  toast(`✅ تم إصلاح ${fixed}/${orphans.length} طلب`);
  refreshAll && refreshAll();
};

