      toast('↩️ رجعت لـ مش مدفوعة');
      loadPayables();
    } else toast('❌ ' + (r?.error || 'فشل'));
  } catch(e){ toast('❌ ' + e.message); }
}

async function deletePayable(id, isRecurring){
  let alsoChildren = false;
  if(isRecurring){
