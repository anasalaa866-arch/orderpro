// 🆕 v256: Excel export (XLSX) للنتائج المفلترة
function exportZeroStocksExcel(){
  const products = zsGetFilteredProducts();
  if(!products.length){ toast('❌ مفيش بيانات للتصدير'); return; }
  
  const fromDate = document.getElementById('zs-from').value;
  const toDate = document.getElementById('zs-to').value;
  const combinedVal = document.getElementById('zs-warehouse-combined').value;
  const scope = combinedVal === '__all__' ? 'global' : 'warehouse';
  const wh = _zsWarehouses.find(w => w.id == combinedVal);
  const scopeLabel = scope === 'global' ? 'كل المخازن' : (wh?.name || '');
  
  const filterLabel = _zsResultFilter === 'out_everywhere' ? '-نفد-في-الكل' 
                    : _zsResultFilter === 'available_elsewhere' ? '-متاح-في-تاني' 
                    : '';
  
  // لو SheetJS متاحة، استخدمها (لو لا، نستخدم CSV كـ fallback)
  if (typeof XLSX !== 'undefined') {
    const data = products.map((p, i) => ({
      '#': i + 1,
      'المنتج': p.product_title || '-',
      'SKU': p.sku || '-',
      'أول مرة خلص': new Date(p.first_zero_date).toLocaleDateString('ar-EG'),
      'عدد المرات': p.zero_event_count,
      'الرصيد (المخزن)': p.current_stock,
      'الرصيد (كل المخازن)': p.total_stock_all_warehouses || 0,
      'الحالة': (p.total_stock_all_warehouses || 0) === 0 ? 'نفد فعلياً' : 'متاح في مخزن تاني',
    }));
    
    const ws = XLSX.utils.json_to_sheet(data);
    ws['!cols'] = [
      {wch:5}, {wch:40}, {wch:18}, {wch:15}, {wch:12}, {wch:18}, {wch:18}, {wch:22}
    ];
    
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'منتجات نفدت');
    
    XLSX.writeFile(wb, `منتجات-خلصت-${scopeLabel}${filterLabel}-${fromDate}-${toDate}.xlsx`);
    toast('✅ تم تنزيل ملف Excel');
    return;
  }
  
  // fallback: CSV
  const header = '#,المنتج,SKU,أول مرة خلص,عدد المرات,الرصيد (المخزن),الرصيد (كل المخازن),الحالة\n';
  const rows = products.map((p, i) => {
    const safeTitle = (p.product_title || '').replace(/"/g, '""');
    const safeSku = (p.sku || '').replace(/"/g, '""');
    const date = new Date(p.first_zero_date).toLocaleDateString('ar-EG');
    const status = (p.total_stock_all_warehouses || 0) === 0 ? 'نفد فعلياً' : 'متاح في مخزن تاني';
    return `${i+1},"${safeTitle}","${safeSku}","${date}",${p.zero_event_count},${p.current_stock},${p.total_stock_all_warehouses || 0},"${status}"`;
  }).join('\n');
  
  const csv = '\uFEFF' + header + rows;
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `منتجات-خلصت-${scopeLabel}${filterLabel}-${fromDate}-${toDate}.csv`;
  a.click();
  URL.revokeObjectURL(url);
  
  toast('✅ تم التحميل (CSV)');
}

