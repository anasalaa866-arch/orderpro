        <th style="text-align:right;padding:10px">الأقساط</th>
        <th style="text-align:right;padding:10px">المتبقي</th>
        <th style="text-align:right;padding:10px">الحالة</th>
        <th style="text-align:right;padding:10px">التاريخ</th>
        <th style="text-align:center;padding:10px">إجراءات</th>
      </tr></thead><tbody>${rows}</tbody></table>`;
    
