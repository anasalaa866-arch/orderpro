  const shippingInput = document.getElementById('accept-shipping');
  const targetSel = document.getElementById('accept-target');
  const shippingCost = parseFloat(shippingInput.value);
  const target = targetSel.value;

  if(isNaN(shippingCost) || shippingCost < 0){
    toast('❌ أدخل سعر شحن صحيح');
    shippingInput.focus();
    return;
  }
  if(!target){
    toast('❌ اختر الوجهة');
    targetSel.focus();
    return;
  }

  try{
    const r = await apiFetch('/api/shop-transfers/'+t.id+'/accept-and-assign', 'POST', {
      shippingCost,
      target,
      acceptedBy: currentUser?.username || 'admin'
    });
    if(r && r.success){
      // حدّث الطلب في الذاكرة المحلية
      const orderIdx = orders.findIndex(o => o.id === r.orderId);
      if(orderIdx >= 0){
        orders[orderIdx].ship = r.shippingCost;
        orders[orderIdx].deliveryType = 'normal';
        orders[orderIdx].status = 'جاري التوصيل';
        if(r.isBosta){
          orders[orderIdx].isBosta = true;
          orders[orderIdx].courierId = null;
        } else {
          orders[orderIdx].isBosta = false;
          // courier_id يتعبى من الـ sync
        }
        debouncedSaveOrders();
      }
      closeAcceptAndAssign();
      toast('✅ تم الاستلام — الطلب انتقل لـ ' + r.assignedTo);
      loadShopTransfers();
      refreshAll();
      // حمل البيانات من السيرفر تاني عشان نضمن تطابق
      if(typeof loadOrders === 'function') loadOrders().catch(()=>{});
    } else {
      toast('❌ فشل: ' + (r?.error || 'غير معروف'));
    }
  }catch(e){
    toast('❌ خطأ: ' + e.message);
  }
}

