      `<option value="${t.id}" ${currentType && t.id === currentType.id ? 'disabled' : ''}>${t.emoji || '📦'} ${escapeHtml(t.label_ar)}${currentType && t.id === currentType.id ? ' (الحالي)' : ''}</option>`
    ).join('');
  
  document.getElementById('cot-reason').value = '';
