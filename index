      <td><strong>${o.total.toLocaleString()} ج</strong><br>${o.paid?'<span style="font-size:10px;color:var(--success)">مدفوع</span>':'<span style="font-size:10px;color:var(--warn)">COD</span>'}</td>
      <td style="color:var(--muted);font-size:12px">${exportDate}</td>
      <td>
        <div style="display:flex;gap:4px;flex-wrap:wrap">
          <button class="btn btn-ghost btn-xs" style="color:var(--accent);border-color:var(--accent)" onclick="openEditOrder('${o.id}')">✏️</button>
          <button class="btn btn-ghost btn-xs" style="color:#64748b;border-color:#64748b;font-size:10px" onclick="openOrderHistory('${o.id}')" title="تاريخ">📋</button>
          <button class="btn btn-ghost btn-xs" style="color:#6366f1;border-color:#6366f1" onclick="printPackingSlip('${o.id}')" title="فاتورة">🧾</button>
          <button class="btn btn-ghost btn-xs" style="color:var(--warn);border-color:var(--warn)" onclick="undoBostaExport('${o.id}')">↩ إلغاء</button>
        </div>
      </td>
    </tr>`;
  }).join('') : '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--muted)">لا توجد طلبات مصدّرة 📭</td></tr>';

  // Pagination render
  renderBostaExpPagination(total, totalPages);
}

function renderBostaExpPagination(totalCount, totalPages){
  const el = $('bosta-exp-pagination');
  if(!el) return;
  if(totalPages <= 1){
    el.innerHTML = totalCount ? `<span style="color:var(--muted);font-size:12px">${totalCount} طلب</span>` : '';
    return;
  }
  const startIdx = (bostaExpPage - 1) * BOSTA_EXP_PAGE_SIZE;
  const endIdx = Math.min(startIdx + BOSTA_EXP_PAGE_SIZE, totalCount);

  const pages = [];
  if(totalPages <= 7){
    for(let i=1; i<=totalPages; i++) pages.push(i);
  } else {
    pages.push(1);
    if(bostaExpPage > 3) pages.push('...');
    for(let i=Math.max(2, bostaExpPage-1); i<=Math.min(totalPages-1, bostaExpPage+1); i++) pages.push(i);
    if(bostaExpPage < totalPages-2) pages.push('...');
    pages.push(totalPages);
  }

  const btn = (page, label, disabled) => {
    const active = page === bostaExpPage;
    const style = active
      ? 'background:var(--accent);color:#fff;border:1px solid var(--accent);font-weight:800'
      : disabled
        ? 'background:transparent;color:var(--muted);border:1px solid var(--border);cursor:not-allowed;opacity:.5'
        : 'background:var(--card);color:var(--text);border:1px solid var(--border);cursor:pointer';
    return `<button ${disabled?'disabled':''} onclick="goToBostaExpPage(${page})" style="${style};padding:6px 12px;border-radius:6px;font-family:Cairo,sans-serif;font-size:12px;min-width:34px">${label}</button>`;
  };

  const parts = [];
  parts.push(`<span style="color:var(--muted);font-size:12px;margin-left:12px">${startIdx+1}-${endIdx} من ${totalCount}</span>`);
  parts.push(btn(bostaExpPage-1, '←', bostaExpPage<=1));
  pages.forEach(p => {
    if(p === '...') parts.push('<span style="color:var(--muted);padding:0 4px">...</span>');
    else parts.push(btn(p, String(p), false));
  });
  parts.push(btn(bostaExpPage+1, '→', bostaExpPage>=totalPages));

  el.innerHTML = parts.join('');
}

function goToBostaExpPage(p){
