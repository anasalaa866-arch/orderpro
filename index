// Helper: ارسم جدول من ShopifyQL tableData
function _renderShopifyQLTable(tableData, container){
  if(!tableData || !tableData.columns || !tableData.rows){
    container.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)">مفيش بيانات</div>';
    return;
  }
  
  const columns = tableData.columns || [];
  const rows = tableData.rows || [];
  
  if(!rows.length){
    container.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)">📭 مفيش بيانات للفترة دي</div>';
    return;
  }
  
  let html = `
    <div style="overflow-x:auto">
      <table style="width:100%;border-collapse:collapse;font-size:12px">
        <thead>
          <tr style="background:var(--bg)">
            ${columns.map(c => `<th style="padding:10px;text-align:right;border-bottom:2px solid var(--border);font-weight:700">${escapeHtml(c.displayName || c.name)}</th>`).join('')}
          </tr>
        </thead>
        <tbody>
          ${rows.map(row => {
            // 🔧 v233: في schema الـ ShopifyQL الجديد، الـ row ممكن يكون:
            // 1. Array (الشكل القديم) ← row.map شغّال
            // 2. String JSON (الشكل الجديد) ← لازم نـ parse
            // 3. Object (نادر) ← نحوّله لـ array من القيم
            let cells = [];
            if(Array.isArray(row)){
              cells = row;
            } else if(typeof row === 'string'){
              try{ 
                const parsed = JSON.parse(row); 
                cells = Array.isArray(parsed) ? parsed : [parsed]; 
              } catch{ 
                cells = [row]; 
              }
            } else if(row && typeof row === 'object'){
              cells = Object.values(row);
            } else {
              cells = [row];
            }
            
            return `<tr style="border-bottom:1px solid var(--border)">
              ${cells.map((cell, i) => {
                const col = columns[i];
                let displayVal = cell;
                if(col && col.dataType){
                  if(col.dataType === 'Money' || col.dataType === 'NUMBER' || col.dataType === 'Decimal'){
                    const num = parseFloat(cell);
                    if(!isNaN(num)) displayVal = num.toLocaleString('ar-EG', {maximumFractionDigits: 2});
                  } else if(col.dataType === 'DateTime' || col.dataType === 'Date'){
                    if(cell){
                      try{
                        const dt = new Date(cell);
                        if(!isNaN(dt.getTime())){
                          displayVal = dt.toLocaleDateString('ar-EG', {day:'numeric', month:'short', year:'numeric'});
                        }
                      }catch(e){}
                    }
                  }
                }
                return `<td style="padding:8px 10px">${escapeHtml(String(displayVal != null ? displayVal : '—'))}</td>`;
              }).join('')}
            </tr>`;
          }).join('')}
        </tbody>
      </table>
    </div>
    <div style="margin-top:10px;display:flex;justify-content:space-between;align-items:center;font-size:11px;color:var(--muted)">
      <div>📊 ${rows.length} صف</div>
      <button class="btn btn-ghost btn-xs" onclick="downloadShopifyReportCSV('${_shopifyReportsState.currentReport}')">⬇️ تحميل CSV</button>
    </div>
  `;
  
  container.innerHTML = html;
}

function renderSalesReport(data, container){
  // ملخص علوي + جدول
  const tableData = data.tableData;
  if(!tableData || !tableData.rows || !tableData.rows.length){
    container.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)">📭 مفيش مبيعات في الفترة دي</div>';
    return;
  }
  
  // احسب الإجماليات
  const columns = tableData.columns || [];
  const rawRows = tableData.rows || [];
  
  // 🔧 v233: parse الـ rows لو كانوا strings
  const rows = rawRows.map(row => {
    if(Array.isArray(row)) return row;
    if(typeof row === 'string'){
      try{ const p = JSON.parse(row); return Array.isArray(p) ? p : [p]; }
      catch{ return [row]; }
    }
    if(row && typeof row === 'object') return Object.values(row);
    return [row];
  });
  
  // ابحث عن أعمدة مهمة
  const totalSalesIdx = columns.findIndex(c => c.name === 'total_sales' || c.name === 'totalSales');
  const ordersIdx = columns.findIndex(c => c.name === 'orders');
  
  let totalSalesSum = 0, ordersSum = 0;
  if(totalSalesIdx >= 0){
    rows.forEach(row => {
      const v = parseFloat(row[totalSalesIdx]);
      if(!isNaN(v)) totalSalesSum += v;
    });
  }
  if(ordersIdx >= 0){
    rows.forEach(row => {
      const v = parseFloat(row[ordersIdx]);
      if(!isNaN(v)) ordersSum += v;
    });
  }
  
  container.innerHTML = `
    <div class="stats-row" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr));margin-bottom:14px">
      <div class="sc green">
        <div class="sc-icon">💰</div>
