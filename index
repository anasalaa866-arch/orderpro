  const stkMode = document.querySelector('input[name="stk-mode"]:checked')?.value || 'partial';
  
  const payload = {
    name,
    description,
    warehouseId,
    stkMode: stkMode === 'random' || stkMode === 'template' ? 'partial' : stkMode,
    showSystemQty: document.getElementById('new-stk-show-system')?.checked === true
  };
  
  if(_stkTplSaveType === 'fixed_products'){
