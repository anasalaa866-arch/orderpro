// Helper: retry الطلبات اللي فاتت
async function _retryMissingPrints(orderIds){
  if(!orderIds.length) return;
  if(!confirm(`هل تريد طباعة ${orderIds.length} طلب اللي فاتوا؟`)) return;
  
  toast(`⏳ جاري تحضير ${orderIds.length} فاتورة...`);
  
  try {
    const sessionId = 'retry-' + Date.now();
    const r = await apiFetch('/api/invoices/batch-html','POST',{ orderIds, sessionId });
    if(!r || !r.invoices){
      toast('❌ فشل التحضير');
      return;
    }
    
    const pages = [];
    r.invoices.forEach(inv => {
      if(inv.html){
        const bodyMatch = inv.html.match(/<body[^>]*>([\s\S]*)<\/body>/i);
        pages.push(bodyMatch ? bodyMatch[1] : inv.html);
      }
    });
    
    if(!pages.length){
      toast('❌ مفيش فواتير جاهزة');
      return;
    }
    
    // افتح نافذة طباعة بسيطة
    const w = window.open('','_blank','width=900,height=1000');
    w.document.write(`<!DOCTYPE html><html lang="en"><head>
      <meta charset="UTF-8"><title>Retry Print - ${pages.length} orders</title>
      <style>
        body{font-family:Cairo,sans-serif;margin:0;padding:0;color:#000}
        .page{page-break-after:always;padding:0;position:relative}
        .page:last-child{page-break-after:auto}
        @page{size:A4;margin:8mm}
        @media print{ .no-print{display:none!important} }
      </style>
    </head><body>
      ${pages.map(p => `<div class="page">${p}</div>`).join('')}
      <script>
        window.addEventListener('load', () => setTimeout(() => window.print(), 500));
      <\/script>
    </body></html>`);
    w.document.close();
    
    // سجل الطباعة لكل طلب
    orderIds.forEach(id => _logPrintAction(id, 'invoice'));
    
    toast(`✅ تم تحضير ${pages.length} فاتورة`);
  } catch(e){
    toast('❌ ' + e.message);
  }
}

// 🆕 v379: prefetch كل صور الفواتير قبل الطباعة + حولها لـ blob URLs
// المشكلة: الـ batches الكبيرة (118+ طلب = 200+ صورة) → Shopify CDN rate-limit
// الحل: نحمّل الصور بـ concurrency محدودة (10 في وقت واحد)، نحطها في cache
//       نحول الـ image src في الـ HTML pages لـ blob URLs محلية
// النتيجة: نافذة الطباعة ما بـ تحتاج شبكة، الصور دايماً تظهر
async function _prefetchBatchImages(allPagesArr){
  // اجمع كل الـ image URLs الفريدة من كل الصفحات
  const allUrls = new Set();
  const urlRegex = /<img\s[^>]*src="([^"]+)"/gi;
  for(const page of allPagesArr){
    if(typeof page !== 'string') continue;
    let m;
    while((m = urlRegex.exec(page)) !== null){
      const url = m[1];
      // ما نـ prefetch ش data: URLs (already inline) أو blob: URLs
      if(url.startsWith('http://') || url.startsWith('https://') || url.startsWith('//')){
        allUrls.add(url);
      }
    }
  }
  
  const total = allUrls.size;
  if(total === 0){
    console.log('[v379] no remote images to prefetch');
    return;
  }
  
  console.log(`[v379] prefetching ${total} unique images`);
  
  // overlay للـ progress
  const ov = document.createElement('div');
  ov.id = 'img-prefetch-overlay';
  ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:99999;display:flex;align-items:center;justify-content:center;padding:20px';
  ov.innerHTML = `
    <div style="background:var(--bg);border-radius:14px;padding:30px;max-width:480px;width:100%;text-align:center;border:1px solid var(--border)">
      <div style="font-size:48px;margin-bottom:12px">🖼️</div>
      <div style="font-weight:800;font-size:16px;margin-bottom:6px">جاري تحميل الصور...</div>
      <div style="font-size:12px;color:var(--muted);margin-bottom:14px">عشان الطباعة تطلع نظيفة بدون رموز فاضية</div>
      <div style="background:var(--elev);border-radius:99px;height:20px;overflow:hidden;border:1px solid var(--border)">
        <div id="img-prog-bar" style="height:100%;background:linear-gradient(90deg,var(--accent),var(--gold));width:0%;transition:width .2s"></div>
      </div>
      <div id="img-prog-text" style="margin-top:10px;font-size:13px;font-weight:700">0 / ${total}</div>
      <div id="img-prog-detail" style="margin-top:4px;font-size:10px;color:var(--muted)"></div>
    </div>
  `;
  document.body.appendChild(ov);
  
  const urlToBlob = {}; // url -> blob URL
  let done = 0;
  let failed = 0;
  const startTs = Date.now();
  
  const updateProgress = () => {
    const pct = Math.round((done / total) * 100);
    const bar = document.getElementById('img-prog-bar');
    const txt = document.getElementById('img-prog-text');
    const dtl = document.getElementById('img-prog-detail');
    if(bar) bar.style.width = pct + '%';
    if(txt) txt.textContent = `${done} / ${total} (${pct}%)`;
    if(dtl) dtl.textContent = failed > 0 ? `${failed} فشل` : '';
  };
  
  // helper - تحميل صورة واحدة بـ retry
  const fetchOne = async (url, retries = 2) => {
    for(let attempt = 0; attempt <= retries; attempt++){
      try {
        const resp = await fetch(url, { mode: 'cors', cache: 'force-cache' });
        if(!resp.ok) throw new Error('HTTP ' + resp.status);
        const blob = await resp.blob();
        // ما نحفظ ش حاجة أكبر من 2MB (احتياط)
        if(blob.size > 2 * 1024 * 1024){
          console.warn('[v379] image too large, skipping:', url, blob.size);
          return null;
        }
        return URL.createObjectURL(blob);
      } catch(e){
        if(attempt === retries){
          console.warn('[v379] failed after retries:', url, e.message);
          return null;
        }
        // backoff قبل الـ retry
        await new Promise(rs => setTimeout(rs, 200 * (attempt + 1)));
      }
    }
    return null;
  };
  
  // download بـ concurrency محدودة (10 في وقت واحد)
  const urlsList = [...allUrls];
  const CONCURRENCY = 10;
  
  for(let i = 0; i < urlsList.length; i += CONCURRENCY){
    const chunk = urlsList.slice(i, i + CONCURRENCY);
    await Promise.all(chunk.map(async (url) => {
      const blobUrl = await fetchOne(url);
      if(blobUrl){
        urlToBlob[url] = blobUrl;
      } else {
        failed++;
      }
      done++;
      updateProgress();
    }));
  }
  
  const took = ((Date.now() - startTs) / 1000).toFixed(1);
  console.log(`[v379] prefetch done: ${done}/${total} in ${took}s (${failed} failed)`);
  
  // استبدل كل URLs بالـ blob URLs المحلية في الـ HTML pages
  for(let i = 0; i < allPagesArr.length; i++){
    if(typeof allPagesArr[i] !== 'string') continue;
    let html = allPagesArr[i];
    for(const [originalUrl, blobUrl] of Object.entries(urlToBlob)){
      // escape regex special chars
      const escaped = originalUrl.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      html = html.replace(new RegExp(`src="${escaped}"`, 'g'), `src="${blobUrl}"`);
    }
    allPagesArr[i] = html;
  }
  
  // اقفل الـ overlay
  ov.remove();
  
  if(failed > 0){
    toast(`⚠️ ${failed} صورة لم تحمّل — هتظهر فاضية`, 'warn');
  } else {
    toast(`✅ ${done} صورة جاهزة`, 'success');
  }
}

