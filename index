// يستخدم الـ pending PO الموجود أو ينشئ واحد جديد
async function wlAddToPO(variantId){
  // الـ implementation البسيط: روح لصفحة purchase orders بـ pre-selected variant
  // (لأن إنشاء PO فيها تفاصيل كتيرة عن supplier وغيره)
  const product = (_wlData?.products || []).find(p => String(p.variant_id) === String(variantId));
  if(!product){ toast('❌ المنتج مش موجود', 'error'); return; }
  
  // خزّن في sessionStorage عشان لما تفتح صفحة الـ PO تستخدمها
  try {
    const queue = JSON.parse(sessionStorage.getItem('_poQuickAdd') || '[]');
    if(!queue.find(q => q.variant_id === product.variant_id)){
      queue.push({
        variant_id: product.variant_id,
        product_title: product.product_title,
        sku: product.sku,
        vendor: product.vendor,
        suggested_qty: Math.ceil((parseFloat(product.avg_30d || 0) * 30) || 10) // 30 يوم تغطية
      });
      sessionStorage.setItem('_poQuickAdd', JSON.stringify(queue));
    }
    toast(`✅ "${product.product_title}" انضاف لقائمة أمر الشراء (${queue.length} منتج)\nروح لـ "أوامر الشراء" عشان تكمّل`, 'success');
  } catch(e){
    toast('⚠️ فشل الإضافة: ' + e.message, 'error');
  }
}

