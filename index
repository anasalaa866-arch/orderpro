// 🆕 v330: عرض المخزون مفصّل لكل مخزن
// mode: 'table' (compact chips) أو 'cards' (rows مع أسماء المخازن كاملة)
function wlRenderStockBreakdown(p, warehouses, mode){
  mode = mode || 'table';
  const stocks = p.stockByWarehouse || {};
  const total = p.total_stock || 0;
  
  // فلتر المخازن اللي ليها قيمة حقيقية (أو كلها لو في cards mode)
  const relevantWh = warehouses.filter(w => {
    const qty = stocks[w.id] || 0;
    return mode === 'cards' ? true : qty > 0;
  });
  
  if(!relevantWh.length){
    // مفيش مخزون في أي مخزن
    return `<div style="font-weight:800;font-size:16px;color:#ef4444">0 <span style="font-size:10px;font-weight:400">(نفد)</span></div>`;
  }
  
  if(mode === 'table'){
    // Compact: chips صغيرة
    const chips = relevantWh.map(w => {
      const qty = stocks[w.id] || 0;
      const color = qty === 0 ? '#94a3b8' : qty < 10 ? '#f59e0b' : '#22c55e';
      const bg = qty === 0 ? '#f1f5f9' : qty < 10 ? '#fef3c7' : '#dcfce7';
      // اسم المخزن مختصر (أول كلمة أو أول 8 حروف)
      const shortName = (w.name || '').split(' ')[0].substring(0, 10);
      return `<span title="${escapeHtml(w.name || '')}: ${qty} قطعة" style="display:inline-block;background:${bg};color:${color};font-size:10px;font-weight:700;padding:3px 7px;border-radius:99px;margin:1px;white-space:nowrap">${escapeHtml(shortName)}: <strong>${qty}</strong></span>`;
    }).join('');
    
    return `
      <div style="line-height:1.6">${chips}</div>
      <div style="font-size:11px;color:var(--muted);margin-top:3px;font-weight:600">المجموع: <strong style="color:${total === 0 ? '#ef4444' : 'var(--text)'};font-size:13px">${total}</strong></div>
    `;
  }
  
  // Cards mode: قائمة كاملة بأسماء المخازن
  const rows = relevantWh.map(w => {
    const qty = stocks[w.id] || 0;
    const color = qty === 0 ? '#94a3b8' : qty < 10 ? '#f59e0b' : '#22c55e';
    return `
      <div style="display:flex;justify-content:space-between;align-items:center;padding:4px 8px;background:var(--bg);border-radius:6px;font-size:11px">
        <span style="color:var(--text);font-weight:600">${w.is_pos ? '🏪' : '📦'} ${escapeHtml(w.name || '')}</span>
        <strong style="color:${color};font-size:13px">${qty}</strong>
      </div>
    `;
  }).join('');
  
  return `
    <div style="background:var(--card);border:1px solid var(--border);border-radius:8px;padding:6px;display:flex;flex-direction:column;gap:3px">
      <div style="font-size:10px;color:var(--muted);font-weight:700;padding:0 4px 2px">📍 توزيع المخزون</div>
      ${rows}
    </div>
  `;
}

// Sparkline SVG: رسم بياني صغير من 4 نقط (7d, 30d, 60d, 90d)
// 🆕 v328: بسيط ونظيف، بدون أي library
function wlRenderSparkline(p, size){
  const values = [
    parseFloat(p.avg_90d || 0),
    parseFloat(p.avg_60d || 0),
    parseFloat(p.avg_30d || 0),
    parseFloat(p.avg_7d || 0)
  ];
  const max = Math.max(...values, 0.01);
  const w = size === 'large' ? 240 : 90;
  const h = size === 'large' ? 40 : 26;
  const padding = 2;
  const stepX = (w - padding * 2) / 3;
  
  const points = values.map((v, i) => {
    const x = padding + i * stepX;
    const y = h - padding - (v / max) * (h - padding * 2);
    return { x, y, v };
  });
  
  const pathD = 'M ' + points.map(pt => `${pt.x.toFixed(1)},${pt.y.toFixed(1)}`).join(' L ');
  
  // اللون: مقارنة avg_7d بـ avg_30d
  const trend = values[3] > values[2] * 1.1 ? 'up' : values[3] < values[2] * 0.9 ? 'down' : 'stable';
  const color = trend === 'up' ? '#22c55e' : trend === 'down' ? '#ef4444' : '#64748b';
  
  const labels = ['90', '60', '30', '7'];
  const labelTags = size === 'large' ? points.map((pt, i) => `<text x="${pt.x}" y="${h - 1}" text-anchor="middle" font-size="8" fill="#94a3b8">${labels[i]}d</text>`).join('') : '';
  
  return `
    <svg width="${w}" height="${size === 'large' ? h + 12 : h}" style="overflow:visible">
      <path d="${pathD}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      ${points.map(pt => `<circle cx="${pt.x}" cy="${pt.y}" r="2.5" fill="${color}"><title>${pt.v.toFixed(2)} قطعة/يوم</title></circle>`).join('')}
      ${labelTags}
    </svg>
  `;
}

function wlPeriodLabel(key){
  const map = { avg_7d: '7 أيام', avg_30d: '30 يوم', avg_60d: '60 يوم', avg_90d: '90 يوم' };
  return map[key] || key;
}

