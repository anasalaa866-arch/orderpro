var _allSettlements = [];
var _settlementsLoaded = false;
var _currentSettleOrders = [];

async function loadSettlements(){
  if(!API_URL){ _settlementsLoaded=true; return; }
  try{
    const data = await apiFetch('/api/settlements');
    if(data && data.settlements){
      _allSettlements = data.settlements.map(s=>({
        ...s,
        orderIds: Array.isArray(s.orderIds)?s.orderIds:JSON.parse(s.orderIds||'[]'),
        ts: new Date(s.ts)
      }));
    }
  }catch(e){ console.error('loadSettlements:',e); }
  _settlementsLoaded = true;
}

function getSettledIds(cId){
  const ids = new Set();
  _allSettlements.filter(s=>String(s.courierId)===String(cId))
    .forEach(s=>(s.orderIds||[]).forEach(id=>ids.add(id)));
  return ids;
}

// يتحقق إن الطلب مسوّى (في أي settlement)
function isOrderSettled(orderId){
  if(!_allSettlements || !orderId) return false;
  for(const s of _allSettlements){
    if((s.orderIds||[]).includes(orderId)) return true;
  }
  return false;
}

// حماية: يرجع true لو المستخدم مسموح له يعدل طلب مسوّى
// الأدمن فقط يقدر يعدل (بعد تحذير). باقي المستخدمين مش يقدروا.
function canEditSettled(){
  return currentUser && currentUser.role === 'admin';
}

// تحذير قبل تعديل طلب مسوّى — يرجع true لو المستخدم أكد
function confirmEditSettledOrder(orderId){
  if(!isOrderSettled(orderId)) return true; // مش مسوّى، اعمل اللي إنت عايزه
  if(!canEditSettled()){
    toast('🔒 هذا الطلب مسوّى — لا يمكن تعديله');
    return false;
  }
  return confirm('⚠️ تحذير: هذا الطلب مسوّى بالفعل.\n\nالتعديل قد يؤثر على كشف الحساب السابق.\nهل أنت متأكد من المتابعة؟');
}

function getPendingSettleOrders(cId){
  const settled = getSettledIds(cId);
