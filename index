function openNewStocktaker(){
  document.getElementById('stk-emp-id').value = '';
  document.getElementById('stocktaker-modal-title').textContent = '👷 إضافة موظف جرد';
  ['stk-emp-name','stk-emp-phone','stk-emp-username','stk-emp-password'].forEach(id => {
    const el = document.getElementById(id); if(el) el.value = '';
  });
  openM('m-new-stocktaker');
}

function editStocktaker(id){
  const s = couriers.find(c => c.id == id);
  if(!s) return;
  document.getElementById('stk-emp-id').value = id;
  document.getElementById('stocktaker-modal-title').textContent = '✏️ تعديل موظف جرد';
  document.getElementById('stk-emp-name').value = s.name || '';
  document.getElementById('stk-emp-phone').value = s.phone || '';
  document.getElementById('stk-emp-username').value = s.username || '';
  document.getElementById('stk-emp-password').value = ''; // ما نظهرش الباسورد
  openM('m-new-stocktaker');
}

async function saveStocktaker(){
  const id = document.getElementById('stk-emp-id').value;
  const name = document.getElementById('stk-emp-name').value.trim();
  const phone = document.getElementById('stk-emp-phone').value.trim();
  const username = document.getElementById('stk-emp-username').value.trim().toLowerCase();
  const password = document.getElementById('stk-emp-password').value.trim();
  
  if(!name){ toast('❌ الاسم مطلوب'); return; }
  if(!username){ toast('❌ اسم المستخدم مطلوب'); return; }
  if(!id && !password){ toast('❌ كلمة المرور مطلوبة'); return; }
  if(password && password.length < 4){ toast('❌ كلمة المرور على الأقل 4 حروف'); return; }
  
  try{
    if(id){
      // تعديل
      const updates = { name, phone, role: 'stocktaker' };
      await apiFetch('/api/couriers/' + id, 'PATCH', updates);
      
      // حدّث الـ Stars credentials
      if(username || password){
        const credPayload = { username };
        if(password) credPayload.password = password;
        await apiFetch('/api/couriers/' + id + '/stars-credentials', 'POST', credPayload);
      }
      
      // local update
      const c = couriers.find(c => c.id == id);
      if(c){ c.name = name; c.phone = phone; c.role = 'stocktaker'; c.username = username; }
      
      toast('✅ تم التحديث');
    } else {
      // جديد
      const r = await apiFetch('/api/couriers', 'POST', {
        name, phone, zone: 'الجرد', vehicle: '—', ship: 0,
        role: 'stocktaker', status: 'نشط'
      });
      
      const newCourier = r?.courier || r;
      if(newCourier?.id){
        // اعمل Stars credentials
        await apiFetch('/api/couriers/' + newCourier.id + '/stars-credentials', 'POST', {
          username, password
        });
        
        couriers.push({...newCourier, role: 'stocktaker', username});
        toast('✅ تم الإضافة');
      }
    }
    
    closeM('m-new-stocktaker');
    renderStocktakersList();
    if(typeof renderCouriers === 'function') renderCouriers();
  }catch(e){
    toast('❌ ' + e.message);
  }
}

async function deleteStocktaker(id){
  const s = couriers.find(c => c.id == id);
  if(!s) return;
  if(!confirm(`حذف موظف الجرد "${s.name}"؟\n\nده هيمنعه من دخول Stars.`)) return;
  
  try{
    await apiFetch('/api/couriers/' + id, 'DELETE');
    couriers = couriers.filter(c => c.id != id);
    saveCouriers && saveCouriers();
    renderStocktakersList();
    if(typeof renderCouriers === 'function') renderCouriers();
    toast('✅ تم الحذف');
  }catch(e){
    toast('❌ ' + e.message);
  }
}

// ============================================================
