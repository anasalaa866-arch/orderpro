function applyAISuggestions(criticalOnly = false){
  if(!_aiAnalysis?.suggestions) return;
  
  let count = 0;
  _reorderProducts.forEach(p => {
    if(p.ai_suggested_qty != null){
      if(criticalOnly){
        if(p.ai_priority === 'critical' || p.ai_priority === 'urgent'){
          p.requested_qty = p.ai_suggested_qty;
          if(p.ai_suggested_qty > 0) count++;
        } else {
          p.requested_qty = 0;
        }
      } else {
        p.requested_qty = p.ai_suggested_qty;
        if(p.ai_suggested_qty > 0) count++;
      }
    }
  });
  
  renderReorderTable();
  updateReorderTotals();
  toast(`✅ تم تطبيق ${count} اقتراح`, 'success');
}

