// ===== Change courier role (courier/preparer/shop/stocktaker/cashier) =====
async function changeCourierRole(courierId){
  const c = couriers.find(x => x.id == courierId);
  if(!c){ toast('❗ المندوب غير موجود'); return; }
  const current = c.role || 'courier';
  const labels = { courier: 'مندوب', preparer: 'محضر', shop: 'محل', stocktaker: 'جرد', cashier: 'كاشير', store_manager: 'مدير محل' };
  const currentLabel = labels[current] || 'مندوب';
  const opts = `الدور الحالي: ${currentLabel}\n\n` +
               `اختر الدور الجديد:\n` +
               `1 = مندوب توصيل\n` +
               `2 = موظف تحضير (باركود)\n` +
               `3 = موظف محل (Pickup)\n` +
               `4 = موظف جرد (Stocktaker)\n` +
               `5 = كاشير POS\n` +
               `6 = مدير محل (Store Manager)`;
  const defaultChoice = current === 'preparer' ? '2' : current === 'shop' ? '3' : current === 'stocktaker' ? '4' : current === 'cashier' ? '5' : current === 'store_manager' ? '6' : '1';
  const choice = prompt(opts, defaultChoice);
  if(choice === null) return;
  const roleMap = { '1': 'courier', '2': 'preparer', '3': 'shop', '4': 'stocktaker', '5': 'cashier', '6': 'store_manager' };
  const newRole = roleMap[choice.trim()];
  if(!newRole){ toast('❌ اختيار غير صحيح'); return; }
  try{
    const r = await apiFetch('/api/couriers/'+courierId, 'PATCH', { role: newRole });
    if(r && r.courier){
      c.role = newRole;
      saveCouriers();
      renderCouriers();
      toast('✅ تم تغيير الدور إلى: ' + (labels[newRole] || newRole));
      
      // 🆕 v262: لو cashier أو store_manager، اطلب اختيار المحل
      if(newRole === 'cashier' || newRole === 'store_manager'){
        setTimeout(() => assignCourierToStore(courierId), 300);
      }
    } else {
      toast('❌ فشل التحديث');
    }
  }catch(e){
    toast('❌ خطأ: ' + e.message);
  }
}

// 🆕 v262: ربط الكاشير/المدير بمحل
async function assignCourierToStore(courierId){
  const c = couriers.find(x => x.id == courierId);
  if(!c) return;
  
  try {
    const r = await apiFetch('/api/pos/stores');
    const stores = r?.stores || [];
    
    if(!stores.length){
      toast('⚠️ لازم تنشئ محل أولاً');
      return;
    }
    
    const opts = `اختار المحل:\n\n` + stores.map((s, i) => `${i+1} = ${s.name}`).join('\n') + '\n\n0 = بدون محل';
    const choice = prompt(opts, '1');
    if(choice === null) return;
    
    let storeId = null;
    const idx = parseInt(choice.trim());
    if(idx > 0 && idx <= stores.length){
      storeId = stores[idx-1].id;
    } else if(idx !== 0){
      toast('❌ اختيار غير صحيح');
      return;
    }
    
    await apiFetch('/api/couriers/' + courierId, 'PATCH', { storeId });
    toast(`✅ تم الربط بـ ${storeId ? stores.find(s => s.id === storeId)?.name : 'بدون محل'}`);
    
    // لو store_manager، حدّث الـ store ليكون هو المدير
    if(c.role === 'store_manager' && storeId){
      try {
        await apiFetch('/api/pos/stores/' + storeId, 'PUT', { managerId: courierId });
        toast('✅ تم تعيينه كمدير المحل');
        
        // 🛡️ v264: لو store_manager، اطلب PIN
        if(c.role === 'store_manager'){
          setTimeout(() => setManagerPin(courierId), 500);
        }
      } catch(e){}
    }
  } catch(e) {
    toast('❌ ' + e.message);
  }
}

