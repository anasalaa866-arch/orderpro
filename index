// ============================================================
// 🧠 v388: TRANSFER PLAN (ذكاء التحويلات — على مستوى الصفحة)
// ============================================================
// الـ user يختار مخزن مصدر + وجهة، يضغط "حلّل"، فيظهر جدول
// بكل المنتجات اللي الوجهة محتاجاها والمصدر عنده منها فائض.
// يختار اللي عايزه (checkbox)، يعدّل الكميات، وينشئ تحويل واحد مجمّع.
let _tpData = null;        // { from, to, plan[], stats }
let _tpSelected = {};      // { variant_id: qty }  — المنتجات المحددة وكمياتها
let _tpWarehouses = [];    // قائمة المخازن للـ dropdowns

function tpToggleSettings(){
  const p = document.getElementById('tp-settings-panel');
  if(p) p.style.display = (p.style.display === 'none' ? 'block' : 'none');
}

// تحميل المخازن في الـ dropdowns (أول مرة)
async function tpLoadWarehouses(){
  if(_tpWarehouses.length) return;
  try {
    const r = await apiFetch('/api/inventory/warehouses');
    _tpWarehouses = r || [];
  } catch(e){
    toast('❌ فشل تحميل المخازن: ' + e.message);
    return;
  }
  const opts = '<option value="">— اختر المخزن —</option>' +
    _tpWarehouses.map(w => {
      const icon = w.is_pos ? '🏪' : '📦';
      const master = w.is_master ? ' ⭐' : '';
      return `<option value="${w.id}">${icon} ${escapeHtml(w.name)}${master}</option>`;
    }).join('');
  const fromSel = document.getElementById('tp-from');
  const toSel = document.getElementById('tp-to');
  if(fromSel) fromSel.innerHTML = opts;
  if(toSel) toSel.innerHTML = opts;
}

function tpSwap(){
  const fromSel = document.getElementById('tp-from');
  const toSel = document.getElementById('tp-to');
  if(!fromSel || !toSel) return;
  const tmp = fromSel.value;
  fromSel.value = toSel.value;
  toSel.value = tmp;
  tpOnWhChange();
}

function tpOnWhChange(){
  // لو المصدر = الوجهة، نبّه
  const from = document.getElementById('tp-from')?.value;
  const to = document.getElementById('tp-to')?.value;
  const btn = document.getElementById('tp-analyze-btn');
  if(btn){
    const valid = from && to && from !== to;
    btn.disabled = !valid;
    btn.style.opacity = valid ? '1' : '0.5';
    btn.style.cursor = valid ? 'pointer' : 'not-allowed';
  }
}

async function tpAnalyze(){
  const from = document.getElementById('tp-from')?.value;
  const to = document.getElementById('tp-to')?.value;
  if(!from || !to){ toast('⚠️ اختر المخزن المصدر والوجهة'); return; }
  if(from === to){ toast('⚠️ المصدر والوجهة لازم يكونوا مختلفين'); return; }

  const days = parseInt(document.getElementById('tp-days')?.value) || 14;
  const target = parseInt(document.getElementById('tp-target')?.value) || 14;
  const critical = parseInt(document.getElementById('tp-critical')?.value) || 7;
  const includeAll = document.getElementById('tp-include-all')?.checked || false;

  const results = document.getElementById('tp-results');
  results.innerHTML = `
    <div style="text-align:center;padding:40px;color:var(--muted)">
      <div style="font-size:32px;animation:spin 1s linear infinite">⏳</div>
      <div style="margin-top:8px;font-weight:700">جاري تحليل المبيعات والمخزون...</div>
    </div>`;

  try {
    const params = new URLSearchParams({
      fromWarehouseId: from,
      toWarehouseId: to,
      days, targetCoverage: target, criticalThreshold: critical,
      includeAll: includeAll ? 'true' : 'false'
    });
    const r = await apiFetch('/api/transfer-plan?' + params.toString());
    _tpData = r;
    _tpSelected = {};

    // افتراضياً: حدد كل اللي محتاج تحويل وعنده مصدر كافي
    (r.plan || []).forEach(p => {
      if(p.to_needs && p.suggested_qty > 0){
        _tpSelected[p.variant_id] = p.suggested_qty;
      }
    });

    tpUpdateStats();
    tpRender();
  } catch(e){
    results.innerHTML = `
      <div style="text-align:center;padding:30px">
        <div style="font-size:36px;color:#ef4444">❌</div>
        <div style="font-weight:700;color:#ef4444;margin-top:8px">فشل التحليل</div>
        <div style="font-size:12px;color:var(--muted);margin-top:6px">${escapeHtml(e.message)}</div>
      </div>`;
  }
}

function tpUpdateStats(){
  if(!_tpData) return;
  const s = _tpData.stats || {};
  document.getElementById('tp-stats').style.display = 'grid';
  document.getElementById('tp-toolbar').style.display = 'block';
  document.getElementById('tp-stat-needs').textContent = s.needs_transfer || 0;
  document.getElementById('tp-stat-qty').textContent = (s.total_suggested_qty || 0).toLocaleString('ar-EG');
  document.getElementById('tp-stat-insufficient').textContent = s.insufficient_source || 0;
  tpUpdateSelectionUI();
}

function tpUpdateSelectionUI(){
  const ids = Object.keys(_tpSelected).filter(k => (_tpSelected[k] || 0) > 0);
  const count = ids.length;
  const totalQty = ids.reduce((sum, k) => sum + (_tpSelected[k] || 0), 0);
  const selStat = document.getElementById('tp-stat-selected');
  if(selStat) selStat.textContent = count;

  const bar = document.getElementById('tp-action-bar');
  const summary = document.getElementById('tp-bar-summary');
  if(bar && _tpData){
    if(count > 0){
      bar.style.display = 'block';
      summary.innerHTML = `📤 <strong>${escapeHtml(_tpData.from.warehouse_name)}</strong> → 📥 <strong>${escapeHtml(_tpData.to.warehouse_name)}</strong> · ${count} منتج · ${totalQty.toLocaleString('ar-EG')} قطعة`;
    } else {
      bar.style.display = 'none';
    }
  }
}

function tpToggleProduct(variantId, suggestedQty){
  if(_tpSelected[variantId] != null){
    delete _tpSelected[variantId];
  } else {
    _tpSelected[variantId] = suggestedQty || 1;
  }
  tpRender();
}

function tpSetQty(variantId, val){
  const q = Math.max(0, parseInt(val) || 0);
  if(q === 0){
    delete _tpSelected[variantId];
  } else {
    _tpSelected[variantId] = q;
  }
  tpUpdateSelectionUI();
  // حدّث الـ preview لهذا الصف فقط
  tpUpdateRowPreview(variantId);
}

function tpQtyStep(variantId, delta){
  const inp = document.getElementById('tp-qty-' + variantId);
  if(!inp) return;
  let v = Math.max(0, (parseInt(inp.value) || 0) + delta);
  inp.value = v;
  tpSetQty(variantId, v);
  // حدّث حالة الـ checkbox
  const cb = document.getElementById('tp-cb-' + variantId);
  if(cb) cb.checked = v > 0;
}

function tpSelectAll(select){
  if(!_tpData) return;
  let visible = tpVisiblePlan();
  visible.forEach(p => {
    if(select){
      // حدد بالكمية المقترحة (أو 1 لو صفر)
      _tpSelected[p.variant_id] = p.suggested_qty > 0 ? p.suggested_qty : Math.max(1, p.needed_qty);
    } else {
      delete _tpSelected[p.variant_id];
    }
  });
  tpRender();
}

function tpVisiblePlan(){
  if(!_tpData) return [];
  let plan = _tpData.plan || [];
  const search = (document.getElementById('tp-search')?.value || '').trim().toLowerCase();
  if(search){
    plan = plan.filter(p =>
      (p.product_title || '').toLowerCase().includes(search) ||
      (p.sku || '').toLowerCase().includes(search) ||
      (p.barcode || '').toLowerCase().includes(search)
    );
  }
  return plan;
}

function tpUpdateRowPreview(variantId){
  if(!_tpData) return;
  const p = (_tpData.plan || []).find(x => x.variant_id === variantId);
  if(!p) return;
  const box = document.getElementById('tp-preview-' + variantId);
  if(!box) return;
  box.innerHTML = tpRowPreviewHtml(p, _tpSelected[variantId] || 0);
}

// HTML الـ preview لصف واحد (رصيد المصدر/الوجهة بعد التحويل)
function tpRowPreviewHtml(p, qty){
  const fromAfter = p.from_stock - qty;
  const toAfter = p.to_stock + qty;
  const fromDaysAfter = p.from_velocity > 0 ? (fromAfter / p.from_velocity).toFixed(1) + 'ي' : '∞';
  const toDaysAfter = p.to_velocity > 0 ? (toAfter / p.to_velocity).toFixed(1) + 'ي' : '∞';
  let warn = '';
  if(qty > p.from_stock){
    warn = `<span style="color:#ef4444;font-weight:700">⛔ أكبر من رصيد المصدر</span>`;
  } else if(qty > p.from_can_spare && qty > 0){
    warn = `<span style="color:#f59e0b;font-weight:700">⚠️ هينزل المصدر تحت الحد الآمن</span>`;
  }
  if(qty <= 0) return `<span style="color:var(--muted)">—</span>`;
  return `
    <span style="font-size:11px">
      📤 ${p.from_stock}→<strong style="color:${fromAfter<0?'#ef4444':'inherit'}">${fromAfter}</strong> (${fromDaysAfter})
      &nbsp;·&nbsp;
      📥 ${p.to_stock}→<strong style="color:#065f46">${toAfter}</strong> (${toDaysAfter})
      ${warn ? '<br>'+warn : ''}
    </span>`;
}

function tpRender(){
  const results = document.getElementById('tp-results');
  if(!results || !_tpData) return;

  const plan = tpVisiblePlan();
  tpUpdateSelectionUI();

  if(!plan.length){
    const allEmpty = !(_tpData.plan || []).length;
    results.innerHTML = `
      <div style="text-align:center;padding:50px;color:var(--muted)">
        <div style="font-size:48px;opacity:.4">${allEmpty ? '✅' : '🔍'}</div>
        <div style="font-weight:700;margin-top:10px">${allEmpty ? 'مفيش منتجات محتاجة تحويل' : 'مفيش نتائج للبحث'}</div>
        <div style="font-size:12px;margin-top:4px">${allEmpty ? `المخزون متوازن بين ${escapeHtml(_tpData.from.warehouse_name)} و ${escapeHtml(_tpData.to.warehouse_name)}` : 'جرّب كلمة بحث تانية'}</div>
      </div>`;
    return;
  }

  const statusInfo = st =>
    st === 'critical' ? {c:'#ef4444', t:'🔴 حرج'} :
    st === 'low' ? {c:'#f59e0b', t:'🟠 منخفض'} :
    st === 'excess' ? {c:'#10b981', t:'🟢 فائض'} :
    st === 'ok' ? {c:'#3b82f6', t:'🔵 طبيعي'} : {c:'#6b7280', t:'⚪ خامل'};

  const fmtDays = d => d === null ? '∞' : d + 'ي';

  const rows = plan.map(p => {
    const isSelected = _tpSelected[p.variant_id] != null;
    const qty = _tpSelected[p.variant_id] || 0;
    const si = statusInfo(p.to_status);
    const insufficientBadge = (p.to_needs && !p.has_enough_source)
      ? `<span style="background:#fef3c7;color:#92400e;padding:1px 6px;border-radius:4px;font-size:9px;font-weight:700;margin-right:4px">⚠️ المصدر مش كفاية</span>` : '';

    return `
      <div class="tp-row" style="display:grid;grid-template-columns:30px 1fr 90px 90px 120px 1fr;gap:10px;align-items:center;padding:10px 12px;border-bottom:1px solid var(--border);background:${isSelected?'#f0f9ff':'transparent'}">
        <div style="text-align:center">
          <input type="checkbox" id="tp-cb-${p.variant_id}" ${isSelected?'checked':''}
                 onchange="tpToggleProduct('${p.variant_id}', ${p.suggested_qty > 0 ? p.suggested_qty : Math.max(1,p.needed_qty)})"
                 style="width:17px;height:17px;cursor:pointer">
        </div>
        <div style="min-width:0">
          <div style="font-weight:700;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escapeHtml(p.product_title)}${p.variant_title ? ' - '+escapeHtml(p.variant_title) : ''}</div>
          <div style="font-size:10px;color:var(--muted);font-family:monospace">${p.sku ? escapeHtml(p.sku) : ''}</div>
          <div style="margin-top:2px">${insufficientBadge}<span style="font-size:10px;color:${si.c};font-weight:700">${si.t}</span></div>
        </div>
        <div style="text-align:center">
          <div style="font-size:10px;color:var(--muted)">📤 المصدر</div>
          <div style="font-weight:800">${p.from_stock}</div>
          <div style="font-size:10px;color:var(--muted)">${fmtDays(p.from_days_left)} · يبعت ${p.from_can_spare}</div>
        </div>
        <div style="text-align:center">
          <div style="font-size:10px;color:var(--muted)">📥 الوجهة</div>
          <div style="font-weight:800;color:${si.c}">${p.to_stock}</div>
          <div style="font-size:10px;color:var(--muted)">${fmtDays(p.to_days_left)} · محتاج ${p.needed_qty}</div>
