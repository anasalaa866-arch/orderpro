async function markAllSystemQty(){
  if(!confirm(`ملأ كل الكميات الفعلية = كميات النظام؟\n\n(للمنتجات اللي ما عُدّتش بعد)`)) return;
  
  const uncounted = _stkCurrentItems.filter(i => i.counted_qty == null);
  if(!uncounted.length){ toast('⚠️ كله معدود'); return; }
  
  toast(`🔄 جاري تحديث ${uncounted.length} منتج...`);
  
  let done = 0;
  for(const item of uncounted){
    try {
      await apiFetch('/api/stocktake/items/' + item.id, 'PUT', {countedQty: item.system_qty});
      item.counted_qty = item.system_qty;
      done++;
    } catch(e) {}
  }
  
  toast(`✅ تم تحديث ${done} منتج`);
  renderStocktakeDetail();
}

