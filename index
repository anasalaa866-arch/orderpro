async function doBatchPrint(){
  const selected = [...document.querySelectorAll('.batch-chk:checked')].map(c=>c.value);
  if(!selected.length){ toast('❗ اختر دفعة واحدة على الأقل'); return; }

  const optSummary = document.getElementById('opt-summary').checked;
  const optDivider = document.getElementById('opt-divider').checked;
  const optBosta = document.getElementById('opt-bosta').checked;
  const optSkipUnassigned = document.getElementById('opt-skip-unassigned')?.checked ?? true;

  document.getElementById('batch-print-popup').remove();

  // اجمع كل الطلبات المطلوبة
  const allPages = []; // مصفوفة صفحات HTML
  const allOrderIds = []; // كل الـ IDs اللي هنطبعها (عشان نعمل pre-cache)

  // البداية: جمّع الـ groups والترتيب
  const batchesData = []; // [{batchCode, sortedKeys, groups, ordered: [...orders]}]
  let totalUnassignedSkipped = 0;
  // 🆕 v305: counter per-courier للـ verification
  const finalCounter = {}; // { courierName: count }

  for(const batchCode of selected){
    const batchOrders = orders.filter(o=>o.batchCode===batchCode);
    if(!batchOrders.length) continue;

    const groups = {};
    batchOrders.forEach(o=>{
      // 🆕 v305: استبعاد طلبات غير موزعة لو الـ option شغّال
      if(optSkipUnassigned && !o.isBosta && !o.courierId){
        totalUnassignedSkipped++;
        return;
      }
      // 🆕 v305: استبعاد لو courierId موجود لكن المندوب اتمسح
      if(optSkipUnassigned && !o.isBosta && o.courierId){
        const c = couriers.find(cc=>String(cc.id)===String(o.courierId));
        if(!c){ totalUnassignedSkipped++; return; }
      }

      const key = o.isBosta ? 'bosta' : String(o.courierId||'unassigned');
      if(!groups[key]){
        const cname = o.isBosta ? 'بوسطة' : (couriers.find(c=>String(c.id)===String(o.courierId))?.name || 'غير محدد');
        groups[key] = { name: cname, express: [], normal: [], isBosta: o.isBosta };
      }
      if(isSameDay(o)) groups[key].express.push(o);
      else groups[key].normal.push(o);
    });

    if(!optBosta) delete groups['bosta'];

    const sortedKeys = Object.keys(groups).sort((a,b)=>{
      if(a==='bosta') return 1;
      if(b==='bosta') return -1;
      return groups[a].name.localeCompare(groups[b].name,'ar');
    });

    const estimatePagesCount = (o) => {
      let items = [];
      try { items = JSON.parse(o.lineItemsJson || '[]'); } catch(e) {}
      if(!items.length && o.items) items = o.items.split(',').filter(x=>x.trim());
      const count = items.length;
      if(count <= 6) return 1;
      if(count <= 15) return 2;
      return Math.ceil(count / 8);
    };
    sortedKeys.forEach(key => {
      const g = groups[key];
      g._pageInfo = {};
      [...g.express, ...g.normal].forEach(o => { g._pageInfo[o.id] = estimatePagesCount(o); });
    });

