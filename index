async function copyFromLastPO(){
  if(!_reorderSupplierId) return;
  
  try {
    // جيب آخر PO لنفس المورد
    const r = await apiFetch('/api/purchase-orders?supplierId=' + _reorderSupplierId + '&limit=10');
    const pos = (r?.orders || []).filter(po => ['sent', 'partial_received', 'received', 'closed'].includes(po.status));
    
    if(!pos.length){
      toast('❌ مفيش طلبات سابقة للمورد ده'); return;
    }
    
    const lastPO = pos[0];
    
    if(!confirm(`نسخ الكميات من آخر طلب: ${lastPO.po_number}\n(${new Date(lastPO.order_date).toLocaleDateString('ar-EG')} - ${parseFloat(lastPO.total).toFixed(0)} ج)\n\nهيتم استبدال الكميات الحالية. متأكد؟`)) return;
    
    // جيب items
    const detailR = await apiFetch('/api/purchase-orders/' + lastPO.id);
    const lastItems = detailR?.items || [];
    
    if(!lastItems.length){
      toast('❌ الطلب السابق فاضي'); return;
    }
    
    // ابني map من variant_id → qty
    const itemMap = {};
    lastItems.forEach(it => {
      if(it.variant_id) itemMap[it.variant_id] = { qty: it.ordered_qty, cost: parseFloat(it.unit_cost) };
    });
    
    // طبّق على القائمة الحالية
    let count = 0;
    _reorderProducts.forEach(p => {
      const last = itemMap[p.variant_id];
      if(last){
        p.requested_qty = last.qty;
        if(last.cost > 0) p.unit_cost = last.cost;
        count++;
      }
    });
    
    renderReorderTable();
    updateReorderTotals();
    toast(`✅ تم نسخ ${count} منتج من الطلب السابق`, 'success');
  } catch(e) { toast('❌ ' + e.message); }
}

