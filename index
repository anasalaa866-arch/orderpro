function updateCoBulk(cId){
  const chks=[...document.querySelectorAll(`.co-chk[data-cid="${cId}"]:checked`)];
  const bar=document.getElementById('co-bulk-bar-'+cId);
  const cnt=document.getElementById('co-bulk-count-'+cId);
  if(bar){bar.style.display=chks.length?'flex':'none';}
  if(cnt)cnt.textContent=chks.length+' طلب محدد';
}
function coToggleAll(val,cId){
  document.querySelectorAll(`.co-chk[data-cid="${cId}"]`).forEach(c=>c.checked=val);
  updateCoBulk(cId);
}
function coDeselectAll(cId){
  document.querySelectorAll(`.co-chk[data-cid="${cId}"]`).forEach(c=>c.checked=false);
  updateCoBulk(cId);
}
async function coBulkReassign(cId){
  const ids=[...document.querySelectorAll(`.co-chk[data-cid="${cId}"]:checked`)].map(c=>c.value);
  if(!ids.length){toast('❗ اختر طلبات أولاً');return;}
  const html=`<div style="padding:12px">
    <div style="font-weight:700;margin-bottom:12px">تعيين ${ids.length} طلب لـ:</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">
      ${couriers.filter(c=>c.id!=cId).map(c=>`
        <button class="btn btn-ghost btn-sm" style="justify-content:flex-start" onclick="doCoBulkReassign('${ids.join(',')}',${c.id});closeM('m-co-reassign')">
          ${c.name}
        </button>`).join('')}
      <button class="btn btn-ghost btn-sm" style="justify-content:flex-start" onclick="doCoBulkReassign('${ids.join(',')}','bosta');closeM('m-co-reassign')">
        🚚 بوسطة
      </button>
    </div>
  </div>`;
  let modal=document.getElementById('m-co-reassign');
  if(!modal){
    modal=document.createElement('div');
    modal.id='m-co-reassign';
    modal.className='overlay';
    modal.innerHTML=`<div class="modal" style="width:400px"><div class="mhd"><h3>🔄 إعادة تعيين</h3><button class="xbtn" onclick="closeM('m-co-reassign')">✕</button></div><div class="mbody" id="m-co-reassign-body"></div></div>`;
    document.body.appendChild(modal);
  }
  document.getElementById('m-co-reassign-body').innerHTML=html;
