function saveChk(){
  const num=($('chk-num-sel')?.value)||($('chk-num')?.value?.trim())||'';
  // 🆕 v194: لازم اختيار من الـ dropdown — مفيش إدخال يدوي
  const payee=$('chk-payee-sel')?.value?.trim()||'';
  const amount=parseFloat($('chk-amount').value),date=$('chk-date').value;
  if(!num){toast('❗ اختر رقم الشيك');return;}
  if(!payee){toast('❗ اختر المورد من القائمة');return;}
  if(!amount||!date){toast('❗ يرجى ملء الحقول المطلوبة');return;}
  // 🆕 v291: ما نسمحش بـ __lazy__ placeholder يـ save كصورة
  const imgToSave = (chkImgData === '__lazy__') ? '' : (chkImgData || '');
  const data={id:editingChkId||(Date.now()+'_'+Math.random().toString(36).slice(2,5)),
    num,payee,amount,date,bookId:$('chk-book-sel').value||'',
    invoice:$('chk-invoice').value.trim(),note:$('chk-note').value.trim(),
    img:imgToSave,status:editingChkId?(chkList.find(x=>x.id===editingChkId)?.status||'pending'):'pending',
    createdAt:editingChkId?(chkList.find(x=>x.id===editingChkId)?.createdAt||new Date().toISOString()):new Date().toISOString()};
  
  // 🆕 v291: لو editing وفيه صورة original في DB لكن ما اتحملش (chkImgData فاضي)
  // ما نبعتش img فاضي عشان ما نمسحش الصورة الأصلية
  const original = editingChkId ? chkList.find(x=>x.id===editingChkId) : null;
  if(editingChkId && original && original.hasImg && !imgToSave){
    delete data.img; // ما نبعتش img → الـ backend يحتفظ بالأصلية
  }
  
  if(editingChkId){const idx=chkList.findIndex(x=>x.id===editingChkId);if(idx>=0){
    chkList[idx]={...chkList[idx], ...data}; // merge عشان hasImg ما يتحذفش
  }}
  else chkList.push({...data, hasImg: !!imgToSave});
  saveChks(true);if(API_URL)apiFetch('/api/checks','POST',data).catch(()=>{});
  closeM('m-chk');chkRenderActive();toast('✅ تم حفظ الشيك');
}
async function chkMarkDone(id){
  const c=chkList.find(x=>x.id===id);if(!c)return;
  c.status='done';c.doneAt=new Date().toISOString();
  saveChks(true);
  chkRenderActive();
  // 🆕 v291: ما نبعتش "__lazy__" placeholder كـ img — هـ يدمر الصورة الأصلية
  // إعمل copy ونشيل الـ placeholder
  const payload = { ...c };
  if(payload.img === '__lazy__') delete payload.img;
  // 🔧 v298: await + غير في الـ queue لو فشل
  if(API_URL){
    try {
      const r = await apiFetch('/api/checks','POST',payload);
      if(r){
        toast('✅ تم تحديد الشيك كمصروف ومحفوظ على السيرفر');
      } else {
        // الـ apiFetch بترجع null لو فشل + بـ تـ enqueue تلقائياً
        toast('⏳ تم محلياً - هيتسجل لما النت يرجع');
        // تأكد إنها في الـ queue (في حالة الـ apiFetch مشتغلش enqueue)
        if(typeof addToOfflineQueue==='function'){
          // ما نضيفهاش لو موجودة بالفعل
          const exists = _offlineQueue?.some(it => it.path==='/api/checks' && it.body?.id===c.id);
          if(!exists) addToOfflineQueue('/api/checks','POST',payload);
        }
      }
    } catch(e) {
      toast('⚠️ ' + (e.message || 'فشل الحفظ على السيرفر - محفوظ محلياً'));
      if(typeof addToOfflineQueue==='function'){
        const exists = _offlineQueue?.some(it => it.path==='/api/checks' && it.body?.id===c.id);
        if(!exists) addToOfflineQueue('/api/checks','POST',payload);
      }
    }
  } else {
    toast('✅ تم التحديد محلياً (مفيش سيرفر)');
  }
}

