async function loadUnsyncedSales(){
  const statsEl = document.getElementById('unsynced-stats');
  const listEl = document.getElementById('unsynced-list');
  
  if(!listEl) return;
  
  listEl.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">⏳ جاري التحميل...</div>';
  
  try {
    const r = await apiFetch('/api/pos/sales/unsynced');
    const sales = r?.sales || [];
    
    // Update badge in nav
    const badge = document.getElementById('nb-unsynced');
    if(badge){
      badge.textContent = sales.length;
      badge.style.display = sales.length > 0 ? 'inline-flex' : 'none';
      if(sales.length > 0){
        badge.style.background = '#ef4444';
      }
    }
    
    // Stats
    const totalAmount = sales.reduce((s, t) => s + parseFloat(t.total || 0), 0);
    const oldestDate = sales.length ? new Date(sales[sales.length - 1].created_at) : null;
    const oldestHours = oldestDate ? Math.floor((Date.now() - oldestDate.getTime()) / (1000 * 60 * 60)) : 0;
    
    statsEl.innerHTML = `
      <div style="background:linear-gradient(135deg,#fee2e2 0%,#fff 100%);border:1px solid #ef4444;border-radius:10px;padding:14px;text-align:center">
        <div style="font-size:11px;color:var(--muted)">⚠️ بيعات فاشلة</div>
        <div style="font-size:28px;font-weight:800;color:#ef4444">${sales.length}</div>
        <div style="font-size:10px;color:var(--muted)">محتاجة مزامنة</div>
      </div>
      <div style="background:linear-gradient(135deg,#fef3c7 0%,#fff 100%);border:1px solid #fbbf24;border-radius:10px;padding:14px;text-align:center">
        <div style="font-size:11px;color:var(--muted)">💰 الإجمالي</div>
        <div style="font-size:24px;font-weight:800;color:#d97706">${totalAmount.toFixed(0)} ج</div>
        <div style="font-size:10px;color:var(--muted)">قيمة البيعات</div>
      </div>
      ${oldestDate ? `
        <div style="background:linear-gradient(135deg,#ede9fe 0%,#fff 100%);border:1px solid #7c3aed;border-radius:10px;padding:14px;text-align:center">
          <div style="font-size:11px;color:var(--muted)">⏰ أقدم بيعة</div>
          <div style="font-size:20px;font-weight:800;color:#5b21b6">${oldestHours < 24 ? oldestHours+'س' : Math.floor(oldestHours/24)+'ي'}</div>
          <div style="font-size:10px;color:var(--muted)">من ${oldestDate.toLocaleDateString('ar-EG')}</div>
        </div>
      ` : ''}
    `;
    
    // Show retry-all button if there are sales
    document.getElementById('retry-all-btn').style.display = sales.length > 0 ? 'inline-block' : 'none';
    
    if(!sales.length){
      listEl.innerHTML = `
        <div style="text-align:center;padding:40px">
          <div style="font-size:48px">✅</div>
          <div style="font-size:16px;font-weight:700;color:#22c55e;margin-top:8px">عظيم! كل البيعات متزامنة مع Shopify</div>
        </div>
      `;
      return;
    }
    
    listEl.innerHTML = sales.map(sale => {
      const date = new Date(sale.created_at).toLocaleString('ar-EG', {dateStyle:'short', timeStyle:'short'});
      const lastAttempt = sale.sync_attempted_at ? new Date(sale.sync_attempted_at).toLocaleString('ar-EG', {dateStyle:'short', timeStyle:'short'}) : 'لم تتم المحاولة';
      
      return `
        <div style="background:var(--bg);border:1px solid #ef4444;border-radius:10px;padding:12px;margin-bottom:8px">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px;margin-bottom:8px">
            <div style="flex:1;min-width:200px">
              <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                <span style="font-family:monospace;font-weight:800;font-size:14px">${escapeHtml(sale.sale_number || '-')}</span>
