function closeBatch(){
  try{
    const current = JSON.parse(localStorage.getItem('current_batch')||'null');
    if(!current){ toast('❗ مفيش دفعة مفتوحة'); return; }

    // عدد طلبات الدفعة
    const count = orders.filter(o=>o.batchCode===current.code).length;
    if(!confirm('هتقفل الدفعة '+current.code+' ('+count+' طلب)؟\nهتبدأ دفعة جديدة تلقائياً.'))return;

    current.status = 'closed';
    current.closedAt = new Date().toISOString();
    current.orderCount = count;

    // حدث الـ history
    const history = JSON.parse(localStorage.getItem('batch_history')||'[]');
    const idx = history.findIndex(b=>b.code===current.code);
    if(idx>=0) history[idx] = current;
    localStorage.setItem('batch_history', JSON.stringify(history));
    localStorage.removeItem('current_batch');

    if(API_URL) apiFetch('/api/batches/'+encodeURIComponent(current.code),'PATCH',{status:'closed',closedAt:current.closedAt,orderCount:count}).catch(()=>{});

    toast('🔒 تم إقفال الدفعة '+current.code);

    // افتح دفعة جديدة تلقائياً
    ensureCurrentBatch();
    updateBatchIndicator();
  }catch(e){ console.error('closeBatch:',e); toast('❌ خطأ: '+e.message); }
}

