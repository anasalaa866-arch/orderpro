async function confirmAssign(){
  if(!selectedCourierId){toast('❗ اختر مندوب أولاً');return}
  // خد snapshots فوراً قبل أي async
  const currentOrderId = assignOrderId;
  const currentCourierId = selectedCourierId;
  if(!currentOrderId){ toast('❗ لا يوجد طلب محدد'); return; }

  const o=orders.find(x=>x.id===currentOrderId);
  const c=couriers.find(x=>x.id==currentCourierId);
  if(!o){ toast('❗ الطلب غير موجود'); return; }

  // تحقق إن الطلب مش موزع لنفس المندوب بالفعل (حماية من double-click)
  // لو موزع لمندوب تاني، ده reassignment مسموح
  const sameBosta = String(currentCourierId)==='bosta' && o.isBosta;
  const sameCourier = o.courierId && String(o.courierId) === String(currentCourierId);
  if(o.status==='جاري التوصيل' && (sameCourier || sameBosta)){
    toast('⚠️ الطلب '+currentOrderId+' موزع لنفس المندوب بالفعل');
    closeM('m-assign');
    return;
  }

  // 🆕 v217: لو الطلب عنده orderTypeId والمندوب عنده rate، خلي الـ Backend يحدد السعر تلقائي
  // (بدون إرسال ship → الـ Backend يجيب السعر من courier_ship_rates)
  // لو الـ user عدّل الـ assign-ship يدوي، نبعت القيمة المعدّلة
  const shipInputVal = $('assign-ship').value;
  const note=$('assign-note').value;
  const isBosta = String(currentCourierId)==='bosta';
  // 🔧 v241: استخدم async batch
  const batch = await ensureCurrentBatchAsync();
  
  // 🆕 v241: validation
  if(!batch || !batch.code){
    console.error('❌ confirmAssign: batch.code is empty!', batch);
    toast('❌ خطأ: مفيش دفعة مفتوحة - حاول تاني');
    return;
  }
  
  console.log(`📦 confirmAssign: order=${currentOrderId}, courier=${currentCourierId}, batch=${batch.code}`);
  
  // فحص: لو الطلب عنده orderTypeId والمندوب موجود، نسيب الـ Backend يحدد
  // إلا لو الـ user عدّل القيمة في الـ input
  const hasOrderType = o.orderTypeId && !isBosta;
  const userEditedShip = shipInputVal !== '' && shipInputVal !== String(o.ship||defaultShip);
  
  const upd={courierId:currentCourierId, note, status:'جاري التوصيل', isBosta, batchCode:batch.code};
  
  if(hasOrderType && !userEditedShip){
    // ما نبعتش ship - الـ Backend هيحسبه من courier_ship_rates
    // (الـ getShipCost في الـ frontend هيقرأه من الـ response)
  } else {
    // النظام القديم: ابعت ship صراحةً
    upd.ship = +shipInputVal || getShipCost(o, c);
  }
  
  if(isBosta){
    bostaIds[currentOrderId]=true;
    localStorage.setItem('bosta_ids',JSON.stringify(bostaIds));
  } else if(bostaIds[currentOrderId]){
    // الطلب كان لـ bosta، دلوقتي اتعاد توزيعه — شيله من القايمة
    delete bostaIds[currentOrderId];
    localStorage.setItem('bosta_ids',JSON.stringify(bostaIds));
  }

  // snapshot للـ shopify queue
  const orderSnapshot = { ...o, ...upd };

  if(API_URL){
    const r=await apiFetch('/api/orders/'+currentOrderId,'PATCH',upd);
    if(r){
      Object.assign(o,r.order);
      // 🆕 v217: لو الـ Backend رجّع ship مختلف (auto-rate)، حدّث الـ UI
      if(r.order && r.order.ship != null) o.ship = parseFloat(r.order.ship);
    } else {
      Object.assign(o,upd);
    }
  } else {
    Object.assign(o,upd);
  }
  if(!isBosta && c) c.status='نشط';
  // Shopify fulfill للمناديب و لبوسطة — الكل بياخد fulfill + tag
  if(isBosta) shopifyFulfill(orderSnapshot, 'Bosta');
  else if(c) shopifyFulfill(orderSnapshot, c.name);
  closeM('m-assign');
  pushNotif('🚴',`تم تعيين ${c?.name||'بوسطة'}`,`الطلب ${currentOrderId} — ${o.name}`);
  refreshAll();
  updateBatchIndicator();
  toast(`✅ تم تعيين ${c?.name||'بوسطة'} — ${batch.code}`);
}

