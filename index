function exportTrackerCSV(){
  const { from, to, byNum, allNums } = _getTrackerData();
  if(!allNums.length){ toast('❗ مفيش بيانات للتصدير'); return; }

  const headers = ['رقم الطلب','الحالة','العميل','التليفون','المبلغ','المندوب','التاريخ','ملاحظات'];
  const rows = allNums.map(num => {
    const o = byNum[num];
    if(!o) return ['SH-'+num, '⛔ مفقود', '', '', '', '', '', 'مفيش طلب بالرقم ده'].map(v=>`"${v}"`).join(',');
    let courier = '';
    if(o.isBosta) courier = 'بوسطة';
    else if(o.courierId){
      const c = (typeof couriers !== 'undefined' && Array.isArray(couriers)) ? couriers.find(cc=>String(cc.id)===String(o.courierId)) : null;
      courier = c?.name || '#'+o.courierId;
    }
    const date = o.createdAt ? new Date(o.createdAt).toLocaleString('ar-EG') : '';
    return [
      o.id || '', o.status || '', o.name || '', o.phone || '',
      parseFloat(o.total||o.cod||0).toFixed(2), courier, date, ''
    ].map(v => `"${String(v).replace(/"/g,'""')}"`).join(',');
  });
  const csv = '\uFEFF' + headers.join(',') + '\n' + rows.join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `tracker-${from}-to-${to}-${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  URL.revokeObjectURL(url);
  toast('✅ تم التصدير');
}

