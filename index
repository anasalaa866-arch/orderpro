async function loadDashboardTrend(){
  const days = document.getElementById('dash-trend-days')?.value || '30';
  const chartEl = document.getElementById('dash-trend-chart');
  
  chartEl.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">⏳ جاري التحميل...</div>';
  
  try {
    const r = await apiFetch('/api/analytics/daily-trend?days=' + days);
    const trend = r.trend || [];
    
    if(!trend.length){
      chartEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)">مفيش بيانات</div>';
      return;
    }
    
    // Simple SVG chart
    const maxRevenue = Math.max(...trend.map(t => parseFloat(t.total_revenue) || 0), 1);
    const totalRevenue = trend.reduce((s, t) => s + (parseFloat(t.total_revenue) || 0), 0);
    const avgRevenue = totalRevenue / trend.length;
    const totalOrders = trend.reduce((s, t) => s + (parseInt(t.total_orders) || 0), 0);
    
    const chartWidth = 800;
    const chartHeight = 200;
    const padding = { top: 20, right: 20, bottom: 40, left: 60 };
    const innerW = chartWidth - padding.left - padding.right;
    const innerH = chartHeight - padding.top - padding.bottom;
    
    const xStep = innerW / Math.max(1, trend.length - 1);
    
    // Bars
    const bars = trend.map((t, i) => {
      const onlineH = (parseFloat(t.online_revenue) / maxRevenue) * innerH;
      const posH = (parseFloat(t.pos_revenue) / maxRevenue) * innerH;
      const totalH = onlineH + posH;
      const x = padding.left + (i * xStep) - (xStep * 0.4);
      const yPos = padding.top + innerH - posH;
      const yOnline = padding.top + innerH - totalH;
      const w = xStep * 0.7;
      
      return `
        <g>
          <rect x="${x}" y="${yPos}" width="${w}" height="${posH}" fill="#fbbf24" rx="2"/>
          <rect x="${x}" y="${yOnline}" width="${w}" height="${onlineH}" fill="#3b82f6" rx="2"/>
          <title>${new Date(t.date).toLocaleDateString('ar-EG')}: ${parseFloat(t.total_revenue).toFixed(0)} ج (${t.total_orders} طلب)</title>
        </g>
      `;
    }).join('');
    
    // X axis labels (every 5th)
    const labels = trend.map((t, i) => {
      if(i % Math.max(1, Math.floor(trend.length / 8)) !== 0 && i !== trend.length - 1) return '';
      const x = padding.left + i * xStep;
      const date = new Date(t.date);
      const label = date.getDate() + '/' + (date.getMonth() + 1);
      return `<text x="${x}" y="${chartHeight - 10}" text-anchor="middle" font-size="10" fill="var(--muted)">${label}</text>`;
    }).join('');
    
    // Y axis
    const yLabels = [0, 0.5, 1].map(p => {
      const y = padding.top + innerH - (p * innerH);
      const value = (maxRevenue * p).toFixed(0);
      return `
        <line x1="${padding.left}" y1="${y}" x2="${chartWidth - padding.right}" y2="${y}" stroke="var(--border)" stroke-dasharray="2,2"/>
        <text x="${padding.left - 5}" y="${y + 4}" text-anchor="end" font-size="10" fill="var(--muted)">${value}</text>
      `;
    }).join('');
    
    chartEl.innerHTML = `
      <div style="display:flex;gap:20px;justify-content:space-around;margin-bottom:14px;flex-wrap:wrap">
        <div style="text-align:center">
          <div style="font-size:11px;color:var(--muted)">إجمالي الإيرادات</div>
          <div style="font-size:20px;font-weight:800;color:#3b82f6">${totalRevenue.toFixed(0)} ج</div>
        </div>
        <div style="text-align:center">
          <div style="font-size:11px;color:var(--muted)">المتوسط اليومي</div>
          <div style="font-size:20px;font-weight:800;color:#22c55e">${avgRevenue.toFixed(0)} ج</div>
        </div>
        <div style="text-align:center">
          <div style="font-size:11px;color:var(--muted)">إجمالي الطلبات</div>
          <div style="font-size:20px;font-weight:800;color:#7c3aed">${totalOrders}</div>
        </div>
      </div>
      
      <div style="display:flex;gap:14px;justify-content:center;margin-bottom:10px;font-size:11px">
        <div style="display:flex;align-items:center;gap:5px"><div style="width:14px;height:14px;background:#3b82f6;border-radius:3px"></div> أونلاين</div>
        <div style="display:flex;align-items:center;gap:5px"><div style="width:14px;height:14px;background:#fbbf24;border-radius:3px"></div> POS</div>
      </div>
      
      <div style="overflow-x:auto">
        <svg viewBox="0 0 ${chartWidth} ${chartHeight}" style="width:100%;min-width:600px;height:auto">
          ${yLabels}
          ${bars}
          ${labels}
        </svg>
      </div>
    `;
  } catch(e) {
    chartEl.innerHTML = `<div style="color:var(--danger);text-align:center">❌ ${escapeHtml(e.message)}</div>`;
  }
}

