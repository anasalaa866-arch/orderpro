// 🆕 v256: state للفلتر النتيجة
let _zsResultFilter = 'all';

// 🆕 v256: helper - جيب المنتجات بعد فلتر النتيجة الحالي
function zsGetFilteredProducts(){
  const all = _zsResults?.products || [];
  if (_zsResultFilter === 'out_everywhere') {
    return all.filter(p => (p.total_stock_all_warehouses || 0) === 0);
  }
  if (_zsResultFilter === 'available_elsewhere') {
    return all.filter(p => (p.total_stock_all_warehouses || 0) > 0);
  }
  return all;
}

// 🆕 v256: حدّث counts في الـ filter chips
function zsUpdateFilterCounts(){
  const all = _zsResults?.products || [];
  const outAll = all.filter(p => (p.total_stock_all_warehouses || 0) === 0).length;
  const elsewhere = all.filter(p => (p.total_stock_all_warehouses || 0) > 0).length;
  
  const setText = (id, val) => {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  };
  setText('zs-cnt-all', all.length);
  setText('zs-cnt-out', outAll);
  setText('zs-cnt-elsewhere', elsewhere);
}

// 🆕 v256: فلتر النتيجة
function zsSetResultFilter(filter, btn){
  _zsResultFilter = filter;
  document.querySelectorAll('#zs-filter-chips .chip').forEach(c => c.classList.remove('on'));
  if(btn) btn.classList.add('on');
  renderZSResults();
}

