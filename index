const TRACKER_DEFAULT_START = 141600;
const TRACKER_MAX_RANGE = 50000; // حد أقصى 50K row عشان نمنع crash

function _extractOrderNum(orderId){
  if(!orderId) return 0;
  const s = String(orderId);
  // جرب SH-XXXXX format الأول
  let m = s.match(/SH[-_]?(\d+)/i);
  if(m) return parseInt(m[1]);
  // جرب #XXXXX format
  m = s.match(/#(\d+)/);
  if(m) return parseInt(m[1]);
  // آخر سلسلة أرقام في الـ string
  const matches = s.match(/\d+/g);
  if(!matches || !matches.length) return 0;
  // خد آخر number في الـ ID (أصغر غالباً)
  const nums = matches.map(n => parseInt(n)).filter(n => n > 0 && n < 10000000);
  if(!nums.length) return 0;
  // رجع أصغر رقم منطقي (مثلاً 141600 مش 5654000123456)
  return Math.min(...nums);
}

function _getTrackerData(){
  const fromInput = parseInt(document.getElementById('trk-from')?.value);
  const from = fromInput && fromInput > 0 ? fromInput : TRACKER_DEFAULT_START;

  const byNum = {};
  let maxNum = 0;
  if(!Array.isArray(orders)) return { from, to: from, byNum, allNums: [] };

  orders.forEach(o => {
    const num = _extractOrderNum(o.id);
    // 🔧 v309: حد أقصى منطقي - متفسحش الـ range يبقى ضخم
    if(num >= from && num < from + TRACKER_MAX_RANGE){
      byNum[num] = o;
      if(num > maxNum) maxNum = num;
    }
  });

  const toInput = parseInt(document.getElementById('trk-to')?.value);
  let to = toInput && toInput > 0 ? toInput : maxNum;

  // 🛡️ v309: الحد الأقصى للـ rows
  if(to - from > TRACKER_MAX_RANGE){
    console.warn(`Tracker: range too big (${to-from}), truncating to ${TRACKER_MAX_RANGE}`);
    to = from + TRACKER_MAX_RANGE;
  }

  if(to < from || maxNum === 0 || !isFinite(to) || !isFinite(from)) {
    return { from, to: from, byNum, allNums: [] };
  }

  const rangeSize = to - from + 1;
  // 🛡️ آخر safety check قبل الـ allocation
  if(rangeSize > TRACKER_MAX_RANGE || rangeSize < 0){
    return { from, to: from, byNum, allNums: [] };
  }

  const allNums = [];
  for(let i = from; i <= to; i++) allNums.push(i);
  return { from, to, byNum, allNums };
}

