      const isNow=new Date()>=w.start&&new Date()<=w.end;
      const hasPast=w.end<new Date();
      const bg=isNow?'#fff8e1':hasPast&&w.pending.length>0?'#fff5f5':'';
      const pendingAmt=w.pending.reduce((s,c)=>s+Number(c.amount),0);
