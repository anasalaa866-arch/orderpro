function addAiMessage(role, text){
  const el = document.getElementById('ai-messages');
  if(!el) return;
  const isUser = role === 'user';
  const msg = document.createElement('div');
  msg.style.cssText = `max-width:85%;padding:10px 14px;border-radius:14px;font-size:13px;line-height:1.6;white-space:pre-wrap;word-wrap:break-word;${isUser?'align-self:flex-start;background:#6366f1;color:#fff;border-bottom-right-radius:4px':'align-self:flex-end;background:var(--bg);color:var(--text);border:1px solid var(--border);border-bottom-left-radius:4px'}`;
  msg.textContent = text;
  el.appendChild(msg);
  el.scrollTop = el.scrollHeight;
}

function buildAiContext(){
  // snapshot بسيط من البيانات المهمة
  const todayStr = new Date().toISOString().slice(0,10);
  const stats = {
    today: todayStr,
    orders_total: orders.length,
    orders_by_status: {},
    unassigned_count: 0,
    today_orders: 0,
    couriers: couriers.map(c=>({
      name: c.name,
      zone: c.zone||'',
      active_orders: orders.filter(o=>String(o.courierId)===String(c.id)&&o.status==='جاري التوصيل').length,
      completed_orders: orders.filter(o=>String(o.courierId)===String(c.id)&&o.status==='مكتمل').length,
    })),
    treasuries: (_treasuries||[]).map(t=>({
      name: t.name, balance: getTreasuryBalance(t.id)
    })),
    problems_count: orders.filter(o=>o.hasProblem).length,
  };
  orders.forEach(o=>{
    stats.orders_by_status[o.status] = (stats.orders_by_status[o.status]||0)+1;
    if(!o.courierId && o.status!=='مكتمل' && o.status!=='ملغي') stats.unassigned_count++;
    if(o.createdAt && o.createdAt.slice(0,10)===todayStr) stats.today_orders++;
  });
  return stats;
}

async function sendAiMessage(){
  const input = document.getElementById('ai-input');
  const btn = document.getElementById('ai-send-btn');
  if(!input) return;
  const msg = input.value.trim();
  if(!msg) return;
  input.value = '';
  addAiMessage('user', msg);
  _aiHistory.push({ role:'user', content: msg });

  // typing indicator
  const el = document.getElementById('ai-messages');
  const typing = document.createElement('div');
  typing.id = 'ai-typing';
  typing.style.cssText = 'align-self:flex-end;padding:10px 14px;color:var(--muted);font-size:13px';
  typing.textContent = '⏳ يفكر...';
  el.appendChild(typing);
  el.scrollTop = el.scrollHeight;
  if(btn) btn.disabled = true;

  try{
    if(!API_URL){ throw new Error('Backend غير متصل'); }
    const context = buildAiContext();
    const r = await fetch(API_URL.replace(/\/$/,'')+'/api/ai/chat', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ message: msg, history: _aiHistory.slice(0,-1), context })
    });
    const data = await r.json();
    typing.remove();
    if(!r.ok || data.error){
      addAiMessage('assistant', '❌ '+(data.error||'حصل خطأ'));
      _aiHistory.pop();
    } else {
      addAiMessage('assistant', data.text);
      _aiHistory.push({ role:'assistant', content: data.text });
      // حافظ على الـ history قصير
      if(_aiHistory.length > 14) _aiHistory = _aiHistory.slice(-14);
    }
  }catch(e){
    typing.remove();
    addAiMessage('assistant', '❌ حصل خطأ: '+e.message);
    _aiHistory.pop();
  } finally {
    if(btn) btn.disabled = false;
    input.focus();
  }
}

