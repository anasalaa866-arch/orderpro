        <div>✅ تم العد: <strong>${counted}</strong> (${progress}%)</div>
        <div>⚠️ فروقات: <strong style="color:${differences ? 'var(--warn)' : 'var(--success)'}">${differences}</strong></div>
        <div>الحالة: <strong>${escapeHtml(s.status)}</strong></div>
      </div>
      <div style="background:#e2e8f0;border-radius:99px;height:6px;margin-top:8px;overflow:hidden">
        <div style="background:var(--success);height:100%;width:${progress}%;transition:width .3s"></div>
      </div>
    </div>
  `;
  
  // Action buttons
  let actionsHtml = '';
  if(isActive){
    actionsHtml = `
      <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap">
        <button class="btn btn-success" onclick="approveStocktake()">✅ اعتماد + تحديث Shopify</button>
        <button class="btn btn-ghost" onclick="cancelStocktake()" style="color:var(--danger)">❌ إلغاء الجرد</button>
        <button class="btn btn-ghost" onclick="printStkReport()" style="color:var(--accent)">📄 تقرير PDF</button>
        <!-- 🆕 v364: زرار refresh الـ snapshot -->
        <button class="btn btn-ghost" onclick="refreshStkSnapshot()" style="color:#f59e0b" title="جيب آخر on_hand من Shopify عشان تتأكد من الـ snapshot قبل الـ approve">🔄 تحديث الـ snapshot من Shopify</button>
        <!-- 🆕 v398: زرار ضيف كل المنتجات الناقصة بستوكها -->
        <button class="btn btn-ghost" onclick="mergeAllStkProducts()" style="color:#7c3aed" title="ضيف كل المنتجات اللي ليها رصيد في المخزن ومش في الجرد، بستوكها الفعلي — من غير ما يمسح اللي اتعدّ">➕ ضيف كل المنتجات الناقصة</button>
        ${total > 0 ? `<button class="btn btn-ghost" onclick="markAllSystemQty()" style="margin-right:auto">⚡ ملأ الكميات الفعلية = النظام</button>` : ''}
      </div>
      <!-- 🆕 v364: ملاحظة عن الـ on_hand -->
      <div style="background:#eff6ff;border:1px solid #6366f1;border-radius:6px;padding:8px 12px;margin-bottom:10px;font-size:11px;color:#1e40af">
        💡 <strong>"النظام"</strong> = الكمية الفعلية في الرف من Shopify (<code>on_hand</code>) — مش الـ available (اللي بـ يخصم الـ unfulfilled orders).
        لو الجلسة قديمة، اضغط <strong>🔄 تحديث الـ snapshot</strong> قبل الاعتماد عشان تتأكد إن الأرقام لسه دقيقة.
      </div>
    `;
  } else {
    // الجلسة منتهية - إظهار زرار التقرير بس
    actionsHtml = `
      <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap">
        <button class="btn btn-primary" onclick="printStkReport()">📄 تقرير PDF</button>
      </div>
    `;
  }
  
  // 🆕 v258: على الـ web - mode الجدول فقط (الـ scan في Stars بس)
  const tabsHtml = '';
  _stkCurrentTab = 'grid';
  
