              const time = new Date(sale.created_at).toLocaleTimeString('ar-EG', {hour:'2-digit',minute:'2-digit'});
              const isPickup = sale.is_pickup === true;
              const paysStr = (sale.payments || []).filter(p => p && p.method).map(p => {
                const mi = methodLabels[p.method]?.icon || '•';
                return `${mi} ${parseFloat(p.amount).toFixed(0)}`;
