  spBulkUpdateAddBtn();
  // sync the select-all checkbox
  const newCount = _spBulkResults.filter(v => !v.already_added).length;
  document.getElementById('sp-bulk-select-all').checked = _spBulkSelected.size === newCount && newCount > 0;
