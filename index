let _stkrSearchTimer = null;
let _stkrSessionsLoaded = false;

async function stkrInit(){
  // حمّل قايمة الجلسات مرة واحدة
  if(!_stkrSessionsLoaded){
    try {
      const r = await apiFetch('/api/stocktake/report/sessions');
      const sessions = (r && r.sessions) ? r.sessions : [];
      const sel = document.getElementById('stkr-session');
      if(sel){
        const opts = ['<option value="">كل الجلسات</option>'];
        for(const s of sessions){
          const date = s.started_at ? new Date(s.started_at).toLocaleDateString('ar-EG') : '';
          const statusLabel = s.status === 'approved' ? '✅ مقفول' : s.status === 'in_progress' ? '🔄 شغّال' : s.status;
          const title = s.title || `جرد ${s.warehouse_name||''}`;
          opts.push(`<option value="${s.id}">${escapeHtml(title)} · ${date} · ${statusLabel} (${s.entries_count||0})</option>`);
        }
        sel.innerHTML = opts.join('');
      }
      _stkrSessionsLoaded = true;
    } catch(e){}
  }
  stkrLoad();
}

function stkrSearchDebounced(){
  if(_stkrSearchTimer) clearTimeout(_stkrSearchTimer);
  _stkrSearchTimer = setTimeout(stkrLoad, 400);
}

async function stkrLoad(){
  if(!API_URL){ return; }
  const cont = document.getElementById('stkr-results');
  const sessionId = document.getElementById('stkr-session')?.value || '';
  const search = (document.getElementById('stkr-search')?.value || '').trim();

  if(cont) cont.innerHTML = '<div style="text-align:center;padding:40px;color:var(--muted)">⏳ بيتحمّل...</div>';

  try {
    const params = new URLSearchParams({ limit: '500' });
    if(sessionId) params.set('sessionId', sessionId);
    if(search) params.set('search', search);
    const r = await apiFetch('/api/stocktake/report?' + params.toString());
    const entries = (r && r.entries) ? r.entries : [];
    const total = r?.total || 0;

    const countEl = document.getElementById('stkr-count');
    if(countEl) countEl.textContent = `${total} عملية عدّ` + (total > entries.length ? ` (عرض أول ${entries.length})` : '');

    if(!entries.length){
      cont.innerHTML = `<div style="text-align:center;padding:40px;color:var(--muted)"><div style="font-size:42px;opacity:.3">${search?'🔎':'📋'}</div><div style="margin-top:10px;font-weight:700">${search?'مفيش نتائج للبحث':'مفيش عمليات عدّ'}</div></div>`;
      return;
    }

    const rows = entries.map(e => {
      const when = e.counted_at ? new Date(e.counted_at).toLocaleString('ar-EG', {dateStyle:'short', timeStyle:'short'}) : '—';
      const diff = (e.difference != null) ? e.difference : null;
      const diffStr = diff == null ? '—'
        : diff === 0 ? `<span style="color:#16a34a">✓ 0</span>`
        : diff > 0 ? `<span style="color:#2563eb">+${diff}</span>`
        : `<span style="color:#dc2626">${diff}</span>`;
      return `
        <tr>
          <td style="font-size:12px;font-weight:600">${escapeHtml(e.product_title||'—')}${e.variant_title?`<span style="color:var(--muted);font-weight:400"> · ${escapeHtml(e.variant_title)}</span>`:''}<div style="font-size:10px;color:var(--muted);font-family:monospace">${escapeHtml(e.sku||e.variant_id||'')}</div></td>
          <td style="text-align:center;font-weight:800;font-size:14px">${e.qty}</td>
          <td style="text-align:center;font-size:11px;color:var(--muted)">${e.location_note?escapeHtml(e.location_note):'—'}</td>
          <td style="text-align:center;font-size:12px;font-weight:600">${escapeHtml(e.counted_by||'—')}</td>
          <td style="text-align:center;font-size:11px;color:var(--muted)">${when}</td>
        </tr>`;
    }).join('');

    cont.innerHTML = `
      <div class="card">
        <div class="tw" style="overflow-x:auto">
          <table style="width:100%;font-size:12px">
            <thead><tr>
              <th>المنتج</th>
              <th style="text-align:center">الكمية المعدودة</th>
              <th style="text-align:center">المكان/ملاحظة</th>
              <th style="text-align:center">مين عدّ</th>
              <th style="text-align:center">الوقت</th>
            </tr></thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
      </div>`;
  } catch(e){
    if(cont) cont.innerHTML = '<div style="text-align:center;padding:40px;color:var(--danger)">❌ ' + escapeHtml(e.message) + '</div>';
  }
}

