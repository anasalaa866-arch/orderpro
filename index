async function loadPayablesReport(){
  const cont = document.getElementById('payables-report-content');
  cont.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)">⏳ جاري التحميل...</div>';
  try {
    // جيب كل الدفعات وكل الشيكات للسنة الحالية
    const now = new Date();
    const year = now.getFullYear();
    const yearStartStr = year + '-01-01';
    const yearEndStr = year + '-12-31';

    const [payR, chkR] = await Promise.all([
      apiFetch(`/api/payables?from=${yearStartStr}&to=${yearEndStr}`),
      apiFetch('/api/checks')
    ]);

    const payables = (payR?.payables || []).filter(p => p.due_date && p.due_date >= yearStartStr && p.due_date <= yearEndStr);
    const checks = (chkR?.checks || chkR || []).filter(c => c.date && c.date >= yearStartStr && c.date <= yearEndStr);

    renderCombinedReport(payables, checks, year);
  } catch(e) {
    cont.innerHTML = `<div style="color:#dc2626;padding:14px">❌ ${escapeHtml(e.message)}</div>`;
  }
}

function renderCombinedReport(payables, checks, year){
  const cont = document.getElementById('payables-report-content');

  // وحّد الـ items: { type, date, amount, status, label, category }
  const items = [];
  payables.forEach(p => {
    items.push({
      type: 'payable',
      id: p.id,
      date: p.due_date,
      amount: parseFloat(p.amount || 0),
      status: p.status === 'paid' ? 'done' : 'pending',
      label: p.title,
      payee: p.payee,
      category: p.category
    });
  });
  checks.forEach(c => {
    items.push({
      type: 'check',
      id: c.id,
      date: c.date,
      amount: parseFloat(c.amount || 0),
      status: c.status, // pending or done
      label: 'شيك ' + (c.num || '') + ' - ' + (c.payee || ''),
      payee: c.payee,
      category: 'check',
      num: c.num
    });
  });

  // ━━━ ملخصات أعلى ━━━
  const today = new Date(); today.setHours(0,0,0,0);
  const todayStr = today.toISOString().slice(0,10);
  const totalAll = items.reduce((s, i) => s + i.amount, 0);
  const overdueItems = items.filter(i => i.status === 'pending' && i.date < todayStr);
  const overdueTotal = overdueItems.reduce((s, i) => s + i.amount, 0);
  const doneItems = items.filter(i => i.status === 'done');
  const doneTotal = doneItems.reduce((s, i) => s + i.amount, 0);
  const pendingItems = items.filter(i => i.status === 'pending');
  const pendingTotal = pendingItems.reduce((s, i) => s + i.amount, 0);

  // الأسبوع الحالي (الجمعة → الخميس)
  const yearStartDate = new Date(year, 0, 1);
  const yearStartDay = yearStartDate.getDay();
  let daysToFirstFriday = (5 - yearStartDay + 7) % 7;
  let firstFriday = new Date(year, 0, 1 + daysToFirstFriday - 7);

  // أنشئ كل الأسابيع
  const weeks = [];
  for(let w = 1; w <= 53; w++){
    const start = new Date(firstFriday);
    start.setDate(firstFriday.getDate() + (w-1)*7);
    start.setHours(0,0,0,0);
    const end = new Date(start);
    end.setDate(start.getDate() + 6);
    end.setHours(23,59,59,999);
    if(start.getFullYear() > year) break;

    const weekItems = items.filter(i => {
      const d = new Date(i.date);
      return d >= start && d <= end;
    });
    const total = weekItems.reduce((s, i) => s + i.amount, 0);
    const pending = weekItems.filter(i => i.status === 'pending');
    const done = weekItems.filter(i => i.status === 'done');
    weeks.push({ w, start, end, items: weekItems, total, pending, done });
  }

  // ━━━ الملخص الشهري ━━━
  const months = {};
  for(let m = 1; m <= 12; m++) months[m] = { items: [], total: 0 };
  items.forEach(i => {
    const m = new Date(i.date).getMonth() + 1;
    if(months[m]){ months[m].items.push(i); months[m].total += i.amount; }
  });
  const monthNames = ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];

  // ━━━ الـ HTML ━━━
  let html = `
    <!-- بطاقات الملخص -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;margin-bottom:14px">
      <div style="background:linear-gradient(135deg,#dbeafe,#fff);border:1px solid #93c5fd;border-radius:10px;padding:12px">
        <div style="display:flex;align-items:center;gap:6px;color:#1e3a8a;font-weight:700;font-size:11px">📋 إجمالي غير مصروف</div>
        <div style="font-size:22px;font-weight:900;color:#1e3a8a;margin-top:6px">${pendingTotal.toLocaleString()} ج</div>
        <div style="font-size:10px;color:var(--muted)">${pendingItems.length} بند</div>
      </div>
      <div style="background:linear-gradient(135deg,#fef3c7,#fff);border:1px solid #fbbf24;border-radius:10px;padding:12px">
        <div style="display:flex;align-items:center;gap:6px;color:#78350f;font-weight:700;font-size:11px">📅 هذا الأسبوع</div>
        <div style="font-size:22px;font-weight:900;color:#d97706;margin-top:6px" id="cur-week-total">—</div>
        <div style="font-size:10px;color:var(--muted)" id="cur-week-range">—</div>
      </div>
      <div style="background:linear-gradient(135deg,#fee2e2,#fff);border:1px solid #fca5a5;border-radius:10px;padding:12px">
        <div style="display:flex;align-items:center;gap:6px;color:#7f1d1d;font-weight:700;font-size:11px">⚠️ متأخرة</div>
        <div style="font-size:22px;font-weight:900;color:#dc2626;margin-top:6px">${overdueTotal.toLocaleString()} ج</div>
        <div style="font-size:10px;color:var(--muted)">${overdueItems.length} بند</div>
      </div>
      <div style="background:linear-gradient(135deg,#dcfce7,#fff);border:1px solid #86efac;border-radius:10px;padding:12px">
        <div style="display:flex;align-items:center;gap:6px;color:#14532d;font-weight:700;font-size:11px">✅ تم صرفها</div>
        <div style="font-size:22px;font-weight:900;color:#16a34a;margin-top:6px">${doneTotal.toLocaleString()} ج</div>
        <div style="font-size:10px;color:var(--muted)">${doneItems.length} بند</div>
      </div>
    </div>

    <div style="text-align:right;font-weight:700;color:var(--text);margin-bottom:8px">${items.length} بند</div>

    <!-- الجدول -->
    <table style="width:100%;border-collapse:collapse;font-size:12px;background:var(--card);border:1px solid var(--border);border-radius:8px;overflow:hidden">
      <thead>
        <tr style="background:var(--bg);border-bottom:2px solid var(--border)">
          <th style="padding:10px;text-align:right">الأسبوع</th>
          <th style="padding:10px;text-align:right">من</th>
          <th style="padding:10px;text-align:right">إلى</th>
          <th style="padding:10px;text-align:right">عدد البنود</th>
          <th style="padding:10px;text-align:right">إجمالي المستحق</th>
          <th style="padding:10px;text-align:right">مصروف</th>
          <th style="padding:10px;text-align:right">لم يُصرف</th>
        </tr>
      </thead>
      <tbody>
  `;

  // ━━━ ملخص شهري ━━━
  html += `<tr><td colspan="7" style="padding:10px;background:#fff8e1;font-weight:700;color:#d97706;font-size:13px">📆 ملخص شهري — ${year}</td></tr>`;
  Object.entries(months).filter(([m,d]) => d.items.length > 0).forEach(([m,d]) => {
    const pending = d.items.filter(i => i.status === 'pending').reduce((s,i) => s + i.amount, 0);
    const done = d.items.filter(i => i.status === 'done').reduce((s,i) => s + i.amount, 0);
    html += `<tr style="background:#fafafa">
      <td colspan="3" style="padding:8px;font-weight:700;color:#d97706">${monthNames[m-1]}</td>
      <td style="padding:8px">${d.items.length} بند</td>
      <td style="padding:8px;font-weight:700">${d.total.toLocaleString()} ج</td>
      <td style="padding:8px;color:#16a34a">${done.toLocaleString()} ج</td>
      <td style="padding:8px;color:#dc2626">${pending.toLocaleString()} ج</td>
    </tr>`;
  });

  // ━━━ تفاصيل أسبوعية ━━━
  html += `<tr><td colspan="7" style="padding:10px;background:#fff8e1;font-weight:700;color:#d97706;font-size:13px">📅 تفاصيل أسبوعية — ${year}</td></tr>`;
  const nowDate = new Date();
  let curWeekIdx = -1;
  weeks.forEach((w, idx) => {
    const isNow = nowDate >= w.start && nowDate <= w.end;
    if(isNow) curWeekIdx = idx;
    const hasPast = w.end < nowDate;
    const bg = isNow ? '#fff8e1' : (hasPast && w.pending.length > 0 ? '#fff5f5' : '');
    const pendingAmt = w.pending.reduce((s,i) => s + i.amount, 0);
    const doneAmt = w.done.reduce((s,i) => s + i.amount, 0);
    html += `<tr style="background:${bg};${w.items.length === 0 ? 'opacity:.5' : ''}">
      <td style="padding:8px"><strong style="color:${isNow ? '#d97706' : 'var(--text)'}">أسبوع ${w.w}${isNow ? ' ◀ الآن' : ''}</strong></td>
      <td style="padding:8px;font-size:11px">${w.start.toLocaleDateString('ar-EG',{month:'short',day:'numeric'})}</td>
      <td style="padding:8px;font-size:11px">${w.end.toLocaleDateString('ar-EG',{month:'short',day:'numeric'})}</td>
      <td style="padding:8px">${w.items.length || '—'}</td>
      <td style="padding:8px;font-weight:${w.total > 0 ? '700' : '400'};color:${w.total > 0 ? 'var(--text)' : 'var(--muted)'}">${w.total > 0 ? w.total.toLocaleString() + ' ج' : '—'}</td>
      <td style="padding:8px;color:#16a34a">${doneAmt > 0 ? doneAmt.toLocaleString() + ' ج' : '—'}</td>
      <td style="padding:8px;color:${pendingAmt > 0 ? '#dc2626' : 'var(--muted)'}">${pendingAmt > 0 ? pendingAmt.toLocaleString() + ' ج' : '—'}</td>
    </tr>`;
  });

  html += `
      </tbody>
    </table>

    <div style="margin-top:14px;text-align:left">
      <button class="btn btn-secondary" onclick="exportCombinedReport()">📥 تصدير CSV</button>
    </div>
  `;

  cont.innerHTML = html;

  // املأ بطاقة الأسبوع الحالي
  if(curWeekIdx >= 0){
    const w = weeks[curWeekIdx];
    const totalEl = document.getElementById('cur-week-total');
    const rangeEl = document.getElementById('cur-week-range');
    if(totalEl) totalEl.textContent = w.total > 0 ? w.total.toLocaleString() + ' ج' : '0 ج';
    if(rangeEl) rangeEl.textContent = `${w.start.toLocaleDateString('ar-EG',{month:'short',day:'numeric'})} → ${w.end.toLocaleDateString('ar-EG',{month:'short',day:'numeric'})}`;
  }

  // خزّن للـ export
  window._payablesReportData = { items, year, weeks, months };
}

function exportCombinedReport(){
  const data = window._payablesReportData;
  if(!data) return;
  const rows = [['النوع', 'العنوان', 'الجهة', 'الفئة', 'التاريخ', 'المبلغ', 'الحالة']];
  data.items.forEach(it => {
    const catLabel = it.type === 'check' ? 'شيك' : (PAYABLE_CATEGORIES[it.category]?.label || it.category || '-');
    rows.push([
      it.type === 'check' ? 'شيك' : 'دفعة',
      it.label || '',
      it.payee || '',
      catLabel,
      it.date,
      it.amount,
      it.status === 'done' ? 'مصروف' : 'لم يُصرف'
    ]);
  });
  const csv = '\ufeff' + rows.map(r => r.map(c => `"${String(c||'').replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `payables-checks-report-${data.year}.csv`;
  a.click();
}


