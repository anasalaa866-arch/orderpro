// 🆕 v203: Shared Formatters (موحدين عبر الكود كله)
// كانوا متكررين في حتت كتير، دلوقتي مكان واحد
function fmtMoney(n){
  return (parseFloat(n) || 0).toLocaleString('ar-EG', { maximumFractionDigits: 0 }) + ' ج';
}
function fmtNum(n){
  return (parseFloat(n) || 0).toLocaleString('ar-EG', { maximumFractionDigits: 0 });
}
function fmtHours(h){
  if(!h || h === 0) return '—';
  if(h < 1) return Math.round(h * 60) + ' د';
  if(h < 24) return h.toFixed(1) + ' س';
  return Math.round(h / 24) + ' يوم';
}
function fmtDate(d, opts = {}){
  if(!d) return '—';
  const date = (d instanceof Date) ? d : new Date(d);
  if(isNaN(date)) return '—';
  return date.toLocaleDateString('ar-EG', {
    year: 'numeric',
    month: opts.short ? 'short' : 'long',
    day: 'numeric',
  });
}
function fmtTime(d){
  if(!d) return '—';
  const date = (d instanceof Date) ? d : new Date(d);
  if(isNaN(date)) return '—';
  return date.toLocaleTimeString('ar-EG', { hour: '2-digit', minute: '2-digit', timeZone: 'Africa/Cairo' });
}
function fmtDateTime(d){
  if(!d) return '—';
  return fmtDate(d, { short: true }) + ' · ' + fmtTime(d);
}
// تنسيق relative (e.g. "من 5 دقائق", "منذ يومين")
function fmtRelative(d){
  if(!d) return '—';
  const date = (d instanceof Date) ? d : new Date(d);
  if(isNaN(date)) return '—';
  const diff = Date.now() - date.getTime();
  const min = Math.floor(diff / 60000);
  if(min < 1) return 'الآن';
  if(min < 60) return `منذ ${min} د`;
  const hr = Math.floor(min / 60);
  if(hr < 24) return `منذ ${hr} س`;
  const day = Math.floor(hr / 24);
  if(day < 30) return `منذ ${day} يوم`;
  return fmtDate(d, { short: true });
}
// safer escapeHtml
function escapeHtml(s){
  if(s == null) return '';
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// 🆕 v216: escape for HTML attributes (for onclick, value, etc.)
function escapeAttr(s){
  if(s == null) return '';
  return String(s).replace(/["']/g, c => c === '"' ? '&quot;' : '&#39;');
}

