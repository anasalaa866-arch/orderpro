// 🆕 v291: تصدير الطلبات المتأخرة لـ CSV
function exportLateOrdersCSV(){
  const minDays = parseInt(document.getElementById('late-min-days')?.value || '3');
  const courierFilter = document.getElementById('late-courier-filter')?.value || '';
  let late = _getLateOrders(minDays);
  if (courierFilter) late = late.filter(o => String(o.courierId) === String(courierFilter));
  if (!late.length) { toast('❌ مفيش طلبات للتصدير'); return; }

  const now = Date.now();
  const day = 24 * 60 * 60 * 1000;

  const headers = ['رقم الطلب', 'المندوب', 'العميل', 'التليفون', 'العنوان', 'COD', 'تاريخ الإنشاء', 'عدد الأيام', 'الحالة'];
  const rows = late.map(o => {
    const ageDays = Math.floor((now - new Date(o.createdAt).getTime()) / day);
    const c = (typeof couriers !== 'undefined' && Array.isArray(couriers)) ? couriers.find(cc => cc.id == o.courierId) : null;
    return [
      o.id || '',
      (c?.name || ''),
      (o.customer || ''),
      (o.phone || ''),
      (o.address || o.area || ''),
      parseFloat(o.cod || o.total || 0).toFixed(2),
      new Date(o.createdAt).toLocaleDateString('ar-EG'),
      ageDays,
      o.status || ''
    ].map(v => `"${String(v).replace(/"/g, '""')}"`).join(',');
  });
  const csv = '\uFEFF' + headers.join(',') + '\n' + rows.join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = 'طلبات_متأخرة_' + new Date().toISOString().slice(0,10) + '.csv';
  a.click();
  URL.revokeObjectURL(url);
  toast('✅ تم التصدير');
}

