  try{
    const data = await apiFetch('/api/stocktake/sessions/' + _stkCurrentSession.id + '/report');
    if(!data || !data.session){ toast('❌ فشل تحميل البيانات'); return; }
    
    const s = data.session;
    const stats = data.stats;
    const items = data.items;
    
    const startedDate = s.started_at ? new Date(s.started_at).toLocaleString('ar-EG') : '—';
