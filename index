// قراءة المرفقات → Base64
document.addEventListener('change', async e => {
  if (e.target && e.target.id === 'tsk-attachments') {
    const files = Array.from(e.target.files || []);
    _taskAttachmentsBuffer = [];
    const preview = document.getElementById('tsk-attachments-preview');
    preview.innerHTML = '';
    for (const f of files) {
      if (f.size > 4 * 1024 * 1024) { toast('❌ ' + f.name + ' أكبر من 4MB'); continue; }
      try {
        const b64 = await new Promise((resolve, reject) => {
          const r = new FileReader();
          r.onload = () => resolve(r.result.split(',')[1]);
          r.onerror = reject;
          r.readAsDataURL(f);
        });
        _taskAttachmentsBuffer.push({ filename: f.name, content_type: f.type, data_base64: b64 });
        const sizeKB = Math.round(f.size / 1024);
        preview.insertAdjacentHTML('beforeend',
          `<div style="display:inline-flex;align-items:center;gap:5px;padding:4px 10px;background:var(--bg);border:1px solid var(--border);border-radius:8px;font-size:11px">
            📎 ${escapeHtml(f.name)} <span style="color:var(--muted)">(${sizeKB}KB)</span>
          </div>`);
      } catch(err) { toast('❌ خطأ في ' + f.name); }
    }
  }
});

async function saveTask(){
  const title = document.getElementById('tsk-title').value.trim();
  const description = document.getElementById('tsk-description').value.trim();
  const priority = document.getElementById('tsk-priority').value;
  const due_date = document.getElementById('tsk-due-date').value;
  const assigned_to = document.getElementById('tsk-assigned-to').value;

  if (!title) { toast('❗ العنوان مطلوب'); return; }
  if (!assigned_to) { toast('❗ اختار الشخص اللي هتكلفه'); return; }

  const payload = {
    title, description, priority,
    due_date: due_date || null,
    assigned_to,
    share_with: _taskShareSelected,
    attachments: _taskAttachmentsBuffer
  };

  try {
    if (_editingTask) {
      const r = await apiFetch('/api/tasks/' + _editingTask.id, 'PATCH', payload);
      if (r?.error) { toast('❌ ' + r.error); return; }
      toast('✅ تم تحديث التاسك');
    } else {
      const r = await apiFetch('/api/tasks', 'POST', payload);
      if (r?.error) { toast('❌ ' + r.error); return; }
      toast('✅ تم إنشاء التاسك');
    }
    closeM('m-task-edit');
    loadTasks();
    refreshTasksBadge();
  } catch(e) { toast('❌ ' + e.message); }
}

