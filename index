    if(!_whatsappTpls.length){
      list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)">مفيش تيمبليتس</div>';
      return;
    }
    
    const today = new Date().toISOString().slice(0,10);
    
    list.innerHTML = _whatsappTpls.map(t => {
      const expired = t.valid_until && t.valid_until < today;
      const upcoming = t.valid_from && t.valid_from > today;
      const dateRange = (t.valid_from || t.valid_until) ? 
        `${t.valid_from ? new Date(t.valid_from).toLocaleDateString('ar-EG') : '∞'} → ${t.valid_until ? new Date(t.valid_until).toLocaleDateString('ar-EG') : '∞'}` : 
