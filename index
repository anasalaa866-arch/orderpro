table{width:100%;border-collapse:collapse;font-size:11px}
th{background:#f3f4f6;padding:8px;text-align:right;border:1px solid #ccc;font-weight:700}
td{padding:6px 8px;border:1px solid #ddd}
tr.overdue td{background:#fef2f2}
tr.done td{background:#f0fdf4;color:#666;text-decoration:line-through}
.totals{margin-top:14px;padding:10px;border-top:2px solid #000;display:flex;justify-content:space-between;font-weight:700}
.btn-print{position:fixed;top:10px;left:10px;padding:8px 16px;background:#000;color:#fff;border:none;border-radius:6px;cursor:pointer}
@media print{.btn-print{display:none}}
</style></head><body>
<button class="btn-print" onclick="window.print()">🖨️ طباعة</button>
<div class="hdr">
  <div>
    <h1>📚 تقرير دفتر شيكات: ${b.name}</h1>
    <div class="meta">${b.bank?b.bank+' · ':''}أرقام: ${b.firstNum||1} → ${b.lastNum||((b.firstNum||1)+b.pages-1)} · ${checks.length} شيك من ${b.pages}</div>
  </div>
  <div class="meta">${today}<br>CAFELAX</div>
</div>
<div class="summary">
  <div class="box"><div class="lbl">إجمالي القيمة</div><div class="val">${fmt(totalAmt)} ج</div></div>
  <div class="box"><div class="lbl">غير مصروف</div><div class="val" style="color:#92400e">${fmt(totalPending)} ج</div></div>
  <div class="box"><div class="lbl">تم صرفه</div><div class="val" style="color:#065f46">${fmt(totalDone)} ج</div></div>
</div>
${checks.length ? `<table>
  <thead><tr><th>#</th><th>رقم الشيك</th><th>لصالح</th><th>القيمة</th><th>الاستحقاق</th><th>فاتورة</th><th>الحالة</th><th>ملاحظات</th></tr></thead>
  <tbody>${checks.map((c,i)=>{
    const overdue = c.status!=='done' && c.date && new Date(c.date)<new Date(new Date().toDateString());
    const cls = c.status==='done'?'done':overdue?'overdue':'';
    const status = c.status==='done'?'✅ مصروف':overdue?'⚠️ متأخر':'⏳ لم يُصرف';
    return `<tr class="${cls}"><td>${i+1}</td><td><strong>${c.num||'—'}</strong></td><td><strong>${c.payee||'—'}</strong></td><td>${fmt(c.amount)} ج</td><td>${fmtDate(c.date)}</td><td>${c.invoice||'—'}</td><td>${status}</td><td style="font-size:10px;color:#666">${c.note||''}</td></tr>`;
