// ===== CAFELAX STARS: Set courier credentials =====
async function openStarsCredentials(courierId){
  const c = couriers.find(x => x.id == courierId);
  if(!c){ toast('❗ المندوب غير موجود'); return; }

  const current = c.username || '';
  const username = prompt('⭐ Cafelax Stars — حساب دخول\n\nالمندوب: ' + c.name + '\n\nأدخل اسم المستخدم (بالإنجليزية):', current);
  if(username === null) return;
  if(!username.trim()){ toast('❌ اسم المستخدم مطلوب'); return; }

  const password = prompt('أدخل كلمة المرور (4 أحرف على الأقل):');
  if(password === null) return;
  if(!password || password.length < 4){ toast('❌ كلمة المرور قصيرة'); return; }

  try{
    // SHA-256 hash
    const passHash = await _sha256Hash(password);
    const r = await apiFetch('/api/couriers/'+courierId+'/set-credentials', 'POST', {
      username: username.trim(),
      passHash
    });
    if(r && r.success){
      c.username = username.trim();
      saveCouriers();
      renderCouriers();
      const credText = `المندوب: ${c.name}\nاسم المستخدم: ${username}\nكلمة المرور: ${password}\n\nرابط التطبيق:\n${window._starsAppUrl || 'Cafelax Stars'}`;
      infoModal('✅ تم حفظ حساب الدخول', credText + '\n\nشارك دي مع المندوب عشان يدخل التطبيق.', { copyText: credText });
    } else {
      toast('❌ فشل: ' + (r?.error || 'غير معروف'));
    }
  }catch(e){
    toast('❌ خطأ: ' + e.message);
  }
}

async function _sha256Hash(str){
  const buf = new TextEncoder().encode(str);
  const hashBuf = await crypto.subtle.digest('SHA-256', buf);
  return Array.from(new Uint8Array(hashBuf)).map(b => b.toString(16).padStart(2,'0')).join('');
}

