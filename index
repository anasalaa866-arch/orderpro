// 🆕 v337: Barcode quick-add في الـ PO
// flow: امسح barcode → يدور على المنتج → يضيفه (أو يزود qty لو موجود) → focus على cost field
let _poBarcodeBusy = false;

// 🆕 v337: auto-trigger detection
// لو الـ user وقف عن الكتابة لـ 400ms ومعاه على الأقل 4 حروف → اعتبره خلاص وزود
let _poBarcodeTimer = null;
let _poBarcodeLastInput = 0;
function handleBarcodeInput(){
  const input = document.getElementById('po-barcode-quickadd');
  const val = (input.value || '').trim();
  _poBarcodeLastInput = Date.now();
  
  // إلغاء أي timer قديم
  if(_poBarcodeTimer) clearTimeout(_poBarcodeTimer);
  
  // مفيش value → خلاص
  if(!val) return;
  
  // قصير جداً → استنى أكتر
  if(val.length < 4) return;
  
  // استنى 400ms بدون كتابة جديدة → اعتبره خلاص
  _poBarcodeTimer = setTimeout(() => {
    // double-check إن مفيش keystroke حصل في خلال الـ delay (defensive)
    if(Date.now() - _poBarcodeLastInput >= 350){
      handleBarcodeQuickAdd();
    }
  }, 400);
}

async function handleBarcodeQuickAdd(){
  if(_poBarcodeBusy) return; // منع double-call
  
  // إلغاء الـ auto-timer لو موجود (عشان مايضربش مرتين)
  if(_poBarcodeTimer){
    clearTimeout(_poBarcodeTimer);
    _poBarcodeTimer = null;
  }
  
  const input = document.getElementById('po-barcode-quickadd');
  const statusEl = document.getElementById('po-barcode-status');
  const barcode = (input.value || '').trim();
  
  if(!barcode){
    return;
  }
  
  _poBarcodeBusy = true;
  
  // اعرض status "جاري البحث"
  statusEl.style.display = 'block';
  statusEl.style.background = '#fef3c7';
  statusEl.style.color = '#92400e';
  statusEl.textContent = '⏳ جاري...';
  
  try {
    // ابحث بالباركود
    const r = await apiFetch('/api/inventory/search?q=' + encodeURIComponent(barcode) + '&limit=5');
    const results = r?.results || [];
    
    // دور على exact match بالباركود الأول
    let match = results.find(p => 
      (p.barcode || '').trim() === barcode || 
      (p.sku || '').trim() === barcode
    );
    
    // لو مش لاقي exact، خد أول نتيجة (لو واحدة بس)
    if(!match && results.length === 1) match = results[0];
    
    if(!match){
      // مفيش match
      statusEl.style.background = '#fef2f2';
      statusEl.style.color = '#991b1b';
      statusEl.textContent = '❌ مش موجود';
      input.style.borderColor = '#dc2626';
      
      // beep بسيط (لو في audio context)
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.frequency.value = 200;
        gain.gain.value = 0.15;
        osc.start();
        setTimeout(() => { osc.stop(); ctx.close(); }, 200);
      } catch(e){}
      
      setTimeout(() => {
        statusEl.style.display = 'none';
        input.style.borderColor = '#3b82f6';
        input.select(); // اختار الـ text عشان scanner التاني يكتب فوقه
      }, 1500);
      
      _poBarcodeBusy = false;
      return;
    }
    
    // ✅ لاقي المنتج - تأكد لو موجود بالفعل في الـ PO
    const existingIdx = _poItems.findIndex(it => 
      String(it.variantId) === String(match.variant_id) ||
      (it.barcode && match.barcode && it.barcode === match.barcode)
    );
    
    if(existingIdx >= 0){
      // موجود → زود qty
      _poItems[existingIdx].orderedQty = (_poItems[existingIdx].orderedQty || 0) + 1;
      _poJustAddedIdx = existingIdx;
      
      statusEl.style.background = '#dbeafe';
      statusEl.style.color = '#1e40af';
      statusEl.textContent = `🔁 +1 (الآن ${_poItems[existingIdx].orderedQty})`;
    } else {
      // جديد → أضف
      _poItems.push({
        variantId: match.variant_id,
        productTitle: match.product_title,
        variantTitle: match.variant_title || '',
        sku: match.sku || '',
        barcode: match.barcode || '',
        orderedQty: 1,
        unitCost: 0,
        notes: ''
      });
      _poJustAddedIdx = _poItems.length - 1;
      
      statusEl.style.background = '#dcfce7';
      statusEl.style.color = '#166534';
      statusEl.textContent = '✅ تمت إضافته';
    }
    
    renderPOItems();
    updatePOTotals();
    
    // beep نجاح
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.frequency.value = 800;
      gain.gain.value = 0.1;
      osc.start();
      setTimeout(() => { osc.stop(); ctx.close(); }, 100);
    } catch(e){}
    
    // فضّي الـ input وركّز عليه للـ scan التالي
    input.value = '';
    input.focus();
    
    // اختفي الـ status بعد ثانية
    setTimeout(() => { 
      statusEl.style.display = 'none'; 
    }, 1200);
    
    // 🎯 focus على cost field للمنتج المضاف (يتحط delay صغير عشان renderPOItems تخلص)
    // لكن مش بنقفل الـ focus من الـ barcode input — الـ user يضغط Tab لو عايز يعدل cost
    
  } catch(e) {
    console.error('Barcode quick-add error:', e);
    statusEl.style.background = '#fef2f2';
    statusEl.style.color = '#991b1b';
    statusEl.textContent = '❌ خطأ: ' + (e.message || 'فشل');
    setTimeout(() => { statusEl.style.display = 'none'; }, 2000);
  } finally {
    _poBarcodeBusy = false;
  }
}

// 🆕 v337: حفظ index آخر منتج اتضاف عشان نـ highlight السطر
let _poJustAddedIdx = -1;

let _poSearchTimer = null;
async function searchPOItem(){
  const q = document.getElementById('po-item-search').value.trim();
  const resultsEl = document.getElementById('po-item-results');
  
  if(!q || q.length < 2){
    resultsEl.style.display = 'none';
    return;
  }
  
  if(_poSearchTimer) clearTimeout(_poSearchTimer);
  _poSearchTimer = setTimeout(async () => {
    try {
      // ابحث في inventory
      const r = await apiFetch('/api/inventory/search?q=' + encodeURIComponent(q) + '&limit=20');
      _poVariantSearchResults = r?.results || [];
      
      if(!_poVariantSearchResults.length){
        resultsEl.innerHTML = '<div style="padding:10px;text-align:center;color:var(--muted);font-size:12px">مفيش نتائج</div>';
      } else {
        resultsEl.innerHTML = _poVariantSearchResults.map((v, i) => `
          <div onclick="selectPOItem(${i})" style="padding:10px;border-bottom:1px solid var(--border);cursor:pointer;font-size:12px" onmouseover="this.style.background='var(--elev)'" onmouseout="this.style.background='transparent'">
            <div style="font-weight:700">${escapeHtml(v.product_title || v.title || '')}${v.variant_title ? ' - '+escapeHtml(v.variant_title) : ''}</div>
