// 🆕 v331: الـ render الرئيسية - بتطبق كل الفلاتر + الـ sort + pagination
function wlRenderProducts(){
  const container = document.getElementById('wl-content-container');
  if(!container || !_wlData) return;
  
  let products = (_wlData.products || []).slice();
  const totalLoaded = products.length;
  
  // ─── الفلاتر ───
  
  // 1) Search
  if(_wlSearchQuery){
    const q = _wlSearchQuery;
    products = products.filter(p => {
      const title = (p.product_title || '').toLowerCase();
      const variant = (p.variant_title || '').toLowerCase();
      const sku = (p.sku || '').toLowerCase();
      const barcode = (p.barcode || '').toLowerCase();
      const notes = (p.notes || '').toLowerCase();
      return title.includes(q) || variant.includes(q) || sku.includes(q) || barcode.includes(q) || notes.includes(q);
    });
  }
  
  // 2) Category
  const fCat = document.getElementById('wl-f-category')?.value || '';
  if(fCat) products = products.filter(p => p.category === fCat);
  
  // 3) Trend
  const fTrend = document.getElementById('wl-f-trend')?.value || '';
  if(fTrend) products = products.filter(p => p.trend === fTrend);
  
  // 4) Stock status
  const fStock = document.getElementById('wl-f-stock')?.value || '';
  if(fStock === 'out') products = products.filter(p => (p.total_stock || 0) === 0);
  else if(fStock === 'low') products = products.filter(p => p.days_remaining < 7 && p.avg_30d > 0);
  else if(fStock === 'instock') products = products.filter(p => (p.total_stock || 0) > 0);
  
  // 5) Warehouse - منتج له qty > 0 في المخزن ده
  const fWh = document.getElementById('wl-f-warehouse')?.value || '';
  if(fWh) products = products.filter(p => {
    const stocks = p.stockByWarehouse || {};
    return (stocks[fWh] || 0) > 0;
  });
  
  // ─── الترتيب ───
  const sortBy = document.getElementById('wl-sort')?.value || 'added_at';
  const order = document.getElementById('wl-order')?.value || 'desc';
  const compareA = document.getElementById('wl-compare-a')?.value || 'avg_30d';
  const compareB = document.getElementById('wl-compare-b')?.value || 'avg_7d';
  
  products.sort((a, b) => {
    let va, vb;
    
    // sort خاص بنسبة التغيّر
    if(sortBy === 'trend_pct'){
      const aA = parseFloat(a[compareA] || 0);
      const aB = parseFloat(a[compareB] || 0);
      const bA = parseFloat(b[compareA] || 0);
      const bB = parseFloat(b[compareB] || 0);
      va = aA > 0 ? ((aB - aA) / aA) * 100 : 0;
      vb = bA > 0 ? ((bB - bA) / bA) * 100 : 0;
      return order === 'asc' ? va - vb : vb - va;
    }
    
    va = a[sortBy];
    vb = b[sortBy];
    
    // نصوص
    if(typeof va === 'string'){
      return order === 'asc' ? va.localeCompare(vb || '') : (vb || '').localeCompare(va);
    }
    // تواريخ
    if(sortBy === 'added_at'){
      va = new Date(va).getTime();
      vb = new Date(vb).getTime();
    } else {
      va = parseFloat(va) || 0;
      vb = parseFloat(vb) || 0;
    }
    return order === 'asc' ? va - vb : vb - va;
  });
  
  const totalFiltered = products.length;
  
  // ─── معلومات النتائج + Active filters ───
  wlUpdateResultsInfo(totalLoaded, totalFiltered);
  wlUpdateActiveFiltersIndicator();
  
  // ─── Empty states ───
  if(!totalLoaded){
    container.innerHTML = `
      <div style="text-align:center;padding:50px 20px;color:var(--muted)">
        <div style="font-size:64px;opacity:.3;margin-bottom:10px">⭐</div>
        <div style="font-size:16px;font-weight:700;margin-bottom:6px">قائمة المراقبة فاضية</div>
        <div style="font-size:13px;margin-bottom:14px">ابدأ بإضافة المنتجات اللي تحب تراقبها</div>
        <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap">
          <button class="btn btn-primary btn-sm" onclick="wlOpenAddModal()">➕ ضيف منتج</button>
          <button class="btn btn-ghost btn-sm" onclick="wlOpenImportModal()">📥 استيراد Excel</button>
        </div>
      </div>
    `;
    document.getElementById('wl-pagination').innerHTML = '';
    return;
  }
  
  if(!totalFiltered){
    container.innerHTML = `
      <div style="text-align:center;padding:40px 20px;color:var(--muted)">
        <div style="font-size:48px;opacity:.3;margin-bottom:10px">🔍</div>
        <div style="font-size:14px;font-weight:700;margin-bottom:6px">مفيش نتائج</div>
        <div style="font-size:12px;margin-bottom:14px">الفلاتر اللي اخترتها مش بترجع أي منتج</div>
        <button class="btn btn-ghost btn-sm" onclick="wlResetAllFilters()">↺ صفّر الفلاتر</button>
      </div>
    `;
    document.getElementById('wl-pagination').innerHTML = '';
    return;
  }
  
  // ─── Pagination ───
  const totalPages = Math.ceil(totalFiltered / _wlPageSize);
  if(_wlCurrentPage > totalPages) _wlCurrentPage = 1; // safety
  
  const startIdx = (_wlCurrentPage - 1) * _wlPageSize;
  const endIdx = startIdx + _wlPageSize;
  const pageProducts = products.slice(startIdx, endIdx);
  
  // ─── Render ───
  if(_wlView === 'cards'){
    container.innerHTML = wlRenderCards(pageProducts);
  } else {
    container.innerHTML = wlRenderTable(pageProducts);
  }
  
  // ─── Pagination buttons ───
  wlRenderPagination(totalPages, totalFiltered);
}

// 🆕 v331: عرض معلومات النتائج
function wlUpdateResultsInfo(totalLoaded, totalFiltered){
  const el = document.getElementById('wl-results-info');
  if(!el) return;
  
  const startIdx = (_wlCurrentPage - 1) * _wlPageSize + 1;
  const endIdx = Math.min(_wlCurrentPage * _wlPageSize, totalFiltered);
  
  if(totalFiltered === totalLoaded){
    el.innerHTML = `📊 عرض <strong style="color:var(--text)">${startIdx}-${endIdx}</strong> من <strong style="color:var(--text)">${totalFiltered}</strong> منتج`;
  } else {
    el.innerHTML = `📊 عرض <strong style="color:var(--text)">${startIdx}-${endIdx}</strong> من <strong style="color:var(--accent)">${totalFiltered}</strong> مفلتر <span style="color:var(--muted)">(الإجمالي ${totalLoaded})</span>`;
  }
}

