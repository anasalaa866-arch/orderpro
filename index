async function confirmReceive(){
  if(!_currentPO) return;
  
  const items = [];
  let hasOverReceive = false;
  
  _currentPO.items.forEach(it => {
    const input = document.getElementById('receive-qty-' + it.id);
    if(!input) return;
    
    const qty = parseInt(input.value) || 0;
    if(qty <= 0) return;
    
    const newTotal = it.received_qty + qty;
    if(newTotal > it.ordered_qty){
      hasOverReceive = true;
    }
    
    items.push({
      poItemId: it.id,
      qtyReceived: qty
    });
  });
  
  if(!items.length){ toast('❌ مفيش كميات للاستلام'); return; }
  
  if(hasOverReceive){
    if(!confirm('⚡ في كميات أكتر من المطلوب (over-receive)\n\nمتأكد إنك عايز تكمل؟')) return;
  }
  
  const notes = document.getElementById('po-receive-notes').value.trim();
  
  try {
    // 🆕 v336: indicator دامج بيقول إن البضاعة بترفع على Shopify
    toast('⏳ جاري التحديث في OrderPro + Shopify...', 'info');
    
    const r = await apiFetch('/api/purchase-orders/' + _currentPO.order.id + '/receive', 'POST', {
      items, notes
    });
    
    if(r?.success){
      // 🆕 v336: عرض تفاصيل sync Shopify
      const sync = r.shopifySync;
      if(sync?.status === 'success'){
        toast(`✅ تم الاستلام + تحديث Shopify (${sync.itemsPushed} منتج)`, 'success');
        
        // alert نظيف بدل التذكير القديم
        const skippedMsg = (sync.skipped && sync.skipped.length)
          ? `\n\n⚠️ ${sync.skipped.length} منتج اتعداه (مفيش inventory_item_id):\n${sync.skipped.slice(0,5).map(s => '• ' + (s.sku || s.productTitle || 'unknown')).join('\n')}`
          : '';
        
        setTimeout(() => {
          alert(
            `✅ تم بنجاح\n\n` +
            `• OrderPro: تم تسجيل الاستلام\n` +
            `• Shopify: تم تحديث المخزون (${sync.itemsPushed} منتج)\n` +
            `• Reason: "${sync.reasonText}"\n` +
            `• Group: ${sync.adjustmentGroupId || '—'}` +
            skippedMsg
          );
        }, 300);
      } else {
        toast('✅ تم الاستلام', 'success');
      }
      
      closeM('m-po-receive');
      loadPurchaseOrdersPage();
    }
  } catch(e) {
    // 🆕 v336: error handling محسّن - يميز بين أخطاء Shopify و OrderPro
    const errMsg = e.message || 'فشل';
    if(errMsg.includes('Shopify') || errMsg.includes('location')){
      alert(
        `❌ فشل تحديث Shopify\n\n` +
        `${errMsg}\n\n` +
        `⚠️ تم إلغاء الـ receive بالكامل في OrderPro (rollback).\n` +
        `جرب تاني بعد ما تتأكد:\n` +
        `• الإنترنت شغال\n` +
        `• اعمل "🔁 مزامنة كاملة" في صفحة المخزون (هتربط المخازن تلقائياً)\n` +
        `• كل المنتجات synced من Shopify`
      );
    } else {
      toast('❌ ' + errMsg);
    }
  }
}

