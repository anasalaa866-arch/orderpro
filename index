async function loadCartAudit(){
  if(!API_URL) return;
  await loadCartAuditSummary();

  // املأ filter dropdowns
  await _fillCartAuditFilters();

  const params = new URLSearchParams();
  const storeFilter = $('audit-store-filter')?.value;
  const cashierFilter = $('audit-cashier-filter')?.value;
  const actionFilter = $('audit-action-filter')?.value;
  const fromDate = $('audit-from')?.value;
  const toDate = $('audit-to')?.value;
  const search = $('audit-search')?.value?.trim();

  if(storeFilter) params.append('store_id', storeFilter);
  if(cashierFilter) params.append('cashier_id', cashierFilter);
  if(actionFilter) params.append('action_type', actionFilter);
  if(fromDate) params.append('from', fromDate);
  if(toDate) params.append('to', toDate + 'T23:59:59');
  if(search) params.append('search', search);
