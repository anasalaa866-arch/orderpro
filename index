let _wlSearchTimer = null;
async function wlSearchProducts(query){
  query = (query || '').trim();
  const resultsEl = document.getElementById('wl-search-results');
  if(!resultsEl) return;
  
  if(query.length < 2){
    resultsEl.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted);font-size:12px">اكتب على الأقل حرفين...</div>';
    return;
  }
  
  // debounce
  clearTimeout(_wlSearchTimer);
  _wlSearchTimer = setTimeout(async () => {
    resultsEl.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">⏳ جاري البحث...</div>';
    try {
      // 🛠️ v329: استخدام endpoint مخصص للـ watchlist (أسرع + null-safe)
      const r = await apiFetch('/api/watchlist/search?q=' + encodeURIComponent(query) + '&limit=20');
      // 🛠️ v329: defensive parsing - الـ apiFetch ممكن يرجع null لو في خطأ
      const products = (r && Array.isArray(r.products)) ? r.products : [];
      
      if(!products.length){
        resultsEl.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted);font-size:12px">⚠️ مفيش نتائج للبحث "' + escapeHtml(query) + '"</div>';
        return;
      }
      
      // اعرف اللي موجودين في الـ watchlist عشان نظهر علامة
      const inWatchlist = new Set((_wlData?.products || []).map(p => String(p.variant_id)));
      
      resultsEl.innerHTML = products.map(p => {
        const vid = String(p.variant_id || '');
        const isIn = inWatchlist.has(vid);
        const stockBadge = p.total_stock === 0 
          ? '<span style="background:#fee2e2;color:#dc2626;font-size:9px;font-weight:700;padding:2px 6px;border-radius:99px;margin-right:4px">نفد</span>'
          : `<span style="background:#dbeafe;color:#1e40af;font-size:9px;font-weight:700;padding:2px 6px;border-radius:99px;margin-right:4px">${p.total_stock}</span>`;
        return `
          <div style="display:flex;align-items:center;gap:10px;padding:8px;background:${isIn ? '#f0fdf4' : 'var(--card)'};border:1px solid ${isIn ? '#86efac' : 'var(--border)'};border-radius:8px;margin-bottom:4px">
            ${p.image_url ? `<img src="${p.image_url}" style="width:38px;height:38px;border-radius:6px;object-fit:cover;border:1px solid var(--border)">` : '<div style="width:38px;height:38px;border-radius:6px;background:var(--bg);display:inline-flex;align-items:center;justify-content:center;font-size:18px">📦</div>'}
            <div style="flex:1;min-width:0">
              <div style="font-weight:700;font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escapeHtml(p.product_title || '')}${p.variant_title ? ' — <span style="color:var(--muted);font-weight:400">' + escapeHtml(p.variant_title) + '</span>' : ''}</div>
              <div style="font-size:10px;color:var(--muted)">${stockBadge}${escapeHtml(p.sku || '')}${p.barcode ? ' · ' + escapeHtml(p.barcode) : ''}</div>
            </div>
            ${isIn 
              ? '<span style="background:#22c55e;color:#fff;font-size:10px;font-weight:700;padding:4px 8px;border-radius:99px">✓ موجود</span>'
              : `<button onclick="wlAddProduct('${vid}', this)" style="padding:5px 10px;background:var(--accent);color:#fff;border:none;border-radius:6px;font-family:Cairo,sans-serif;font-size:11px;font-weight:700;cursor:pointer">+ ضيف</button>`
            }
          </div>
        `;
      }).join('');
    } catch(e){
      resultsEl.innerHTML = '<div style="text-align:center;padding:20px;color:var(--danger);font-size:12px">❌ ' + escapeHtml(e.message || 'فشل البحث') + '</div>';
    }
  }, 300);
}

