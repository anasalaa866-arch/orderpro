let _tasks = [];
let _tasksMe = '';
let _tasksFilter = 'inbox';
let _editingTask = null;
let _taskShareSelected = []; // array of usernames
let _taskAttachmentsBuffer = []; // {filename, content_type, data_base64}

// Status & priority configs
const TASK_STATUSES = {
  new: { label: 'جديد', color: '#3b82f6', icon: '🆕' },
  in_progress: { label: 'قيد التنفيذ', color: '#f97316', icon: '⚡' },
  review: { label: 'مراجعة', color: '#a855f7', icon: '👁️' },
  completed: { label: 'مكتمل', color: '#16a34a', icon: '✅' },
  cancelled: { label: 'ملغي', color: '#94a3b8', icon: '❌' }
};
const TASK_PRIORITIES = {
  urgent: { label: 'عاجلة', color: '#ef4444', icon: '🔴' },
  normal: { label: 'عادية', color: '#3b82f6', icon: '🔵' },
  low: { label: 'منخفضة', color: '#16a34a', icon: '🟢' }
};

function _allUsernames(){
  // كل users من sysUsers + admin
  const list = (sysUsers || []).map(u => ({ username: u.username, name: u.name }));
  if (!list.find(u => u.username === 'admin')) list.unshift({ username: 'admin', name: 'المدير' });
  return list;
}

function _userDisplayName(username){
  if (!username) return '-';
  if (username === 'admin') return 'المدير';
  const u = (sysUsers || []).find(x => x.username === username);
  return u?.name || username;
}

async function loadTasks(){
  if (!API_URL) return;
  const status = document.getElementById('tasks-status-filter')?.value || '';
  try {
    const url = '/api/tasks?filter=' + _tasksFilter + (status ? '&status=' + status : '');
    const r = await apiFetch(url);
    _tasks = r?.tasks || [];
    _tasksMe = r?.me || '';
    renderTasksList();
    updateTasksStats();
  } catch(e) {
    document.getElementById('tasks-list').innerHTML = `<div class="card"><div class="card-body" style="text-align:center;color:var(--danger)">❌ ${escapeHtml(e.message)}</div></div>`;
  }
}

function updateTasksStats(){
  const now = Date.now();
  const weekAgo = now - 7 * 24 * 60 * 60 * 1000;
  let inbox = 0, progress = 0, overdue = 0, doneWeek = 0;
  _tasks.forEach(t => {
    const isOpen = t.status !== 'completed' && t.status !== 'cancelled';
    if (t.assigned_to === _tasksMe && isOpen) inbox++;
    if (t.status === 'in_progress' && t.assigned_to === _tasksMe) progress++;
    if (isOpen && t.assigned_to === _tasksMe && t.due_date && new Date(t.due_date).getTime() < now) overdue++;
    if (t.status === 'completed' && t.completed_at && new Date(t.completed_at).getTime() >= weekAgo) doneWeek++;
  });
  if ($('tsk-stat-inbox')) $('tsk-stat-inbox').textContent = inbox;
  if ($('tsk-stat-progress')) $('tsk-stat-progress').textContent = progress;
  if ($('tsk-stat-overdue')) $('tsk-stat-overdue').textContent = overdue;
  if ($('tsk-stat-done')) $('tsk-stat-done').textContent = doneWeek;
}

function taskSetFilter(f, btn){
  _tasksFilter = f;
