  const totalDone = checks.filter(c=>c.status==='done').reduce((s,c)=>s+Number(c.amount||0),0);
  const totalPending = totalAmt - totalDone;
  const today = new Date().toLocaleDateString('ar-EG',{year:'numeric',month:'long',day:'numeric'});

  const html = `<!DOCTYPE html><html dir="rtl" lang="ar"><head><meta charset="UTF-8"><title>تقرير دفتر ${b.name}</title>
<style>
@page{size:A4;margin:12mm}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Cairo','Segoe UI',Tahoma,sans-serif;font-size:12px;color:#000}
