async function approveStocktake(){
  const counted = _stkCurrentItems.filter(i => i.counted_qty != null);
  const differences = _stkCurrentItems.filter(i => i.counted_qty != null && i.counted_qty !== i.system_qty).length;
  
  if(!counted.length){ toast('❌ لازم تعد منتج واحد على الأقل'); return; }
  
  // اعرض mode info في الـ confirm
  const sessionMode = _stkCurrentSession?.stk_mode || 'partial';
  const modeLabels = {
    full: '📦 جرد كلي (المعدوش = صفر)',
    partial: '📋 جرد جزئي (المعدوش = تجاهل)',
    scan: '🔍 جرد بـ Scan (المعدوش = تجاهل)'
  };
  const modeLabel = modeLabels[sessionMode] || sessionMode;
  
  if(!confirm(`هتعتمد الجرد؟\n\n📊 ${counted.length} منتج معدود\n⚠️ ${differences} منتج بفرق عن الـ snapshot\n${modeLabel}\n\n📌 الرفع بـ Adjustment Delta:\n   - بـ يطبّق الفروقات (+/-) على Shopify\n   - لو الجرد لقى -2، Shopify -= 2 (مش بـ يـ SET على القيمة)\n   - يطبّق صح حتى لو في بيوع بين العد والاعتماد\n\n⚠️ مش هينفع تتراجع بعد الاعتماد!`)) return;
  
  await _doApproveStocktake(false);
}

// internal helper - يقوم بالـ approve call عبر SSE stream
// confirmZeroUncounted: لو true، الـ backend بـ يـ apply الـ "uncounted = 0" بدون سؤال
async function _doApproveStocktake(confirmZeroUncounted){
  // 🔧 v295: مفيش mode/confirmMovement - الـ delta هو الـ default الوحيد
  const sessionId = _stkCurrentSession.id;
  const baseUrl = (API_URL || BACKEND_URL).replace(/\/$/, '');
  
  // فتح progress modal
  _showStkProgressModal();
  _updateStkProgress({ done: 0, total: 0, message: '⏳ جاري الاتصال...' });
  
  const opts = {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    mode: 'cors',
    body: JSON.stringify({ confirmZeroUncounted })
  };
  if(window._adminToken) opts.headers['Authorization'] = 'Bearer ' + window._adminToken;
  
  let lastEventData = null;
  let buffer = '';
  let runIdReceived = null;
  
  try {
    const res = await fetch(baseUrl + '/api/stocktake/sessions/' + sessionId + '/approve-stream', opts);
    
    if(!res.ok || !res.body){
      _closeStkProgressModal();
      const errText = await res.text().catch(() => '');
      toast('❌ ' + (errText || 'فشل الاتصال بـ stream'));
      return;
    }
    
    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    
    while(true){
      const { done, value } = await reader.read();
      if(done) break;
      
      buffer += decoder.decode(value, { stream: true });
      
      // split events بـ \n\n
      const events = buffer.split('\n\n');
      buffer = events.pop(); // الجزء الأخير لو مش كامل
      
      for(const ev of events){
        if(!ev.startsWith('data: ')) continue;
        const jsonStr = ev.slice(6).trim();
        if(!jsonStr) continue;
        
        let data;
        try { data = JSON.parse(jsonStr); } catch(e){ continue; }
        lastEventData = data;
        
        if(data.type === 'start'){
          runIdReceived = data.run_id;
          _updateStkProgress({ 
            done: 0, total: data.total, 
            message: data.total === 0 ? '✅ مفيش تغييرات' : `جاري رفع ${data.total} منتج...`
          });
        }
        else if(data.type === 'progress'){
          _updateStkProgress({
            done: data.done, total: data.total,
            item: data.item,
            status: data.status,
            error: data.error_message
          });
        }
        else if(data.type === 'confirmation_required'){
          // full mode + uncounted با stock
          _closeStkProgressModal();
          _showZeroUncountedConfirmModal({
            error: 'confirmation_required',
            mode: data.mode,
            message: data.message,
            total_count: data.total_count,
            total_impact_qty: data.total_impact_qty,
            total_impact_value: data.total_impact_value,
            uncounted_with_stock: data.uncounted_with_stock
          });
          return;
        }
        else if(data.type === 'done'){
          // أظهر النتيجة النهائية في الـ modal
          _finalizeStkProgress(data, sessionId);
          return;
        }
        else if(data.type === 'error'){
          _closeStkProgressModal();
          toast('❌ ' + (data.message || 'فشل'));
          return;
        }
      }
    }
    
    // الـ stream اقفل بدون done event
    if(lastEventData?.type !== 'done'){
      _closeStkProgressModal();
      toast('⚠️ الاتصال اتقطع');
    }
  } catch(e) {
    _closeStkProgressModal();
    toast('❌ ' + e.message);
  }
}


