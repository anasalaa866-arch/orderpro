        <input id="stk-scan-qty" class="form-input" type="number" value="1" min="1" style="width:70px;font-size:18px;text-align:center" title="الكمية المضافة لكل scan">
      </div>
      <div style="margin-top:8px;font-size:11px;color:var(--muted)">💡 كل scan بيزود الكمية بـ <strong>${1}</strong> (تقدر تغيره يمين)</div>
