function wlHandleExcelFile(input){
  const file = input.files[0];
  if(!file) return;
  
  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const data = new Uint8Array(e.target.result);
      const wb = XLSX.read(data, { type: 'array' });
      const sheet = wb.Sheets[wb.SheetNames[0]];
      const rows = XLSX.utils.sheet_to_json(sheet, { header: 1, raw: false });
      
      // استخرج الباركودات من العمود الأول (تخطّى الـ header لو موجود)
      const identifiers = [];
      for(let i = 0; i < rows.length; i++){
        const cell = rows[i][0];
        if(cell == null || cell === '') continue;
        const str = String(cell).trim();
        // skip headers بكلمات شائعة
        if(i === 0 && /barcode|باركود|sku|كود|product/i.test(str)) continue;
        identifiers.push(str);
      }
      
      wlShowImportPreview(identifiers);
    } catch(err){
      toast('❌ خطأ في قراءة الملف: ' + err.message, 'error');
    }
  };
  reader.readAsArrayBuffer(file);
}

