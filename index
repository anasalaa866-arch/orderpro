          <span>❌ ${risk.cancelledOrders} ملغي</span>
          <span>↩️ ${risk.refundedOrders} مرتجع</span>
        </div>
        ${risk.notes ? `<div style="margin-top:6px;padding:6px 8px;background:#fef9c3;border-radius:4px;font-size:11px;color:#713f12">📝 ${escapeHtml(risk.notes)}</div>` : ''}
      </div>
    `).join('');

    overlay.innerHTML = `
      <div style="background:var(--card);border-radius:12px;max-width:600px;width:100%;max-height:85vh;display:flex;flex-direction:column;box-shadow:0 25px 60px rgba(0,0,0,.4)">
        <div style="background:linear-gradient(135deg,#dc2626,#ef4444);color:white;padding:16px 20px;border-radius:12px 12px 0 0">
          <h3 style="margin:0;font-size:17px;display:flex;align-items:center;gap:8px">
            🚨 تحذير: عملاء بنسبة رفض عالية
          </h3>
          <div style="font-size:12px;opacity:.9;margin-top:4px">
            وجدنا <strong>${riskyList.length}</strong> عميل سيئ من إجمالي ${totalCount} طلب — هتوزع على <strong>${escapeHtml(courierName)}</strong>
          </div>
        </div>
        <div style="padding:14px 20px;overflow-y:auto;flex:1">
          <div style="font-size:13px;color:var(--muted);margin-bottom:12px">
            العملاء التاليين عندهم نسبة إلغاء/رفض أعلى من <strong>${_riskSettings.threshold}%</strong>:
          </div>
          ${riskyHtml}
        </div>
        <div style="padding:14px 20px;border-top:1px solid var(--border);display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end">
          <button class="btn btn-ghost btn-sm" id="risk-cancel-btn">❌ إلغاء التوزيع</button>
          <button class="btn btn-sm" style="background:#fbbf24;color:#78350f;font-weight:700" id="risk-exclude-btn">⚠️ استبعد السيئين، وزع الباقي</button>
          <button class="btn btn-sm" style="background:#dc2626;color:white;font-weight:700" id="risk-proceed-btn">⚡ وزع الكل بمسئوليتي</button>
        </div>
      </div>
    `;

    document.body.appendChild(overlay);

    const cleanup = () => overlay.remove();

    overlay.querySelector('#risk-cancel-btn').onclick = () => { cleanup(); resolve(false); };
    overlay.querySelector('#risk-proceed-btn').onclick = () => { cleanup(); resolve(true); };
    overlay.querySelector('#risk-exclude-btn').onclick = () => {
      // امسح الـ checkboxes للعملاء السيئين
      const riskyIds = new Set(riskyList.map(r => r.order.id));
      document.querySelectorAll('.assign-chk:checked').forEach(chk => {
        if(riskyIds.has(chk.value)) chk.checked = false;
      });
      cleanup();
      toast(`⚠️ تم استبعاد ${riskyList.length} عميل — اضغط توزيع تاني`);
      resolve(false); // لا توزع، خليه يضغط تاني
    };

    overlay.onclick = (e) => {
      if(e.target === overlay){ cleanup(); resolve(false); }
    };
  });
}

