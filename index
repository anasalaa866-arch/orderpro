// 🔧 v292: فقط الطلبات النشطة (status='جاري التوصيل') - مش تحت التسوية ولا أي حالة تانية
// 🔧 v293: استثناء طلبات بوسطة (هي ليها صفحتها)
function _getLateOrders(minDays){
  const now = Date.now();
  const cutoffMs = minDays * 24 * 60 * 60 * 1000;
  return orders.filter(o => {
    if (!o.courierId) return false;                            // لازم يكون مع مندوب
    if (o.status !== 'جاري التوصيل') return false;             // فقط النشطة - مش تحت التسوية ولا مكتمل ولا ملغي
    // استثني طلبات بوسطة
    if (o.isBosta || o.bostaId || o.courierId === 'bosta') return false;
    const created = new Date(o.createdAt || 0).getTime();
    if (!created) return false;
    return (now - created) >= cutoffMs;
  });
}

