function renderBatchesPage(){
  const container = document.getElementById('exp-products-container');
  if(!container) return;
  
  const search = ($('exp-search')?.value || '').toLowerCase().trim();
  let products = _batchesData.products || [];
  
  if(search){
    products = products.filter(p => 
      (p.product_title || '').toLowerCase().includes(search) ||
      (p.sku || '').toLowerCase().includes(search) ||
      (p.barcode || '').toLowerCase().includes(search)
    );
  }
  
  if($('exp-count')) $('exp-count').textContent = products.length + ' منتج';
  
  if(!products.length){
    container.innerHTML = `
      <div style="padding:50px;text-align:center;color:var(--muted)">
        <div style="font-size:40px;margin-bottom:10px">📦</div>
        <div style="font-weight:700;margin-bottom:6px">مفيش batches</div>
        <div style="font-size:12px">اضغط "+ Batch جديد" تبدأ تضيف منتجات بتواريخ صلاحية</div>
      </div>
    `;
    return;
  }
  
  container.innerHTML = products.map(p => {
    const batches = Array.isArray(p.batches) ? p.batches : [];
    const nearestExp = p.nearest_exp;
    const daysLeft = nearestExp ? Math.ceil((new Date(nearestExp) - new Date()) / (1000*60*60*24)) : null;
    const isUrgent = daysLeft !== null && daysLeft <= 60 && daysLeft >= 0;
    const isExpired = daysLeft !== null && daysLeft < 0;
    
    return `
      <div class="card" style="overflow:hidden;border-right:4px solid ${isExpired ? 'var(--danger)' : (isUrgent ? 'var(--warn)' : 'var(--success)')}">
        <!-- Header -->
        <div style="padding:14px 16px;background:var(--bg);display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap">
          <div style="flex:1;min-width:200px">
            <div style="font-weight:800;font-size:14px;color:var(--text)">📦 ${escapeHtml(p.product_title || '')}${p.variant_title ? ' - ' + escapeHtml(p.variant_title) : ''}</div>
            <div style="font-size:11px;color:var(--muted);font-family:monospace;margin-top:3px">
              ${p.sku ? 'SKU: ' + escapeHtml(p.sku) : ''}${p.sku && p.barcode ? ' · ' : ''}${p.barcode ? escapeHtml(p.barcode) : ''}
            </div>
          </div>
          <div style="display:flex;gap:10px;align-items:center;font-size:12px">
            <div style="text-align:center">
              <div style="color:var(--muted);font-size:10px">المجموع</div>
              <div style="font-weight:800;font-size:16px">${p.total_tracked || 0}</div>
            </div>
            <button class="btn btn-primary btn-xs" onclick='openAddBatchForProduct(${JSON.stringify({variant_id: p.variant_id, product_title: p.product_title, variant_title: p.variant_title, sku: p.sku, barcode: p.barcode}).replace(/'/g,"&apos;")})'>+ Batch</button>
          </div>
        </div>
        
        <!-- Batches list -->
        <div style="padding:0">
          ${batches.map((b, idx) => {
            const dLeft = b.daysLeft;
            const expColor = dLeft < 0 ? 'var(--danger)' : (dLeft <= 60 ? 'var(--warn)' : 'var(--success)');
            const expLabel = dLeft < 0 ? 'منتهي منذ ' + Math.abs(dLeft) + ' يوم' : 
                            dLeft === 0 ? 'النهاردة!' : 
                            'بعد ' + dLeft + ' يوم';
            const dateFmt = new Date(b.expDate).toLocaleDateString('ar-EG', {year:'numeric',month:'short',day:'numeric'});
            const isPending = b.status === 'depleted_pending';
            const isOldest = idx === 0 && b.status === 'active';
            
            return `
              <div style="padding:10px 16px;border-top:1px solid var(--border);display:grid;grid-template-columns:auto 1fr auto auto;gap:14px;align-items:center;font-size:12px;${isPending ? 'background:#fef3c7' : (isOldest ? 'background:#f0fdf4' : '')}">
                <div style="font-family:monospace;color:var(--muted);font-weight:700">#${b.id}</div>
                <div>
                  <div style="font-weight:700">${dateFmt}</div>
                  <div style="font-size:11px;color:${expColor};margin-top:2px">${expLabel}${isOldest ? ' · 🎯 الـ batch الأقدم' : ''}${isPending ? ' · ⚠️ منتظر تأكيد' : ''}</div>
                </div>
                <div style="text-align:center">
                  <div style="font-weight:800;font-size:14px;color:${b.currentQuantity === 0 ? 'var(--danger)' : 'var(--text)'}">${b.currentQuantity}</div>
                  <div style="font-size:10px;color:var(--muted)">من ${b.originalQuantity}</div>
                </div>
                <div style="display:flex;gap:4px">
                  <button class="btn btn-ghost btn-xs" onclick="editBatch(${b.id})" title="تعديل">✏️</button>
                  <button class="btn btn-ghost btn-xs" onclick="deleteBatch(${b.id})" style="color:var(--danger)" title="حذف">🗑️</button>
                </div>
              </div>
            `;
          }).join('')}
        </div>
      </div>
    `;
  }).join('');
}

