async function tpCreateBulkTransfer(){
  if(!_tpData) return;
  const items = Object.keys(_tpSelected)
    .filter(k => (_tpSelected[k] || 0) > 0)
    .map(k => ({ variantId: k, qty: _tpSelected[k] }));

  if(!items.length){ toast('⚠️ مفيش منتجات محددة'); return; }

  // تحقق: مفيش كمية أكبر من رصيد المصدر
  const overflows = [];
  items.forEach(it => {
    const p = (_tpData.plan || []).find(x => x.variant_id === it.variantId);
    if(p && it.qty > p.from_stock){
      overflows.push(`${p.product_title} (${it.qty} > رصيد ${p.from_stock})`);
    }
  });
  if(overflows.length){
    toast('⛔ كميات أكبر من رصيد المصدر:\n' + overflows.slice(0,3).join('\n'));
    return;
  }

  const totalQty = items.reduce((s, it) => s + it.qty, 0);
  const confirmed = confirm(
    `تأكيد إنشاء تحويل مجمّع؟\n\n` +
    `📤 من: ${_tpData.from.warehouse_name}\n` +
    `📥 إلى: ${_tpData.to.warehouse_name}\n` +
    `📦 عدد المنتجات: ${items.length}\n` +
    `🔢 إجمالي الكمية: ${totalQty} قطعة\n\n` +
    `هيتم إنشاء تحويل واحد فيه كل المنتجات المحددة.`
  );
  if(!confirmed) return;

  const btn = document.getElementById('tp-create-btn');
  if(btn){ btn.disabled = true; btn.textContent = '⏳ جاري الإنشاء...'; }

  try {
    const payload = {
      fromWarehouseId: _tpData.from.warehouse_id,
      toWarehouseId: _tpData.to.warehouse_id,
      notes: `تحويل مجمّع من ذكاء التحويلات (${new Date().toLocaleDateString('ar-EG')}) — ${items.length} منتج`,
      items
    };
    const r = await apiFetch('/api/transfers', 'POST', payload);
    if(r && (r.success || r.id)){
      toast(`✅ تم إنشاء التحويل: ${items.length} منتج · ${totalQty} قطعة`);
      // أعد التحليل عشان نشوف الأرصدة المحدّثة
      setTimeout(() => tpAnalyze(), 800);
    } else {
      toast('❌ ' + (r?.error || 'فشل الإنشاء'));
      if(btn){ btn.disabled = false; btn.textContent = '✅ أنشئ تحويل واحد بكل المحدد'; }
    }
  } catch(e){
    toast('❌ ' + e.message);
    if(btn){ btn.disabled = false; btn.textContent = '✅ أنشئ تحويل واحد بكل المحدد'; }
  }
}

