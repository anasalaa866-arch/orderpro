function selectExpiryProduct(product){
  _expSelectedProduct = product;
  
  // املأ الـ hidden fields
  if($('exp-name'))     $('exp-name').value     = product.product_title + (product.variant_title ? ' - ' + product.variant_title : '');
  if($('exp-sku'))      $('exp-sku').value      = product.sku || '';
  if($('exp-category')) $('exp-category').value = product.product_type || '';
  
  // فضي الـ search
  if($('exp-modal-search')) $('exp-modal-search').value = '';
  const resEl = document.getElementById('exp-search-results');
  if(resEl) resEl.style.display = 'none';
  
  showExpirySelected();
  
  // beep نجاح
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain); gain.connect(ctx.destination);
    osc.frequency.value = 800; gain.gain.value = 0.1;
    osc.start();
    setTimeout(() => { osc.stop(); ctx.close(); }, 100);
  } catch(e){}
  
  // focus على exp-date عشان أسرع flow
  setTimeout(() => {
    const dateInp = document.getElementById('exp-date');
    if(dateInp && !dateInp.value) dateInp.focus();
  }, 100);
}

function showExpirySelected(){
  const selEl = document.getElementById('exp-selected');
  const nameEl = document.getElementById('exp-selected-name');
  const infoEl = document.getElementById('exp-selected-info');
  
  if(!_expSelectedProduct || !selEl) return;
  
  const p = _expSelectedProduct;
  const fullName = (p.product_title || p.name || '') + (p.variant_title ? ' - ' + p.variant_title : '');
  
  if(nameEl) nameEl.textContent = fullName;
  if(infoEl){
    const parts = [];
    if(p.sku) parts.push('SKU: ' + p.sku);
    if(p.barcode) parts.push(p.barcode);
    if(p.product_type) parts.push('📂 ' + p.product_type);
    infoEl.textContent = parts.join(' · ');
  }
  selEl.style.display = 'block';
}

function clearExpirySelection(){
  _expSelectedProduct = null;
  ['exp-name','exp-sku','exp-category'].forEach(id => {
    const el = $(id);
    if(el) el.value = '';
  });
