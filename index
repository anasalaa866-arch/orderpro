let batchActive=false,batchOrders=[],batchIndex=0,batchName='',batchResults=[];

let _currentBatchCode = '';

// ===== AUTO BATCH MANAGEMENT =====
// النظام: في أي وقت فيه دفعة مفتوحة تلقائياً. لما تقفل يبدأ واحدة جديدة تلقائي.
function getTodayBatchDate(){
  const d = new Date();
  return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
}

// يحمّل الدفعة المفتوحة من السيرفر (يستدعى عند بدء التطبيق)
async function loadCurrentBatchFromServer(){
  if(!API_URL) return;
  try{
    const r = await apiFetch('/api/batches/current','GET');
    // 🛡️ لو الـ response undefined/null → اعتبرها خطأ، ما تمسحش البيانات المحلية
    if(r === null || r === undefined){
      console.warn('loadCurrentBatchFromServer: response فارغ — نحتفظ بالـ localStorage');
      return;
    }

    // 🔧 v241: الـ Backend (v131+) بيرجّع { batch: {...} }
    // الـ Backend القديم كان بيرجّع { code, date, ... } مباشرة
    const batchData = r.batch || r;

    if(batchData && batchData.code){
      // السيرفر عنده دفعة مفتوحة — استخدمها
      const serverBatch = { 
        code: batchData.code, 
        date: batchData.date, 
        status: batchData.status, 
        startedAt: batchData.startedAt 
      };
      localStorage.setItem('current_batch', JSON.stringify(serverBatch));
      _currentBatchCode = batchData.code;
      console.log('✅ Loaded current batch from server:', batchData.code);
    } else if(r.batch === null || (r && Object.keys(r).length === 0 && r.constructor === Object)) {
      // السيرفر أكد إنه مفيش دفعة مفتوحة
      const local = localStorage.getItem('current_batch');
      if(local){
        try{
          const l = JSON.parse(local);
          // لو الدفعة المحلية أحدث من 24 ساعة، نحترمها لحين تأكيد
          const ageHours = (Date.now() - new Date(l.startedAt || 0).getTime()) / (3600*1000);
          if(ageHours < 24){
            console.warn('🤔 السيرفر قال مفيش دفعة، بس الدفعة المحلية حديثة — نحتفظ بيها');
            return;
          }
        }catch(e){}
        console.log('🔄 Server has no open batch — clearing stale localStorage batch');
        localStorage.removeItem('current_batch');
        _currentBatchCode = null;
      }
    }
    updateBatchIndicator && updateBatchIndicator();
  }catch(e){
    console.warn('loadCurrentBatchFromServer failed:', e.message);
    // لا نمس الـ localStorage لو حصل خطأ
  }
}

// 🔧 v241: ensureCurrentBatch - الـ batch دلوقتي مركزي على الـ Backend
// كل الأجهزة بتشترك في نفس الـ current batch لتجنب inconsistency
// ensureCurrentBatch sync (للـ logic القديم - بيقرأ من cache localStorage)
function ensureCurrentBatch(){
  // أولاً جرب من cache المحلي (للسرعة)
  const today = getTodayBatchDate();
  try{
    const stored = JSON.parse(localStorage.getItem('current_batch')||'null');
    if(stored && stored.date === today && stored.status === 'open'){
      _currentBatchCode = stored.code;
      return stored;
    }
  }catch(e){}

  // مفيش cache صالح → ابني واحد محلي مؤقت (هيتعدّل من loadCurrentBatchFromServer)
  let dayCounter = 1;
  try{
    const history = JSON.parse(localStorage.getItem('batch_history')||'[]');
    const todayBatches = history.filter(b=>b.date===today);
    dayCounter = todayBatches.length + 1;
  }catch(e){}

  const code = 'B-'+today+'-'+String(dayCounter).padStart(2,'0');
  const batch = { code, date: today, status: 'open', startedAt: new Date().toISOString() };
  _currentBatchCode = code;
  try{
    localStorage.setItem('current_batch', JSON.stringify(batch));
    const history = JSON.parse(localStorage.getItem('batch_history')||'[]');
    history.push(batch);
    localStorage.setItem('batch_history', JSON.stringify(history));
  }catch(e){}

  // sync to server (fire-and-forget - الـ ensureCurrentBatchAsync بيهندله)
  if(API_URL) apiFetch('/api/batches','POST',batch).catch(()=>{});

  return batch;
}

// 🆕 v241: ensureCurrentBatchAsync - النسخة الـ async اللي بتسأل الـ Backend الأول
// لازم تتنادى قبل أي عملية توزيع عشان نضمن إن كل الأجهزة عندها نفس الـ batch
async function ensureCurrentBatchAsync(){
  if(!API_URL){
    return ensureCurrentBatch(); // offline mode - استخدم localStorage
  }
  
  try{
    // اسأل الـ Backend الأول - هل في batch مفتوح؟
    const r = await apiFetch('/api/batches/current');
    
    if(r && r.batch && r.batch.code){
      // فيه batch مفتوح على الـ Backend - استخدمه + حدّث الـ localStorage
      const batch = r.batch;
      _currentBatchCode = batch.code;
      try{
        localStorage.setItem('current_batch', JSON.stringify(batch));
        // حدّث الـ history لو مش موجود
        const history = JSON.parse(localStorage.getItem('batch_history')||'[]');
        if(!history.find(b => b.code === batch.code)){
          history.push(batch);
          localStorage.setItem('batch_history', JSON.stringify(history));
        }
      }catch(e){}
      return batch;
    }
    
    // مفيش batch مفتوح → ابني جديد على الـ Backend
    const today = getTodayBatchDate();
    let dayCounter = 1;
    try{
      // اسأل الـ Backend عن كل الـ batches بتاعت اليوم
      const allR = await apiFetch('/api/batches');
      if(allR && Array.isArray(allR)){
        const todayBatches = allR.filter(b => (b.code || '').includes(today));
        dayCounter = todayBatches.length + 1;
      }
    }catch(e){
      // fallback للـ localStorage
      const history = JSON.parse(localStorage.getItem('batch_history')||'[]');
      const todayBatches = history.filter(b=>b.date===today);
      dayCounter = todayBatches.length + 1;
    }
    
    const code = 'B-'+today+'-'+String(dayCounter).padStart(2,'0');
    const batch = { code, date: today, status: 'open', startedAt: new Date().toISOString() };
    
    // اعمل save على الـ Backend الأول (مهم!)
    const saveR = await apiFetch('/api/batches','POST',batch);
    if(saveR && saveR.batch){
      // الـ Backend ممكن يرجع batch بكود مختلف لو في race condition
      Object.assign(batch, saveR.batch);
    }
    
    _currentBatchCode = batch.code;
    try{
      localStorage.setItem('current_batch', JSON.stringify(batch));
      const history = JSON.parse(localStorage.getItem('batch_history')||'[]');
      if(!history.find(b => b.code === batch.code)){
        history.push(batch);
        localStorage.setItem('batch_history', JSON.stringify(history));
      }
    }catch(e){}
    
    return batch;
  }catch(e){
    console.warn('ensureCurrentBatchAsync failed, falling back to local:', e.message);
    return ensureCurrentBatch();
  }
}

// 🆕 v241: تحدث الـ batch من الـ Backend عند الـ login + كل دقيقتين
async function syncCurrentBatchFromServer(){
  if(!API_URL) return;
  try{
    const r = await apiFetch('/api/batches/current');
    if(r && r.batch && r.batch.code){
      _currentBatchCode = r.batch.code;
      localStorage.setItem('current_batch', JSON.stringify(r.batch));
    }
  }catch(e){}
}

