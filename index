      } else if(fCourierId === 'bosta' && o.is_bosta){
        cacheStatus += `\n⚠️ الطلب marked كـ bosta في الـ frontend (is_bosta=true في DB)`;
        cacheStatus += `\n💡 شوفه في tab "بوسطة" أو في صفحة "مخزن العبور"`;
      } else if(fStatus !== o.status){
        cacheStatus += `\n❌ STATUS MISMATCH! DB="${o.status}" frontend="${fStatus}"`;
      } else {
        // كل حاجة matching - يبقى موجود لكن مش ظاهر في tab معين
        cacheStatus += `\n✅ كل البيانات matching بين DB والـ frontend!\n`;
        
        if(fStatus === 'جاري التوصيل'){
          cacheStatus += `💡 المفروض يظهر في tab "📦 نشط" للمندوب ${courierName}`;
        } else if(fStatus === 'تحت التسوية'){
          cacheStatus += `💡 شوفه في tab "⏳ تحت التسوية" للمندوب`;
        } else if(fStatus === 'مكتمل'){
          cacheStatus += `💡 شوفه في tab "✅ مكتمل" للمندوب`;
        } else if(fStatus === 'مسوّى'){
          cacheStatus += `💡 الطلب مسوّى — مش بـ يظهر في الـ tabs العادية. شوف صفحة التسويات.`;
        } else {
          cacheStatus += `💡 status="${fStatus}" — مش في أي tab نموذجي. ممكن يكون في الـ tab "الكل".`;
        }
      }
    }
    
    const msg = 
      `🔍 تشخيص الطلب ${o.id}\n` +
      `${'─'.repeat(40)}\n\n` +
      `📦 العميل: ${o.name || '—'}\n` +
      `💰 المبلغ: ${o.total} ج\n` +
      `📅 من ${r.daysAgo} يوم (${orderDate})\n\n` +
      `🗄️  في DB:\n` +
      `  • courier_id: ${o.courier_id || 'null'} ${o.is_bosta ? '+ is_bosta=true' : ''}\n` +
      `  • status: "${o.status}"\n` +
      `  • المندوب: ${courierName}\n` +
      `  • المصدر: ${o.source_name || o.src || '—'}\n` +
      (o.merged_into ? `  • مدموج في: ${o.merged_into}\n` : '') +
      (o.settled_at ? `  • مسوّى في: ${new Date(o.settled_at).toLocaleString('ar-EG')}\n` : '') +
      cacheStatus;
    
    alert(msg);
    console.log('🔍 Order diagnosis:', { db: o, frontend: inFrontendCache, diagnosis: d });
  } catch(e){
    toast('❌ ' + e.message, 'error');
  }
}

function renderCourierOrdersPage(){
  const tabs = $('courier-tabs');
  const content = $('courier-orders-content');
  
  // 🆕 v374: اشمل أي user عنده طلبات حتى لو مش في الـ couriers list
  // (مثلاً: كاشير/مدير محل عمل توصيل بنفسه)
  const courierIdsWithOrders = new Set();
  orders.forEach(o => {
    if(o.courierId && o.courierId !== 'bosta'){
      courierIdsWithOrders.add(String(o.courierId));
    }
  });
  
  // ابني list موسعة: الـ couriers الأصليين + أي user عنده طلبات
  const knownCourierIds = new Set(couriers.map(c => String(c.id)));
  const orphanCourierIds = [...courierIdsWithOrders].filter(id => !knownCourierIds.has(id));
  
  // ابني displayCouriers
  const displayCouriers = [...couriers];
  for(const orphanId of orphanCourierIds){
    displayCouriers.push({
      id: parseInt(orphanId),
      name: `👤 #${orphanId}`,  // user مجهول لكن عنده طلبات
      phone: '—',
      role: 'unknown',
      _isOrphan: true
    });
  }
  
  if(!displayCouriers.length){
    content.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted)">لا يوجد مناديب أو مستخدمين عندهم طلبات</div>';
    return;
  }

  if(!activeCourierTab || !displayCouriers.find(c=>c.id==activeCourierTab)){
    activeCourierTab = displayCouriers[0].id;
