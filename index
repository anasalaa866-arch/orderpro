function _updateStkProgress(p){
  const st = window._stkProgState || { ok: 0, fail: 0, total: 0, done: 0, errors: [] };
  if(p.total != null) st.total = p.total;
  if(p.done != null) st.done = p.done;
  
  if(p.status === 'success') st.ok++;
  else if(p.status === 'failed'){
    st.fail++;
    if(p.item){
      st.errors.unshift({
        product_title: p.item.product_title,
        sku: p.item.sku,
        error: p.error || 'فشل'
      });
      if(st.errors.length > 30) st.errors.length = 30;
    }
  }
  
  const pct = st.total > 0 ? Math.round((st.done / st.total) * 100) : 0;
  const bar = document.getElementById('stk-prog-bar');
  const pctEl = document.getElementById('stk-prog-pct');
  const okEl = document.getElementById('stk-prog-ok');
  const failEl = document.getElementById('stk-prog-fail');
  const remainEl = document.getElementById('stk-prog-remain');
  const subEl = document.getElementById('stk-prog-sub');
  const currentEl = document.getElementById('stk-prog-current');
  
  if(bar) bar.style.width = pct + '%';
  if(pctEl) pctEl.textContent = pct + '%';
  if(okEl) okEl.textContent = st.ok;
  if(failEl) failEl.textContent = st.fail;
  if(remainEl) remainEl.textContent = Math.max(0, st.total - st.done);
  
  if(subEl){
    subEl.textContent = p.message || `${st.done} / ${st.total} منتج`;
  }
  
  if(p.item && currentEl){
    const status = p.status === 'success' ? '✓' : p.status === 'failed' ? '✗' : '⏳';
    const color = p.status === 'success' ? '#16a34a' : p.status === 'failed' ? '#dc2626' : 'var(--muted)';
    currentEl.innerHTML = `<span style="color:${color};font-weight:900;margin-left:6px">${status}</span> ${(p.item.product_title || '').slice(0,60)}${p.item.variant_title && p.item.variant_title !== 'Default Title' ? ` · ${p.item.variant_title}` : ''} <span style="color:var(--muted);font-size:10px;margin-right:8px">(${p.item.system_qty}→${p.item.counted_qty})</span>`;
  }
  
  // show errors list لو فيه فشل
  if(st.errors.length > 0){
    const errBox = document.getElementById('stk-prog-errors');
    const errList = document.getElementById('stk-prog-errors-list');
    if(errBox) errBox.style.display = 'block';
    if(errList){
      errList.innerHTML = st.errors.slice(0, 10).map(e => 
        `<div style="padding:3px 0;border-bottom:1px dashed var(--border)"><strong>${(e.product_title||'').slice(0,40)}</strong> <span style="color:var(--muted)">(${(e.sku||'').slice(0,15)})</span><br><span style="color:#dc2626;font-size:9px">${(e.error||'').slice(0,80)}</span></div>`
      ).join('');
    }
  }
  
  window._stkProgState = st;
}

function _finalizeStkProgress(data, sessionId){
  const ok = data.summary?.success_count || 0;
  const fail = data.summary?.failed_count || 0;
  const total = data.summary?.total_attempted || 0;
  const runId = data.summary?.run_id;
  // 🆕 v295: adjust-delta mode
  const updated = data.summary?.updated ?? data.updated ?? 0;
  const skipped = data.summary?.skipped || 0;
  
  const titleEl = document.getElementById('stk-prog-title');
  const subEl = document.getElementById('stk-prog-sub');
  const barEl = document.getElementById('stk-prog-bar');
  
  if(titleEl){
    titleEl.innerHTML = fail === 0 
      ? `<span style="color:#16a34a">✅ تم بنجاح</span>` 
      : `<span style="color:#f59e0b">⚠️ تم مع أخطاء</span>`;
  }
  if(subEl){
    let breakdown = `<strong>تم رفع الفروق على Shopify</strong><br>`;
    breakdown += `✅ ${updated} منتج اتعدّل`;
    if(skipped > 0) breakdown += ` · ⏭️ ${skipped} مفيش فرق`;
    if(fail > 0) breakdown += ` · ✗ ${fail} فشل`;
    subEl.innerHTML = breakdown;
  }
  if(barEl && fail > 0){
    barEl.style.background = 'linear-gradient(90deg,#f59e0b,#ef4444)';
  }
  
  // action buttons
  const actions = document.getElementById('stk-prog-actions');
  if(actions){
    actions.style.display = 'flex';
    let html = '';
    if(fail > 0){
      html += `<button class="btn btn-sm" style="background:#dc2626;color:#fff;border:none" onclick="openApprovalReport(${sessionId}, '${runId}'); _closeStkProgressModal()">📋 شوف الـ ${fail} منتج اللي فشل</button>`;
    } else {
      html += `<button class="btn btn-sm btn-primary" onclick="openApprovalReport(${sessionId}, '${runId}'); _closeStkProgressModal()">📊 تقرير كامل</button>`;
    }
    html += `<button class="btn btn-sm btn-ghost" onclick="_closeStkProgressModal()">إغلاق</button>`;
    actions.innerHTML = html;
  }
  
  // refresh الـ stocktake page في الخلفية
  closeM('m-stk-detail');
  loadStocktakePage().catch(()=>{});
}

function _closeStkProgressModal(){
  document.getElementById('stk-progress-modal')?.remove();
  window._stkProgState = null;
}

