  if(pass){
    // المستخدم كتب كلمة مرور جديدة - hash وحدّث
    passHash = await hashPass(pass);
    if(editingUsername){
      const oldUser = sysUsers.find(u => u.username === editingUsername);
      passwordChanged = oldUser && oldUser.passHash !== passHash;
