  // اختار مندوب افتراضي
  if(!_cdashActiveCourierId || !list.find(c => c.id === _cdashActiveCourierId)){
    _cdashActiveCourierId = list[0].id;
  }

  // ارسم الـ tabs
  tabsEl.innerHTML = list.map(c => {
