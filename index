    return;
  }
  const rows = _moLineItems.map((it, idx) => `
    <div style="display:flex;align-items:center;gap:8px;padding:8px;background:var(--card);border:1px solid var(--border);border-radius:7px;margin-bottom:4px">
      ${it.imageUrl ? `<img src="${escapeHtml(it.imageUrl)}" style="width:36px;height:36px;border-radius:5px;object-fit:cover">` : '<div style="width:36px;height:36px;background:#e5e7eb;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:14px">📦</div>'}
      <div style="flex:1;min-width:0">
        <div style="font-weight:700;font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escapeHtml(it.productTitle)}${it.variantTitle ? ' — '+escapeHtml(it.variantTitle) : ''}</div>
        <div style="font-size:10px;color:var(--muted)">SKU: ${escapeHtml(it.sku || '-')}</div>
      </div>
      <div style="display:flex;align-items:center;gap:4px">
        <button onclick="moChangeQty(${idx},-1)" style="width:24px;height:24px;border:1px solid var(--border);background:#fff;border-radius:5px;cursor:pointer;font-weight:700">-</button>
        <input type="number" min="1" value="${it.qty}" onchange="moSetQty(${idx},this.value)" style="width:50px;text-align:center;padding:3px;border:1px solid var(--border);border-radius:5px;font-family:Cairo,sans-serif;font-size:12px">
        <button onclick="moChangeQty(${idx},1)" style="width:24px;height:24px;border:1px solid var(--border);background:#fff;border-radius:5px;cursor:pointer;font-weight:700">+</button>
      </div>
      <input type="number" step="0.01" value="${parseFloat(it.price).toFixed(2)}" onchange="moSetPrice(${idx},this.value)" style="width:80px;padding:4px 6px;border:1px solid var(--border);border-radius:5px;font-family:Cairo,sans-serif;font-size:12px;text-align:left" title="السعر/قطعة">
      <span style="min-width:70px;text-align:left;font-weight:700;font-size:12px">${(it.qty * it.price).toFixed(0)} ج</span>
      <button onclick="moRemoveItem(${idx})" style="width:24px;height:24px;border:none;background:#fee2e2;color:#dc2626;border-radius:5px;cursor:pointer;font-weight:700">×</button>
