async function retrySync(saleId, btn){
  const originalText = btn.textContent;
  btn.disabled = true;
  btn.textContent = '⏳ جاري...';
  
  try {
    await apiFetch('/api/pos/sales/' + saleId + '/retry-sync', 'POST');
    toast('✅ تمت المزامنة', 'success');
    loadUnsyncedSales();
  } catch(e) {
    toast('❌ ' + e.message, 'error');
    btn.disabled = false;
    btn.textContent = originalText;
  }
}

async function retryAllUnsynced(){
  if(!confirm('إعادة مزامنة كل البيعات الفاشلة (حد أقصى 50)؟\n\nده ممكن ياخد دقيقة أو أكتر.')) return;
  
  toast('⏳ جاري المزامنة...', 'info');
  
  try {
    const r = await apiFetch('/api/pos/sales/retry-all-unsynced', 'POST');
    
    if(r.success > 0 && r.failed === 0){
      toast(`✅ تمت مزامنة ${r.success} بيعة بنجاح`, 'success');
    } else if(r.success > 0){
      toast(`⚠️ نجح ${r.success} وفشل ${r.failed}`, 'warning');
    } else {
      toast(`❌ فشل الكل (${r.failed})`, 'error');
    }
    
    loadUnsyncedSales();
  } catch(e) {
    toast('❌ ' + e.message, 'error');
  }
}

