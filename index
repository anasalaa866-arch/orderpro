function reorderResetFilters(){
  document.getElementById('reorder-f-search').value = '';
  document.getElementById('reorder-f-priority').value = '';
  document.getElementById('reorder-f-status').value = '';
  document.getElementById('reorder-f-sort').value = 'priority';
  _reorderFilters = { search: '', priority: '', status: '', sort: 'priority' };
  renderReorderTable();
}

// 🆕 v333: applyReorderFilters → بيرجع الـ filtered + sorted list مع indices أصلية
// (الـ indices أصلية مهمة عشان الـ inputs بتربط بـ idx في الـ array الأصلي)
function applyReorderFilters(){
  // ابني array من {product, originalIdx}
  let list = _reorderProducts.map((p, idx) => ({ p, idx }));
  
  // 1) Search
  if(_reorderFilters.search){
    const q = _reorderFilters.search;
    list = list.filter(({p}) => {
      const title = (p.product_title || '').toLowerCase();
      const variant = (p.variant_title || '').toLowerCase();
      const sku = (p.sku || '').toLowerCase();
      const barcode = (p.barcode || '').toLowerCase();
      return title.includes(q) || variant.includes(q) || sku.includes(q) || barcode.includes(q);
    });
  }
  
  // 2) Priority filter
  if(_reorderFilters.priority){
    list = list.filter(({p}) => {
      const lbl = p.priority_label || '';
      switch(_reorderFilters.priority){
        case 'critical': return lbl.includes('نفد') || lbl.includes('عاجل');
        case 'urgent':   return lbl.includes('قريب');
        case 'medium':   return lbl.includes('متوسط');
        case 'ok':       return lbl.includes('كافي');
        case 'dead':     return lbl.includes('راكد');
        default: return true;
      }
    });
  }
  
  // 3) Request status filter
  if(_reorderFilters.status){
    list = list.filter(({p}) => {
      switch(_reorderFilters.status){
        case 'requested':     return (p.requested_qty || 0) > 0;
        case 'not_requested': return (p.requested_qty || 0) === 0;
        case 'suggested':     return ((p.ai_suggested_qty != null ? p.ai_suggested_qty : p.suggested_qty) || 0) > 0;
        default: return true;
      }
    });
  }
  
  // 4) Sort
  const sortKey = _reorderFilters.sort;
  list.sort((a, b) => {
    const pa = a.p, pb = b.p;
    switch(sortKey){
      case 'priority':
        // اللي عنده priority_score أقل، يطلع فوق (نفس الـ default logic)
        return (pa.priority_score ?? 9999) - (pb.priority_score ?? 9999);
      case 'days_remaining_asc':
        return (parseFloat(pa.days_remaining) || 9999) - (parseFloat(pb.days_remaining) || 9999);
      case 'total_stock_asc':
        return (parseInt(pa.total_stock) || 0) - (parseInt(pb.total_stock) || 0);
      case 'avg_30d_desc':
        return (parseFloat(pb.avg_30d) || 0) - (parseFloat(pa.avg_30d) || 0);
      case 'suggested_desc': {
        const sa = (pa.ai_suggested_qty != null ? pa.ai_suggested_qty : pa.suggested_qty) || 0;
        const sb = (pb.ai_suggested_qty != null ? pb.ai_suggested_qty : pb.suggested_qty) || 0;
        return sb - sa;
      }
      case 'requested_desc':
        return (parseInt(pb.requested_qty) || 0) - (parseInt(pa.requested_qty) || 0);
      case 'title_asc':
        return (pa.product_title || '').localeCompare(pb.product_title || '');
      default:
        return 0;
    }
  });
  
  return list;
}

