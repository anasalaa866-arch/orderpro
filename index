          <button onclick="courierAccTogglePaid()" style="width:100%;padding:10px;border-radius:10px;border:1px dashed var(--accent);background:var(--accent-light);color:var(--accent);font-family:Cairo,sans-serif;font-weight:700;font-size:13px;cursor:pointer;margin-bottom:10px">💳 تحويل لمدفوع (لا تحصيل)</button>
        ` : currentPaid ? `
          <button onclick="courierAccTogglePaid()" style="width:100%;padding:8px;border-radius:10px;border:1px solid #16a34a;background:#dcfce7;color:#166534;font-family:Cairo,sans-serif;font-weight:700;font-size:12px;cursor:pointer;margin-bottom:10px">💳 مدفوع — اضغط للإلغاء</button>
        ` : ''}

        <div style="display:flex;gap:8px;justify-content:space-between">
          <button onclick="courierAccPrev()" ${s.index===0?'disabled':''} style="padding:10px 18px;border-radius:10px;border:1px solid var(--border);background:var(--card);font-family:Cairo,sans-serif;font-size:13px;cursor:${s.index===0?'not-allowed':'pointer'};opacity:${s.index===0?'.4':'1'}">← السابق</button>
          <button onclick="courierAccNext()" style="padding:10px 22px;border-radius:10px;border:none;background:var(--accent);color:#fff;font-family:Cairo,sans-serif;font-weight:700;font-size:13px;cursor:pointer">${s.index===s.orders.length-1?'عرض الملخص →':'التالي →'}</button>
