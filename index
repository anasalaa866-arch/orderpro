  const opts = _treasuries.map(t=>`<option value="${t.id}">${t.name}</option>`).join('');
  const dateStr = new Date(ts).toISOString().split('T')[0];

  const div = document.createElement('div');
  div.id = 'settle-treasury-popup';
  div.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:99999;display:flex;align-items:center;justify-content:center';
  div.innerHTML = `
    <div style="background:var(--card);border-radius:16px;padding:24px;width:min(400px,92vw);font-family:Cairo,sans-serif;direction:rtl">
      <div style="font-size:16px;font-weight:800;margin-bottom:4px">💰 إضافة للخزنة</div>
      <div style="font-size:12px;color:var(--muted);margin-bottom:16px">تسوية ${courierName} — صافي <strong style="color:var(--success)">${fmtAmt(net)} ج</strong></div>
      <div style="margin-bottom:12px">
        <label style="font-size:12px;font-weight:700;color:var(--muted);display:block;margin-bottom:4px">الخزنة</label>
        <select id="stt-treasury" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:8px;font-family:Cairo,sans-serif;font-size:13px">${opts}</select>
      </div>
      <div style="margin-bottom:12px">
        <label style="font-size:12px;font-weight:700;color:var(--muted);display:block;margin-bottom:4px">المبلغ</label>
        <input id="stt-amount" type="number" value="${net}" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:8px;font-family:Cairo,sans-serif;font-size:13px">
      </div>
      <div style="margin-bottom:16px">
        <label style="font-size:12px;font-weight:700;color:var(--muted);display:block;margin-bottom:4px">البيان</label>
        <input id="stt-reason" value="تسوية ${courierName}" style="width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:8px;font-family:Cairo,sans-serif;font-size:13px">
      </div>
      <div style="display:flex;gap:8px;justify-content:flex-end">
        <button onclick="document.getElementById('settle-treasury-popup').remove()" style="background:none;border:1px solid var(--border);border-radius:8px;padding:8px 18px;font-family:Cairo,sans-serif;cursor:pointer;font-size:13px">تخطي</button>
        <button onclick="confirmSettleToTreasury('${dateStr}')" style="background:var(--success);color:#fff;border:none;border-radius:8px;padding:8px 18px;font-family:Cairo,sans-serif;font-weight:700;font-size:13px;cursor:pointer">✅ إضافة للخزنة</button>
      </div>
    </div>`;
  document.body.appendChild(div);
}

function confirmSettleToTreasury(dateStr){
  const tId = document.getElementById('stt-treasury')?.value;
  const amount = parseFloat(document.getElementById('stt-amount')?.value)||0;
  const reason = document.getElementById('stt-reason')?.value.trim()||'تسوية مندوب';
  if(!tId||!amount){ toast('❗ اختر الخزنة والمبلغ'); return; }
  const tx = {id:Date.now()+'_tx', treasuryId:tId, type:'in', amount, reason, date:dateStr};
  _treasuryTx.push(tx);
  if(API_URL) apiFetch('/api/treasury-tx','POST',tx).catch(()=>{});
  document.getElementById('settle-treasury-popup')?.remove();
  if(_activeTreasuryId===tId) renderTreasuryTxList(tId);
  toast('✅ تم إضافة '+amount.toLocaleString()+' ج للخزنة');
}

function printCurrentSettle(){
  const c = couriers.find(x=>x.id==settlingCourierId);
  if(!c||!_currentSettleOrders.length){ toast('لا توجد طلبات'); return; }
  _doPrintSettle(c, _currentSettleOrders, true, null, {adj:window._settleAdj||[], adjTotal:(window._settleAdj||[]).reduce((s,a)=>s+a.amount,0)});
}

function printSettleSlip(cId){
  const c = couriers.find(x=>x.id==cId);
  if(!c) return;
  const pending = getPendingSettleOrders(cId);
  if(!pending.length){ toast('لا توجد طلبات جديدة'); return; }
  _doPrintSettle(c, pending, false);
}

function printHistorySettle(settlementId){
  const s = _allSettlements.find(x=>String(x.id)===String(settlementId));
  if(!s) return;
  const c = couriers.find(x=>String(x.id)===String(s.courierId));
  if(!c) return;
  // 🆕 v196: استخدم الـ orderIds المحفوظ في التسوية مباشرة، مش الـ status الحالي
  // لأن الـ status ممكن يتغير بعد التسوية (طلب يبقى مرتجع بدل مكتمل)
  // وده كان بيخلي عدد الطلبات في الـ PDF أقل من الفعلي
  const orderIdsInSettle = s.orderIds || [];

  // ابحث عن الطلبات المعرّفة في التسوية، حتى لو status اتغيّر دلوقتي
  const ordersFromSettle = orderIdsInSettle.map(id => orders.find(o => o.id === id)).filter(Boolean);

  // لو فيه طلبات مفقودة (مش في الـ orders array)، عرّف placeholder خفيف
  const foundIds = new Set(ordersFromSettle.map(o=>o.id));
  const missingIds = orderIdsInSettle.filter(id => !foundIds.has(id));
  if(missingIds.length){
    console.warn('Settlement', settlementId, '- missing orders:', missingIds);
    // أضف placeholder للطلبات المفقودة (بحد أدنى من البيانات)
    missingIds.forEach(id => {
      ordersFromSettle.push({
        id, name:'(بيانات غير متاحة)', area:'—', total:0, paid:false, ship:0, _missing:true
      });
    });
  }

  _doPrintSettle(c, ordersFromSettle, false, s.ts, {adj: s.adj||[], adjTotal: s.adjTotal||0});
}

