  const visibleCouriers = couriers.filter(c => {
    const r = c.role || 'courier';
    return r === 'courier' || r === 'shop';
  });
  visibleCouriers.forEach(c=>{
    const done=getPendingSettleOrders(c.id); // يشمل تحت التسوية + مكتمل غير مسوّى
    const activeOnly = oByC(c.id,'جاري التوصيل'); // طلبات شغالة لسه
    const hasActive = activeOnly.length > 0;
    const codOrders=done.filter(o=>!o.paid);
    const paidOrders=done.filter(o=>o.paid);
    const cod=codOrders.reduce((a,o)=>a+o.total,0);
    // 🔧 v238: استخدم getShipCost (اللي بيستخدم courier_ship_rates) بدل o.ship||50
    const ship=done.reduce((a,o)=>a+getShipCost(o,c),0);
    const doneNorm=done.filter(o=>deliveryType(o)==='normal'),doneExp=done.filter(o=>isSameDay(o)),donePick=done.filter(o=>isPickup(o));
    // 🔧 v238: نفس الإصلاح للعادي والمستعجل
    const shipNorm=doneNorm.reduce((a,o)=>a+getShipCost(o,c),0);
    const shipExp=doneExp.reduce((a,o)=>a+getShipCost(o,c),0);
    totCod+=cod;totShip+=ship;
    rows+=`<tr>
      <td><strong>${c.name}</strong><br><span style="font-size:10px;color:var(--muted)">${c.phone}</span></td>
      <td style="text-align:center">
        ${done.length} طلب<br>
        <span style="font-size:10px;color:var(--muted)">عادي: ${doneNorm.length} | سريع: ${doneExp.length}</span><br>
        ${hasActive?`<span style="font-size:10px;color:var(--warn)">🚴 ${activeOnly.length} جاري التوصيل</span>`:''}
        ${paidOrders.length?`<span style="font-size:10px;color:var(--success)">💳 مدفوع: ${paidOrders.length}</span>`:''}
      </td>
      <td class="mpos">
        ${cod.toLocaleString()} ج<br>
        ${paidOrders.length?`<span style="font-size:10px;color:var(--success)">+${paidOrders.reduce((a,o)=>a+o.total,0).toLocaleString()} ج مدفوع</span>`:''}
      </td>
      <td class="mwarn">
        ${shipNorm.toLocaleString()} ج عادي<br>
        <span style="font-size:10px;color:var(--danger)">+${shipExp.toLocaleString()} ج سريع</span>
      </td>
      <td class="mpos">${(cod-ship).toLocaleString()} ج</td>
      <td class="mpurp">${ship.toLocaleString()} ج</td>
      <td>${done.length>0?'<span class="badge b-wait">⏳ جاهزة للتسوية</span>':hasActive?'<span class="badge b-go">🚴 طلبات شغالة</span>':'<span class="badge b-done">✅ لا يوجد</span>'}</td>
      <td><div style="display:flex;gap:4px;flex-wrap:wrap">
        <button class="btn btn-xs" style="background:#4f46e5;color:#fff;border:none;font-size:11px" onclick="openCourierAccSession(${c.id})" title="محاسبة المندوب خطوة خطوة">📋 بدء محاسبة</button>
