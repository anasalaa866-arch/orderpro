function onSettleCashierChange(){
  const cashierId = $('settle-form-cashier').value;
  const infoEl = $('settle-form-info');
  const expectedEl = $('settle-form-expected');
  
  if(!cashierId){
    infoEl.style.display = 'none';
    return;
  }
  
  // ابحث في الـ pending cache
  const pending = _settlementsCache.pending.find(p => p.cashierId == cashierId);
  if(pending){
    const posCash = parseFloat(pending.posCash) || 0;
    const pickupCash = parseFloat(pending.pickupCash) || 0;
    const total = parseFloat(pending.totalCash) || 0;
    
    let breakdown = '';
    if(pickupCash > 0){
      breakdown = `
        <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px dashed #cbd5e1">
          <span>💰 بيعات POS:</span>
          <strong>${posCash.toLocaleString()} ج <span style="font-size:11px;color:var(--muted)">(${pending.posCount || 0} بيعة)</span></strong>
        </div>
        <div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px dashed #cbd5e1">
          <span>🏪 طلبات Pickup:</span>
          <strong style="color:#0891b2">${pickupCash.toLocaleString()} ج <span style="font-size:11px;color:var(--muted)">(${pending.pickupCount || 0} استلام)</span></strong>
        </div>
      `;
    }
    
    expectedEl.innerHTML = `
      ${breakdown}
      <div style="display:flex;justify-content:space-between;padding-top:6px;${breakdown ? 'margin-top:4px;border-top:2px solid #0369a1' : ''}">
        <span style="font-weight:700">إجمالي الكاش المتوقع:</span>
        <strong style="color:var(--danger);font-size:17px">${total.toLocaleString()} ج</strong>
      </div>
    `;
    // Auto-fill amount لو cash
    if($('settle-form-method').value === 'cash'){
      $('settle-form-amount').value = total.toFixed(2);
      onSettleAmountChange();
    }
  } else {
    expectedEl.innerHTML = `<div style="color:var(--muted)">مفيش بيعات لسه متصفّيتش لهذا الكاشير</div>`;
  }
  infoEl.style.display = '';
}

function onSettleAmountChange(){
  const cashierId = $('settle-form-cashier').value;
  const amount = parseFloat($('settle-form-amount').value) || 0;
  const diffEl = $('settle-form-diff');
  
  if(!cashierId || !amount){
    diffEl.textContent = '';
    return;
  }
  
  const pending = _settlementsCache.pending.find(p => p.cashierId == cashierId);
  if(!pending){
    diffEl.textContent = '';
    return;
  }
  
  const expected = parseFloat(pending.totalCash) || 0;
  const diff = amount - expected;
  
  if(Math.abs(diff) < 1){
    diffEl.innerHTML = `<span style="color:var(--success)">✓ المبلغ مظبوط</span>`;
  } else if(diff > 0){
    diffEl.innerHTML = `<span style="color:#0891b2">⚠️ زيادة: +${diff.toLocaleString()} ج</span>`;
  } else {
    diffEl.innerHTML = `<span style="color:var(--danger)">⚠️ نقصان: ${diff.toLocaleString()} ج</span>`;
  }
}

async function saveSettlement(){
  const cashierId = $('settle-form-cashier').value;
  const amount = parseFloat($('settle-form-amount').value);
  const method = $('settle-form-method').value;
  const notes = $('settle-form-notes').value.trim();
  
  if(!cashierId){ toast('❗ اختر كاشير', 'warning'); return; }
  if(!amount || amount <= 0){ toast('❗ أدخل المبلغ', 'warning'); return; }
  
  try {
    const r = await apiFetch('/api/cashier-settlements', 'POST', {
      cashierId: parseInt(cashierId),
      amount,
      method,
      notes: notes || null
    });
    
    if(r.success){
      toast('✅ تم تسجيل التصفية', 'success');
      closeM('m-new-settlement');
      loadCashierSettlements();
    } else {
      toast('❌ ' + (r.error || 'فشل الحفظ'), 'error');
    }
  } catch(e) {
    toast('❌ ' + e.message, 'error');
  }
}

