async function savePayable(){
  const title = $('payable-title').value.trim();
  const payee = $('payable-payee').value.trim();
  const category = $('payable-category').value;
  const amount = parseFloat($('payable-amount').value);
  const due_date = $('payable-due-date').value;
  const notes = $('payable-notes').value.trim();
  const is_recurring = $('payable-recurring').checked;
  const recurrence_type = $('payable-recurrence-type').value;
  const recurrence_interval = parseInt($('payable-recurrence-interval').value) || 1;
  const recurrence_end_date = $('payable-recurrence-end').value || null;
  const auto_generate_instances = $('payable-auto-generate').checked;

  if(!title){ toast('❗ العنوان مطلوب'); return; }
  if(!amount || amount <= 0){ toast('❗ المبلغ غير صحيح'); return; }
  if(!due_date){ toast('❗ تاريخ الاستحقاق مطلوب'); return; }

  try {
    if(_editingPayableId){
      const r = await apiFetch('/api/payables/' + _editingPayableId, 'PATCH', {
        title, payee, category, amount, due_date, notes
      });
      if(r?.success){
        toast('✅ تم التعديل');
        closeM('m-payable');
        loadPayables();
      } else toast('❌ ' + (r?.error || 'فشل'));
    } else {
      const r = await apiFetch('/api/payables', 'POST', {
        title, payee, category, amount, due_date, notes,
        is_recurring, recurrence_type, recurrence_interval, recurrence_end_date,
        auto_generate_instances
      });
      if(r?.success){
        const msg = r.generatedCount > 0
          ? `✅ تم - مع ${r.generatedCount} دفعة جاية`
          : '✅ تم';
        toast(msg);
        closeM('m-payable');
        loadPayables();
      } else toast('❌ ' + (r?.error || 'فشل'));
    }
  } catch(e){ toast('❌ ' + e.message); }
}

