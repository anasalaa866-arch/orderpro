async function approvePaymentReview(id){
  if(!confirm('موافقة على تحويل الطلب لمدفوع؟\n\nالطلب هيعتبر مدفوع وهتتحدث حسابات المندوب.')) return;
  try{
    const r = await apiFetch('/api/pending-reviews/'+id+'/approve','POST',{
      reviewedBy: currentUser?.username || 'admin'
    });
    if(r && r.success){
      toast('✅ تم الاعتماد');
      loadStarsReviews();
      loadOrders();
      return;
    }

    // الـ response جالى null أو success=false — تأكد من السيرفر إن الموافقة فعلاً اتحفظت
    // ده بيحصل أحياناً بسبب انقطاع شبكة بسيط بين الـ request والـ response
    // المراجعة ممكن تكون اتنفّذت في السيرفر بنجاح، فنتحقق
    try{
      const allReviews = await apiFetch('/api/pending-reviews','GET');
      if(allReviews){
        const stillPending = (allReviews.reviews || allReviews || []).find(rv =>
          String(rv.id) === String(id) && rv.status === 'pending'
        );
        if(!stillPending){
          // الموافقة اتحفظت فعلاً — كان فيه noise في الشبكة بس
          toast('✅ تم الاعتماد');
          loadStarsReviews();
          loadOrders();
          return;
        }
      }
    }catch(verifyErr){ /* لو حتى التحقق فشل، نعرض الفشل */ }

    toast('❌ فشل العملية — حاول تاني');
  }catch(e){ toast('❌ '+e.message); }
}

