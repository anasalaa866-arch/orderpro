function dsInit(){
  const sel=$('ds-courier-sel');
  if(!sel) return;

  const activeOrders=orders.filter(o=>o.status==='جاري التوصيل'&&!isTransit(o));

  if(!activeOrders.length && !couriers.length){
    sel.innerHTML='<option>لا توجد طلبات نشطة</option>';
    if($('ds-sheet'))$('ds-sheet').innerHTML='<div style="padding:40px;text-align:center;color:var(--muted)">لا توجد طلبات جاري التوصيل</div>';
    return;
  }

  const activeCidSet = new Set(activeOrders.map(o=>String(o.courierId||'')).filter(x=>x&&x!=='null'&&x!=='bosta'));

  const withOrders = couriers.filter(c=>activeCidSet.has(String(c.id)));
  const withoutOrders = couriers.filter(c=>!activeCidSet.has(String(c.id)));

  const knownCourierIds = new Set(couriers.map(c=>String(c.id)));
  const orphanIds = [...activeCidSet].filter(id=>!knownCourierIds.has(id));

  let opts = '';

  opts += withOrders.map(c=>{
    const cnt = activeOrders.filter(o=>String(o.courierId)===String(c.id)||Number(o.courierId)===Number(c.id)).length;
    return `<option value="${c.id}">${c.name} — ${cnt} طلب</option>`;
  }).join('');

  opts += withoutOrders.map(c=>`<option value="${c.id}">${c.name}</option>`).join('');

  opts += orphanIds.map(id=>{
    const cnt = activeOrders.filter(o=>String(o.courierId)===id).length;
    return `<option value="${id}">مندوب #${id} — ${cnt} طلب</option>`;
  }).join('');

  const bostaCnt = activeOrders.filter(o=>o.isBosta||String(o.courierId)==='bosta').length;
  if(bostaCnt>0) opts += `<option value="bosta">🚚 بوسطة (${bostaCnt})</option>`;

  sel.innerHTML = opts || '<option>لا توجد طلبات</option>';
  dsRender();
}

