    if(!data.topProducts.length){
      topProducts.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">مفيش بيانات كافية</div>';
    } else {
      topProducts.innerHTML = data.topProducts.map((p, i) => `
        <div style="display:flex;align-items:center;gap:10px;padding:10px;border-bottom:1px solid var(--border)">
          <div style="font-size:18px;font-weight:800;color:${i===0?'#f59e0b':i===1?'#94a3b8':i===2?'#a16207':'var(--muted)'}">#${i+1}</div>
          <div style="flex:1;min-width:0">
            <div style="font-weight:700;font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="${escapeAttr(p.name)}">${escapeHtml(p.name)}</div>
            <div style="font-size:10px;color:var(--muted)">${p.count} مرة · ${Math.round(p.revenue).toLocaleString()} ج</div>
          </div>
        </div>
      `).join('');
    }
  }
  
  // Top areas
  const topAreas = document.getElementById('sd-top-areas');
  if(topAreas){
    if(!data.topAreas.length){
      topAreas.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">مفيش بيانات</div>';
    } else {
      topAreas.innerHTML = data.topAreas.map((a, i) => `
        <div style="display:flex;align-items:center;gap:10px;padding:10px;border-bottom:1px solid var(--border)">
          <div style="font-size:18px">${['🥇','🥈','🥉','4️⃣','5️⃣'][i]||'📍'}</div>
          <div style="flex:1;min-width:0">
            <div style="font-weight:700;font-size:13px">${escapeHtml(a.area)}</div>
            <div style="font-size:10px;color:var(--muted)">${a.orders} طلب · ${Math.round(a.revenue).toLocaleString()} ج</div>
          </div>
        </div>
      `).join('');
    }
  }
  
  // Monthly comparison
  setText('sd-this-month-rev', Math.round(data.monthly.thisMonthRevenue).toLocaleString() + ' ج');
  setText('sd-this-month-orders', data.monthly.thisMonthOrders);
  setText('sd-last-month-rev', Math.round(data.monthly.lastMonthRevenue).toLocaleString() + ' ج');
  setText('sd-last-month-orders', data.monthly.lastMonthOrders);
  
  const growthEl = document.getElementById('sd-monthly-growth');
  const growthCard = document.getElementById('sd-monthly-growth-card');
  if(growthEl && growthCard){
    const g = data.monthly.growthPct;
    const isUp = g >= 0;
    growthEl.textContent = (isUp ? '↑ +' : '↓ ') + Math.abs(g) + '%';
