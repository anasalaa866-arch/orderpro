          <div style="font-weight:800;font-size:14px;color:#78350f">شيفتات قفلها الكاشير ومستنية المدير يصفّيها (${_pendingSessions.length})</div>
          <div style="font-size:11px;color:#92400e;margin-top:2px">دي مش في الـ DB كـ settlements بعد - المدير لازم يدخل Stars ويصفّيها عشان تظهر هنا كتصفية كاملة</div>
        </div>
      </div>
      ${sessionsHtml}
    </div>
  `;
}

function renderPendingSessionCard(s){
  const closedAt = s.cashier_closed_at ? new Date(s.cashier_closed_at) : null;
  const closedStr = closedAt ? closedAt.toLocaleString('ar-EG', { dateStyle: 'short', timeStyle: 'short' }) : '—';
  const totalAmt = parseFloat(s.total_amount || 0);
  const cashAmt = parseFloat(s.by_method?.cash?.total || 0);
  const visaAmt = parseFloat(s.by_method?.visa?.total || 0);
  const instaAmt = parseFloat(s.by_method?.instapay?.total || 0);
  
  const hours = s.hours_since_closed || 0;
  const days = Math.floor(hours / 24);
  const remHours = hours % 24;
  const sinceStr = days > 0 ? `${days} يوم ${remHours}س` : `${hours}س`;
  
  // اللون يتغير حسب لما اتأخر
  const urgencyColor = hours > 48 ? '#dc2626' : hours > 24 ? '#ea580c' : '#d97706';
  const urgencyBg = hours > 48 ? '#fee2e2' : hours > 24 ? '#ffedd5' : '#fef3c7';
  
  return `
    <div class="card" style="margin-bottom:10px;border-right:4px solid ${urgencyColor};background:linear-gradient(to left, ${urgencyBg} 0%, transparent 30%)">
      <div class="card-body" style="padding:12px">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:10px">
          <div style="flex:1">
            <div style="font-weight:800;font-size:14px">
              👤 ${escapeHtml(s.cashier_name || '-')} 
              <span style="font-size:10px;background:${urgencyColor};color:#fff;padding:2px 6px;border-radius:99px;margin-right:4px">🟡 مستني المدير</span>
            </div>
            <div style="font-size:11px;color:var(--muted);margin-top:3px">🏪 ${escapeHtml(s.store_name || '-')} · 🔒 قفل من ${closedStr} · ⏱️ منذ ${sinceStr}</div>
            <div style="font-size:11px;color:var(--muted);margin-top:2px">
              ${s.sales_count || 0} بيعة POS
              ${s.pickup_count > 0 ? ` · 📦 ${s.pickup_count} pickup` : ''}
              · إجمالي: <strong style="color:var(--text)">${totalAmt.toLocaleString()} ج</strong>
            </div>
          </div>
        </div>
        
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:8px;margin-bottom:10px">
          ${cashAmt > 0 ? `
            <div style="background:#fff;border:1px solid #fbbf24;border-radius:8px;padding:8px">
              <div style="font-size:10px;color:#78350f;font-weight:700">💵 كاش (بيعات)</div>
              <div style="font-size:15px;font-weight:900;color:#d97706">${cashAmt.toLocaleString()} ج</div>
              ${s.counted_cash !== null && s.counted_cash !== undefined ? `
                <div style="font-size:9px;color:var(--muted);margin-top:2px">عدّ الكاشير: <strong>${parseFloat(s.counted_cash).toLocaleString()} ج</strong></div>
              ` : ''}
            </div>
          ` : ''}
          ${visaAmt > 0 ? `
            <div style="background:#fff;border:1px solid #c7d2fe;border-radius:8px;padding:8px">
              <div style="font-size:10px;color:#312e81;font-weight:700">💳 فيزا</div>
              <div style="font-size:15px;font-weight:900;color:#6366f1">${visaAmt.toLocaleString()} ج</div>
              ${s.counted_visa !== null && s.counted_visa !== undefined ? `
                <div style="font-size:9px;color:var(--muted);margin-top:2px">عدّ الكاشير: <strong>${parseFloat(s.counted_visa).toLocaleString()} ج</strong></div>
              ` : ''}
            </div>
          ` : ''}
          ${instaAmt > 0 ? `
            <div style="background:#fff;border:1px solid #c7d2fe;border-radius:8px;padding:8px">
              <div style="font-size:10px;color:#312e81;font-weight:700">📱 انستاباي</div>
