      bulkActivateTrack(r.jobId);
    } else {
      toast('❌ ' + (r?.error || 'فشل بدء العملية'));
    }
  } catch(e){
    toast('❌ ' + e.message);
  }
}

async function bulkActivateCheckActive(){
  if(!API_URL) return;
  try {
    const r = await apiFetch('/api/admin/bulk-activate-locations');
    const running = (r?.jobs || []).find(j => j.status === 'running');
    if(running) bulkActivateTrack(running.id);
  } catch(e){}
}

function bulkActivateTrack(jobId){
  const card = document.getElementById('bulk-activate-card');
  if(card) card.style.display = 'block';
  if(_bulkActivatePoll) clearInterval(_bulkActivatePoll);

  const poll = async () => {
    try {
      const r = await apiFetch('/api/admin/bulk-activate-locations/' + jobId);
      if(!r || !r.job) return;
      const j = r.job;
      const bar = document.getElementById('bulk-activate-bar');
      const stats = document.getElementById('bulk-activate-stats');
      const title = document.getElementById('bulk-activate-title');
      const note = document.getElementById('bulk-activate-note');

      // مفيش total معروف مسبقاً (بنعدّ بالـ processed)، فنعرض عدّاد بدل %
      if(stats) stats.textContent = `عُولج ${j.processed} منتج · ✅ ${j.activated} تفعيل · ⏭️ ${j.skipped} · ❌ ${j.failed}`;

      if(j.status === 'done'){
        if(bar) bar.style.width = '100%';
        if(title) title.textContent = '✅ خلص تفعيل المخازن';
        if(note) note.textContent = `تم تفعيل ${j.activated} (منتج×مخزن). دلوقتي اعمل "🔁 مزامنة كاملة" عشان الكميات تظهر.`;
        clearInterval(_bulkActivatePoll);
        _bulkActivatePoll = null;
        toast(`✅ خلص: ${j.activated} تفعيل`);
      } else {
        // progress تقديري: بنحرّك الـ bar تدريجياً (مفيش total دقيق)
        if(bar){
          const cur = parseFloat(bar.style.width) || 5;
          bar.style.width = Math.min(95, cur + 2) + '%';
        }
        if(title) title.textContent = '🏬 جاري تفعيل المخازن...';
        if(note && j.last_error) note.textContent = '⚠️ آخر تنبيه: ' + j.last_error;
      }
    } catch(e){}
  };
  poll();
  _bulkActivatePoll = setInterval(poll, 4000);
}

async function showProductHistory(variantId, productTitle){
  try{
    const txs = await apiFetch('/api/inventory/transactions/' + encodeURIComponent(variantId)) || [];
    const html = txs.length ? txs.map(t => {
