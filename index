// تصدير شيكات الدفتر لـ Excel
function exportBookExcel(bookId){
  const b = chkBooks.find(x=>x.id===bookId);
  if(!b) return;
  const checks = chkList.filter(c=>c.bookId===bookId).sort((a,b)=>(parseInt(a.num)||0)-(parseInt(b.num)||0));
  if(!checks.length){ toast('❗ لا توجد شيكات للتصدير'); return; }

  const rows = [
    ['دفتر:', b.name + (b.bank?' — '+b.bank:'')],
    ['عدد الشيكات:', checks.length],
    [],
    ['#','رقم الشيك','لصالح','القيمة','الاستحقاق','فاتورة','الحالة','ملاحظات'],
    ...checks.map((c,i)=>[
      i+1,
      c.num||'',
      c.payee||'',
      Number(c.amount||0),
      c.date||'',
      c.invoice||'',
      c.status==='done'?'مصروف':(chkIsOverdue(c)?'متأخر':'لم يُصرف'),
      c.note||''
    ])
  ];
  const ws = XLSX.utils.aoa_to_sheet(rows);
  ws['!cols'] = [{wch:5},{wch:14},{wch:25},{wch:14},{wch:14},{wch:18},{wch:14},{wch:30}];
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, b.name.slice(0,30));
  XLSX.writeFile(wb, 'دفتر_'+b.name.replace(/[^\u0600-\u06FFa-zA-Z0-9_]/g,'_')+'.xlsx');
  toast('✅ تم التصدير');
}

