}

function moChangeQty(idx, delta){
  if(!_moLineItems[idx]) return;
  _moLineItems[idx].qty = Math.max(1, _moLineItems[idx].qty + delta);
  renderMOProducts();
}

function moSetQty(idx, val){
  if(!_moLineItems[idx]) return;
  _moLineItems[idx].qty = Math.max(1, parseInt(val) || 1);
  renderMOProducts();
}

function moSetPrice(idx, val){
  if(!_moLineItems[idx]) return;
  _moLineItems[idx].price = Math.max(0, parseFloat(val) || 0);
  renderMOProducts();
}

function moRemoveItem(idx){
  _moLineItems.splice(idx, 1);
  renderMOProducts();
}

