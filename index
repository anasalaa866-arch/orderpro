        <div>مفيش منتجات</div>
        <div style="font-size:11px;margin-top:4px;color:#8c9196">امسح باركود من فوق، أو اضغط "➕ إضافة منتج" للبحث بالاسم</div>
      </div>
    `;
    return;
  }
  
  // 🆕 v337: Shopify-style table layout
