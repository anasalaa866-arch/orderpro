// 🆕 v400: progress bar للمزامنة
let _syncPoll = null;
function syncTrackJob(jobId){
  const card = document.getElementById('sync-progress-card');
  if(card) card.style.display = 'block';
  if(_syncPoll) clearInterval(_syncPoll);

  const poll = async () => {
    try {
      const r = await apiFetch('/api/inventory/sync/' + jobId);
      if(!r || !r.job) return;
      const j = r.job;
      const bar = document.getElementById('sync-progress-bar');
      const title = document.getElementById('sync-progress-title');
      const stats = document.getElementById('sync-progress-stats');

      const kindLabel = j.kind === 'full' ? 'مزامنة كاملة' : 'مزامنة الكميات';

      if(j.status === 'running'){
        if(title) title.textContent = `🔄 ${kindLabel} — ${j.phase || '...'}`;
        const parts = [];
        if(j.products_synced) parts.push(`${j.products_synced} منتج`);
        if(j.levels_synced) parts.push(`${j.levels_synced} كمية`);
        if(j.warehouses_synced) parts.push(`${j.warehouses_synced} مخزن`);
        if(stats) stats.textContent = parts.join(' · ') || 'بدء...';
        // progress تقديري بالمرحلة (مفيش total دقيق)
        if(bar){
          let pct = 5;
          if(j.phase === 'المخازن') pct = 10;
          else if(j.phase === 'المنتجات') pct = 40;
          else if(j.phase === 'الكميات') pct = 75;
          const cur = parseFloat(bar.style.width) || 0;
          bar.style.width = Math.max(cur, pct) + '%';
        }
      } else if(j.status === 'done'){
        if(bar) bar.style.width = '100%';
        if(title) title.textContent = `✅ خلصت ${kindLabel}`;
        if(stats) stats.textContent = `${j.products_synced||0} منتج · ${j.levels_synced||0} كمية · ${j.duration_sec||0}s`;
        clearInterval(_syncPoll); _syncPoll = null;
        toast(`✅ خلصت المزامنة في ${j.duration_sec||0}s`);
        // حدّث الصفحة
        if(typeof loadInventoryPage === 'function') loadInventoryPage();
        else if(typeof refreshInventoryItems === 'function') refreshInventoryItems();
        // اخفي الكارت بعد 5 ثواني
        setTimeout(() => { if(card) card.style.display = 'none'; }, 5000);
      } else if(j.status === 'error'){
        if(title) title.textContent = '❌ فشلت المزامنة';
        if(stats) stats.textContent = j.error || '';
        if(bar) bar.style.background = '#ef4444';
        clearInterval(_syncPoll); _syncPoll = null;
        toast('❌ فشلت المزامنة: ' + (j.error || ''));
      }
    } catch(e){}
  };
  poll();
  _syncPoll = setInterval(poll, 2000);
}

