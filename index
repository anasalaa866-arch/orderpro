// لحل مشكلة الـ race condition لما نوزع طلبات بسرعة
const _shopifyQueue = [];
let _shopifyProcessing = false;
let _shopifyQueueStats = { pending: 0, done: 0, failed: 0 };
const _shopifyFailedOrders = []; // قائمة الطلبات اللي فشلت

function _updateShopifyQueueBadge(){
  const el = document.getElementById('shopify-queue-badge');
  if(_shopifyQueueStats.pending === 0 && _shopifyQueueStats.done === 0 && _shopifyQueueStats.failed === 0){
    if(el) el.remove();
    return;
  }
  if(!el){
    const badge = document.createElement('div');
    badge.id = 'shopify-queue-badge';
    badge.style.cssText = 'position:fixed;bottom:20px;left:20px;background:#fff;border:2px solid #96bf48;border-radius:12px;padding:12px 16px;box-shadow:0 4px 12px rgba(0,0,0,.15);z-index:9999;font-family:Cairo,sans-serif;font-size:12px;min-width:220px;max-width:320px';
    document.body.appendChild(badge);
  }
  const b = document.getElementById('shopify-queue-badge');
  if(!b) return;
  let html = `<div style="font-weight:700;color:#96bf48;margin-bottom:4px;display:flex;justify-content:space-between;align-items:center">
    <span>🛍️ Shopify Sync</span>
    <span onclick="this.parentElement.parentElement.remove()" style="cursor:pointer;color:var(--muted);font-size:14px;padding:0 4px">✕</span>
  </div>
  <div style="font-size:11px;color:var(--muted);line-height:1.8">`;

  if(_shopifyQueueStats.pending > 0) html += `⏳ ${_shopifyQueueStats.pending} في الانتظار<br>`;
  if(_shopifyQueueStats.done > 0) html += `✅ ${_shopifyQueueStats.done} تم<br>`;
  if(_shopifyQueueStats.failed > 0){
    html += `<span style="color:var(--danger);font-weight:700">❌ ${_shopifyQueueStats.failed} فشل</span>`;
    if(_shopifyFailedOrders.length){
      html += ` <button onclick="showShopifyFailures()" style="font-size:10px;padding:2px 8px;background:var(--danger);color:#fff;border:none;border-radius:4px;cursor:pointer;margin-right:4px">عرض</button>`;
      html += ` <button onclick="retryShopifyFailures()" style="font-size:10px;padding:2px 8px;background:var(--warn);color:#fff;border:none;border-radius:4px;cursor:pointer">إعادة محاولة</button>`;
    }
  }

  html += '</div>';
  b.innerHTML = html;

  // شيل الـ badge بعد 10 ثواني من الانتهاء (بس لو مفيش failures)
  if(_shopifyQueueStats.pending === 0 && _shopifyQueueStats.failed === 0){
    setTimeout(() => {
      _shopifyQueueStats = { pending: 0, done: 0, failed: 0 };
      const el = document.getElementById('shopify-queue-badge');
      if(el) el.remove();
    }, 10000);
  }
}

function showShopifyFailures(){
  if(!_shopifyFailedOrders.length){ toast('✅ لا توجد طلبات فاشلة'); return; }
  const list = _shopifyFailedOrders.map(t => {
    const errDetail = t.lastError ? `\n   ↳ السبب: ${t.lastError.slice(0,200)}` : '';
    return `• ${t.order.id} — ${t.order.name} → ${t.courierName}${errDetail}`;
  }).join('\n\n');
  infoModal('⚠️ طلبات Shopify فشلت', list + '\n\n💡 ممكن تعيد المحاولة من الـ badge، أو تشوف تفاصيل أكتر في Console (F12).', { pre: true });
}

function retryShopifyFailures(){
  if(!_shopifyFailedOrders.length){ toast('✅ لا توجد طلبات فاشلة'); return; }
  const count = _shopifyFailedOrders.length;
  _shopifyFailedOrders.forEach(task => {
    task.attempts = 0; // رجّع العداد
    _shopifyQueue.push(task);
    _shopifyQueueStats.pending++;
  });
  _shopifyQueueStats.failed = 0;
  _shopifyFailedOrders.length = 0;
  _updateShopifyQueueBadge();
  _processShopifyQueue();
  toast(`🔄 إعادة محاولة ${count} طلب`);
}

async function _processShopifyQueue(){
  if(_shopifyProcessing) return;
  _shopifyProcessing = true;

  while(_shopifyQueue.length > 0){
    const task = _shopifyQueue.shift();
    task.attempts = (task.attempts || 0) + 1;
    let success = false;
    try{
      const r = await _doShopifyFulfill(task.order, task.courierName);
      if(r && r.success){
        success = true;
      } else if(r && (r.tagSuccess || r.fulfilled)){
        // نجاح جزئي يتعتبر نجاح
        success = true;
      } else if(r){
        // فشل كامل — احفظ السبب
        task.lastError = (r.errors && r.errors.length ? r.errors.join(' | ') : '') || r.error || r.message || 'فشل بدون سبب واضح';
      }
    }catch(e){
      console.warn('Shopify queue task error:', task.order?.id, e);
      task.lastError = 'خطأ في الاتصال: ' + (e.message || 'unknown');
    }

    if(success){
      _shopifyQueueStats.pending--;
      _shopifyQueueStats.done++;
    } else if(task.attempts < 3){
      // أعد المحاولة (أقصاه 3 محاولات)
      console.log(`⟳ Retry ${task.attempts}/3 for order ${task.order?.id}`);
      _shopifyQueue.push(task); // أعده للطابور
      await new Promise(r => setTimeout(r, 2000)); // انتظار أطول قبل الإعادة
    } else {
      _shopifyQueueStats.pending--;
      _shopifyQueueStats.failed++;
      _shopifyFailedOrders.push(task);
      console.error(`❌ Shopify failed after 3 attempts for order ${task.order?.id}`);
    }

    _updateShopifyQueueBadge();
    await new Promise(r => setTimeout(r, 300));
  }

  _shopifyProcessing = false;
}

async function _doShopifyFulfill(order, courierName){
  if(order.src !== 'shopify') return null;
  const shopifyOrderId = order.shopifyId || order.shopify_id;
  if(!shopifyOrderId) return null;
  if(!API_URL) return null;

  try{
    console.log('Calling shopify/assign:', order.id, '→', courierName);
    // 🔧 v278: ما نبعتش credentials من localStorage عشان السيرفر يستخدم
    // الـ env vars (Railway) أو DB. الـ localStorage ممكن يكون فيه token قديم.
    const r = await apiFetch('/api/shopify/assign','POST',{
      shopifyOrderId: String(shopifyOrderId),
      courierName: courierName || 'OrderPro',
      orderId: order.id,
    });

    if(r && r.logs){
      console.log('=== Shopify fulfill logs for', order.id, '===');
      r.logs.forEach(l => console.log('  ', l));
    }

    if(r && !r.success && r.errors && r.errors.length){
      console.warn('Shopify fulfill failed for', order.id, ':', r.errors);
    }
    return r;
  }catch(e){
    console.error('shopifyFulfill exception:', order.id, e);
    return { success: false, error: e.message };
  }
}

// الـ entry point — بيحط الطلب في queue ويبدأ processing
function shopifyFulfill(order, courierName){
  if(order.src !== 'shopify') return;
  const shopifyOrderId = order.shopifyId || order.shopify_id;
  if(!shopifyOrderId) return;

  _shopifyQueue.push({ order, courierName });
  _shopifyQueueStats.pending++;
  _updateShopifyQueueBadge();

  // ابدأ processing (لو مش شغال)
  _processShopifyQueue();
}

