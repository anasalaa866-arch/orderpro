// 🆕 v296: ابعت الـ PO لـ Shopify كـ Inventory Transfer
async function sendPOToShopify(id){
  if(!confirm('📤 ابعت الـ PO ده لـ Shopify كـ Inventory Transfer؟\n\nده هـ يخلي الـ PO يظهر في Shopify Admin > Inventory > Transfers، والـ team يقدر يستلمه من Shopify Admin أو POS app مباشرة.\n\nالـ inventory في Shopify هـ يحدث تلقائياً لما يـ receive في Shopify.')) return;
  
  toast('📤 جاري الإرسال لـ Shopify...');
  
  // 🔧 v297: نـ use raw fetch عشان نقدر نقرا الـ error body حتى لو 502
  const baseUrl = (API_URL || BACKEND_URL).replace(/\/$/, '');
  const opts = {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    mode: 'cors'
  };
  if(window._adminToken) opts.headers['Authorization'] = 'Bearer ' + window._adminToken;
  
  try {
    const res = await fetch(baseUrl + '/api/purchase-orders/' + id + '/send-to-shopify', opts);
    const r = await res.json().catch(() => ({}));
    
    if(res.ok && r?.success){
      let msg = `✅ تم! Transfer ID: ${r.transfer.id}\n\n`;
      msg += `📦 ${r.transfer.items_count} منتج\n`;
      msg += `📊 Status: ${r.transfer.status}\n`;
      
      if(r.transfer.skipped?.length){
        msg += `\n⚠️ ${r.transfer.skipped.length} منتج اتـ skip (مفيش variant_id):\n`;
        r.transfer.skipped.slice(0, 5).forEach(s => {
          msg += `  • ${s.product_title || s.sku}: ${s.reason}\n`;
        });
      }
      
      if(r.shopify_url){
        msg += `\n🔗 افتح في Shopify: ${r.shopify_url}`;
      }
      
      alert(msg);
      
      if(r.shopify_url && confirm('تفتح الـ transfer في Shopify Admin دلوقتي؟')){
        window.open(r.shopify_url, '_blank');
      }
      
      closeM('m-po-detail');
      loadPurchaseOrdersPage();
    } else {
      // 🔧 v297: detailed error display
      let errorMsg = `❌ فشل الإرسال لـ Shopify (HTTP ${res.status})\n\n`;
      errorMsg += `📋 الـ Error:\n${r?.error || 'غير معروف'}\n`;
      
      if(r?.userErrors?.length){
        errorMsg += `\n📍 Shopify User Errors:\n`;
        r.userErrors.forEach(e => {
          errorMsg += `  • ${e.field?.join('.') || ''}: ${e.message}${e.code ? ` [${e.code}]` : ''}\n`;
        });
      }
      
      if(r?.skipped?.length){
        errorMsg += `\n⚠️ ${r.skipped.length} منتج اتـ skip:\n`;
        r.skipped.slice(0, 5).forEach(s => {
          errorMsg += `  • ${s.product_title || s.sku || s.variant_id}: ${s.reason}\n`;
        });
      }
      
      if(r?.debug){
        errorMsg += `\n🔍 Debug Info:\n`;
        errorMsg += `  PO: ${r.debug.po_number}\n`;
        errorMsg += `  Items: ${r.debug.line_items_built}/${r.debug.items_count}\n`;
        errorMsg += `  Location: ${r.debug.warehouse_location || 'مش مربوط'}\n`;
      }
      
      // أكتر شيوع: scope missing
      errorMsg += `\n💡 لو السبب access scope:\n`;
      errorMsg += `1. روح Shopify Admin → Settings → Apps and sales channels → Develop apps\n`;
      errorMsg += `2. افتح الـ Custom App بتاع CAFELAX\n`;
      errorMsg += `3. ضيف scope: write_inventory_transfers\n`;
      errorMsg += `4. Re-install الـ app + update SHOPIFY_ACCESS_TOKEN في Railway\n`;
      
      console.error('[sendPOToShopify] Full error:', r);
      alert(errorMsg);
    }
  } catch(e) { 
    toast('❌ ' + e.message); 
    console.error('sendPOToShopify error:', e);
  }
}

