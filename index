// 🆕 v331: pagination buttons
function wlRenderPagination(totalPages, totalFiltered){
  const el = document.getElementById('wl-pagination');
  if(!el) return;
  
  if(totalPages <= 1){
    el.innerHTML = '';
    return;
  }
  
  // عشان pagination تبان صحيح في RTL: السابق على اليمين
  const cur = _wlCurrentPage;
  
  // ابني قائمة أرقام الصفحات المعروضة (window of 5 around current)
  const pages = new Set();
  pages.add(1);
  pages.add(totalPages);
  for(let i = cur - 1; i <= cur + 1; i++){
    if(i >= 1 && i <= totalPages) pages.add(i);
  }
  const sortedPages = Array.from(pages).sort((a, b) => a - b);
  
  // ابني buttons
  let html = '';
  
  // السابق
  html += `<button onclick="wlGoToPage(${cur - 1})" ${cur === 1 ? 'disabled' : ''} style="padding:7px 12px;background:${cur === 1 ? 'var(--bg)' : 'var(--card)'};color:${cur === 1 ? 'var(--muted)' : 'var(--text)'};border:1px solid var(--border);border-radius:6px;font-family:Cairo,sans-serif;font-size:12px;font-weight:700;cursor:${cur === 1 ? 'not-allowed' : 'pointer'}">السابق →</button>`;
  
  // أرقام الصفحات
  let lastShown = 0;
  for(const p of sortedPages){
    if(p - lastShown > 1){
      html += `<span style="color:var(--muted);padding:0 4px">...</span>`;
    }
    const isActive = p === cur;
    html += `<button onclick="wlGoToPage(${p})" style="padding:7px 12px;background:${isActive ? 'var(--accent)' : 'var(--card)'};color:${isActive ? '#fff' : 'var(--text)'};border:1px solid ${isActive ? 'var(--accent)' : 'var(--border)'};border-radius:6px;font-family:Cairo,sans-serif;font-size:12px;font-weight:${isActive ? '800' : '700'};cursor:pointer;min-width:36px">${p}</button>`;
    lastShown = p;
  }
  
  // التالي
  html += `<button onclick="wlGoToPage(${cur + 1})" ${cur === totalPages ? 'disabled' : ''} style="padding:7px 12px;background:${cur === totalPages ? 'var(--bg)' : 'var(--card)'};color:${cur === totalPages ? 'var(--muted)' : 'var(--text)'};border:1px solid var(--border);border-radius:6px;font-family:Cairo,sans-serif;font-size:12px;font-weight:700;cursor:${cur === totalPages ? 'not-allowed' : 'pointer'}">← التالي</button>`;
  
  // معلومات: صفحة X من Y
  html += `<span style="margin-right:10px;font-size:11px;color:var(--muted);align-self:center">صفحة <strong style="color:var(--text)">${cur}</strong> من <strong style="color:var(--text)">${totalPages}</strong></span>`;
  
  el.innerHTML = html;
}

