async function confirmPayPayable(){
  if(!_payingPayable) return;
  const paid_method = $('pay-method').value;
  const paid_reference = $('pay-reference').value.trim();
  const paid_notes = $('pay-notes').value.trim();
  const paid_at = $('pay-date').value;

  try {
    const r = await apiFetch('/api/payables/' + _payingPayable.id + '/pay', 'POST', {
      paid_method, paid_reference, paid_notes, paid_at
    });
    if(r?.success){
      toast('✅ تم تسجيل الدفع');
      closeM('m-pay-payable');
      _payingPayable = null;
      loadPayables();
    } else toast('❌ ' + (r?.error || 'فشل'));
  } catch(e){ toast('❌ ' + e.message); }
}

