      tbodyEl.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--muted)">لا توجد بيانات في هذه الفترة</td></tr>';
    } else {
      tbodyEl.innerHTML = preparers.map(p => {
        const completion = p.totalStarted > 0 ? Math.round((p.totalCompleted / p.totalStarted) * 100) : 0;
        const avgStr = p.avgDurationMinutes != null ? _prFmtMinutes(p.avgDurationMinutes) : '—';
        const fastestStr = p.fastestMinutes != null ? _prFmtMinutes(p.fastestMinutes) : '—';
        const slowestStr = p.slowestMinutes != null ? _prFmtMinutes(p.slowestMinutes) : '—';
        const lastActStr = p.lastActivity ? _prFmtDate(p.lastActivity) : '—';
        return `<tr>
          <td><strong>${escapeHtml(p.name)}</strong>${p.preparerId ? '' : ' <span class="badge" style="background:#fef3c7;color:#92400e;font-size:9px">أدمن</span>'}</td>
          <td><strong style="color:#3b82f6">${p.totalStarted}</strong></td>
          <td><strong style="color:#16a34a">${p.totalCompleted}</strong> <span style="font-size:11px;color:var(--muted)">(${completion}%)</span></td>
          <td>${p.totalInProgress > 0 ? '<strong style="color:#f59e0b">' + p.totalInProgress + '</strong>' : '0'}</td>
          <td>${avgStr}</td>
          <td style="color:#16a34a">${fastestStr}</td>
          <td style="color:#f59e0b">${slowestStr}</td>
          <td style="font-size:11px;color:var(--muted)">${lastActStr}</td>
        </tr>`;
      }).join('');
    }
  }
  
  // Details table
  const detailsEl = $('pr-details-tbody');
  const countEl = $('pr-details-count');
  if(countEl) countEl.textContent = `(${details.length} عملية)`;
  
  if(detailsEl){
    if(!details.length){
      detailsEl.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--muted)">مفيش عمليات تحضير</td></tr>';
    } else {
      detailsEl.innerHTML = details.map(d => {
        const statusBadge = d.preparationStatus === 'completed'
          ? '<span class="badge" style="background:#dcfce7;color:#166534">✅ مكتمل</span>'
          : '<span class="badge" style="background:#fef3c7;color:#92400e">⏳ بيتحضّر</span>';
        const durStr = d.durationMinutes != null ? _prFmtMinutes(d.durationMinutes) : '—';
        const completedName = d.completedByName || d.startedByName || '';
        return `<tr>
          <td><strong style="font-family:monospace;font-size:11px">${escapeHtml(d.orderId)}</strong>${d.shopifyId ? '<div style="font-size:9px;color:#22c55e">🛍 ' + escapeHtml(d.shopifyId) + '</div>' : ''}</td>
          <td>${escapeHtml(d.customerName || '—')}</td>
          <td><strong>${(d.total || 0).toLocaleString()} ج</strong></td>
          <td>${escapeHtml(completedName)}</td>
          <td style="font-size:11px">${_prFmtDate(d.startedAt)}</td>
          <td style="font-size:11px">${d.completedAt ? _prFmtDate(d.completedAt) : '—'}</td>
          <td><strong>${durStr}</strong></td>
          <td>${statusBadge}</td>
        </tr>`;
      }).join('');
    }
  }
}

function _prFmtMinutes(mins){
  if(mins == null) return '—';
  if(mins < 1) return Math.round(mins * 60) + ' ث';
  if(mins < 60) return Math.round(mins) + ' د';
  const h = Math.floor(mins / 60);
  const m = Math.round(mins % 60);
  return h + 'س ' + m + 'د';
}

function _prFmtDate(ts){
  if(!ts) return '—';
  const d = new Date(ts);
  return d.toLocaleDateString('ar-EG',{month:'short',day:'numeric'}) + ' ' +
         d.toLocaleTimeString('ar-EG',{hour:'2-digit',minute:'2-digit',timeZone:'Africa/Cairo'});
}

function exportPreparerReportsCsv(){
  if(!_preparerReportsCache || !_preparerReportsCache.details?.length){
    alert('مفيش بيانات للتصدير');
    return;
  }
  const headers = ['رقم الطلب', 'Shopify ID', 'العميل', 'الإجمالي', 'المحضّر', 'ابتدأ', 'خلص', 'المدة (دقيقة)', 'الحالة'];
  const rows = _preparerReportsCache.details.map(d => [
    d.orderId,
    d.shopifyId || '',
    d.customerName || '',
    d.total || 0,
    d.completedByName || d.startedByName || '',
    d.startedAt ? new Date(d.startedAt).toLocaleString('en-GB',{timeZone:'Africa/Cairo'}) : '',
    d.completedAt ? new Date(d.completedAt).toLocaleString('en-GB',{timeZone:'Africa/Cairo'}) : '',
    d.durationMinutes != null ? d.durationMinutes.toFixed(2) : '',
    d.preparationStatus || ''
  ]);
  
  const csv = '\ufeff' + [headers, ...rows]
    .map(row => row.map(cell => {
      const s = String(cell ?? '');
      if(s.includes(',') || s.includes('"') || s.includes('\n')) return '"' + s.replace(/"/g, '""') + '"';
      return s;
    }).join(','))
    .join('\n');
  
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  const from = $('pr-from-date')?.value || 'all';
  const to = $('pr-to-date')?.value || 'all';
  a.download = `preparer-reports-${from}-to-${to}.csv`;
  a.click();
  URL.revokeObjectURL(url);
}

async function openCouriersDashboard(){
  const tabsEl = $('cdash-tabs');
  const contentEl = $('cdash-content');
  if(!tabsEl || !contentEl) return;

  // مناديب فقط (مش shop ولا preparer)
  const list = couriers.filter(c => (c.role||'courier') === 'courier');
  if(!list.length){
    contentEl.innerHTML = '<div class="card"><div class="card-body" style="text-align:center;padding:40px;color:var(--muted)">لا يوجد مناديب مضافين</div></div>';
    tabsEl.innerHTML = '';
