function getTreasuryBalance(tId){
  const t = _treasuries.find(x=>x.id===tId);
  if(!t) return 0;
  const txs = _treasuryTx.filter(x=>x.treasuryId===tId);
  const inAmt = txs.filter(x=>x.type==='in').reduce((s,x)=>s+(parseFloat(x.amount)||0),0);
  const outAmt = txs.filter(x=>x.type==='out').reduce((s,x)=>s+(parseFloat(x.amount)||0),0);
  return (parseFloat(t.opening)||0) + inAmt - outAmt;
}

