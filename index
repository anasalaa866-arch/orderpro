async function testShopifyConnection(){
  if(!API_URL){ toast('❗ الـ Backend مش متصل'); return; }
  const urlInput = $('imp-url')?.value?.trim() || localStorage.getItem('orderpro_shop_url') || '';
  const tokenInput = $('imp-token')?.value?.trim() || localStorage.getItem('orderpro_shop_token') || '';

  toast('⏳ جاري اختبار الاتصال...');

  try{
    // أولاً اختبر الـ credentials اللي حالياً في السيرفر (DB/env)
    const r = await apiFetch('/api/shopify/test','GET');
    const serverStatus = r && r.ok
      ? `✅ السيرفر:\n   متصل بـ ${r.shopName || 'Shopify'}\n   المصدر: ${r.source === 'database' ? '💾 Database' : r.source === 'env' ? '🔐 Environment Vars' : '❓'}`
      : `❌ السيرفر:\n   ${r?.message || 'الـ credentials في السيرفر مش شغالة'}${r?.status ? ' (HTTP '+r.status+')' : ''}`;

    // ثانياً اختبر الـ token اللي في الواجهة (لو فيه)
    let frontStatus = '';
    if(urlInput && tokenInput){
      const localR = await apiFetch('/api/shopify/test','POST',{ shopUrl: urlInput, accessToken: tokenInput }).catch(()=>null);
      // السيرفر مش عامل POST test — نعمل مقارنة بسيطة
      if(r && r.ok && r.source === 'database'){
        // الـ db token شغال — قارن لو مختلف عن اللي في الواجهة
        const tokenPrefix = tokenInput.slice(0,10);
        frontStatus = `\n\nالـ Token الحالي في الواجهة: ${tokenPrefix}... (${tokenInput.length} chars)`;
      }
    }

    infoModal('🧪 نتيجة الفحص', serverStatus + frontStatus + '\n\n💡 لو السيرفر مش شغال، دوس "حفظ التوكن في السيرفر".');
  }catch(e){
    toast('❌ خطأ في الاختبار: ' + e.message);
  }
}

async function forceUpdateServerCredentials(){
  if(!API_URL){ toast('❗ الـ Backend مش متصل'); return; }

  const url = $('imp-url')?.value?.trim() || localStorage.getItem('orderpro_shop_url') || '';
  const token = $('imp-token')?.value?.trim() || localStorage.getItem('orderpro_shop_token') || '';

  if(!url || !token){
    toast('❗ املأ رابط المتجر والـ Token أولاً');
