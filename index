// SVG Chart بسيط للـ 7 أيام
function renderChart7Days(chartData){
  const container = document.getElementById('sd-chart-7days');
  if(!container) return;
  
  if(!chartData || !chartData.length){
    container.innerHTML = '<div style="text-align:center;padding:60px;color:var(--muted)">مفيش بيانات للعرض</div>';
    return;
  }
  
  // ملاحظة: الـ chart بيرسم كل اليوم اللي عندنا
  const maxRev = Math.max(...chartData.map(d => d.revenue), 1);
  const W = 800, H = 220, padX = 40, padY = 30;
  const barW = (W - padX*2) / chartData.length;
  
  const days = ['الأحد','الإثنين','الثلاثاء','الأربعاء','الخميس','الجمعة','السبت'];
  
  let bars = '';
  let labels = '';
  let valLabels = '';
  
  chartData.forEach((d, i) => {
    const x = padX + i * barW + barW * 0.2;
    const w = barW * 0.6;
    const h = (d.revenue / maxRev) * (H - padY*2 - 20);
    const y = H - padY - h;
    
    const dt = new Date(d.day);
    const dayName = days[dt.getDay()];
    const dayNum = dt.getDate();
    const month = ['يناير','فبراير','مارس','أبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'][dt.getMonth()];
    
    bars += `<rect x="${x}" y="${y}" width="${w}" height="${h}" fill="#6366f1" rx="4">
      <title>${dayName} ${dayNum} ${month}: ${Math.round(d.revenue).toLocaleString()} ج · ${d.orders} طلب</title>
    </rect>`;
    
    labels += `<text x="${x + w/2}" y="${H - padY + 16}" text-anchor="middle" font-size="10" fill="#64748b" font-family="Cairo">${dayNum}/${dt.getMonth()+1}</text>`;
    
    if(d.revenue > 0){
      valLabels += `<text x="${x + w/2}" y="${y - 6}" text-anchor="middle" font-size="9" fill="#475569" font-family="Cairo" font-weight="700">${Math.round(d.revenue/1000)}K</text>`;
    }
  });
  
  // Y axis
  const ySteps = 4;
  let yLabels = '';
  let gridLines = '';
  for(let i = 0; i <= ySteps; i++){
    const val = maxRev * i / ySteps;
    const y = H - padY - (i / ySteps) * (H - padY*2 - 20);
    gridLines += `<line x1="${padX}" y1="${y}" x2="${W - padX}" y2="${y}" stroke="#e5e7eb" stroke-dasharray="3,3"/>`;
    yLabels += `<text x="${padX - 6}" y="${y + 3}" text-anchor="end" font-size="9" fill="#94a3b8" font-family="Cairo">${Math.round(val/1000)}K</text>`;
  }
  
  container.innerHTML = `
    <svg width="100%" height="${H}" viewBox="0 0 ${W} ${H}" preserveAspectRatio="xMidYMid meet" style="overflow:visible">
      ${gridLines}
      ${yLabels}
      ${bars}
      ${labels}
      ${valLabels}
    </svg>
  `;
}

