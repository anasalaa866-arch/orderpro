  const totalOrders = sortedKeys.reduce((s,k)=>s+groups[k].express.length+groups[k].normal.length, 0);
  const totalExpress = sortedKeys.reduce((s,k)=>s+groups[k].express.length, 0);
  const dateStr = batchCode.replace('B-','').split('-').slice(0,3).join('-');
  const now = new Date();
  const timeStr = now.toLocaleTimeString('ar-EG',{hour:'2-digit',minute:'2-digit',timeZone:'Africa/Cairo'});

  const rows = sortedKeys.map(key=>{
    const g = groups[key];
    const count = g.express.length + g.normal.length;
    const pageInfo = g._pageInfo || {};
    const sortByNum = (a,b)=>(parseInt((a.id||'').replace(/\D/g,''))||0)-(parseInt((b.id||'').replace(/\D/g,''))||0);

    // ترتيب مع فصل الكبيرة عن الصغيرة للعرض في الملخص
    const isLarge = o => (pageInfo[o.id] || 1) > 1;
    const fmtOrderId = o => {
      const id = (o.id||'').replace(/^SH-/,'').replace(/^MN-/,'');
      const pages = pageInfo[o.id] || 1;
      if(pages > 1) return `<span style="background:#000;color:#fff;padding:2px 6px;border-radius:3px;font-weight:800;display:inline-block;margin:1px 2px">${id} 📄×${pages}</span>`;
      return `<span style="display:inline-block;margin:1px 2px">${id}</span>`;
    };

    const expressLarge = g.express.filter(isLarge).sort(sortByNum);
    const expressSmall = g.express.filter(o => !isLarge(o)).sort(sortByNum);
    const normalLarge = g.normal.filter(isLarge).sort(sortByNum);
    const normalSmall = g.normal.filter(o => !isLarge(o)).sort(sortByNum);

    const expressHtml = [...expressLarge, ...expressSmall].map(fmtOrderId).join(' ');
    const normalHtml = [...normalLarge, ...normalSmall].map(fmtOrderId).join(' ');

    const largeCount = [...expressLarge, ...normalLarge].length;

    return `
      <tr style="border-bottom:1px solid #e5e7eb">
        <td style="padding:14px 10px;vertical-align:top;width:200px">
          <div style="font-size:17px;font-weight:800">${g.isBosta?'🚚 ':''}${g.name}</div>
          <div style="font-size:12px;color:#6b7280;margin-top:4px">${count} order${count>1?'s':''}</div>
          ${g.express.length?`<div style="font-size:11px;color:#dc2626;margin-top:2px;font-weight:700">⚡ ${g.express.length} urgent</div>`:''}
          ${largeCount?`<div style="font-size:11px;color:#000;margin-top:2px;font-weight:700">📄 ${largeCount} multi-page</div>`:''}
        </td>
        <td style="padding:14px 10px;font-size:15px;line-height:2.2;font-weight:700">
          ${g.express.length?`<div style="margin-bottom:8px"><span style="background:#fef3c7;color:#92400e;padding:3px 8px;border-radius:4px;font-size:11px;font-weight:700;margin-left:8px">⚡ Express</span><span style="direction:ltr;unicode-bidi:plaintext;color:#dc2626">${expressHtml}</span></div>`:''}
          ${g.normal.length?`<div><span style="background:#dbeafe;color:#1e40af;padding:3px 8px;border-radius:4px;font-size:11px;font-weight:700;margin-left:8px">Normal</span><span style="direction:ltr;unicode-bidi:plaintext">${normalHtml}</span></div>`:''}
        </td>
      </tr>
    `;
  }).join('');

  return `
    <div style="text-align:center;margin-bottom:25px;padding-bottom:15px;border-bottom:3px solid #000">
      <div style="font-size:13px;font-weight:700;color:#6b7280;margin-bottom:5px">BATCH SUMMARY · ملخص الدفعة</div>
      <div style="font-size:32px;font-weight:800;margin-bottom:5px">${batchCode}</div>
      <div style="font-size:14px;color:#6b7280">${dateStr} — ${timeStr} — ${totalOrders} طلب ${totalExpress?`(⚡ ${totalExpress} مستعجل)`:''}</div>
    </div>
    <table style="width:100%;border-collapse:collapse;font-size:12px">
      <thead>
        <tr style="background:#1e293b;color:#fff">
          <th style="padding:10px;text-align:right;font-size:13px">COURIER · المندوب</th>
          <th style="padding:10px;text-align:right;font-size:13px">ORDER NUMBERS · أرقام الطلبات</th>
        </tr>
      </thead>
      <tbody>${rows}</tbody>
    </table>
    <div style="margin-top:20px;padding:10px 15px;background:#fef3c7;border:1px solid #fde047;border-radius:6px;font-size:12px;color:#92400e;text-align:center">
      <strong>📄×N</strong> = طلب على N صفحات · Multi-page order with N pages — ادبس كل الصفحات مع بعض
    </div>
    <div style="margin-top:15px;padding:12px;background:#f9fafb;border-radius:8px;text-align:center;font-size:11px;color:#6b7280">
      تم التجهيز · Generated ${now.toLocaleDateString('en-GB')} ${timeStr} · CAFELAX OrderPro
    </div>
  `;
}

