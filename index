async function uploadStatement(){
  const storeId = document.getElementById('stmt-store').value;
  const method = document.getElementById('stmt-method').value;
  const periodStart = document.getElementById('stmt-from').value;
  const periodEnd = document.getElementById('stmt-to').value;
  const notes = document.getElementById('stmt-notes').value.trim();
  
  if(!storeId || !method || !periodStart || !periodEnd){
    toast('❌ املأ كل البيانات'); return;
  }
  
  const transactions = _parseStatementCSV();
  if(!transactions || !transactions.length){
    toast('❌ مفيش عمليات صحيحة في الكشف'); return;
  }
  
  const totalAmount = transactions.reduce((s, t) => s + t.amount, 0);
  
  if(!confirm(`رفع ${transactions.length} عملية بإجمالي ${totalAmount.toFixed(2)} ج للمطابقة؟`)) return;
  
  try {
    const r = await apiFetch('/api/store-mgr/statements', 'POST', {
      storeId: parseInt(storeId), method, periodStart, periodEnd,
      totalAmount, transactions, notes
    });
    
    if(r?.success){
      closeM('m-new-statement');
      toast('✅ تم رفع الكشف وعمل المطابقة', 'success');
      
      // اعرض النتيجة
