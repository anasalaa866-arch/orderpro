                ${t.attachments_count > 0 ? `<span style="color:var(--muted);font-size:11px">📎 ${t.attachments_count}</span>` : ''}
                ${sharedCount > 0 ? `<span style="color:var(--muted);font-size:11px">👁️ ${sharedCount}</span>` : ''}
              </div>
              <div style="font-weight:700;font-size:14px;${t.status === 'completed' ? 'text-decoration:line-through;color:var(--muted)' : ''}">${escapeHtml(t.title)}</div>
              ${t.description ? `<div style="font-size:12px;color:var(--muted);margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${escapeHtml(t.description)}</div>` : ''}
              <div style="display:flex;gap:14px;font-size:11px;color:var(--muted);margin-top:6px;flex-wrap:wrap">
                <span>👤 لـ: <strong>${escapeHtml(_userDisplayName(t.assigned_to))}</strong></span>
