async function handleEmpPhotoUpload(event, type){
  const file = event.target.files[0];
  if(!file) return;
  
  // فحص الحجم (قبل الضغط)
  if(file.size > 8 * 1024 * 1024){
    toast('❌ الصورة كبيرة جداً (الحد 8 MB)');
    event.target.value = '';
    return;
  }
  
  if(!file.type.startsWith('image/')){
    toast('❌ لازم صورة');
    event.target.value = '';
    return;
  }
  
  try{
    toast('⏳ جاري الضغط...');
    // الموظف صورة أصغر (للـ avatar)
    const maxDim = type === 'photo' ? 600 : 1400;
    const quality = type === 'photo' ? 0.85 : 0.75;
    const dataUrl = await compressImage(file, maxDim, quality);
    
    setEmpPhoto(type, dataUrl);
    toast('✅ تم الرفع');
  }catch(e){
    console.error('compress failed:', e);
    toast('❌ فشل ضغط الصورة');
  }
  event.target.value = ''; // reset input
}

function setEmpPhoto(type, dataUrl){
  const map = _empPhotoMap[type];
  if(!map) return;
  
  document.getElementById(map.data).value = dataUrl || '';
  const preview = document.getElementById(map.preview);
  const removeBtn = document.getElementById(map.remove);
  
  if(dataUrl){
    preview.innerHTML = `<img src="${dataUrl}" style="width:100%;height:100%;object-fit:cover">`;
    preview.style.borderStyle = 'solid';
    removeBtn.style.display = 'block';
  } else {
    preview.innerHTML = type === 'photo' 
      ? '<span style="color:var(--muted);font-size:11px;text-align:center;padding:10px">📷<br>اضغط للرفع</span>'
      : '<span style="color:var(--muted);font-size:11px;text-align:center;padding:10px">🪪<br>اضغط للرفع</span>';
    preview.style.borderStyle = 'dashed';
    removeBtn.style.display = 'none';
  }
}

