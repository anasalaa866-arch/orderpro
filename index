function renderCartAuditList(){
  const cont = $('cart-audit-content');
  if(!cont) return;
  if(!_cartAuditEvents.length){
    cont.innerHTML = `<div class="card"><div class="card-body" style="text-align:center;padding:30px">
      <div style="font-size:48px;opacity:.3">📋</div>
      <div style="font-size:14px;color:var(--muted);margin-top:8px">مفيش حركات للعرض</div>
    </div></div>`;
    return;
  }

  // مجمع بالـ sale_id لو موجود
  const rows = _cartAuditEvents.map(e => {
    const cfg = ACTION_CONFIG[e.action_type] || { label: e.action_type, icon: '•', color: '#94a3b8' };
    const time = new Date(e.created_at);
    const timeStr = time.toLocaleString('ar-EG', {
      year:'numeric', month:'2-digit', day:'2-digit',
      hour:'2-digit', minute:'2-digit', second:'2-digit'
    });
    const productInfo = e.product_title
      ? `<div style="font-weight:600">${escapeHtml(e.product_title)}${e.variant_title ? ' - '+escapeHtml(e.variant_title) : ''}</div>${e.sku ? `<div style="font-size:10px;color:var(--muted)">SKU: ${escapeHtml(e.sku)}</div>` : ''}`
      : '<span style="color:var(--muted);font-size:11px">—</span>';

    let detailsStr = '';
    if(e.action_type === 'qty_increased' || e.action_type === 'qty_decreased'){
      detailsStr = `من <strong>${e.old_qty}</strong> إلى <strong>${e.new_qty}</strong>`;
    } else if(e.action_type === 'remove_item'){
      detailsStr = `كانت كمية <strong>${e.old_qty}</strong> بـ ${parseFloat(e.old_price || 0).toFixed(0)} ج`;
    } else if(e.action_type === 'clear_cart'){
      try {
        const d = typeof e.details === 'string' ? JSON.parse(e.details) : e.details;
        if(d?.items?.length){
          detailsStr = `<strong>${d.item_count}</strong> منتجات: ` + d.items.slice(0, 3).map(i => escapeHtml(i.productTitle)).join('، ');
          if(d.items.length > 3) detailsStr += ` +${d.items.length - 3} تاني`;
        }
      } catch(e){}
    } else if(e.action_type === 'discount_applied'){
      try {
        const d = typeof e.details === 'string' ? JSON.parse(e.details) : e.details;
        if(d?.code) detailsStr = `كود: <strong>${escapeHtml(d.code)}</strong> - خصم ${parseFloat(d.discount_amount || 0).toFixed(0)} ج`;
      } catch(e){}
    } else if(e.action_type === 'sale_completed'){
      try {
        const d = typeof e.details === 'string' ? JSON.parse(e.details) : e.details;
        if(d) detailsStr = `${d.items_count} منتجات بـ <strong>${parseFloat(d.total || 0).toFixed(0)} ج</strong> (${d.payment_method || '-'})`;
      } catch(e){}
    }

    const isSuspicious = ACTION_CONFIG[e.action_type]?.suspicious;
    return `
      <tr style="${isSuspicious ? 'background:#fef2f2' : ''}">
        <td style="font-size:11px;white-space:nowrap;font-family:monospace">${timeStr}</td>
        <td><strong>${escapeHtml(e.cashier_name || '#'+e.cashier_id)}</strong><div style="font-size:10px;color:var(--muted)">${escapeHtml(e.store_name || '-')}</div></td>
        <td><span style="background:${cfg.color};color:#fff;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:700;white-space:nowrap">${cfg.icon} ${cfg.label}</span></td>
        <td>${productInfo}</td>
        <td style="font-size:11px">${detailsStr || '—'}</td>
        <td style="text-align:left;font-family:monospace;font-size:11px">
          ${e.cart_total_before != null ? '<span style="color:var(--muted)">' + parseFloat(e.cart_total_before).toFixed(0) + '</span>' : ''}
          ${e.cart_total_after != null && e.cart_total_before != null ? '<br>↓<br>' : ''}
          ${e.cart_total_after != null ? '<strong>' + parseFloat(e.cart_total_after).toFixed(0) + ' ج</strong>' : ''}
        </td>
      </tr>
    `;
  }).join('');

  cont.innerHTML = `
    <div class="card">
      <div class="card-hd" style="display:flex;justify-content:space-between;align-items:center">
        <h3 style="margin:0">📜 السجل (${_cartAuditEvents.length} حركة)</h3>
        <span style="font-size:11px;color:var(--muted)">آخر تحديث: ${new Date().toLocaleTimeString('ar-EG')}</span>
      </div>
      <div class="tw" style="overflow-x:auto;max-height:70vh;overflow-y:auto">
        <table style="width:100%;font-size:12px">
          <thead style="position:sticky;top:0;background:var(--card);z-index:1">
            <tr>
              <th>الوقت</th>
              <th>الكاشير / المحل</th>
              <th>الحركة</th>
              <th>المنتج</th>
              <th>التفاصيل</th>
              <th style="text-align:left">إجمالي السلة</th>
            </tr>
          </thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    </div>
  `;
}

