              return `
                <tr class="${isPickup ? 'pickup-row' : ''}">
                  <td style="font-family:monospace;font-size:10px">${escapeHtml(sale.sale_number || '#'+sale.id)}${isPickup ? ' <span class="pickup-badge">pickup</span>' : ''}</td>
