  const sum = data.summary || {};
  const successItems = data.items.filter(i => i.status === 'success');
  const failedItems = data.items.filter(i => i.status === 'failed');
  
  // value impact
  const successValue = successItems.reduce((s, i) => s + (i.value || 0), 0);
  const failedValue = failedItems.reduce((s, i) => s + (i.value || 0), 0);
  
  // error type labels
  const errorTypeLabels = {
    no_inventory_item_id: { ar: '🔌 مش مربوط بـ Shopify', desc: 'المنتج مفيهوش inventory_item_id - يمكن المنتج اتـ archive أو ما اتـ sync' },
