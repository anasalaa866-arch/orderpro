// 🆕 v328: ضيف للـ watchlist من جدول sales-velocity
async function svAddToWatchlist(btn, variantId){
  btn.disabled = true;
  btn.textContent = '⏳';
  try {
    await apiFetch('/api/watchlist', 'POST', { variantId });
    btn.style.background = '#f59e0b';
    btn.style.color = '#fff';
    btn.textContent = '✓';
    toast('✅ اتضاف للمراقبة', 'success');
  } catch(e){
    btn.disabled = false;
    btn.textContent = '⭐';
    toast('❌ ' + e.message, 'error');
  }
}

function setSVFilter(btn, cat){
  _svFilter = cat;
  document.querySelectorAll('.sv-filter').forEach(b => {
    b.style.background = 'var(--bg)';
    b.style.color = 'var(--text)';
    b.style.border = '1px solid var(--border)';
