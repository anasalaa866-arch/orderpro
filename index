              <div style="font-size:11px;color:var(--muted);margin-bottom:3px">COD</div>
              <div style="font-size:18px;font-weight:800;color:${currentPaid?'#16a34a':'var(--text)'}">${currentPaid?'مدفوع':(o.total||0).toLocaleString()+' ج'}</div>
