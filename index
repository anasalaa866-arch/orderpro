async function requestChkVoid(id){
  const c=chkList.find(x=>x.id===id);if(!c)return;
  const reason = prompt(`جعل الشيك "${c.num}" (${c.payee}) - ${c.amount} ج هالك\n\nاكتب السبب (مثلاً: اتقطع، ضاع، اتكتب غلط):`);
  if(reason === null) return;
  if(!reason.trim()) { toast('❌ السبب مطلوب'); return; }
  
  try{
    const r = await apiFetch('/api/checks/'+id+'/request-void','POST',{reason});
    if(r && r.ok){
      c.status = 'void_requested';
      c.note = (c.note || '') + (c.note ? '\n' : '') + `🟡 طلب جعله هالك: ${reason}`;
      saveChks(true);
      chkRenderActive();
      toast('✅ تم إرسال الطلب - في انتظار موافقة المدير');
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  }catch(e){ toast('❌ ' + e.message); }
}

async function approveChkVoid(id){
  const c=chkList.find(x=>x.id===id);if(!c)return;
  if(!confirm(`الموافقة على جعل الشيك "${c.num}" (${c.payee}) - ${c.amount} ج هالك؟\n\n⚠️ ده هيلغي الشيك من الحسابات`)) return;
  
