function ssrcPreset(p){
  const now=new Date(); let from, to=_ssrcYmd(now);
  if(p==='today'){ from=_ssrcYmd(now); }
  else if(p==='yesterday'){ const d=new Date(now); d.setDate(d.getDate()-1); from=_ssrcYmd(d); to=_ssrcYmd(d); }
  else if(p==='7d'){ const d=new Date(now); d.setDate(d.getDate()-6); from=_ssrcYmd(d); }
  else if(p==='month'){ from=`${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-01`; }
  else if(p==='lastmonth'){ const fm=new Date(now.getFullYear(), now.getMonth()-1, 1); const lm=new Date(now.getFullYear(), now.getMonth(), 0); from=_ssrcYmd(fm); to=_ssrcYmd(lm); }
  $('ssrc-from').value=from; $('ssrc-to').value=to; loadSalesSources();
}
function _ssrcMoney(n){ return (Number(n)||0).toLocaleString('en-US',{maximumFractionDigits:0}) + ' ج'; }
