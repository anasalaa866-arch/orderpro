  }catch(e){
    console.error('cdash load error:', e);
    contentEl.innerHTML = '<div class="card"><div class="card-body" style="text-align:center;padding:40px;color:var(--danger)">⚠️ ' + (e.message || 'خطأ في التحميل') + '</div></div>';
