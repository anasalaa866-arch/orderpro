      <div style="flex:1">
        <div style="font-weight:700;font-size:13px">📦 ${formatBatchDate(code)}</div>
        <div style="font-size:11px;color:var(--muted);margin-top:3px">${batchOrders.length} طلب · 💰 ${cod.toLocaleString()} ج COD · 🚴 ${ship.toLocaleString()} ج شحن</div>
        <div style="font-size:10px;color:var(--muted);font-family:monospace;margin-top:2px">${code}</div>
      </div>
    </label>`;
  });

  if(noBatchOrders.length){
    const cod = noBatchOrders.filter(o=>!o.paid).reduce((s,o)=>s+o.total,0);
    // 🔧 v238: استخدم getShipCost
    const ship = noBatchOrders.reduce((s,o)=>s+getShipCost(o,c),0);
    html += `<label style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1.5px solid var(--warn);border-radius:8px;margin-bottom:8px;cursor:pointer;background:var(--warn-light)">
      <input type="checkbox" class="acc-batch-chk" value="__nobatch__" checked style="width:18px;height:18px;cursor:pointer">
      <div style="flex:1">
        <div style="font-weight:700;font-size:13px;color:#92400e">⚠️ طلبات قديمة بدون دفعة</div>
        <div style="font-size:11px;color:#92400e;margin-top:3px">${noBatchOrders.length} طلب · 💰 ${cod.toLocaleString()} ج COD · 🚴 ${ship.toLocaleString()} ج شحن</div>
      </div>
    </label>`;
  }

  html += `<div style="display:flex;gap:8px;justify-content:flex-end;margin-top:14px;padding-top:12px;border-top:1px solid var(--border)">
    <button class="btn btn-ghost btn-sm" onclick="closeM('m-acc-batch')">إلغاء</button>
