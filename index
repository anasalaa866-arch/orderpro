          <div style="font-size:10px;color:var(--muted)">${o.area||''}</div>
        </div>
      </div>`).join('')}`;

  // اختيار الطلب الرئيسي
  const primSel = $('merge-primary-sel');
  if(primSel) primSel.innerHTML = mergeOrders.map(o=>
    `<option value="${o.id}">${o.id} — ${o.name} — ${o.paid?'مدفوع':(o.total||0).toLocaleString()+' ج'}</option>`
  ).join('');

  // تكلفة الشحن من Shopify (shippingPrice) لأول طلب
  const defaultShip = mergeOrders[0]?.shippingPrice || mergeOrders[0]?.ship || 50;
  const shipInput = $('merge-ship-val');
  if(shipInput) shipInput.value = defaultShip;

  updateMergeShip();
  openM('m-merge-orders');
}

function updateMergeShip(){
  const mergeOrders = _mergeIds.map(id=>orders.find(o=>o.id===id)).filter(Boolean);
  const mode = document.querySelector('input[name="merge-ship-mode"]:checked')?.value || 'one';
  const shipInput = $('merge-ship-val');
  // استخدم الشحن الفعلي من Shopify أو الشحن المعين للطلب
  const getShip = o => o.shippingPrice || o.ship || 0;
  if(mode === 'all'){
    if(shipInput) shipInput.value = mergeOrders.reduce((s,o)=>s+getShip(o),0);
  } else {
    if(shipInput) shipInput.value = getShip(mergeOrders[0]);
  }
  renderMergeSummary();
}

function renderMergeSummary(){
  const mergeOrders = _mergeIds.map(id=>orders.find(o=>o.id===id)).filter(Boolean);
  const primaryId = $('merge-primary-sel')?.value;
  const ship = parseFloat($('merge-ship-val')?.value)||0;
  const totalCod = mergeOrders.filter(o=>!o.paid).reduce((s,o)=>s+o.total,0);
  const allIds = mergeOrders.map(o=>o.id);
  const mergedRef = allIds.join(' + ');
  const secondaryIds = allIds.filter(id=>id!==primaryId);
  const summary = $('merge-summary');
  if(!summary) return;
  summary.innerHTML = `
    <div style="font-weight:700;margin-bottom:8px;color:var(--accent)">ملخص الدمج</div>
    <div style="display:flex;flex-direction:column;gap:5px;font-size:12px">
      <div>📦 رقم الطلب الجديد: <strong>${mergedRef}</strong></div>
      <div>💰 إجمالي التحصيل: <strong style="color:var(--success)">${totalCod.toLocaleString()} ج</strong></div>
      <div>🚚 تكلفة الشحن: <strong style="color:var(--warn)">${ship.toLocaleString()} ج</strong></div>
      <div>💵 صافي المحل: <strong style="color:var(--accent)">${(totalCod-ship).toLocaleString()} ج</strong></div>
      <div style="color:var(--muted);margin-top:4px">الطلبات الثانوية (${secondaryIds.length}) ستتحول لحالة "مدمج": <strong>${secondaryIds.join(', ')}</strong></div>
    </div>`;
}

async function confirmMergeOrders(){
  const mergeOrders = _mergeIds.map(id=>orders.find(o=>o.id===id)).filter(Boolean);
  if(mergeOrders.length < 2){ toast('❗ اختر طلبين على الأقل'); return; }
  const primaryId = $('merge-primary-sel')?.value;
  const ship = parseFloat($('merge-ship-val')?.value)||50;
  if(!primaryId){ toast('❗ اختر الطلب الرئيسي'); return; }

  const primary = orders.find(o=>o.id===primaryId);
  const secondaryIds = _mergeIds.filter(id=>id!==primaryId);
  const allOrders = mergeOrders;

  // دمج الـ items والـ total
  const mergedTotal = allOrders.filter(o=>!o.paid).reduce((s,o)=>s+(o.total||0),0);
  const mergedItems = allOrders.map(o=>o.items||'').filter(Boolean).join(', ');
  const mergedRef = allOrders.map(o=>o.id).join(' + ');

  // حدّث الطلب الرئيسي محلياً
  primary.total = mergedTotal;
  primary.items = mergedItems;
  primary.ship = ship;
  primary.mergedIds = _mergeIds;
  primary.displayId = mergedRef;

  // الطلبات الثانوية → مدمج
  secondaryIds.forEach(sid=>{
    const sec = orders.find(o=>o.id===sid);
    if(sec){ sec.status = 'مدمج'; sec.mergedInto = primaryId; }
  });

  debouncedSaveOrders();

  // رفع للـ API
  if(API_URL){
    const lineItemsJson = allOrders.map(o=>{ try{ return JSON.parse(o.lineItemsJson||'[]'); }catch(e){ return []; } }).flat();
    await apiFetch('/api/orders/merge','POST',{
      primaryId, secondaryIds,
      mergedTotal, mergedItems,
      mergedLineItemsJson: JSON.stringify(lineItemsJson),
      shipMode: document.querySelector('input[name="merge-ship-mode"]:checked')?.value||'one',
      shipCost: ship,
    }).catch(e=>console.error('merge error:',e));
  }

  closeM('m-merge-orders');
  renderProblemsPage();
  toast('✅ تم دمج '+allOrders.length+' طلبات في '+primaryId);
}

