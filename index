function getOfferStatus(offer){
  const now = new Date();
  if(!offer.active) return 'paused';
  if(offer.start_at && new Date(offer.start_at) > now) return 'scheduled';
  if(offer.end_at && new Date(offer.end_at) < now) return 'expired';
  return 'active';
}

