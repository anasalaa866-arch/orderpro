// ===== STATE VALIDATION SYSTEM =====
// ملاحظة: السيرفر بينقل من 'جاري التوصيل' لـ 'تحت التسوية' مباشرة (skip لـ 'تم التسليم')
// وكمان في حالات بنرجّع طلب مرتجع لـ 'جديد' عشان يتعاد توزيعه
const STATE_MACHINE = {
  'جديد': ['تم التعيين', 'جاري التوصيل', 'ملغي'],
  'تم التعيين': ['جاري التوصيل', 'جديد', 'ملغي'],
  'جاري التوصيل': ['تم التسليم', 'تحت التسوية', 'مرتجع', 'تم التعيين', 'ملغي'],
  'تم التسليم': ['تحت التسوية', 'مرتجع'],
  'مرتجع': ['تحت التسوية', 'جديد', 'جاري التوصيل'],
  'تحت التسوية': ['مسوّى', 'تم التسليم', 'جاري التوصيل', 'ملغي'],
  'مسوّى': [],
  'ملغي': ['جديد']  // السماح بإلغاء الإلغاء (uncancel)
};

function validateStateTransition(currentStatus, newStatus) {
  if (currentStatus === newStatus) return { valid: true };
  const allowed = STATE_MACHINE[currentStatus] || [];
  if (!allowed.includes(newStatus)) {
    return {
      valid: false,
      error: `لا يمكن تغيير الحالة من "${currentStatus}" إلى "${newStatus}"`
    };
  }
  return { valid: true };
}

function canOrderSettle(order) {
  if (!order) return false;
  const validStatuses = ['تم التسليم', 'مرتجع'];
  if (!validStatuses.includes(order.status)) return false;
  if (!order.courierId) return false;
  if (order.status === 'تم التسليم' && !order.courierDeliveredAt) return false;
  if (order.status === 'مرتجع' && !order.courierReturnedAt) return false;
  return true;
}

function getStatusBadgeClass(status) {
  const map = {
    'جديد': 'b-new',
    'تم التعيين': 'b-assigned',
    'جاري التوصيل': 'b-progress',
    'تم التسليم': 'b-done',
    'مرتجع': 'b-return',
    'تحت التسوية': 'b-settle',
    'مسوّى': 'b-done',
    'ملغي': 'b-cancel'
  };
  return map[status] || 'b-wait';
}

async function safeStatusChange(orderId, newStatus) {
  const order = orders.find(o => o.id === orderId);
  if (!order) {
    toast('الطلب غير موجود', 'error');
    return false;
  }
  
  const validation = validateStateTransition(order.status, newStatus);
  if (!validation.valid) {
    const confirmed = confirm(`⚠️ تحذير:\n\n${validation.error}\n\nهل تريد المتابعة رغم التحذير؟`);
    if (!confirmed) return false;
  }
  
  return true;
}

