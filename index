let editingChkId=null;let chkStatusFilter='all';let chkImgData='';

async function loadChks(){
  if(!API_URL) return;
  try{
    // جيب كل endpoint بشكل منفصل عشان لو واحد فشل ما يأثرش على الباقي
    const results = await Promise.allSettled([
      apiFetch('/api/check-books'),
      apiFetch('/api/checks'),
      apiFetch('/api/vendors')   // 🆕 v194: vendors جديدة
    ]);

    const r1 = results[0].status === 'fulfilled' ? results[0].value : null;
    const r2 = results[1].status === 'fulfilled' ? results[1].value : null;
    const r3 = results[2].status === 'fulfilled' ? results[2].value : null;

    // ⚠️ apiFetch بيرجع null لما يفشل (مش throw)، فلازم نعتبر null = فشل
    const booksFetchFailed = results[0].status === 'rejected' || r1 === null || r1 === undefined;
    const checksFetchFailed = results[1].status === 'rejected' || r2 === null || r2 === undefined;

    if(booksFetchFailed || checksFetchFailed){
      console.warn('⚠️ loadChks: أحد الطلبات فشل أو رجع فاضي، نحتفظ بالبيانات المحلية');
      console.warn('  books response:', r1, '| rejected:', results[0].status === 'rejected');
      console.warn('  checks response:', r2, '| rejected:', results[1].status === 'rejected');
      // بس نرنّد الواجهة بالبيانات المحلية
      chkRenderActive();
      return;
    }

    const dbBooks = r1?.books || [];
    const dbChecks = r2?.checks || [];
    // 🆕 v194: vendors بدل suppliers — استجابة فيها {vendors:[{id,name,phone,note}]}
    const dbVendors = r3?.vendors || r3?.suppliers || [];

    // ⚠️ Safety net: لو الـ DB فيه شيكات بس مفيش دفاتر → ممكن يكون API شغال مع response ناقص
    // نفحص أول لو الـ localStorage عنده دفاتر لنفس الشيكات — لو نعم، ما نمسحش
    if(dbBooks.length === 0 && dbChecks.length > 0 && chkBooks.length > 0){
      console.error('⚠️ تحذير: الـ DB فيه شيكات بس مفيش دفاتر — الـ localStorage عندنا دفاتر، مش هنمسحها.');
      // دمج: استخدم شيكات الـ DB + دفاتر الـ localStorage
      chkList = dbChecks.map(c=>({
        id:c.id, bookId:c.bookId||c.book_id, num:c.num,
        payee:c.payee||c.supplier||'',
        amount:parseFloat(c.amount)||0,
        date:c.date||c.dueDate||c.due_date||'',
        invoice:c.invoice||'', note:c.note||'',
        img:c.img||'', status:c.status||'pending',
        doneAt:c.doneAt||c.done_at||null,
        createdAt:c.createdAt||c.created_at||null,
      }));
      // ارفع الدفاتر المحلية تاني للـ DB عشان الحالة دي ما تتكررش
      console.log('🔄 رفع الدفاتر المحلية تاني للـ DB...');
      apiFetch('/api/sync-checks','POST',{
        books:chkBooks, checks:[], suppliers:chkSuppliers
      }).then(() => console.log('✅ الدفاتر اترفعت تاني')).catch(e => console.warn('sync failed:', e));
      try{
        localStorage.setItem('chk_list',JSON.stringify(chkList));
      }catch(e){}
      chkRenderActive();
      return;
    }

    if(dbBooks.length || dbChecks.length){
      // 🆕 v302: نشيل الشيكات اللي اتحذفت محلياً (لسه ما اترفعتش للسيرفر)
      let deletedIds = [];
      try { deletedIds = JSON.parse(localStorage.getItem('chk_deleted_ids') || '[]'); } catch(e){}
      const deletedSet = new Set(deletedIds);
      const filteredChecks = deletedSet.size ? dbChecks.filter(c => !deletedSet.has(c.id)) : dbChecks;
      if(deletedSet.size && filteredChecks.length < dbChecks.length){
        console.log(`🗑️ شيلت ${dbChecks.length - filteredChecks.length} شيكات محذوفة من الـ DB response`);
      }
      // الـ DB فيه بيانات — استخدمها وحدّث localStorage
      chkBooks = dbBooks.map(b=>({
        id:b.id, name:b.name, bank:b.bank||'', account:b.account||'',
        pages:b.pages||48, note:b.note||'',
        firstNum:b.firstNum||b.first_num||1,
        lastNum:b.lastNum||b.last_num||null,
      }));
      chkList = filteredChecks.map(c=>({
        id:c.id, bookId:c.bookId||c.book_id, num:c.num,
        payee:c.payee||c.supplier||'',
        amount:parseFloat(c.amount)||0,
        date:c.date||c.dueDate||c.due_date||'',
        invoice:c.invoice||'', note:c.note||'',
        img:c.img||'', status:c.status||'pending',
        doneAt:c.doneAt||c.done_at||null,
        createdAt:c.createdAt||c.created_at||null,
      }));
      if(dbVendors.length) chkSuppliers = dbVendors.map(s=>({
        id: s.id || ('v_'+Date.now()),
        name: s.name || String(s),
        phone: s.phone || '',
        note: s.note || ''
      }));
      // احفظ في localStorage
      try{
        localStorage.setItem('chk_books',JSON.stringify(chkBooks));
        localStorage.setItem('chk_list',JSON.stringify(chkList));
        localStorage.setItem('chk_suppliers',JSON.stringify(chkSuppliers));
      }catch(e){}
    } else if(chkBooks.length || chkList.length){
      // الـ DB فاضي بس عندنا بيانات محلية — ارفعها للـ DB
      console.log('DB empty, syncing local data to DB...');
      apiFetch('/api/sync-checks','POST',{
        books:chkBooks, checks:chkList, suppliers:chkSuppliers
      }).then(r => {
        if(r && r.ok){
          console.log(`✅ تم رفع ${r.books || 0} دفتر و ${r.checks || 0} شيك للـ DB`);
          if(chkBooks.length){
            toast('✅ تم رفع ' + chkBooks.length + ' دفتر للسيرفر');
          }
        }
      }).catch(e=>{
        console.warn('sync local->DB:', e);
        if(chkBooks.length){
          toast('⚠️ تحذير: الدفاتر محلية فقط — تعذر رفعها للسيرفر');
        }
      });
    }
    chkRenderActive();
    // 🆕 v278: فحص الدفاتر اليتيمة في الخلفية
    checkOrphanedCheckBooks().catch(()=>{});
  }catch(e){ console.error('loadChks:', e); }
}

let _saveChksTimer=null;
function saveChks(syncNow=true){
  try{
    localStorage.setItem('chk_books',JSON.stringify(chkBooks));
    localStorage.setItem('chk_list',JSON.stringify(chkList));
    localStorage.setItem('chk_suppliers',JSON.stringify(chkSuppliers));
  }catch(e){
    console.error('localStorage save error:', e);
  }
  if(!API_URL) return;
  if(syncNow){
    clearTimeout(_saveChksTimer);
    _saveChksTimer=setTimeout(async ()=>{
      try{
        // 🆕 v302: نبعت deleted_ids كمان عشان السيرفر يحذفها
        let deleted_ids = [];
        try { deleted_ids = JSON.parse(localStorage.getItem('chk_deleted_ids') || '[]'); } catch(e){}
        const r = await apiFetch('/api/sync-checks','POST',{
          books:chkBooks, checks:chkList, suppliers:chkSuppliers,
          deleted_ids
        });
        console.log('✅ Sync checks success:', r);
        // لو الـ sync نجح والـ deleted_ids اترفعت، نمسحها
        if(r && r.ok && deleted_ids.length){
          try { localStorage.setItem('chk_deleted_ids', '[]'); } catch(e){}
        }
      }catch(e){
        console.error('❌ Sync checks failed:', e);
        toast('⚠️ فشل حفظ الشيكات في السيرفر — البيانات محفوظة محلياً', 'error');
      }
    },800);
  }
}
function chkFmtAmount(n){return Number(n||0).toLocaleString('ar-EG');}
function chkFmtDate(d){if(!d)return '—';return new Date(d).toLocaleDateString('ar-EG',{year:'numeric',month:'short',day:'numeric'});}
function chkIsOverdue(c){return c.status==='pending'&&new Date(c.date)<new Date(new Date().toDateString());}
function chkDaysUntil(d){return Math.round((new Date(d)-new Date(new Date().toDateString()))/(864e5));}
function chkGetBadge(c){
  if(c.status==='void')return '<span style="background:#e5e7eb;color:#6b7280;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700;text-decoration:line-through">⛔ هالك</span>';
  if(c.status==='void_requested')return '<span style="background:#fef3c7;color:#92400e;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700">🟡 بانتظار موافقة المدير</span>';
  if(c.status==='done')return '<span style="background:var(--success-light);color:#065f46;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700">✅ تم صرفه</span>';
  if(chkIsOverdue(c))return '<span style="background:var(--danger-light);color:#991b1b;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700">⚠️ متأخر</span>';
  return '<span style="background:var(--warn-light);color:#92400e;padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700">⏳ لم يُصرف</span>';
}
function chkSetFilter(f,btn){
  chkStatusFilter=f;
  document.querySelectorAll('#chk-status-chips .chip').forEach(c=>c.classList.remove('on'));
  if(btn)btn.classList.add('on');
  chkRenderActive();
}

// 🆕 v300: handler للـ period/search/date filters - يحترم الـ chip filter النشط
function chkOnFilterChange(){
  // لو إنت في weekly أو suppliers، الـ period/search مالهومش معنى - رجعنا للـ regular view
  if(chkStatusFilter === 'weekly' || chkStatusFilter === 'suppliers'){
    chkStatusFilter = 'all';
    document.querySelectorAll('#chk-status-chips .chip').forEach(c=>{
      c.classList.remove('on');
      const m = (c.getAttribute('onclick') || '').match(/chkSetFilter\('([^']+)'/);
      if(m && m[1] === 'all') c.classList.add('on');
    });
  }
  // أظهر/خبي date range لو custom اتختار
  const period = document.getElementById('chk-period-filter')?.value;
  const dateRange = document.getElementById('chk-date-range');
  if(dateRange) dateRange.style.display = period === 'custom' ? 'flex' : 'none';
  chkRenderActive();
}

// 🆕 v250: يقرر إيه الـ render حسب الـ filter النشط
function chkRenderActive(){
  // 🔧 v300: تأكد إن الـ chip الصحيح ظاهر كـ active دايماً
  // (في حالة الـ chips اتعملت reset بأي سبب)
  try {
    document.querySelectorAll('#chk-status-chips .chip').forEach(c=>{
      c.classList.remove('on');
      const onclick = c.getAttribute('onclick') || '';
      const m = onclick.match(/chkSetFilter\('([^']+)'/);
      if(m && m[1] === chkStatusFilter) c.classList.add('on');
    });
  } catch(e) {}
  if(chkStatusFilter==='weekly'){renderWeeklyReport();return;}
  if(chkStatusFilter==='suppliers'){renderSuppliersReport();return;}
  renderChecksPage();
}
function renderChecksPage(){
  // 🆕 v298: لو فيه عمليات pending في الـ queue، نـ process قبل ما نـ render
  // عشان نضمن إن البيانات على السيرفر متطابقة مع المعروض
  if(API_URL && typeof processOfflineQueue === 'function' && _offlineQueue && _offlineQueue.length){
    processOfflineQueue().then(() => {
      // بعد ما نرفع الـ queue، نرفش البيانات من السيرفر
      if(typeof loadChks === 'function') loadChks();
    }).catch(()=>{});
  } else if(API_URL && typeof loadChks === 'function'){
    // ارفش البيانات من السيرفر بشكل ساكت (silent refresh) - في background
    loadChks().catch(()=>{});
  }

  const now=new Date(new Date().toDateString());
  
  // 🔧 v219: حساب أسبوع الشيكات يبدأ من الجمعة لينتهي بالخميس
  const today = now.getDay();
  const daysSinceFriday = (today + 2) % 7;
  const weekStart = new Date(now);
  weekStart.setDate(now.getDate() - daysSinceFriday);
  const weekEnd = new Date(weekStart);
  weekEnd.setDate(weekStart.getDate() + 6);
  weekEnd.setHours(23, 59, 59, 999);
  
  const m0=new Date(now.getFullYear(),now.getMonth(),1);
  const m1=new Date(now.getFullYear(),now.getMonth()+1,0);

  // 🆕 v250: تأكد إن الـ chip الصحيح ظاهر كـ active
  document.querySelectorAll('#chk-status-chips .chip').forEach(c=>{
    c.classList.remove('on');
    const onclick = c.getAttribute('onclick') || '';
    const match = onclick.match(/chkSetFilter\('([^']+)'/);
    if(match && match[1] === chkStatusFilter) c.classList.add('on');
  });

  const period=$('chk-period-filter')?.value||'all';
  const q=($('chk-search')?.value||'').toLowerCase();

  const dr=$('chk-date-range');
  if(dr) dr.style.display = period==='custom' ? 'flex' : 'none';

  // ابني الفلتر
  let list=[...chkList];
  if(chkStatusFilter==='pending')list=list.filter(c=>c.status==='pending');
  if(chkStatusFilter==='done')list=list.filter(c=>c.status==='done');
  if(chkStatusFilter==='overdue')list=list.filter(c=>chkIsOverdue(c));
  if(chkStatusFilter==='void')list=list.filter(c=>c.status==='void');
  if(chkStatusFilter==='void_requested')list=list.filter(c=>c.status==='void_requested');
  if(period==='week')list=list.filter(c=>{const d=new Date(c.date);return d>=weekStart&&d<=weekEnd;});
  if(period==='month')list=list.filter(c=>{const d=new Date(c.date);return d>=m0&&d<=m1;});
  if(period==='overdue')list=list.filter(c=>chkIsOverdue(c));
  if(period==='custom'){
    const fromV=$('chk-from')?.value;
    const toV=$('chk-to')?.value;
    if(fromV) list=list.filter(c=>c.date && c.date>=fromV);
    if(toV) list=list.filter(c=>c.date && c.date<=toV);
  }
  if(q)list=list.filter(c=>(c.num+c.payee+(c.invoice||'')).toLowerCase().includes(q));
  list.sort((a,b)=>new Date(a.date)-new Date(b.date));

  // 🆕 v250: الأرقام ديناميكية - من الـ filtered list
  const filteredPending = list.filter(c=>c.status==='pending');
  const filteredDone = list.filter(c=>c.status==='done');
  const filteredOverdue = filteredPending.filter(c=>chkIsOverdue(c));
  const filteredWeek = filteredPending.filter(c=>{const d=new Date(c.date);return d>=weekStart&&d<=weekEnd;});
  
  if($('chk-total-val'))$('chk-total-val').textContent=chkFmtAmount(filteredPending.reduce((s,c)=>s+Number(c.amount),0))+' ج';
  if($('chk-week-val'))$('chk-week-val').textContent=chkFmtAmount(filteredWeek.reduce((s,c)=>s+Number(c.amount),0))+' ج';
  if($('chk-overdue-val'))$('chk-overdue-val').textContent=filteredOverdue.length;
  if($('chk-done-val'))$('chk-done-val').textContent=filteredDone.length;
  // الـ nav badge يبقى من الكل (مش filtered)
  const allOverdue = chkList.filter(c=>c.status==='pending'&&chkIsOverdue(c));
  if($('nb-checks'))$('nb-checks').textContent=allOverdue.length||'';
  
  // 🆕 v250: counter للـ void_requested
  const voidReqCount = chkList.filter(c=>c.status==='void_requested').length;
  const voidReqEl = $('chk-void-req-cnt');
  if(voidReqEl){
    if(voidReqCount > 0){
      voidReqEl.textContent = voidReqCount;
      voidReqEl.style.display = 'inline-block';
    } else {
      voidReqEl.style.display = 'none';
    }
  }

  if($('chk-count'))$('chk-count').textContent=list.length+' شيك';
  const tbody=$('chk-tbody');
  if(!tbody)return;
  if(!list.length){tbody.innerHTML='<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--muted)">لا توجد شيكات</td></tr>';$('chk-sum-row').style.display='none';return;}
  tbody.innerHTML=list.map(c=>{
    const days=chkDaysUntil(c.date);
    const dayLbl=c.status==='pending'?(days<0?`<span style="color:var(--danger);font-size:10px">(${Math.abs(days)} يوم تأخير)</span>`:days<=7?`<span style="color:var(--warn);font-size:10px">(بعد ${days} أيام)</span>`:''):'';
    const book=chkBooks.find(b=>b.id===c.bookId);
    return`<tr style="${chkIsOverdue(c)?'background:#fff5f5':''}${c.status==='void'?'background:#f3f4f6;opacity:.6':''}">
      <td><strong>${c.num}</strong></td>
      <td><strong>${c.payee}</strong>${c.note?`<br><span style="font-size:10px;color:var(--muted)">${c.note}</span>`:''}</td>
      <td style="font-weight:700;font-size:14px">${chkFmtAmount(c.amount)} ج</td>
      <td>${chkFmtDate(c.date)} ${dayLbl}</td>
      <td style="font-size:11px;color:var(--muted)">${book?book.name:'—'}</td>
      <td style="font-size:11px;color:var(--muted)">${c.invoice||'—'}</td>
      <td>${chkGetBadge(c)}</td>
      <td style="text-align:center">${c.img?`<button class="btn btn-ghost btn-xs" onclick="viewChkImg('${c.id}')">🖼️</button>`:'—'}</td>
      <td><div style="display:flex;gap:3px;flex-wrap:wrap">
        ${c.status==='pending'?`<button class="btn btn-xs" style="background:var(--success);color:#fff;border:none" onclick="chkMarkDone('${c.id}')">✅ صُرف</button> <button class="btn btn-ghost btn-xs" style="color:#a16207" onclick="requestChkVoid('${c.id}')" title="طلب جعل الشيك هالك">⚠️ هالك</button>`:''}
        ${c.status==='void_requested'?`<button class="btn btn-xs" style="background:#dc2626;color:#fff;border:none" onclick="approveChkVoid('${c.id}')">✅ موافقة على الهالك</button> <button class="btn btn-ghost btn-xs" onclick="rejectChkVoid('${c.id}')">❌ رفض</button>`:''}
        ${c.status==='done'?`<button class="btn btn-ghost btn-xs" onclick="chkMarkPending('${c.id}')">↩️ إلغاء</button>`:''}
        ${c.status==='void'?`<button class="btn btn-ghost btn-xs" onclick="chkMarkPending('${c.id}')">↩️ إرجاع</button>`:''}
        <button class="btn btn-ghost btn-xs" onclick="openEditChk('${c.id}')">✏️</button>
        <button class="btn btn-ghost btn-xs" style="color:var(--danger)" onclick="deleteChk('${c.id}')">🗑️</button>
      </div></td>
    </tr>`;
  }).join('');
  const total=list.reduce((s,c)=>s+Number(c.amount),0);
  $('chk-sum-row').textContent=`إجمالي ${list.length} شيك: ${chkFmtAmount(total)} ج`;
  $('chk-sum-row').style.display='block';
}
