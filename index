async function confirmReceiveCancellation(orderId){
  const c = _fieldCancels.find(x => x.id === orderId);
  if(!c) return;
  const ok = confirm(`✅ تأكيد استلام البضاعة من ${c.cancelledBySource === 'shop' ? 'المحل' : c.courierName || 'المندوب'}؟\n\nالطلب ${orderId} — ${c.name}\n\nبعد التأكيد، الطلب يعتبر ملغي نهائياً.`);
  if(!ok) return;
  try{
    const r = await apiFetch('/api/field-cancellations/'+orderId+'/confirm-receive','POST',{
      receivedBy: currentUser?.username || 'admin'
    });
    if(r && r.success){
      // حدّث الطلب محلياً
      const oIdx = orders.findIndex(o => o.id === orderId);
      if(oIdx >= 0){ orders[oIdx].status = 'ملغي'; debouncedSaveOrders(); }
      toast('✅ تم تأكيد الاستلام — الطلب ملغي نهائياً');
      loadFieldCancels();
      refreshAll();
    }
  }catch(e){ toast('❌ '+e.message); }
}

async function revertFieldCancellation(orderId){
  const c = _fieldCancels.find(x => x.id === orderId);
  if(!c) return;
  const ok = confirm(`↩️ إرجاع الطلب ${orderId}؟\n\nالطلب هيرجع عند ${c.cancelledBySource === 'shop' ? 'المحل' : c.courierName || 'المندوب'} وهيختفي من هذه القائمة.`);
