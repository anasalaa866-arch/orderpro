async function savePosStore(){
  const id = document.getElementById('pos-store-id').value;
  const name = document.getElementById('pos-store-name').value.trim();
  const warehouseId = document.getElementById('pos-store-wh').value;
  const managerId = document.getElementById('pos-store-manager').value || null;
  const notes = document.getElementById('pos-store-notes').value.trim();
  
  if(!name){ toast('❌ الاسم مطلوب'); return; }
  if(!warehouseId){ toast('❌ المخزن مطلوب'); return; }
  
  // جيب location_id من المخزن
  const wh = _invWarehouses.find(w => w.id == warehouseId);
  const locationId = wh?.shopify_location_id || null;
  
  try {
    if(id){
      await apiFetch('/api/pos/stores/' + id, 'PUT', {
        name, 
        warehouseId: parseInt(warehouseId), 
        locationIdShopify: locationId, 
        managerId: managerId ? parseInt(managerId) : null,
        notes
      });
      toast('✅ تم التحديث');
    } else {
      await apiFetch('/api/pos/stores', 'POST', {
        name, 
        warehouseId: parseInt(warehouseId), 
        locationIdShopify: locationId, 
        managerId: managerId ? parseInt(managerId) : null,
        notes
      });
      toast('✅ تم الإضافة');
    }
    
    // 🆕 v262: لو فيه مدير، اربطه بالمحل (set store_id على الـ courier)
    if(managerId && id){
      try { 
        await apiFetch('/api/couriers/' + managerId, 'PATCH', { storeId: parseInt(id) }); 
      } catch(e){}
    }
    
    closeM('m-new-pos-store');
    loadPosStoresPage();
  } catch(e) { toast('❌ ' + e.message); }
}

// ─── Promo Codes ───
let _promoCodesList = [];

async function loadPromoPage(){
  const container = document.getElementById('promo-codes-list');
  if(!container) return;
  
  try {
    const r = await apiFetch('/api/pos/promo-codes');
    _promoCodesList = r?.codes || [];
    
    if(!_promoCodesList.length){
      container.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)"><div style="font-size:48px;opacity:.3">🎟️</div><div>مفيش أكواد. اضغط ➕ لإضافة كود جديد.</div></div>';
      return;
    }
    
    container.innerHTML = _promoCodesList.map(p => {
      const valueDisplay = p.discount_type === 'percentage' ? `${p.discount_value}%` : `${p.discount_value} ج`;
      const usagePct = p.usage_limit ? Math.round((p.usage_count / p.usage_limit) * 100) : 0;
      const expired = p.valid_until && new Date(p.valid_until) < new Date();
      
      return `<div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:8px">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px;margin-bottom:8px">
          <div>
            <div style="font-weight:800;font-size:16px;color:var(--gold);font-family:monospace;margin-bottom:3px">🎟️ ${escapeHtml(p.code)}</div>
            ${p.title ? `<div style="font-size:12px;font-weight:700">${escapeHtml(p.title)}</div>` : ''}
            <div style="font-size:14px;color:#16a34a;font-weight:700;margin-top:3px">خصم ${valueDisplay}</div>
          </div>
          <div style="display:flex;gap:6px;flex-wrap:wrap">
            <span class="badge" style="background:${p.is_active && !expired ?'#d1fae5':'#fee2e2'};color:${p.is_active && !expired ?'#065f46':'#991b1b'}">
              ${expired ? '⏰ منتهي' : p.is_active ? '✅ نشط' : '⏸️ موقوف'}
            </span>
            <button class="btn btn-ghost btn-xs" onclick="editPromo(${p.id})" style="color:var(--accent)">✏️</button>
            <button class="btn btn-ghost btn-xs" onclick="deletePromo(${p.id})" style="color:var(--danger)">🗑️</button>
          </div>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:8px;font-size:11px;background:#fff;padding:8px;border-radius:6px">
          ${p.min_order_amount > 0 ? `<div>الحد الأدنى: <strong>${p.min_order_amount} ج</strong></div>` : ''}
          ${p.max_discount ? `<div>الحد الأقصى: <strong>${p.max_discount} ج</strong></div>` : ''}
          ${p.valid_from ? `<div>من: <strong>${new Date(p.valid_from).toLocaleDateString('ar-EG')}</strong></div>` : ''}
          ${p.valid_until ? `<div>حتى: <strong>${new Date(p.valid_until).toLocaleDateString('ar-EG')}</strong></div>` : ''}
          <div>الاستخدام: <strong>${p.usage_count}${p.usage_limit ? ' / '+p.usage_limit : ''}</strong></div>
        </div>
      </div>`;
    }).join('');
  } catch(e) {
    container.innerHTML = `<div style="color:var(--danger);padding:20px;text-align:center">❌ ${escapeHtml(e.message)}</div>`;
  }
}

function openNewPromo(){
  document.getElementById('promo-id').value = '';
  document.getElementById('promo-modal-title').textContent = '🎟️ كود جديد';
  ['promo-code','promo-title','promo-value','promo-min','promo-max','promo-from','promo-until','promo-limit'].forEach(id => {
    document.getElementById(id).value = '';
  });
  document.getElementById('promo-type').value = 'percentage';
  document.getElementById('promo-active').checked = true;
  openM('m-new-promo');
}

function editPromo(id){
  const p = _promoCodesList.find(x => x.id == id);
  if(!p) return;
  
  document.getElementById('promo-id').value = p.id;
  document.getElementById('promo-modal-title').textContent = '✏️ تعديل ' + p.code;
  document.getElementById('promo-code').value = p.code;
  document.getElementById('promo-code').disabled = true;
  document.getElementById('promo-title').value = p.title || '';
  document.getElementById('promo-type').value = p.discount_type;
  document.getElementById('promo-value').value = p.discount_value;
  document.getElementById('promo-min').value = p.min_order_amount || '';
  document.getElementById('promo-max').value = p.max_discount || '';
  document.getElementById('promo-from').value = p.valid_from || '';
  document.getElementById('promo-until').value = p.valid_until || '';
  document.getElementById('promo-limit').value = p.usage_limit || '';
  document.getElementById('promo-active').checked = p.is_active;
  
  openM('m-new-promo');
}

async function savePromo(){
  const id = document.getElementById('promo-id').value;
  const code = document.getElementById('promo-code').value.trim().toUpperCase();
  const title = document.getElementById('promo-title').value.trim();
  const discountType = document.getElementById('promo-type').value;
  const discountValue = parseFloat(document.getElementById('promo-value').value);
  const minOrderAmount = parseFloat(document.getElementById('promo-min').value) || 0;
  const maxDiscount = parseFloat(document.getElementById('promo-max').value) || null;
  const validFrom = document.getElementById('promo-from').value || null;
  const validUntil = document.getElementById('promo-until').value || null;
  const usageLimit = parseInt(document.getElementById('promo-limit').value) || null;
  const isActive = document.getElementById('promo-active').checked;
  
  if(!code){ toast('❌ الكود مطلوب'); return; }
  if(!discountValue || discountValue <= 0){ toast('❌ قيمة الخصم مطلوبة'); return; }
  if(discountType === 'percentage' && discountValue > 100){ toast('❌ النسبة لازم تكون <= 100'); return; }
  
  try {
    if(id){
      await apiFetch('/api/pos/promo-codes/' + id, 'PUT', {
        title, discountType, discountValue, minOrderAmount, maxDiscount,
        validFrom, validUntil, usageLimit, isActive
      });
      toast('✅ تم التحديث');
    } else {
      await apiFetch('/api/pos/promo-codes', 'POST', {
        code, title, discountType, discountValue, minOrderAmount, maxDiscount,
        validFrom, validUntil, usageLimit, isActive
      });
      toast('✅ تم الإضافة');
    }
    document.getElementById('promo-code').disabled = false;
    closeM('m-new-promo');
    loadPromoPage();
  } catch(e) { toast('❌ ' + e.message); }
}

async function deletePromo(id){
  const p = _promoCodesList.find(x => x.id == id);
  if(!p) return;
  if(!confirm(`حذف الكود "${p.code}"؟`)) return;
  
  try {
    await apiFetch('/api/pos/promo-codes/' + id, 'DELETE');
    toast('✅ تم الحذف');
    loadPromoPage();
  } catch(e) { toast('❌ ' + e.message); }
}

