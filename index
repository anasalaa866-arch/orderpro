async function confirmChangeOrderType(){
  const orderId = document.getElementById('cot-order-id').value;
  const newTypeId = document.getElementById('cot-new-type').value;
  const reason = document.getElementById('cot-reason').value.trim();
  
  if(!orderId){ toast('❌ خطأ في تحديد الطلب'); return; }
  if(!newTypeId){ toast('⚠️ اختار النوع الجديد'); return; }
  
  const o = orders.find(x => x.id === orderId);
  if(!o){ toast('❌ الطلب غير موجود'); return; }
  
  try{
    await apiFetch('/api/orders/'+encodeURIComponent(orderId)+'/change-type', 'POST', {
      order_type_id: parseInt(newTypeId),
      reason: reason || 'تعديل يدوي من تفاصيل الطلب'
    });
    
    // حدّث محلياً
    o.orderTypeId = parseInt(newTypeId);
    
    closeM('m-change-order-type');
    toast('✅ تم تعديل نوع الطلب');
    
    // أعد رسم الصفحة الحالية
    if(typeof renderAssignPage === 'function' && currentPage === 'assign') renderAssignPage();
    refreshAll();
  }catch(e){
    toast('❌ ' + (e.message || 'فشل التحديث'));
  }
}

function renderAssignGrid(){
  const g=$('assign-cgrid');if(!g)return;
  const o=orders.find(x=>x.id===assignOrderId);
  if(isPickup(o)){
    g.innerHTML='<div style="padding:16px;text-align:center;color:var(--purple);font-weight:600;font-size:13px">🏪 هذا الطلب للاستلام من المحل — لا يحتاج تعيين مندوب</div>';
    return;
  }
  const suggested=suggestCourier(o);
  // 🆕 اعرض المناديب بس (courier) — أي دور تاني يختفي. بوسطة كزرار منفصل تحت
  const assignableCouriers = couriers.filter(c => {
    const r = c.role || 'courier';
    return r === 'courier';
  });
  g.innerHTML=assignableCouriers.map((c,i)=>{
    const active=oByC(c.id,'جاري التوصيل').length;
    const isSugg=suggested&&suggested.id===c.id;
    const isSelected=selectedCourierId==c.id;
    const zm=o?zoneMatchScore(o.area,c.zone):{score:0,reason:'',matched:''};
    const zs=zm.score;
    const matchLabel=zs>=100?'🟢 تطابق تام':zs>=70?'🟡 تطابق جزئي':zs>=50?'🟠 تشابه':zs>0?'🔵 ممكن':'⚫ خارج منطقته';
    const borderStyle=zs>=100?'border-color:#10b981;box-shadow:0 0 0 2px rgba(16,185,129,.2)':zs>=70?'border-color:#f59e0b;box-shadow:0 0 0 2px rgba(245,158,11,.15)':'';
    return`<div class="cc ${isSelected?'selected':''}" id="agc-${c.id}" onclick="selC(${c.id})" style="cursor:pointer;position:relative;${borderStyle}">
      ${isSugg?`<div style="position:absolute;top:-1px;left:-1px;background:#10b981;color:#fff;font-size:9px;font-weight:700;padding:2px 7px;border-radius:8px 0 8px 0">🤖 مقترح</div>`:''}
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;margin-top:${isSugg?'10px':'0'}">
        <div class="cc-av" style="background:${COLORS[i%COLORS.length]};width:32px;height:32px;font-size:13px">${c.name[0]}</div>
        <div><div class="cc-name" style="font-size:12px">${c.name}</div><div class="cc-info" style="font-size:10px">${c.zone}</div></div>
      </div>
      <div class="cc-info">📦 نشط: <strong>${active}</strong></div>
      <div class="cc-info">💰 عادي: <strong>${c.ship} ج</strong> | ⚡ <strong>${c.shipExpress||c.ship} ج</strong></div>
      <div style="margin-top:6px;font-size:10px;font-weight:700">${matchLabel}${zm.matched?' · '+zm.matched:''}</div>
    </div>`}).join('')
    +'<div onclick="selC(\'bosta\')" id="assign-c-bosta" style="cursor:pointer;border:2px solid var(--border);border-radius:12px;padding:12px;background:var(--card)">'
    +'<div style="display:flex;align-items:center;gap:8px">'
    +'<div style="width:32px;height:32px;border-radius:50%;background:#f97316;color:#fff;display:flex;align-items:center;justify-content:center;font-size:16px">📦</div>'
    +'<div><div style="font-size:13px;font-weight:700">بوسطة</div><div style="font-size:10px;color:var(--muted)">توصيل خارجي</div></div>'
    +'</div></div>';
}

function selC(id){
  selectedCourierId=id;
  document.querySelectorAll('#assign-cgrid .cc').forEach(el=>el.classList.remove('selected'));
  $('agc-'+id)&&$('agc-'+id).classList.add('selected');
  const bostaEl=$('assign-c-bosta');
  if(bostaEl) bostaEl.style.border=String(id)==='bosta'?'2px solid var(--accent)':'2px solid var(--border)';
  const c=couriers.find(x=>x.id==id);
  const o=orders.find(x=>x.id===assignOrderId);
  if(c&&o) $('assign-ship').value=getShipCost(o,c);
  if(String(id)==='bosta'&&o) $('assign-ship').value=o.ship||50;
}

// ===== SHOPIFY REVERSE SYNC =====
// فقط المدير يقدر يعمل fulfill على Shopify
async function openOrderHistory(orderId){
  const o = orders.find(x=>x.id===orderId);
  if($('oh-order-id')) $('oh-order-id').textContent = orderId;
  const content = $('oh-content');
  if(content) content.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)">⏳ جاري التحميل...</div>';
  openM('m-order-history');

  if(!API_URL){
    if(content) content.innerHTML = '<div style="padding:20px;text-align:center;color:var(--muted)">لا يوجد سجل بدون الـ Backend</div>';
    return;
  }

  const data = await apiFetch('/api/orders/'+orderId+'/history');
  const history = data?.history || [];

  // أضيف حدث الإنشاء من بيانات الطلب
  const baseEvents = [];
  if(o?.createdAt) baseEvents.push({action:'إنشاء الطلب', ts:o.createdAt, userName:'Shopify', newValue: o.src==='shopify'?'Shopify':'يدوي'});

  const all = [...baseEvents, ...history].sort((a,b)=>new Date(b.ts)-new Date(a.ts));

  if(!all.length){
    if(content) content.innerHTML = '<div style="padding:20px;text-align:center;color:var(--muted)">لا يوجد تاريخ لهذا الطلب</div>';
    return;
  }

  const fmtTs = ts => {
    const d = new Date(ts);
    return d.toLocaleDateString('ar-EG',{year:'numeric',month:'short',day:'numeric'})
      + ' ' + d.toLocaleTimeString('ar-EG',{hour:'2-digit',minute:'2-digit',timeZone:'Africa/Cairo'});
  };

  // 🆕 v335: preparation status banner (لو في معلومات تحضير)
  let prepBanner = '';
  if(o && o.preparationStatus){
    if(o.preparationStatus === 'completed'){
      const completedName = o.preparationCompletedByName || o.preparationStartedByName || 'غير معروف';
      const completedAt = o.preparationCompletedAt ? fmtTs(o.preparationCompletedAt) : '';
      // حساب المدة
      let durationStr = '';
      if(o.preparationStartedAt && o.preparationCompletedAt){
        const ms = new Date(o.preparationCompletedAt) - new Date(o.preparationStartedAt);
        const mins = Math.round(ms / 60000);
        if(mins < 60) durationStr = ` · مدة التحضير: ${mins} دقيقة`;
        else durationStr = ` · مدة التحضير: ${Math.floor(mins/60)}س ${mins%60}د`;
      }
      prepBanner = `
        <div style="background:linear-gradient(135deg,#dcfce7,#bbf7d0);border:1px solid #16a34a;border-radius:10px;padding:12px;margin-bottom:14px">
          <div style="font-weight:800;color:#15803d;font-size:13px;margin-bottom:4px">✅ تم تحضير الطلب</div>
          <div style="font-size:12px;color:#166534">👤 المحضّر: <strong>${escapeHtml(completedName)}</strong></div>
          <div style="font-size:11px;color:#166534;margin-top:2px">🕐 ${completedAt}${durationStr}</div>
        </div>
      `;
    } else if(o.preparationStatus === 'in_progress'){
      const startedName = o.preparationStartedByName || 'غير معروف';
      const startedAt = o.preparationStartedAt ? fmtTs(o.preparationStartedAt) : '';
      // مدة تحت التحضير
      let elapsedStr = '';
      if(o.preparationStartedAt){
        const ms = Date.now() - new Date(o.preparationStartedAt).getTime();
        const mins = Math.round(ms / 60000);
        if(mins < 60) elapsedStr = ` · من ${mins} دقيقة`;
        else elapsedStr = ` · من ${Math.floor(mins/60)}س ${mins%60}د`;
      }
      prepBanner = `
        <div style="background:linear-gradient(135deg,#fef3c7,#fde68a);border:1px solid #f59e0b;border-radius:10px;padding:12px;margin-bottom:14px">
          <div style="font-weight:800;color:#92400e;font-size:13px;margin-bottom:4px">📦 جاري تحضير الطلب</div>
          <div style="font-size:12px;color:#78350f">👤 يحضّره: <strong>${escapeHtml(startedName)}</strong></div>
          <div style="font-size:11px;color:#78350f;margin-top:2px">🕐 ابتدا ${startedAt}${elapsedStr}</div>
        </div>
      `;
    }
  }

  // 🆕 v249: batch deductions banner (لو الطلب خصم من batches)
  let batchBanner = '';
  if(o && API_URL){
    try {
      const bR = await apiFetch('/api/orders/' + encodeURIComponent(orderId) + '/batches');
      const deductions = bR?.deductions || [];
      if(Array.isArray(deductions) && deductions.length){
        // group by variantId
        const byVariant = {};
        deductions.forEach(d => {
          const key = d.variantId;
          if(!byVariant[key]) byVariant[key] = { items: [], totalQty: 0 };
          byVariant[key].items.push(d);
          byVariant[key].totalQty += parseInt(d.qty) || 0;
        });
        
        const today = new Date();
        let hasUrgent = false;
        
        const variantBlocks = Object.entries(byVariant).map(([vid, group]) => {
          return group.items.map(d => {
            const expDate = d.batchInfo?.exp_date || d.expDate;
            const dateFmt = expDate ? new Date(expDate).toLocaleDateString('ar-EG', {year:'numeric',month:'short',day:'numeric'}) : '—';
            const daysLeft = expDate ? Math.ceil((new Date(expDate) - today) / (1000*60*60*24)) : null;
            const isUrgent = daysLeft !== null && daysLeft <= 60;
            if(isUrgent) hasUrgent = true;
            const title = d.batchInfo?.product_title ? (d.batchInfo.product_title + (d.batchInfo.variant_title ? ' - ' + d.batchInfo.variant_title : '')) : 'منتج';
            
            return `
              <div style="display:grid;grid-template-columns:1fr auto auto;gap:10px;padding:8px 10px;background:#fff;border-radius:6px;font-size:12px;align-items:center;${isUrgent ? 'border-right:3px solid #f59e0b' : ''}">
                <div>
                  <div style="font-weight:700;color:#1a1c1d">${escapeHtml(title)}</div>
                  <div style="font-size:10px;color:#6d7175;font-family:monospace">Batch #${d.batchId}</div>
                </div>
                <div style="text-align:center">
                  <div style="font-weight:700;color:${isUrgent ? '#f59e0b' : '#15803d'}">${dateFmt}</div>
                  ${daysLeft !== null ? `<div style="font-size:10px;color:${isUrgent ? '#f59e0b' : '#6d7175'}">${daysLeft < 0 ? 'منتهي' : 'بعد '+daysLeft+' يوم'}</div>` : ''}
                </div>
                <div style="text-align:center;font-weight:800;font-size:14px;color:#1a1c1d">×${d.qty}</div>
              </div>
            `;
          }).join('');
        }).join('');
        
        batchBanner = `
          <div style="background:${hasUrgent ? 'linear-gradient(135deg,#fef3c7,#fff)' : 'linear-gradient(135deg,#dbeafe,#fff)'};border:1px solid ${hasUrgent ? '#f59e0b' : '#3b82f6'};border-radius:10px;padding:12px;margin-bottom:14px">
            <div style="font-weight:800;color:${hasUrgent ? '#92400e' : '#1e40af'};font-size:13px;margin-bottom:8px">
              📦 Batches المخصومة لهذا الطلب
              ${hasUrgent ? '<span style="font-size:11px;font-weight:600;background:#fbbf24;color:#78350f;padding:2px 8px;border-radius:99px;margin-right:6px">⚠️ يحتوي تواريخ قريبة</span>' : ''}
            </div>
            <div style="display:flex;flex-direction:column;gap:6px">
              ${variantBlocks}
            </div>
            ${hasUrgent ? `<div style="font-size:11px;color:#92400e;margin-top:8px">💡 المحضّر لازم يأكد إنه أخد الكميات من الـ batches دي</div>` : ''}
          </div>
        `;
      }
    } catch(e){ /* batch info optional */ }
  }
  
  const iconMap = {
    'إنشاء الطلب':'🆕', 'تغيير الحالة':'🔄', 'تعيين مندوب':'🚴',
    'تعديل البيانات':'✏️', 'تغيير حالة الدفع':'💳', 'إلغاء':'❌',
    'مكتمل':'✅', 'تسوية':'💰', 
    'printed':'🖨️', 'طباعة':'🖨️', // 🆕 v265
    // 🆕 v335: preparation actions
    'preparation_started':'📦',
    'preparation_completed':'✅',
    'barcode_scanned':'🔍',
    'default':'📌'
  };

  // 🆕 v265: ترجمة action 'printed' للعربية
  const actionLabels = {
    'printed': 'طباعة',
    // 🆕 v335: ترجمة preparation actions
    'preparation_started': 'بدء التحضير',
    'preparation_completed': 'تم التحضير',
    'barcode_scanned': 'سكان باركود'
  };

  if(content) content.innerHTML = prepBanner + batchBanner + all.map(h=>{
    const displayAction = actionLabels[h.action] || h.action;
    const icon = iconMap[h.action] || iconMap[displayAction] || iconMap.default;
    const hasChange = h.oldValue && h.newValue && h.oldValue !== h.newValue;
    // 🆕 v195: زر "اعرض التسوية" لو الحدث تسوية
    const settleBtn = h.action === 'تسوية' && h.settlementId
      ? `<button class="btn btn-ghost btn-xs" onclick="goToSettlement('${h.settlementId}')" style="margin-top:6px;font-size:11px">📜 اعرض التسوية</button>`
      : '';
    
    // 🆕 v265: عرض خاص للطباعة
    let extraInfo = '';
    if(h.action === 'printed' && h.newValue){
      extraInfo = `<div style="font-size:11px;color:#6366f1;margin-top:2px;font-weight:700">📄 نوع الطباعة: ${h.newValue}</div>`;
    }
    
    return `<div style="display:flex;gap:12px;padding:10px 0;border-bottom:1px solid var(--border)">
      <div style="font-size:18px;min-width:28px;text-align:center;margin-top:2px">${icon}</div>
      <div style="flex:1">
