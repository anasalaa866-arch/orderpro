        </td>
        <td style="padding:8px 6px;text-align:center">
          <div style="font-size:11px;color:var(--muted)">${labelA}</div>
          <div style="font-weight:700;font-size:13px">${avgA.toFixed(2)}</div>
          <div style="font-size:10px;color:var(--muted)">${labelB}</div>
          <div style="font-weight:700;font-size:13px;color:${diffColor}">${diffIco} ${avgB.toFixed(2)} (${pct >= 0 ? '+' : ''}${pct.toFixed(0)}%)</div>
