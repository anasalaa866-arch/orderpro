        ? `<span style="display:inline-flex;align-items:center;gap:3px;background:${oldType.color}22;color:${oldType.color};padding:3px 9px;border-radius:6px;font-weight:700;font-size:11px">${oldType.emoji||'📦'} ${escapeHtml(oldType.label_ar)}</span>`
        : `<span style="color:var(--muted);font-size:11px">${escapeHtml(c.old_type_label || '—')}</span>`;
      
