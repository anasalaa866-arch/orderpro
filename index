let _settlementsCache = { pending: [], history: [] };

// 🔧 v278: renamed from loadSettlements -> loadCashierSettlements
// لأن كان فيه function تانية بنفس الاسم في السطر 12268 (للمناديب)
// و JS بياخد آخر تعريف فقط، يعني الـ function بتاعت المناديب كانت بتتجاهل
// النتيجة: _allSettlements تفضل فاضية → سجل التسويات عالق + محاسبة المناديب بتعرض كل الطلبات
async function loadCashierSettlements(){
  try {
    // pending
    const pendingR = await apiFetch('/api/cashier-settlements/pending');
    _settlementsCache.pending = pendingR?.pending || [];
    
    // history (with filters)
    const fromDate = $('settle-filter-from')?.value;
    const toDate = $('settle-filter-to')?.value;
    const cashierId = $('settle-filter-cashier')?.value;
    
    const params = new URLSearchParams();
    if(fromDate) params.append('from', fromDate);
    if(toDate) params.append('to', toDate);
    if(cashierId) params.append('cashierId', cashierId);
    
    const historyR = await apiFetch('/api/cashier-settlements?' + params.toString());
    _settlementsCache.history = historyR?.settlements || [];
    
    // stats
    const pendingTotal = _settlementsCache.pending.reduce((a, p) => a + (parseFloat(p.totalCash) || 0), 0);
    $('settle-stat-pending-count').textContent = _settlementsCache.pending.length;
    $('settle-stat-pending-amount').textContent = pendingTotal.toLocaleString() + ' ج';
    
    const stats = historyR?.stats || {};
    $('settle-stat-history-count').textContent = stats.totalSettlements || 0;
    $('settle-stat-history-amount').textContent = (stats.totalAmount || 0).toLocaleString() + ' ج';
    
    // badge in nav
    const navBadge = $('nb-settlements');
    if(navBadge){
      navBadge.textContent = _settlementsCache.pending.length;
      navBadge.style.display = _settlementsCache.pending.length > 0 ? '' : 'none';
    }
    
    // populate cashier filter
    const cashiers = couriers.filter(c => (c.role || '') === 'cashier');
    const filterSelect = $('settle-filter-cashier');
    if(filterSelect){
      const currentVal = filterSelect.value;
      filterSelect.innerHTML = '<option value="">كل الكاشيرز</option>' +
        cashiers.map(c => `<option value="${c.id}" ${currentVal == c.id ? 'selected' : ''}>${escapeHtml(c.name)}</option>`).join('');
    }
    
    renderPendingSettlements();
    renderSettlementsHistory();
  } catch(e) {
    console.error('loadCashierSettlements:', e);
    toast('❌ خطأ في التحميل: ' + e.message, 'error');
  }
}

