// ===== RICH TOAST SYSTEM =====
// Supports pending → success/error transitions with unique IDs
const _richToasts = new Map(); // id -> element
let _toastCounter = 0;

function _ensureToastContainer(){
  let c = document.getElementById('rich-toast-container');
  if(!c){
    c = document.createElement('div');
    c.id = 'rich-toast-container';
    c.style.cssText = 'position:fixed;bottom:20px;left:50%;transform:translateX(-50%);z-index:10001;display:flex;flex-direction:column;gap:8px;align-items:center;pointer-events:none;font-family:Cairo,sans-serif';
    document.body.appendChild(c);
  }
  return c;
}

function _makeToastEl(id, kind, msg, retryFn){
  const bg = kind === 'success' ? '#16a34a'
           : kind === 'error'   ? '#dc2626'
           : kind === 'warning' ? '#ea580c'
           : '#475569'; // pending
  const icon = kind === 'success' ? '✅'
             : kind === 'error'   ? '❌'
             : kind === 'warning' ? '⚠️'
             : '⏳';

  const t = document.createElement('div');
  t.dataset.toastId = id;
  t.style.cssText = `background:${bg};color:#fff;padding:11px 16px;border-radius:10px;font-size:13px;font-weight:500;box-shadow:0 8px 30px rgba(0,0,0,.3);max-width:440px;display:flex;align-items:center;gap:10px;pointer-events:auto;transition:all .3s;opacity:0;transform:translateY(20px)`;

  const spinner = kind === 'pending'
    ? '<div style="width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .8s linear infinite;flex-shrink:0"></div>'
    : `<span style="font-size:16px;flex-shrink:0">${icon}</span>`;

  let actions = '';
  if(kind === 'error' && retryFn){
    actions = `<button class="toast-retry-btn" style="background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);color:#fff;padding:3px 10px;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;font-family:Cairo,sans-serif;margin-right:4px">🔄 إعادة المحاولة</button>`;
  }
  const closeBtn = (kind !== 'pending')
    ? `<span class="toast-close-btn" style="cursor:pointer;opacity:.8;font-size:15px;padding:0 4px;user-select:none;flex-shrink:0">✕</span>`
    : '';

  t.innerHTML = `${spinner}<div style="flex:1;line-height:1.4">${msg}</div>${actions}${closeBtn}`;

  // ensure spin animation exists
  if(!document.getElementById('rich-toast-anim')){
    const s = document.createElement('style');
    s.id = 'rich-toast-anim';
    s.textContent = '@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}';
    document.head.appendChild(s);
  }

  // fade in next tick
  setTimeout(() => { t.style.opacity = '1'; t.style.transform = 'translateY(0)'; }, 10);

  // wire up buttons
  const closeEl = t.querySelector('.toast-close-btn');
  if(closeEl) closeEl.onclick = () => _dismissToast(id);
  const retryEl = t.querySelector('.toast-retry-btn');
  if(retryEl && retryFn) retryEl.onclick = () => { _dismissToast(id); retryFn(); };

  return t;
}

function _dismissToast(id){
  const el = _richToasts.get(id);
  if(!el) return;
  el.style.opacity = '0';
  el.style.transform = 'translateY(20px)';
  setTimeout(() => { if(el.parentNode) el.parentNode.removeChild(el); }, 300);
  _richToasts.delete(id);
}

// Public API:
function toastPending(msg){
  const id = 'tp_' + (++_toastCounter);
  const c = _ensureToastContainer();
  const t = _makeToastEl(id, 'pending', msg);
  c.appendChild(t);
  _richToasts.set(id, t);
  return id;
}

function toastSuccess(idOrMsg, maybeMsg){
  // توست نجاح جديد، أو تحويل pending لنجاح
  if(typeof idOrMsg === 'string' && idOrMsg.startsWith('tp_') && _richToasts.has(idOrMsg)){
    // تحويل pending موجود
    const id = idOrMsg;
    const msg = maybeMsg;
    const old = _richToasts.get(id);
    const c = _ensureToastContainer();
    const t = _makeToastEl(id, 'success', msg);
    c.replaceChild(t, old);
    _richToasts.set(id, t);
    // auto-dismiss بعد 3 ثواني
    setTimeout(() => _dismissToast(id), 3000);
    return id;
  }
  // توست نجاح جديد
  const msg = idOrMsg;
  const id = 'ts_' + (++_toastCounter);
  const c = _ensureToastContainer();
  const t = _makeToastEl(id, 'success', msg);
  c.appendChild(t);
  _richToasts.set(id, t);
  setTimeout(() => _dismissToast(id), 3000);
  return id;
}

function toastError(idOrMsg, maybeMsg, retryFn){
  if(typeof idOrMsg === 'string' && idOrMsg.startsWith('tp_') && _richToasts.has(idOrMsg)){
    const id = idOrMsg;
    const msg = maybeMsg;
    const old = _richToasts.get(id);
    const c = _ensureToastContainer();
    const t = _makeToastEl(id, 'error', msg, retryFn);
    c.replaceChild(t, old);
    _richToasts.set(id, t);
    // errors تفضل 10 ثواني أو تختفي بس لو المستخدم دوس ✕
    setTimeout(() => _dismissToast(id), 10000);
    return id;
  }
  const msg = idOrMsg;
  const id = 'te_' + (++_toastCounter);
  const c = _ensureToastContainer();
  const t = _makeToastEl(id, 'error', msg, retryFn);
  c.appendChild(t);
  _richToasts.set(id, t);
  setTimeout(() => _dismissToast(id), 10000);
  return id;
}

function toastWarning(msg){
  const id = 'tw_' + (++_toastCounter);
  const c = _ensureToastContainer();
  const t = _makeToastEl(id, 'warning', msg);
  c.appendChild(t);
  _richToasts.set(id, t);
  setTimeout(() => _dismissToast(id), 5000);
  return id;
}

// ===== doAction — wrapper موحد =====
// Usage: await doAction('توزيع المندوب', async () => apiPatch(...), { rollback: () => Object.assign(o, snapshot) })
async function doAction(label, apiCall, opts = {}){
  const pendingId = toastPending(label + '...');
  try{
    const result = await apiCall();
    // نجاح: لازم result يكون object ومش null، و success !== false
    if(result && result.success !== false && !result.error){
      toastSuccess(pendingId, '✅ ' + label);
      if(opts.onSuccess) opts.onSuccess(result);
      return { ok: true, result };
    }
    // فشل من السيرفر — رسالة الفشل من result
    const errMsg = result?.error || result?.message || 'فشل بدون سبب واضح';
    const retry = opts.retry !== false
      ? () => doAction(label, apiCall, opts)
      : null;
    toastError(pendingId, '❌ فشل ' + label + '\n↳ ' + errMsg, retry);
    if(opts.rollback) opts.rollback();
    if(opts.onError) opts.onError(result);
    return { ok: false, result };
  }catch(e){
    const retry = opts.retry !== false
      ? () => doAction(label, apiCall, opts)
      : null;
    toastError(pendingId, '❌ خطأ شبكة: ' + label + '\n↳ ' + (e.message || 'unknown'), retry);
    if(opts.rollback) opts.rollback();
    if(opts.onError) opts.onError(e);
    return { ok: false, error: e };
  }
}

