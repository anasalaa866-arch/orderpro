  const closedAt = s.cashier_closed_at ? new Date(s.cashier_closed_at).toLocaleString('ar-EG', { dateStyle: 'short', timeStyle: 'short' }) : (isPending ? '—' : 'لسه شغّال');
  
  // جداول بـ payment method
  let tablesHtml = '';
  for(const [methodKey, sales] of Object.entries(r.byMethod || {})){
    if(!sales || !sales.length) continue;
    const m = methodLabels[methodKey] || methodLabels.other;
    const groupTotal = sales.reduce((t, sale) => t + (parseFloat(sale.total) || 0), 0);
    
