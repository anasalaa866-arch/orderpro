  document.getElementById('po-shipping-display').textContent = shipping.toFixed(2) + ' ج';
  document.getElementById('po-tax-display').textContent = tax.toFixed(2) + ' ج';
  document.getElementById('po-total-display').textContent = total.toFixed(2) + ' ج';
}

