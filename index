function renderSmartDashboard(data){
  // Last updated
  const lastUpd = document.getElementById('sd-last-updated');
  if(lastUpd){
    const dt = new Date(data.generatedAt);
    lastUpd.textContent = `🕐 آخر تحديث: ${dt.toLocaleTimeString('ar-EG',{hour:'2-digit',minute:'2-digit',timeZone:'Africa/Cairo'})} (${dt.toLocaleDateString('ar-EG',{day:'numeric',month:'short',timeZone:'Africa/Cairo'})})`;
  }
  
  // Today KPIs
  setText('sd-today-revenue', data.today.revenue.toLocaleString() + ' ج');
  setText('sd-today-orders', data.today.count);
  setText('sd-avg-order', Math.round(data.today.avgOrderValue).toLocaleString() + ' ج');
  setText('sd-completion-rate', data.today.completionRate + '%');
  setText('sd-cancel-rate', data.today.cancelledRate + '%');
  
  // Growth indicators
  renderGrowthBadge('sd-revenue-growth', data.today.revenueGrowthPct);
  renderGrowthBadge('sd-orders-growth', data.today.ordersGrowthPct);
  
  // Active orders
  setText('sd-unassigned', data.active.unassigned);
  setText('sd-in-progress', data.active.inProgress);
  setText('sd-pending-settle', data.active.pendingSettlement);
  setText('sd-problems', data.active.problems);
  setText('sd-old-pending', data.active.oldPending);
  
