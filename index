function filterAdvances(status, btn){
  _hrAdvancesFilter = status;
  document.querySelectorAll('#hr-adv-tabs .chip').forEach(c => c.classList.remove('on'));
  if(btn) btn.classList.add('on');
  loadHrAdvances();
}

async function openNewAdvance(){
  // املأ الموظفين
  if(!_hrEmployees.length){
    try{ _hrEmployees = await apiFetch('/api/hr/employees') || []; }catch(e){}
  }
  const sel = document.getElementById('adv-emp');
  sel.innerHTML = '<option value="">-- اختر موظف --</option>' +
    _hrEmployees.filter(e => e.active).map(e => `<option value="${e.id}">${escapeHtml(e.name_ar)} (${escapeHtml(e.code||'')})</option>`).join('');
  
  document.getElementById('adv-amount').value = '';
  document.getElementById('adv-reason').value = '';
  document.getElementById('adv-installments').value = '1';
  document.getElementById('adv-monthly').value = '';
  document.getElementById('adv-notes').value = '';
  
  // auto-update monthly when amount changes
  document.getElementById('adv-amount').onchange = updateAdvMonthly;
  
  document.getElementById('m-hr-advance').style.display = 'flex';
}

function updateAdvMonthly(){
  const amt = parseFloat(document.getElementById('adv-amount').value) || 0;
  const inst = parseInt(document.getElementById('adv-installments').value) || 1;
  if(amt > 0 && inst > 0){
    document.getElementById('adv-monthly').value = (amt / inst).toFixed(2);
  }
}

async function saveAdvance(){
  const data = {
    employee_id: document.getElementById('adv-emp').value,
    amount: parseFloat(document.getElementById('adv-amount').value),
    reason: document.getElementById('adv-reason').value.trim(),
    installments_count: parseInt(document.getElementById('adv-installments').value) || 1,
    monthly_deduction: parseFloat(document.getElementById('adv-monthly').value) || 0,
    notes: document.getElementById('adv-notes').value.trim()
  };
  
  if(!data.employee_id) { toast('❌ اختر موظف'); return; }
  if(!data.amount || data.amount <= 0) { toast('❌ المبلغ مطلوب'); return; }
  if(!data.monthly_deduction) data.monthly_deduction = data.amount / data.installments_count;
  
  try{
    await apiFetch('/api/hr/advances', 'POST', data);
    toast('✅ تم تسجيل السلفة - بانتظار الاعتماد');
    closeM('m-hr-advance');
    loadHrAdvances();
  }catch(e){
    toast('❌ ' + e.message);
  }
}

async function approveAdvance(id){
  // 🔧 v248: اختار الخزنة (لو في أكتر من واحدة)
  let treasuryId = null;
  if(_treasuries && _treasuries.length > 0){
    if(_treasuries.length === 1){
      treasuryId = _treasuries[0].id;
      if(!confirm(`اعتماد السلفة وصرفها من خزنة "${_treasuries[0].name}"؟`)) return;
    } else {
      // أكتر من خزنة - اختار
      const opts = _treasuries.map((t,i) => `${i+1}. ${t.name}`).join('\n');
      const choice = prompt(`من أي خزنة تخصم السلفة؟\n\n${opts}\n\nاكتب رقم الخزنة:`);
      if(choice === null) return;
      const idx = parseInt(choice) - 1;
      if(isNaN(idx) || idx < 0 || idx >= _treasuries.length){
        toast('❌ اختيار غير صحيح');
        return;
      }
      treasuryId = _treasuries[idx].id;
    }
  } else {
    if(!confirm('اعتماد السلفة بدون خصم من خزنة؟ (مفيش خزنات معرّفة)')) return;
  }
  
  try{
    const r = await apiFetch('/api/hr/advances/' + id + '/approve', 'POST', { treasury_id: treasuryId });
    if(r && r.success){
      toast(treasuryId ? '✅ تم الاعتماد - تم خصم المبلغ من الخزنة' : '✅ تم الاعتماد (بدون خصم خزنة)');
      loadHrAdvances();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  }catch(e){
    toast('❌ ' + e.message);
  }
}

async function cancelAdvance(id){
  const reason = prompt('سبب الإلغاء (اختياري):');
  if(reason === null) return;
  try{
    await apiFetch('/api/hr/advances/' + id + '/cancel', 'POST', { reason });
    toast('✅ تم الإلغاء');
    loadHrAdvances();
  }catch(e){
    toast('❌ ' + e.message);
  }
}

