  const items = _stkCurrentItems;
  const isActive = s.status === 'in_progress';
  
  const counted = items.filter(i => i.counted_qty != null).length;
  const total = items.length;
  const progress = total ? Math.round(counted * 100 / total) : 0;
  const differences = items.filter(i => i.counted_qty != null && i.counted_qty !== i.system_qty).length;
  
  // Header / stats
  const headerHtml = `
    <div style="background:var(--bg);padding:12px;border-radius:8px;margin-bottom:14px">
