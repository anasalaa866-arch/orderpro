async function startStocktake(){
  const warehouseId = document.getElementById('new-stk-warehouse').value;
  const title = document.getElementById('new-stk-title').value.trim();
  const notes = document.getElementById('new-stk-notes').value.trim();
  const mode = document.querySelector('input[name="stk-mode"]:checked')?.value || 'full';
  const showSystemQty = document.getElementById('new-stk-show-system')?.checked === true;
  
  if(!warehouseId){ toast('❌ اختار مخزن'); return; }
  
  // 🆕 v362: branching للـ template mode (call غير)
  if(mode === 'template'){
    if(!_stkSelectedTemplate){ toast('❌ اختار template'); return; }
    
    try {
      toast('🔄 جاري بدء الجلسة من template...');
      const r = await apiFetch('/api/stocktake/start-from-template', 'POST', {
        templateId: _stkSelectedTemplate.id,
        titleOverride: title || undefined,
        notesOverride: notes || undefined
      });
      if(r?.success){
        toast(`✅ تم بدء "${r.templateName}" - ${r.itemsCount} منتج`);
        closeM('m-new-stocktake');
        await loadStocktakePage();
        openStocktakeSession(r.sessionId);
      } else {
        toast('❌ ' + (r?.error || 'فشل'));
      }
    } catch(e) {
      toast('❌ ' + e.message);
    }
    return;
  }
  
  // 🆕 v362: branching للـ random mode (نولد منتجات قبل ما نـ start)
  if(mode === 'random'){
    const count = parseInt(document.getElementById('stk-random-count')?.value) || 50;
    const strategy = document.querySelector('input[name="stk-rnd-strategy"]:checked')?.value || 'smart';
    if(count < 1 || count > 500){ toast('❌ العدد لازم بين 1 و 500'); return; }
    
    // ولّد المنتجات (لو مفيش preview، عمل واحد)
    let variantIds = [];
    if(_stkRandomPreview?.items?.length){
      // استخدم الـ preview الموجود
      variantIds = _stkRandomPreview.items.map(i => i.variant_id);
    } else {
      // ولّد جديد
      try {
        toast('🎲 جاري التوليد...');
        const r = await apiFetch('/api/stocktake/random-preview', 'POST', {
          warehouseId: parseInt(warehouseId), count, strategy
        });
        if(!r?.items?.length){ toast('❌ مفيش منتجات للتوليد'); return; }
        variantIds = r.items.map(i => i.variant_id);
      } catch(e) { toast('❌ ' + e.message); return; }
    }
    
    // ابدأ الجلسة كـ partial بالـ variantIds دي
    try {
      const payload = {
        warehouseId, 
        title: title || `جرد عشوائي (${strategy === 'smart' ? 'ذكي' : 'بسيط'}) - ${new Date().toLocaleDateString('ar-EG')}`,
        notes,
        mode: 'partial',  // الـ random بـ يتنفذ كـ partial في الـ backend
        showSystemQty,
        variantIds
      };
      const r = await apiFetch('/api/stocktake/start', 'POST', payload);
      if(r?.success){
        toast(`✅ تم بدء جرد عشوائي - ${r.itemsCount} منتج`);
        closeM('m-new-stocktake');
        await loadStocktakePage();
        openStocktakeSession(r.sessionId);
      } else {
        toast('❌ ' + (r?.error || 'فشل'));
      }
    } catch(e) { toast('❌ ' + e.message); }
    return;
  }
  
  // المسارات القديمة (full/partial/scan)
  let payload = {warehouseId, title, notes, mode, showSystemQty};
  
  if(mode === 'partial'){
    if(_stkSelectedVariants.size === 0){
      toast('❌ اختار منتج واحد على الأقل');
      return;
    }
    payload.variantIds = Array.from(_stkSelectedVariants);
  } else if(mode === 'full'){
    if(!confirm('جرد كامل لكل منتجات المخزن؟ ممكن يكون بطيء لو المخزن كبير.')) return;
  }
  
  try{
    toast('🔄 جاري الإنشاء...');
    const r = await apiFetch('/api/stocktake/start', 'POST', payload);
    if(r && r.success){
      toast(`✅ جلسة جرد جديدة - ${r.itemsCount} منتج`);
      closeM('m-new-stocktake');
      await loadStocktakePage();
      openStocktakeSession(r.sessionId);
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  }catch(e){
    toast('❌ ' + e.message);
  }
}

let _stkCurrentSession = null;
let _stkCurrentItems = [];
let _stkCurrentTab = 'grid'; // 'scan' | 'grid'

async function openStocktakeSession(sessionId){
  try{
    const r = await apiFetch('/api/stocktake/sessions/' + sessionId);
    if(!r || !r.session){ toast('❌ مفيش بيانات'); return; }
    
    _stkCurrentSession = r.session;
    _stkCurrentItems = r.items || [];
    
    // 🆕 v254: لو الجلسة scan-only في البداية، افتح على tab Scan
    _stkCurrentTab = (_stkCurrentItems.length === 0) ? 'scan' : 'grid';
    
    // 🆕 v361: badge للـ mode في الـ title
    const modeBadges = {
