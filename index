}

function openRegisterWebhooks(){
  // اقترح الـ baseURL تلقائياً
  const currentUrl = window.location.protocol + '//' + window.location.host;
  const apiBase = (window.API_BASE || '').replace(/\/+$/, '') || currentUrl;
  document.getElementById('webhook-base-url').value = apiBase;
  openM('m-register-webhooks');
}

async function registerWebhooks(){
  const baseUrl = document.getElementById('webhook-base-url').value.trim();
  if(!baseUrl){ toast('❌ ادخل عنوان السيرفر'); return; }
  if(!baseUrl.startsWith('https://')){ toast('❌ لازم HTTPS'); return; }
  
  if(!confirm(`تسجيل webhooks في Shopify؟\n\nBase URL: ${baseUrl}\n\nهيتم مسح أي webhooks قديمة على نفس العنوان وتسجيل الجديد.`)) return;
  
  try {
    toast('🔄 جاري التسجيل...');
    const r = await apiFetch('/api/webhooks/register', 'POST', { baseUrl });
    
    const results = r?.results || [];
    const success = results.filter(x => x.success).length;
    const failed = results.filter(x => !x.success);
    
    let msg = `✅ تم تسجيل ${success}/${results.length} webhooks`;
    if(failed.length){
      msg += '\n\n❌ فشل:\n' + failed.map(f => `${f.topic}: ${f.error}`).join('\n');
    }
    
    alert(msg);
    closeM('m-register-webhooks');
    loadWebhooksPage();
  } catch(e) {
    toast('❌ ' + e.message);
  }
}

