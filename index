function parseStatementPreview(){
  const text = document.getElementById('stmt-transactions').value.trim();
  const status = document.getElementById('stmt-parse-status');
  
  if(!text){ status.textContent = ''; return; }
  
  const lines = text.split('\n').filter(l => l.trim());
  let valid = 0, total = 0;
  
  lines.forEach(line => {
    const parts = line.split(',').map(x => x.trim());
    const amount = parseFloat(parts[0]);
    if(!isNaN(amount) && amount > 0){
      valid++;
      total += amount;
    }
  });
  
  status.textContent = `✅ ${valid}/${lines.length} عملية صحيحة - الإجمالي: ${total.toFixed(0)} ج`;
}

