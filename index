function recalcSuggested(){
  const days = parseInt(document.getElementById('reorder-days').value) || 30;
  
  _reorderProducts.forEach(p => {
    // الكمية المقترحة = (متوسط 30 يوم * أيام التغطية) - الموجود
    const needed = Math.max(0, Math.ceil((p.avg_30d * days) - p.total_stock));
    p.suggested_qty = needed;
    
    // 🆕 v268+: حساب درجة الأولوية للترتيب
    // priority_score: لو أصغر = أولوية أعلى (يطلع فوق)
    // الترتيب:
    // 1. خلصت تماماً + بيع كويس     → score = -1000
    // 2. خلصت تماماً + بيع ضعيف     → score = -500
    // 3. أيام متبقية قليلة            → score = days_remaining
    // 4. مخزون كافي + بيع كويس       → score = days_remaining (هيكون كبير)
    // 5. بطيء الحركة                 → score = 9999 (آخر القائمة)
    
    if(p.total_stock === 0 && p.avg_30d > 0.5){
      // نفد + بيع كويس = أولوية قصوى
      p.priority_score = -1000 + (1 / Math.max(p.avg_30d, 0.1));
      p.priority_label = '🔴 نفد';
    } else if(p.total_stock === 0 && p.avg_30d > 0.1){
      // نفد + بيع متوسط
      p.priority_score = -500;
      p.priority_label = '🟠 نفد';
    } else if(p.avg_30d < 0.1){
      // بطيء جداً = آخر القائمة
      p.priority_score = 9999 + (1000 - p.total_stock); // الأكثر مخزون أخيراً
      p.priority_label = '💀 راكد';
    } else if(p.days_remaining < 7){
      // قرّبت تخلص بسرعة
      p.priority_score = p.days_remaining;
      p.priority_label = '🚨 عاجل';
    } else if(p.days_remaining < 14){
      // قرّبت
      p.priority_score = p.days_remaining;
      p.priority_label = '⚠️ قريب';
    } else if(p.days_remaining < 30){
      p.priority_score = p.days_remaining;
      p.priority_label = '🟡 متوسط';
    } else {
      p.priority_score = p.days_remaining;
      p.priority_label = '🟢 كافي';
    }
    
    // لو الكمية المطلوبة لسه 0، حدّثها للـ suggested
    if(p.requested_qty === 0){
      p.requested_qty = needed;
    }
  });
  
  // 🆕 ترتيب بالأولوية
  _reorderProducts.sort((a, b) => a.priority_score - b.priority_score);
  
  renderReorderTable();
  updateReorderTotals();
}

// 🆕 v333: Filter state للجدول
let _reorderFilters = {
  search: '',
  priority: '',
  status: '',
  sort: 'priority'
};

function reorderOnFilterChange(){
  _reorderFilters.search = (document.getElementById('reorder-f-search')?.value || '').trim().toLowerCase();
