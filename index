async function saveOffer(){
  const name = $('offer-name').value.trim();
  const storeId = $('offer-store').value;
  const active = $('offer-active').value === 'true';
  const startAt = $('offer-start').value || null;
  const endAt = $('offer-end').value || null;
  const notes = $('offer-notes').value.trim();
  
  if(!name){ toast('❗ اسم العرض مطلوب', 'warning'); return; }
  if(!storeId){ toast('❗ اختار محل', 'warning'); return; }
  if(!_offerEditingProducts.length){ toast('❗ ضيف منتج واحد على الأقل', 'warning'); return; }
  
  // validate
  for(const p of _offerEditingProducts){
    if(!p.offerPrice || isNaN(parseFloat(p.offerPrice)) || parseFloat(p.offerPrice) < 0){
      toast(`❗ سعر غلط: ${p.productTitle}`, 'error');
      return;
    }
  }
  
  // validate dates
  if(startAt && endAt && new Date(startAt) >= new Date(endAt)){
    toast('❗ تاريخ النهاية لازم بعد البداية', 'warning');
    return;
  }
  
  const body = {
    name,
    storeId: parseInt(storeId),
    active,
    startAt: startAt ? new Date(startAt).toISOString() : null,
    endAt: endAt ? new Date(endAt).toISOString() : null,
    notes: notes || null,
    products: _offerEditingProducts.map(p => ({
      productId: p.productId,
      variantId: p.variantId,
      productTitle: p.productTitle,
      variantTitle: p.variantTitle,
      sku: p.sku,
      originalPrice: p.originalPrice,
      offerPrice: parseFloat(p.offerPrice),
      imageUrl: p.imageUrl || null
    }))
  };
  
  try {
    if(_offerEditingId){
      await apiFetch(`/api/pos/offers/${_offerEditingId}`, 'PUT', body);
      toast('✅ اتحدّث', 'success');
    } else {
      await apiFetch('/api/pos/offers', 'POST', body);
      toast('✅ اتعمل', 'success');
    }
    closeM('m-offer-editor');
    loadStoreOffers();
  } catch(e){
    toast('❌ ' + e.message, 'error');
  }
}

