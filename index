let _courierAccSession = null;

function openCourierAccSession(cId){
  const c = couriers.find(x=>x.id==cId);
  if(!c){ toast('❗ المندوب غير موجود'); return; }

  // ابدأ من الطلبات النشطة للمندوب (غير ملغي/مدمج/مكتمل مسوّى)
  const settledIds = getSettledIds(cId);
  const allActiveOrders = orders.filter(o=>{
    if(String(o.courierId) !== String(cId)) return false;
    if(o.status === 'مدمج') return false;
    if(settledIds.has(o.id)) return false;
    return ['جاري التوصيل','تحت التسوية','مكتمل'].includes(o.status);
  });

  if(!allActiveOrders.length){
    toast('لا توجد طلبات للمحاسبة');
    return;
