async function loadPosSales(){
  const filterStore = document.getElementById('pos-sales-store-filter')?.value || '';
  const list = document.getElementById('pos-sales-list');
  const stats = document.getElementById('pos-sales-stats');
  
  if(!list) return;
  list.innerHTML = '<div style="text-align:center;padding:20px;color:var(--muted)">⏳ جاري التحميل...</div>';
  
  try {
    const params = new URLSearchParams();
    if(filterStore) params.set('storeId', filterStore);
    params.set('limit', '100');
    
    const [salesR, statsR] = await Promise.all([
      apiFetch('/api/pos/sales?' + params.toString()),
      apiFetch('/api/pos/today-stats' + (filterStore ? '?storeId='+filterStore : ''))
    ]);
    
    const sales = salesR?.sales || [];
    
    // Stats
    if(stats){
      const byM = statsR?.byMethod || {};
      stats.innerHTML = `
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:14px">
          <div class="sc"><div class="sc-icon">📊</div><div class="sc-label">بيعات اليوم</div><div class="sc-val">${statsR?.sales_count || 0}</div></div>
          <div class="sc" style="border-right:4px solid var(--success)"><div class="sc-icon">💰</div><div class="sc-label">إجمالي اليوم</div><div class="sc-val" style="color:var(--success)">${parseFloat(statsR?.total_amount || 0).toFixed(0)} ج</div></div>
          <div class="sc"><div class="sc-icon">💵</div><div class="sc-label">كاش</div><div class="sc-val">${(byM.cash || 0).toFixed(0)} ج</div></div>
          <div class="sc"><div class="sc-icon">💳</div><div class="sc-label">فيزا</div><div class="sc-val">${(byM.visa || 0).toFixed(0)} ج</div></div>
          <div class="sc"><div class="sc-icon">📱</div><div class="sc-label">انستاباي</div><div class="sc-val">${(byM.instapay || 0).toFixed(0)} ج</div></div>
        </div>
      `;
    }
    
    if(!sales.length){
      list.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted)">مفيش بيعات</div>';
      return;
    }
    
    list.innerHTML = `
      <table style="width:100%;border-collapse:collapse;font-size:12px">
        <thead style="background:var(--bg)">
          <tr>
            <th style="text-align:right;padding:8px">رقم البيعة</th>
            <th style="text-align:right;padding:8px">التاريخ</th>
            <th style="text-align:right;padding:8px">الكاشير</th>
            <th style="text-align:right;padding:8px">العميل</th>
            <th style="text-align:center;padding:8px">قطع</th>
            <th style="text-align:left;padding:8px">الإجمالي</th>
            <th style="text-align:center;padding:8px">Sync</th>
          </tr>
        </thead>
        <tbody>
          ${sales.map(s => {
            const dt = new Date(s.created_at).toLocaleString('ar-EG', {dateStyle:'short', timeStyle:'short'});
            const syncBadge = s.synced_to_shopify 
              ? `<span style="color:#16a34a" title="${escapeHtml(s.shopify_order_name||'')}">✅</span>`
              : s.sync_error 
                ? `<span style="color:#ef4444" title="${escapeHtml(s.sync_error)}">⚠️</span>`
                : '<span style="color:#fbbf24">⏳</span>';
            return `<tr style="border-bottom:1px solid var(--border)">
              <td style="padding:6px 8px;font-family:monospace;font-weight:700">${escapeHtml(s.sale_number||'')}</td>
              <td style="padding:6px 8px">${dt}</td>
              <td style="padding:6px 8px">${escapeHtml(s.cashier_name || '—')}</td>
              <td style="padding:6px 8px">${escapeHtml(s.customer_name || '—')}${s.customer_phone ? '<br><span style="font-size:10px;color:var(--muted)">'+escapeHtml(s.customer_phone)+'</span>' : ''}</td>
