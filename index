        <div class="sc-icon">📊</div>
        <div class="sc-label">متوسط الطلب</div>
        <div class="sc-val">${ordersSum > 0 ? Math.round(totalSalesSum/ordersSum).toLocaleString('ar-EG') : 0} ج</div>
      </div>
    </div>
    <div id="sr-table-container"></div>
  `;
  
  _renderShopifyQLTable(tableData, document.getElementById('sr-table-container'));
