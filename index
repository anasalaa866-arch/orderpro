function _renderCdashChart(daily){
  const el = document.getElementById('cdash-chart');
  if(!el) return;
  const max = Math.max(...daily.map(d => d.count), 1);
  const todayStr = new Date().toISOString().slice(0,10);
  el.innerHTML = daily.map(d => {
    const h = (d.count / max) * 100;
    const isToday = d.date === todayStr;
    const color = isToday ? '#fbbf24' : (d.count === 0 ? 'var(--border)' : 'linear-gradient(180deg,#3b82f6,#8b5cf6)');
    const date = new Date(d.date);
    const day = date.getDate();
    return `
      <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%" title="${date.toLocaleDateString('ar-EG')}: ${d.count} طلب">
        <div style="background:${color};width:100%;height:${Math.max(h, d.count > 0 ? 4 : 2)}%;border-radius:3px 3px 0 0;min-height:2px"></div>
        ${(day === 1 || day === 15) ? `<div style="font-size:9px;color:var(--muted);margin-top:2px">${day}</div>` : ''}
      </div>
    `;
  }).join('');
}

