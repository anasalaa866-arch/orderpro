      $('offer-end').value = o.end_at ? toLocalDateTime(o.end_at) : '';
      $('offer-notes').value = o.notes || '';
      
      _offerEditingProducts = (r.products || []).map(p => ({
        productId: p.product_id,
        variantId: p.variant_id,
        productTitle: p.product_title,
        variantTitle: p.variant_title,
        sku: p.sku,
        originalPrice: parseFloat(p.original_price) || 0,
        offerPrice: parseFloat(p.offer_price) || 0,
        imageUrl: p.image_url || ''
      }));
    } catch(e){
      toast('❌ ' + e.message, 'error');
      return;
    }
  } else {
    $('offer-editor-title').textContent = '🏷️ عرض جديد';
  }
  
  renderOfferProductsList();
  openM('m-offer-editor');
}

function toLocalDateTime(iso){
  // convert ISO to "YYYY-MM-DDTHH:mm" for datetime-local input
  if(!iso) return '';
  const d = new Date(iso);
  const pad = n => String(n).padStart(2, '0');
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

function onOfferProductSearch(query){
  clearTimeout(_offerSearchDebounce);
  const results = $('offer-product-search-results');
  
  if(!query || query.trim().length < 2){
    results.innerHTML = '';
    return;
  }
  
  _offerSearchDebounce = setTimeout(async () => {
    try {
      const r = await apiFetch('/api/inventory/items?search=' + encodeURIComponent(query.trim()));
      const items = (r?.items || r || []).slice(0, 20);
      
      if(!items.length){
        results.innerHTML = '<div style="text-align:center;padding:14px;color:var(--muted);font-size:12px">مفيش نتائج</div>';
        return;
      }
      
      // 🆕 v367: استخدم Map + data-id بدل inline JSON
      // الـ pattern ده immune للأحرف الخاصة (apostrophes, quotes, إلخ)
      _offerSearchResultsMap = {};
      
      results.innerHTML = items.map(it => {
        // 🔧 v366: قبول camelCase + snake_case (الـ backend بـ يـ return camelCase)
        const variantId = it.variantId || it.shopify_variant_id || it.variant_id;
        const productId = it.productId || it.shopify_product_id || it.product_id;
        const productTitle = it.productTitle || it.product_title || '';
        const variantTitle = it.variantTitle || it.variant_title || '';
        const imgUrl = it.imageUrl || it.image_url || '';
        const sku = it.sku || '';
        
        const alreadyAdded = _offerEditingProducts.some(p => p.variantId === variantId);
        const price = parseFloat(it.price) || 0;
        
        // 🆕 v367: احفظ في الـ map بدل ما نـ inline JSON
        const itemKey = String(variantId || productId);
        _offerSearchResultsMap[itemKey] = {
          productId, variantId,
          productTitle, variantTitle, sku,
          originalPrice: price,
          imageUrl: imgUrl
        };
        
        // 🆕 v365: عرض بـ صورة + اسم واضح
        return `<div style="display:flex;align-items:center;gap:10px;padding:10px;border-bottom:1px solid var(--border);${alreadyAdded?'opacity:.5;background:#f3f4f6':''}">
          <div style="width:50px;height:50px;flex-shrink:0;border-radius:6px;overflow:hidden;background:#f3f4f6;display:flex;align-items:center;justify-content:center">
            ${imgUrl 
              ? `<img src="${escapeHtml(imgUrl)}" style="width:100%;height:100%;object-fit:cover" onerror="this.style.display='none';this.parentNode.innerHTML='📦'">`
              : '<span style="font-size:24px;opacity:.4">📦</span>'}
          </div>
          <div style="flex:1;min-width:0">
            <div style="font-weight:700;font-size:13px;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${escapeHtml(productTitle)}</div>
            ${variantTitle && variantTitle !== 'Default Title' ? `<div style="font-size:11px;color:var(--accent);font-weight:600">${escapeHtml(variantTitle)}</div>` : ''}
            <div style="display:flex;gap:10px;font-size:10px;color:var(--muted);margin-top:2px">
              <span>SKU: <code style="background:#f3f4f6;padding:1px 4px;border-radius:3px">${escapeHtml(sku || '—')}</code></span>
              <span style="font-weight:700;color:#475569">💰 ${price.toLocaleString()} ج</span>
            </div>
          </div>
          ${alreadyAdded 
            ? '<span style="font-size:11px;color:#22c55e;font-weight:700;padding:6px 10px;background:#dcfce7;border-radius:6px;flex-shrink:0">✓ مُضاف</span>'
            : `<button class="btn btn-success btn-sm" data-pid="${escapeHtml(itemKey)}" onclick="addOfferProductFromMap(this.dataset.pid)" style="flex-shrink:0">➕ ضيف</button>`}
        </div>`;
      }).join('');
    } catch(e){
      results.innerHTML = '<div style="color:var(--danger);padding:8px;font-size:12px">❌ ' + escapeHtml(e.message) + '</div>';
    }
  }, 350);
}

function addProductToOffer(prod){
  // prevent duplicates
  if(_offerEditingProducts.some(p => p.variantId === prod.variantId)){
    toast('المنتج مُضاف بالفعل', 'warning');
    return;
  }
  
  _offerEditingProducts.push({
    ...prod,
    offerPrice: prod.originalPrice // default = original (الـ admin هيعدلها)
  });
  
  renderOfferProductsList();
  // re-render search لتحديث "مُضاف"
  onOfferProductSearch($('offer-product-search').value);
  toast('✅ اتضاف', 'success');
}

function removeProductFromOffer(idx){
  _offerEditingProducts.splice(idx, 1);
  renderOfferProductsList();
  onOfferProductSearch($('offer-product-search').value);
}

function updateOfferProductPrice(idx, type, value){
  const prod = _offerEditingProducts[idx];
  if(!prod) return;
  
  const orig = parseFloat(prod.originalPrice) || 0;
  const v = parseFloat(value) || 0;
  
  if(type === 'price'){
    prod.offerPrice = v;
    // update percentage display
    const pctEl = $('offer-pct-' + idx);
    if(pctEl && orig > 0){
      const pct = ((orig - v) / orig) * 100;
      pctEl.textContent = pct >= 0 ? `-${pct.toFixed(0)}%` : `+${Math.abs(pct).toFixed(0)}%`;
      pctEl.style.color = pct >= 0 ? '#22c55e' : '#ef4444';
    }
  } else if(type === 'percentage'){
    if(orig <= 0){ toast('السعر الأصلي صفر - استخدم الخانة الأولى', 'warning'); return; }
    prod.offerPrice = orig * (1 - v / 100);
    const priceEl = $('offer-price-' + idx);
    if(priceEl) priceEl.value = prod.offerPrice.toFixed(2);
  }
}

