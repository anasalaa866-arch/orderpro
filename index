function renderInventoryTable(){
  const container = document.getElementById('inv-table-container');
  if(!container) return;
  
  const search = (document.getElementById('inv-search')?.value || '').trim().toLowerCase();
  const filterStatus = document.getElementById('inv-filter-status')?.value || 'all';
  const filterWh = document.getElementById('inv-filter-warehouse')?.value || '';
  
  let items = [..._invItems];
  
  if(search){
    items = items.filter(i => 
      (i.productTitle||'').toLowerCase().includes(search) ||
      (i.variantTitle||'').toLowerCase().includes(search) ||
      (i.sku||'').toLowerCase().includes(search) ||
      (i.barcode||'').toLowerCase().includes(search)
    );
  }
  
  if(filterStatus !== 'all'){
    items = items.filter(i => i.status === filterStatus);
  }
  
  if(filterWh){
    items = items.filter(i => i.levels[filterWh] && i.levels[filterWh].qty > 0);
  }
  
  _invFilteredItems = items;
  
  if(!items.length){
    container.innerHTML = '<div style="text-align:center;padding:40px;color:var(--muted)">لا توجد منتجات تطابق الفلتر</div>';
    return;
  }
  
  // 🆕 v255: Pagination logic
  const totalPages = Math.ceil(items.length / _invPageSize);
  if(_invCurrentPage > totalPages) _invCurrentPage = totalPages;
  if(_invCurrentPage < 1) _invCurrentPage = 1;
  
  const startIdx = (_invCurrentPage - 1) * _invPageSize;
  const endIdx = Math.min(startIdx + _invPageSize, items.length);
  const pageItems = items.slice(startIdx, endIdx);
  
  // ابني الـ columns headers
  const whCols = _invWarehouses.map(w => 
    `<th style="text-align:center;padding:10px;font-size:11px;font-weight:700;color:var(--muted);min-width:90px">${escapeHtml(w.name)}</th>`
  ).join('');
  
  const rows = pageItems.map(item => {
    const statusBadge = item.status === 'out' 
      ? '<span class="badge" style="background:#fee2e2;color:#991b1b">❌ منتهي</span>'
