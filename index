async function approvePayroll(id){
  // 🔧 v248: اختار الخزنة
  let treasuryId = null;
  if(_treasuries && _treasuries.length > 0){
    if(_treasuries.length === 1){
      treasuryId = _treasuries[0].id;
      if(!confirm(`اعتماد ودفع الكشف من خزنة "${_treasuries[0].name}"؟\n\n⚠️ سيتم:\n- خصم إجمالي الصافي من الخزنة\n- تطبيق الجزاءات المعلّقة\n- تحديث المتبقي من السلف`)) return;
    } else {
      const opts = _treasuries.map((t,i) => `${i+1}. ${t.name}`).join('\n');
      const choice = prompt(`من أي خزنة تدفع الرواتب؟\n\n${opts}\n\nاكتب رقم الخزنة:`);
      if(choice === null) return;
      const idx = parseInt(choice) - 1;
      if(isNaN(idx) || idx < 0 || idx >= _treasuries.length){
        toast('❌ اختيار غير صحيح');
        return;
      }
      treasuryId = _treasuries[idx].id;
    }
  } else {
    if(!confirm('اعتماد بدون خصم من خزنة؟')) return;
  }
  
  try{
    const r = await apiFetch('/api/hr/payroll-runs/' + id + '/approve', 'POST', { treasury_id: treasuryId });
    if(r && r.success){
      toast(treasuryId ? '✅ تم الاعتماد والدفع - تم الخصم من الخزنة' : '✅ تم الاعتماد');
      closeM('m-hr-payroll-detail');
      loadHrPayroll();
    } else {
      toast('❌ ' + (r?.error || 'فشل'));
    }
  }catch(e){
    toast('❌ ' + e.message);
  }
}

