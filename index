function renderPendingSessionsSection(){
  if(!_pendingSessions || !_pendingSessions.length) return '';
  
  const sessionsHtml = _pendingSessions.map(s => renderPendingSessionCard(s)).join('');
  
  return `
    <div style="margin-bottom:18px">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;padding:10px;background:linear-gradient(135deg,#fef3c7,#fff);border:1px solid #fbbf24;border-radius:8px">
