// 🆕 v213: حسب مخاطر مجموعة طلبات قبل التوزيع
async function _checkBatchRisks(orderList){
  // 🔧 v225: استخدم order endpoint (الجديد بـ customer_id) بدل الـ batch القديم
  // ده بيحل مشكلة 401 على /api/customer-risk/batch
  if(!orderList || !orderList.length) return { risky: [], safe: [] };
  
  const threshold = _riskSettings.threshold || 30;
  const minOrders = _riskSettings.minOrders || 3;
  
  // جيب التقييم لكل طلب فيه phone
  const ordersWithPhone = orderList.filter(o => o.phone && o.phone !== '—');
  if(!ordersWithPhone.length) return { risky: [], safe: orderList };
  
  // parallel fetch بـ batches من 5
  const BATCH_SIZE = 5;
  for(let i = 0; i < ordersWithPhone.length; i += BATCH_SIZE){
    const batch = ordersWithPhone.slice(i, i + BATCH_SIZE);
    const promises = batch.map(async (o) => {
      // استخدم cache لو متاح
      if(_riskCache[o.phone]) return;
      try{
        const r = await apiFetch('/api/orders/'+encodeURIComponent(o.id)+'/customer-risk', 'GET');
        if(r && !r.error){
          _riskCache[o.phone] = r;
        }
      }catch(e){
        // silent fail - الطلب هيعتبر آمن
      }
    });
    await Promise.all(promises);
  }

  const risky = [], safe = [];
  for(const o of orderList){
    const risk = _riskCache[o.phone];
    if(risk && risk.totalOrders >= minOrders && risk.riskPercentage >= threshold){
      risky.push({ order: o, risk });
    } else {
      safe.push(o);
    }
  }
  return { risky, safe };
}

