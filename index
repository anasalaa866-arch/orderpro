              <div style="background:${instaDone ? '#dcfce7' : '#e0e7ff'};border:1px solid ${instaDone ? '#86efac' : '#818cf8'};border-radius:8px;padding:8px">
                <div style="font-size:10px;color:${instaDone ? '#14532d' : '#312e81'};font-weight:700">📱 انستاباي</div>
                <div style="font-size:16px;font-weight:900;color:${instaDone ? '#16a34a' : '#4f46e5'}">${instaAmt.toLocaleString()} ج</div>
                ${instaDone ? `
                  <div style="font-size:9px;color:#14532d;font-weight:700">✅ متأكد ${new Date(s.instapay_confirmed_at).toLocaleDateString('ar-EG')}</div>
                  ${s.instapay_confirmed_by ? `<div style="font-size:9px;color:var(--muted);margin-top:1px">بواسطة ${escapeHtml(s.instapay_confirmed_by)}</div>` : ''}
                ` : '<div style="font-size:9px;color:#312e81;font-weight:700">⏳ مش متأكد</div>'}
              </div>
            ` : ''}
            ${visaAmt > 0 ? `
              <div style="background:#f3f4f6;border:1px solid var(--border);border-radius:8px;padding:8px">
                <div style="font-size:10px;color:var(--muted);font-weight:700">💳 فيزا</div>
                <div style="font-size:16px;font-weight:900">${visaAmt.toLocaleString()} ج</div>
                <div style="font-size:9px;color:var(--muted)">تلقائياً</div>
              </div>
            ` : ''}
          </div>

          <div style="display:flex;gap:6px;flex-wrap:wrap">
            <button class="btn btn-sm btn-ghost" onclick="openSettlementDetails(${s.id})" style="flex:1;min-width:120px">📋 تفاصيل</button>
            <button class="btn btn-sm btn-ghost" onclick="printSettlement(${s.id})" style="flex:1;min-width:100px">🖨️ طباعة</button>
            ${cashPending ? `<button class="btn btn-sm" onclick="openReceiveCash(${s.id})" style="background:#16a34a;color:#fff;border-color:#16a34a;flex:1;min-width:140px">💵 استلم الكاش (${cashAmt.toLocaleString()})</button>` : ''}
            ${instaPending ? `<button class="btn btn-sm" onclick="confirmInstapay(${s.id})" style="background:#4f46e5;color:#fff;border-color:#4f46e5;flex:1;min-width:140px">📱 أكد الانستاباي</button>` : ''}
            ${cashDone ? `<button class="btn btn-sm btn-ghost" onclick="unreceiveCash(${s.id})" style="color:#dc2626;border-color:#fecaca" title="ارجاع - يشيل من الخزنة">↩️ ارجاع الكاش</button>` : ''}
            ${instaDone ? `<button class="btn btn-sm btn-ghost" onclick="unconfirmInstapay(${s.id})" style="color:#dc2626;border-color:#fecaca" title="ارجاع التأكيد">↩️ ارجاع الانستاباي</button>` : ''}
          </div>
        </div>
      </div>
    `;
  }).join('');

  cont.innerHTML = html;
}

