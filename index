      return `<tr>
        <td style="font-size:11px">
          <div style="font-weight:700">${dateStr}</div>
          <div style="color:var(--muted)">${timeStr}</div>
        </td>
        <td><strong style="font-size:12px">${escapeHtml(c.order_id)}</strong></td>
        <td>${oldBadge}</td>
        <td>${newBadge}</td>
