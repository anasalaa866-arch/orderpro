function handleExpiryInput(){
  const input = document.getElementById('exp-modal-search');
  const val = (input.value || '').trim();
  _expLastInput = Date.now();
  
  if(_expSearchTimer) clearTimeout(_expSearchTimer);
  
  // فضي الـ results لو فاضي
  if(!val){
    const resEl = document.getElementById('exp-search-results');
