        <tr><td>💳 فيزا (معدود)</td><td><strong>${parseFloat(s.counted_visa || 0).toLocaleString()} ج</strong></td></tr>
        <tr><td>📱 انستاباي (معدود)</td><td><strong>${parseFloat(s.counted_instapay || 0).toLocaleString()} ج</strong></td></tr>
