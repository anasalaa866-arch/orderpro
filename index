function moAddProductFromSearch(idx){
  const p = _moProductSearchResults[idx];
  if(!p) return;
  // 🔧 v311: الـ inventory/items بترجع camelCase
  const variantId = p.variantId || p.shopify_variant_id || p.variant_id;
  if(!variantId){ toast('❌ المنتج ده مالوش variant_id - مش هينفع'); return; }

  // لو موجود، زود الكمية
  const existing = _moLineItems.find(it => String(it.variantId) === String(variantId));
  if(existing){
    existing.qty++;
  } else {
    _moLineItems.push({
      variantId: String(variantId),
      productTitle: p.productTitle || p.product_title || '',
      variantTitle: p.variantTitle || p.variant_title || '',
      sku: p.sku || '',
      qty: 1,
      price: parseFloat(p.price || 0),
      imageUrl: p.imageUrl || p.image_url || ''
    });
  }
  closeM('m-mo-product-picker');
  renderMOProducts();
  toast('✅ تم الإضافة');
}

async function submitManualOrder(){
  const code = document.getElementById('mo-code').value.trim();
  const note = document.getElementById('mo-note').value.trim();
  const warehouseId = document.getElementById('mo-warehouse').value;

  // 🆕 v313: استخدم الـ selected customer
  const customerName = _moSelectedCustomer?.name || '';
  const customerPhone = _moSelectedCustomer?.phone || '';
  const customerAddress = _moSelectedCustomer?.address || '';
  const customerCity = _moSelectedCustomer?.city || 'القاهرة';

  if(!code){ toast('❗ الكود مطلوب'); return; }
  if(!_moLineItems.length){ toast('❗ ضيف منتج واحد على الأقل'); return; }

  // تأكيد
  const total = _moLineItems.reduce((s,it)=>s+(it.qty*it.price),0);
  const customerLine = _moSelectedCustomer ? `\nالعميل: ${customerName} (${customerPhone})` : '\n⚠️ بدون عميل';
  if(!confirm(`تأكيد إنشاء الطلب على Shopify؟\n\nالكود: ${code}${customerLine}\nالمنتجات: ${_moLineItems.length}\nالإجمالي: ${total.toFixed(2)} ج\n\n⚠️ هيتم خصم المنتجات من المخزن`)) return;

  const payload = {
    code, note,
    warehouseId: parseInt(warehouseId) || null,
    customerName, customerPhone, customerAddress, customerCity,
    customerShopifyId: _moSelectedCustomer?.shopifyId || null,
    lineItems: _moLineItems.map(it => ({
      variantId: it.variantId,
      quantity: it.qty,
      price: it.price,
      title: it.productTitle
    }))
  };

  const btn = document.querySelector('#m-manual-order .btn-primary');
  if(btn){ btn.disabled = true; btn.textContent = '⏳ جاري الإنشاء...'; }

  // 🆕 v315: امسح أي manual-orders requests stale من الـ offline queue (من محاولات سابقة فاشلة)
  try {
    if (typeof _offlineQueue !== 'undefined' && Array.isArray(_offlineQueue)) {
      const before = _offlineQueue.length;
      _offlineQueue = _offlineQueue.filter(item => !(item.path && item.path.includes('/manual-orders')));
      const after = _offlineQueue.length;
      if (before !== after) {
        console.log(`Cleared ${before - after} stale manual-orders from offline queue`);
        try { localStorage.setItem(OFFLINE_QUEUE_KEY, JSON.stringify(_offlineQueue)); } catch(e){}
      }
    }
  } catch(e){}

  try {
    // 🔧 v315: استخدم raw fetch بدل apiFetch عشان نشوف الـ error details بالكامل
    const baseUrl = (API_URL || BACKEND_URL || '').replace(/\/$/, '');
    if(!baseUrl) throw new Error('مفيش API URL');

    const headers = { 'Content-Type': 'application/json' };
    if(window._adminToken) headers['Authorization'] = 'Bearer ' + window._adminToken;

    const httpResp = await fetch(baseUrl + '/api/manual-orders', {
      method: 'POST',
      headers,
      mode: 'cors',
      body: JSON.stringify(payload)
    });

    let r;
    try { r = await httpResp.json(); } catch(e) { r = null; }

    if(!httpResp.ok || !r || r.error){
      // 🆕 v312: اعرض الـ details من Shopify في popup مفصّل
      const errDetails = r?.details ? JSON.stringify(r.details, null, 2) : (r ? JSON.stringify(r, null, 2) : '(فاضي)');
      const status = ` (HTTP ${httpResp.status})`;
      console.error('Manual order error:', { status: httpResp.status, body: r });

      const errorMsg = r?.error || (httpResp.status === 401 ? 'مش مسجل دخول - افتح تب جديد وسجل دخول' :
                                     httpResp.status === 500 ? 'خطأ في السيرفر - راجع Railway logs' :
                                     httpResp.status === 404 ? 'الـ endpoint مش موجود - تأكد إن server-v199 رفع على Railway' :
                                     'خطأ غير معروف');

      const errOv = document.createElement('div');
      errOv.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:99999;display:flex;align-items:center;justify-content:center;padding:20px';
      errOv.innerHTML = `
        <div style="background:#fff;border-radius:12px;width:min(600px,95vw);max-height:90vh;overflow-y:auto;padding:20px;font-family:Cairo,sans-serif">
          <div style="font-weight:800;color:#dc2626;font-size:16px;margin-bottom:10px">❌ فشل إنشاء الطلب${status}</div>
          <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:8px;padding:10px;margin-bottom:10px;font-size:13px">${escapeHtml(errorMsg)}</div>
          <div style="font-weight:700;font-size:12px;margin-bottom:4px">الـ Response الكامل من السيرفر:</div>
          <pre style="background:#f3f4f6;border-radius:6px;padding:10px;font-size:11px;max-height:300px;overflow:auto;direction:ltr;text-align:left;white-space:pre-wrap;word-break:break-word">${escapeHtml(errDetails)}</pre>
          <div style="margin-top:10px;font-size:11px;color:#666">
            💡 لو الـ response فاضي، يبقى السيرفر بـ يرجع 500 بدون body - راجع Railway logs.
          </div>
          <div style="text-align:left;margin-top:14px">
            <button onclick="this.closest('div[style*=fixed]').remove()" style="padding:8px 16px;border-radius:7px;border:none;background:#3b82f6;color:#fff;font-family:Cairo,sans-serif;font-weight:700;cursor:pointer">حسناً</button>
          </div>
        </div>`;
      document.body.appendChild(errOv);
      return;
    }
    toast(`✅ تم إنشاء الطلب ${r.order.name} على Shopify`);
    // 🆕 v314: لو الـ fulfillment اتنقل (يعني المخزن المطلوب مكنش فيه stock)
    if(r.fulfillment?.moved > 0){
      setTimeout(() => {
        toast(`✅ تم تخصيم المنتجات من المخزن: ${r.warehouse?.name || '?'}`, 'success');
      }, 1500);
    }
    closeM('m-manual-order');
    loadManualOrders();
  } catch(e) {
    toast('❌ ' + e.message);
    console.error('Manual order fetch failed:', e);
  } finally {
    if(btn){ btn.disabled = false; btn.textContent = '💾 إنشاء الطلب على Shopify'; }
  }
}

