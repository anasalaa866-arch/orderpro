function renderCourierRates(){
  const tbody = document.getElementById('courier-rates-tbody');
  if(!tbody) return;
  if(!_currentCourierRates.length){
    tbody.innerHTML = '<tr><td colspan="3" style="text-align:center;padding:30px;color:var(--muted)">مفيش أنواع طلبات. اضف أنواع الأول من صفحة "أنواع الطلبات".</td></tr>';
    return;
  }
  tbody.innerHTML = _currentCourierRates.map((r, idx) => `
    <tr>
      <td style="font-size:24px;text-align:center">${r.emoji || '📦'}</td>
      <td><strong>${escapeHtml(r.label_ar)}</strong></td>
      <td>
        <input type="number" 
               id="rate-input-${r.order_type_id}" 
               value="${r.ship_cost}" 
               min="0" 
               step="0.5"
               class="form-input"
               style="max-width:150px"
               onchange="updateRateInState(${r.order_type_id}, this.value)">
      </td>
    </tr>
  `).join('');
}

function updateRateInState(orderTypeId, value){
  const rate = _currentCourierRates.find(r => r.order_type_id === orderTypeId);
  if(rate){
    const cost = (value !== '' && value != null) ? parseFloat(value) : 0;
    rate.ship_cost = isNaN(cost) ? 0 : cost;
  }
}

async function saveCourierRates(){
  if(!_currentRatesCourierId){ toast('⚠️ اختار مندوب'); return; }
  
  // اجمع الأسعار من الـ inputs (احتياطاً)
  const rates = _currentCourierRates.map(r => {
    const input = document.getElementById('rate-input-'+r.order_type_id);
    const val = input ? input.value : r.ship_cost;
    const cost = (val !== '' && val != null) ? parseFloat(val) : 0;
    return {
      order_type_id: r.order_type_id,
      ship_cost: isNaN(cost) ? 0 : cost
    };
  });
  
  try{
    await apiFetch('/api/couriers/'+_currentRatesCourierId+'/ship-rates', 'PUT', rates);
    toast('✅ تم حفظ الأسعار');
    // 🆕 v235: حدّث الـ cache المحلي عشان الأسعار الجديدة تطبّق فوراً
    await loadCourierRatesMap();
  }catch(e){
    toast('❌ ' + e.message);
  }
}

