  renderPOItems();
  updatePOTotals();
}

function removePOItem(idx){
  _poItems.splice(idx, 1);
  renderPOItems();
  updatePOTotals();
}

function updatePOTotals(){
  const subtotal = _poItems.reduce((s, it) => s + (it.orderedQty * it.unitCost), 0);
