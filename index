function renderOrdersPagination(totalCount, totalPages){
  const el = document.getElementById('orders-pagination');
  if(!el) return;
  if(totalPages <= 1){
    el.innerHTML = totalCount ? `<span style="color:var(--muted);font-size:12px">${totalCount} طلب</span>` : '';
    return;
  }
  const startIdx = (ordersPage - 1) * ORDERS_PAGE_SIZE;
  const endIdx = Math.min(startIdx + ORDERS_PAGE_SIZE, totalCount);

  // اختر الصفحات اللي هتظهر (حد أقصى 7 أزرار)
  const pages = [];
  if(totalPages <= 7){
    for(let i=1; i<=totalPages; i++) pages.push(i);
  } else {
    pages.push(1);
    if(ordersPage > 3) pages.push('...');
    for(let i=Math.max(2, ordersPage-1); i<=Math.min(totalPages-1, ordersPage+1); i++) pages.push(i);
    if(ordersPage < totalPages-2) pages.push('...');
    pages.push(totalPages);
  }

  const btn = (page, label, disabled) => {
    const active = page === ordersPage;
    const style = active
      ? 'background:var(--accent);color:#fff;border:1px solid var(--accent);font-weight:800'
      : disabled
        ? 'background:transparent;color:var(--muted);border:1px solid var(--border);cursor:not-allowed;opacity:.5'
        : 'background:var(--card);color:var(--text);border:1px solid var(--border);cursor:pointer';
    return `<button ${disabled?'disabled':''} onclick="goToOrdersPage(${page})" style="${style};padding:6px 12px;border-radius:6px;font-family:Cairo,sans-serif;font-size:12px;min-width:34px">${label}</button>`;
  };

  const parts = [];
  parts.push(`<span style="color:var(--muted);font-size:12px;margin-left:12px">${startIdx+1}-${endIdx} من ${totalCount}</span>`);
  parts.push(btn(ordersPage-1, '←', ordersPage<=1));
  pages.forEach(p => {
    if(p === '...') parts.push('<span style="color:var(--muted);padding:0 4px">...</span>');
    else parts.push(btn(p, String(p), false));
  });
  parts.push(btn(ordersPage+1, '→', ordersPage>=totalPages));

  el.innerHTML = parts.join('');
}

