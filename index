// 🆕 v154: Helper - يتحقق لو الطلب اتطبع قبل كده + يطلع تحذير
async function _checkAndWarnIfPrintedBefore(orderId, printType){
  if(!API_URL) return true; // لو مفيش backend، اطبع
  
  try {
    const r = await apiFetch('/api/orders/' + encodeURIComponent(orderId) + '/print-history');
    const prints = r?.prints || [];
    
    if(!prints.length) return true; // مفيش طباعات سابقة
    
    // فلتر بالنوع المطلوب
    const sameType = prints.filter(p => {
      const v = p.new_value || '';
      const typeLabels = { invoice: 'فاتورة', awb: 'بوليصة', sticker: 'استيكر', barcode: 'باركود' };
      return v === typeLabels[printType] || v.includes(typeLabels[printType] || '');
    });
    
    if(!sameType.length) return true;
    
    const last = sameType[0];
    const lastTime = new Date(last.ts).toLocaleString('ar-EG');
    
    // عرض كل الطباعات السابقة
    let history = sameType.slice(0, 5).map((p, i) => {
      const t = new Date(p.ts).toLocaleString('ar-EG', {dateStyle:'short', timeStyle:'short'});
      return `${i+1}. ${t} بواسطة ${p.user_name || 'غير معروف'}`;
    }).join('\n');
    
    if(sameType.length > 5){
      history += `\n... و ${sameType.length - 5} مرات أخرى`;
    }
    
    const typeLabels = { invoice: 'الفاتورة', awb: 'البوليصة', sticker: 'الاستيكر', barcode: 'الباركود', receipt: 'الإيصال' };
    const typeLabel = typeLabels[printType] || 'الطلب';
    
    return confirm(
      `⚠️ تحذير - الطلب ده اتطبع قبل كده!\n\n` +
      `${typeLabel} اتطبعت ${sameType.length} مرة:\n\n` +
      `${history}\n\n` +
      `هل أنت متأكد من الطباعة مرة أخرى؟`
    );
  } catch(e) {
    console.warn('print history check failed:', e);
    return true; // لو فشل التحقق، اطبع عادي
  }
}

