// 🆕 v262: helper لملء dropdown المدراء
async function _fillStoreManagersDropdown(selectedId){
  const mgrSel = document.getElementById('pos-store-manager');
  if(!mgrSel) return;
  
  // الموظفين بدور store_manager
  const managers = (couriers || []).filter(c => c.role === 'store_manager');
  
  if(!managers.length){
    mgrSel.innerHTML = '<option value="">-- مفيش مدراء (أنشئ موظف بدور "مدير محل" أولاً) --</option>';
    return;
  }
  
  mgrSel.innerHTML = '<option value="">-- بدون مدير --</option>' + 
    managers.map(m => `<option value="${m.id}" ${m.id == selectedId ? 'selected' : ''}>${escapeHtml(m.name)}${m.phone ? ' ('+escapeHtml(m.phone)+')' : ''}</option>`).join('');
}

